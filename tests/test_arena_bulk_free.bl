// Arena bulk-free pressure: many iterations each enter `with arena { }`,
// allocate a working set, and exit. If the region were not reclaimed at `}`,
// cumulative footprint across iterations would OOM.
//
// TODO: scale per-iter sizes up once arena realloc stops tripping bdwgc on
// larger lists, and switch from loop-completion to a live-bytes assertion
// once the arena counter intrinsic exists.

fn fill_arena_once(iter: Int) -> Int {
    with arena {
        let mut acc = 0
        let mut xs: List[Int] = []
        let mut i = 0
        while i < 1000 {
            xs.push(i)
            acc = acc + i
            i = i + 1
        }
        let mut strs: List[Str] = []
        let mut j = 0
        while j < 100 {
            strs.push("iter_{iter}_item_{j}")
            j = j + 1
        }
        assert_eq(xs.len(), 1000)
        assert_eq(strs.len(), 100)
        acc
    }
    499500
}

test "arena bulk-free survives repeated allocation pressure" {
    let mut k = 0
    while k < 200 {
        let sum = fill_arena_once(k)
        assert_eq(sum, 499500)
        k = k + 1
    }
    assert_eq(k, 200)
}
