    ensure_struct_result_type, ensure_take_iter,
    find_from_impl, find_tryfrom_impl, fresh_temp,
    get_fn_ret, get_fn_ret_struct, get_fn_ret_struct_inner, get_fn_ret_type,
    get_impl_method_ret, get_list_elem_map_key_type, get_list_elem_map_val_type,
    get_list_elem_struct, get_list_elem_type,
    get_list_nested_elem_struct, get_list_nested_elem_type,
    get_map_value_list_elem, get_map_value_struct, get_map_value_type, get_set_elem_type,
    get_struct_field_closure_sig, get_struct_field_type,
    get_var_channel_inner, get_var_enum, get_var_iterator_inner,
    get_var_option_inner, get_var_option_inner2, get_var_option_inner2_struct,
    get_var_option_inner_struct,
    get_var_result_err, get_var_result_err_struct,
    get_var_result_ok, get_var_result_ok_elem, get_var_result_ok_elem_struct,
    get_var_result_ok_struct, get_var_struct,
    get_variant_field_count, get_variant_field_name,
    get_variant_field_type_str, get_variant_index, get_variant_tag,
    has_derive_method, is_compound_ct, is_data_enum, is_enum_type, is_fn_registered, is_scope_var, is_str_backed_enum,
    is_generic_fn, is_struct_type, is_trait_type, is_user_effect_handle,
    lookup_builtin_trait_impl, lookup_impl_method, mangle_generic_name,
    option_c_type, reg_fn, register_mono_fn, register_mono_instance,
    resolve_import_alias, resolve_ptr_inner_c, resolve_struct_from_c_name,
    result_c_type, result_c_type_mixed,
    set_list_elem_struct, set_list_elem_type, set_list_nested_elem_type,
    set_map_types, set_map_value_list_elem, set_map_value_struct, set_set_elem_type, set_var, set_var_handle,
    set_var_handle_full, set_var_iterator, set_var_option,
    set_var_option_inner2, set_var_option_inner2_struct,
    set_var_option_struct, set_var_result, set_var_result_ok_elem, set_var_result_struct, set_var_struct,
    struct_option_c_type, struct_result_c_type,
    tp_child1_kind, tp_child2_kind, tp_get_kind, tp_get_sname,
    type_from_name, type_from_name_tag, type_name_from_ct, is_compound_tag, is_intrinsic_method, ue_methods,
    var_enums, VarEnumEntry
}
import diagnostics.{diag_error_at, diag_source_file}

// Arg offset for trait-qualified builtin calls: MapOps.contains_key(m, k) has receiver at args[0]
let mut btc_arg_offset: Int = 0

fn emit_panic_tag_check(tmp: Str, tag_val: Int, msg: Str, loc_line: Int) ! Codegen.Emit {
    emit_line("if ({tmp}.tag == {tag_val}) \{ fprintf(stderr, \"panic: {msg} at {diag_source_file}:{loc_line}\\n\"); exit(1); }")
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_result_unwrap_inner(
    obj_str: Str, node: Int,
    inner_t: Int, inner_s: Str,
    field: Str,
    elem_kind: Int, elem_sname: Str,
    propagate_option: Int
) ! Codegen.Emit, Codegen.Scope {
    let is_ok = field == "ok"
    let panic_tag = if is_ok { 1 } else { 0 }
    let panic_msg = if is_ok { "unwrap called on Err" } else { "unwrap_err called on Ok" }
    let loc_line = node_line(node)
    let tmp = fresh_temp(if is_ok { "_runw_" } else { "_ruew_" })
    emit_line("__typeof__({obj_str}) {tmp} = {obj_str};")
    if inner_s != "" && is_compound_ct(inner_t) == 0 {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        let val_tmp = fresh_temp(if is_ok { "_runv_" } else { "_ruerr_" })
        emit_line("{c_type_c_name(inner_s)} {val_tmp} = {tmp}.{field};")
        set_var_struct(val_tmp, inner_s)
        expr_result_str = val_tmp
        expr_result_type = CT_VOID
    } else if inner_t == CT_STRING {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        expr_result_str = "{tmp}.{field}"
        expr_result_type = CT_STRING
    } else if inner_t == CT_LIST {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        let val_tmp = fresh_temp(if is_ok { "_runv_" } else { "_ruerr_" })
        emit_line("blink_list* {val_tmp} = {tmp}.{field};")
        set_var(val_tmp, CT_LIST, 0)
        if elem_kind >= 0 {
            set_list_elem_type(val_tmp, elem_kind)
            expr_list_elem_type = elem_kind
        }
        if elem_sname != "" {
            set_list_elem_struct(val_tmp, elem_sname)
        }
        expr_result_str = val_tmp
        expr_result_type = CT_LIST
    } else if inner_t == CT_MAP {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        let val_tmp = fresh_temp(if is_ok { "_runv_" } else { "_ruerr_" })
        emit_line("blink_map* {val_tmp} = {tmp}.{field};")
        set_var(val_tmp, CT_MAP, 0)
        expr_result_str = val_tmp
        expr_result_type = CT_MAP
    } else if inner_t == CT_BYTES {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        let val_tmp = fresh_temp(if is_ok { "_runv_" } else { "_ruerr_" })
        emit_line("blink_bytes* {val_tmp} = {tmp}.{field};")
        set_var(val_tmp, CT_BYTES, 0)
        expr_result_str = val_tmp
        expr_result_type = CT_BYTES
    } else if propagate_option != 0 && inner_t == CT_OPTION && inner_s != "" {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        let val_tmp = fresh_temp(if is_ok { "_runv_" } else { "_ruerr_" })
        emit_line("{c_type_c_name(inner_s)} {val_tmp} = {tmp}.{field};")
        set_var(val_tmp, CT_OPTION, 0)
        if inner_s.starts_with("Option_") {
            let opt_inner_tag = inner_s.slice(7, inner_s.len())
            let opt_inner_ct = type_from_name_tag(opt_inner_tag)
            if is_compound_tag(opt_inner_tag) != 0 || is_struct_type(opt_inner_tag) != 0 || is_enum_type(opt_inner_tag) != 0 {
                set_var_option_struct(val_tmp, opt_inner_ct, opt_inner_tag)
                expr_option_inner = opt_inner_ct
                expr_option_inner_struct = opt_inner_tag
            } else {
                set_var_option(val_tmp, opt_inner_ct)
                expr_option_inner = opt_inner_ct
                expr_option_inner_struct = ""
            }
        } else {
            set_var_option_struct(val_tmp, CT_INT, inner_s)
            expr_option_inner = CT_INT
            expr_option_inner_struct = inner_s
        }
        expr_result_str = val_tmp
        expr_result_type = CT_OPTION
    } else {
        emit_panic_tag_check(tmp, panic_tag, panic_msg, loc_line)
        expr_result_str = "{tmp}.{field}"
        if inner_t == CT_FLOAT {
            expr_result_type = CT_FLOAT
        } else {
            expr_result_type = CT_INT
        }
    }
}

pub fn resolve_push_struct(val_str: Str, list_name: Str) -> Str {
    let s = get_var_struct(val_str)
    if s != "" {
        return s
    }
    let ve = get_var_enum(val_str)
    if ve != "" && is_data_enum(ve) != 0 {
        return ve
    }
    get_list_elem_struct(list_name)
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_str_method(node: Int, obj_str: Str, _obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "len" {
        expr_result_str = "blink_str_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "char_at" || method == "charAt" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        expr_result_str = "blink_str_char_at({obj_str}, {idx_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "substring" || method == "substr" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let start_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let len_str = expr_result_str
        expr_result_str = "blink_str_substr({obj_str}, {start_str}, {len_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "contains" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let needle_str = expr_result_str
        expr_result_str = "blink_str_contains({obj_str}, {needle_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "starts_with" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let pfx_str = expr_result_str
        expr_result_str = "blink_str_starts_with({obj_str}, {pfx_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "ends_with" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let sfx_str = expr_result_str
        expr_result_str = "blink_str_ends_with({obj_str}, {sfx_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "concat" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let other_str = expr_result_str
        expr_result_str = "blink_str_concat({obj_str}, {other_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "slice" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let start_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let end_str = expr_result_str
        expr_result_str = "blink_str_slice({obj_str}, {start_str}, {end_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "to_int" {
        expr_result_str = "blink_parse_int({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "split" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let delim_str = expr_result_str
        expr_result_str = "blink_str_split({obj_str}, {delim_str})"
        expr_result_type = CT_LIST
        set_list_elem_type(expr_result_str, CT_STRING)
        expr_list_elem_type = CT_STRING
        return 1
    }
    if method == "trim" {
        expr_result_str = "blink_str_trim({obj_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "to_upper" {
        expr_result_str = "blink_str_to_upper({obj_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "to_lower" {
        expr_result_str = "blink_str_to_lower({obj_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "replace" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let needle_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let repl_str = expr_result_str
        expr_result_str = "blink_str_replace({obj_str}, {needle_str}, {repl_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "index_of" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let needle_str = expr_result_str
        expr_result_str = "blink_str_index_of({obj_str}, {needle_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "lines" {
        expr_result_str = "blink_str_lines({obj_str})"
        expr_result_type = CT_LIST
        set_list_elem_type(expr_result_str, CT_STRING)
        expr_list_elem_type = CT_STRING
        return 1
    }
    if method == "is_empty" {
        expr_result_str = "(strlen({obj_str}) == 0)"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "parse_float" {
        expr_result_str = "blink_parse_float({obj_str})"
        expr_result_type = CT_FLOAT
        return 1
    }
    if method == "parse_int" {
        expr_result_str = "blink_parse_int({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "as_cstr" {
        expr_result_str = "blink_strdup({obj_str})"
        expr_result_type = CT_PTR
        return 1
    }
    0
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_list_method(node: Int, obj_str: Str, obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "push" {
        let mut push_var_name = ""
        if node_kind(obj_node) == NodeKind.Ident {
            push_var_name = node_name(obj_node)
        }
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let val_str = expr_result_str
        let val_type = expr_result_type
        if val_type != CT_INT {
            set_list_elem_type(obj_str, val_type)
        }
        let val_struct = resolve_push_struct(val_str, obj_str)
        if val_struct != "" {
            set_list_elem_struct(obj_str, val_struct)
            set_list_elem_type(obj_str, CT_VOID)
            let box_tmp = fresh_temp("_box")
            emit_line("{c_type_c_name(val_struct)}* {box_tmp} = ({c_type_c_name(val_struct)}*)blink_alloc(sizeof({c_type_c_name(val_struct)}));")
            emit_line("*{box_tmp} = {val_str};")
            emit_line("blink_list_push({obj_str}, (void*){box_tmp});")
        } else if val_type == CT_INT {
            emit_line("blink_list_push({obj_str}, (void*)(intptr_t){val_str});")
        } else if val_type == CT_FLOAT {
            let box_tmp = fresh_temp("_fbox")
            emit_line("double* {box_tmp} = (double*)blink_alloc(sizeof(double));")
            emit_line("*{box_tmp} = {val_str};")
            emit_line("blink_list_push({obj_str}, (void*){box_tmp});")
        } else if val_type == CT_OPTION {
            let opt_inner_s = expr_option_inner_struct
            let opt_tag = if opt_inner_s != "" { opt_inner_s } else { c_type_tag(expr_option_inner) }
            let opt_sname = "Option_{opt_tag}"
            if opt_inner_s != "" {
                ensure_struct_option_type(opt_inner_s)
            } else {
                ensure_option_type(expr_option_inner)
            }
            set_list_elem_struct(obj_str, opt_sname)
            set_list_elem_type(obj_str, CT_VOID)
            let opt_c = c_type_c_name(opt_sname)
            let box_tmp = fresh_temp("_obox")
            emit_line("{opt_c}* {box_tmp} = ({opt_c}*)blink_alloc(sizeof({opt_c}));")
            emit_line("*{box_tmp} = {val_str};")
            emit_line("blink_list_push({obj_str}, (void*){box_tmp});")
        } else if val_type == CT_RESULT {
            let res_ok_s = expr_result_ok_struct
            let res_err_s = expr_result_err_struct
            let ok_tag = if res_ok_s != "" { res_ok_s } else { c_type_tag(expr_result_ok_type) }
            let err_tag = if res_err_s != "" { res_err_s } else { c_type_tag(expr_result_err_type) }
            let res_sname = "Result_{ok_tag}_{err_tag}"
            ensure_mixed_result_type(expr_result_ok_type, expr_result_err_type, res_ok_s, res_err_s)
            set_list_elem_struct(obj_str, res_sname)
            set_list_elem_type(obj_str, CT_VOID)
            let res_c = c_type_c_name(res_sname)
            let box_tmp = fresh_temp("_rbox")
            emit_line("{res_c}* {box_tmp} = ({res_c}*)blink_alloc(sizeof({res_c}));")
            emit_line("*{box_tmp} = {val_str};")
            emit_line("blink_list_push({obj_str}, (void*){box_tmp});")
        } else {
            emit_line("blink_list_push({obj_str}, (void*){val_str});")
        }
        if push_var_name != "" {
            emit_trace_state(push_var_name, "push", val_str, val_type)
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "pop" {
        let mut elem_type = get_list_elem_type(obj_str)
        let mut elem_struct = get_list_elem_struct(obj_str)
        if elem_struct == "" && elem_type < 0 && expr_list_elem_struct != "" {
            elem_struct = expr_list_elem_struct
            elem_type = CT_VOID
        }
        let res = fresh_temp("_lpop_")
        if (elem_type == CT_VOID || elem_type == CT_STRUCT || elem_type == CT_ENUM) && elem_struct != "" {
            ensure_struct_option_type(elem_struct)
            let opt_type = struct_option_c_type(elem_struct)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = ({c_type_c_name(elem_struct)}*)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option_struct(res, CT_VOID, elem_struct)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_VOID
            expr_option_inner_struct = elem_struct
        } else if elem_type == CT_STRING {
            ensure_option_type(CT_STRING)
            let opt_type = option_c_type(CT_STRING)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = (const char*)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_STRING)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_STRING
            expr_option_inner_struct = ""
        } else if elem_type == CT_FLOAT {
            ensure_option_type(CT_FLOAT)
            let opt_type = option_c_type(CT_FLOAT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = *(double*)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_FLOAT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_FLOAT
            expr_option_inner_struct = ""
        } else if elem_type == CT_LIST {
            ensure_option_type(CT_LIST)
            let opt_type = option_c_type(CT_LIST)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_list*)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_LIST)
            let pop_nested = get_list_nested_elem_type(obj_str)
            if pop_nested != -1 {
                set_var_option_inner2(res, pop_nested)
            }
            let pop_nested_s = get_list_nested_elem_struct(obj_str)
            if pop_nested_s != "" {
                set_var_option_inner2_struct(res, pop_nested_s)
            }
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_LIST
            expr_option_inner_struct = ""
            expr_option_inner_list_elem = pop_nested
            expr_option_inner_list_struct = pop_nested_s
        } else if elem_type == CT_MAP {
            let pop_map_k = get_list_elem_map_key_type(obj_str)
            let pop_map_v = get_list_elem_map_val_type(obj_str)
            let k_tag = if pop_map_k >= 0 { c_type_tag(pop_map_k) } else { "str" }
            let v_tag = if pop_map_v >= 0 { c_type_tag(pop_map_v) } else { "int" }
            let map_struct = "Map_{k_tag}_{v_tag}"
            ensure_struct_option_type(map_struct)
            let opt_type = struct_option_c_type(map_struct)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_map*)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option_struct(res, CT_MAP, map_struct)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_MAP
            expr_option_inner_struct = map_struct
        } else {
            ensure_option_type(CT_INT)
            let opt_type = option_c_type(CT_INT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_len({obj_str}) > 0) \{")
            emit_line("    {res}.tag = 1; {res}.value = (int64_t)(intptr_t)blink_list_pop({obj_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_INT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_INT
            expr_option_inner_struct = ""
        }
        return 1
    }
    if method == "len" {
        expr_result_str = "blink_list_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "is_empty" {
        expr_result_str = "(blink_list_len({obj_str}) == 0)"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "clear" {
        emit_line("blink_list_clear({obj_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "get" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        let mut elem_type = get_list_elem_type(obj_str)
        let mut elem_struct = get_list_elem_struct(obj_str)
        if elem_struct == "" && elem_type < 0 && expr_list_elem_struct != "" {
            elem_struct = expr_list_elem_struct
            elem_type = CT_VOID
        }
        let idx_tmp = fresh_temp("_lgi_")
        emit_line("int64_t {idx_tmp} = {idx_str};")
        let res = fresh_temp("_lget_")
        if (elem_type == CT_VOID || elem_type == CT_STRUCT || elem_type == CT_ENUM) && elem_struct != "" {
            ensure_struct_option_type(elem_struct)
            let opt_type = struct_option_c_type(elem_struct)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = ({c_type_c_name(elem_struct)}*)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option_struct(res, CT_VOID, elem_struct)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_VOID
            expr_option_inner_struct = elem_struct
        } else if elem_type == CT_STRING {
            ensure_option_type(CT_STRING)
            let opt_type = option_c_type(CT_STRING)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (const char*)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_STRING)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_STRING
            expr_option_inner_struct = ""
        } else if elem_type == CT_FLOAT {
            ensure_option_type(CT_FLOAT)
            let opt_type = option_c_type(CT_FLOAT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = *(double*)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_FLOAT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_FLOAT
            expr_option_inner_struct = ""
        } else if elem_type == CT_LIST {
            ensure_option_type(CT_LIST)
            let opt_type = option_c_type(CT_LIST)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_list*)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_LIST)
            let nested_et = get_list_nested_elem_type(obj_str)
            if nested_et != -1 {
                set_var_option_inner2(res, nested_et)
            }
            let nested_es = get_list_nested_elem_struct(obj_str)
            if nested_es != "" {
                set_var_option_inner2_struct(res, nested_es)
            }
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_LIST
            expr_option_inner_struct = ""
            expr_option_inner_list_elem = nested_et
            expr_option_inner_list_struct = nested_es
        } else if elem_type == CT_MAP {
            let map_k = get_list_elem_map_key_type(obj_str)
            let map_v = get_list_elem_map_val_type(obj_str)
            let k_tag = if map_k >= 0 { c_type_tag(map_k) } else { "str" }
            let v_tag = if map_v >= 0 { c_type_tag(map_v) } else { "int" }
            let map_struct = "Map_{k_tag}_{v_tag}"
            ensure_struct_option_type(map_struct)
            let opt_type = struct_option_c_type(map_struct)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_map*)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option_struct(res, CT_MAP, map_struct)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_MAP
            expr_option_inner_struct = map_struct
        } else {
            ensure_option_type(CT_INT)
            let opt_type = option_c_type(CT_INT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_list_in_bounds({obj_str}, {idx_tmp})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (int64_t)(intptr_t)blink_list_get({obj_str}, {idx_tmp});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_INT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_INT
            expr_option_inner_struct = ""
        }
        return 1
    }
    if method == "set" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let val_str2 = expr_result_str
        let val_type2 = expr_result_type
        let val_struct2 = get_var_struct(val_str2)
        if val_type2 == CT_STRUCT && val_struct2 != "" {
            let box_tmp = fresh_temp("_box")
            emit_line("{c_type_c_name(val_struct2)}* {box_tmp} = ({c_type_c_name(val_struct2)}*)blink_alloc(sizeof({c_type_c_name(val_struct2)}));")
            emit_line("*{box_tmp} = {val_str2};")
            emit_line("blink_list_set({obj_str}, {idx_str}, (void*){box_tmp});")
        } else if val_type2 == CT_INT {
            emit_line("blink_list_set({obj_str}, {idx_str}, (void*)(intptr_t){val_str2});")
        } else if val_type2 == CT_FLOAT {
            let box_tmp = fresh_temp("_fbox")
            emit_line("double* {box_tmp} = (double*)blink_alloc(sizeof(double));")
            emit_line("*{box_tmp} = {val_str2};")
            emit_line("blink_list_set({obj_str}, {idx_str}, (void*){box_tmp});")
        } else {
            emit_line("blink_list_set({obj_str}, {idx_str}, (void*){val_str2});")
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "join" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let delim_str = expr_result_str
        expr_result_str = "blink_str_join({obj_str}, {delim_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "concat" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let other_str = expr_result_str
        expr_result_str = "blink_list_concat({obj_str}, {other_str})"
        expr_result_type = CT_LIST
        return 1
    }
    if method == "slice" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let start_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let end_str = expr_result_str
        expr_result_str = "blink_list_slice({obj_str}, {start_str}, {end_str})"
        expr_result_type = CT_LIST
        return 1
    }
    0
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_map_method(node: Int, obj_str: Str, obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "insert" {
        let mut set_var_name = ""
        if node_kind(obj_node) == NodeKind.Ident {
            set_var_name = node_name(obj_node)
        }
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let key_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let val_str2 = expr_result_str
        let val_type2 = expr_result_type
        let val_list_elem = expr_list_elem_type
        let val_struct = if val_type2 == CT_STRUCT { resolve_push_struct(val_str2, "") } else { "" }
        if val_struct != "" {
            let struct_c = c_type_c_name(val_struct)
            let box_tmp = fresh_temp("_sbox")
            emit_line("{struct_c}* {box_tmp} = ({struct_c}*)blink_alloc(sizeof({struct_c}));")
            emit_line("*{box_tmp} = {val_str2};")
            emit_line("blink_map_set({obj_str}, {key_str}, (void*){box_tmp});")
        } else if val_type2 == CT_INT {
            emit_line("blink_map_set({obj_str}, {key_str}, (void*)(intptr_t){val_str2});")
        } else if val_type2 == CT_FLOAT {
            let box_tmp = fresh_temp("_fbox")
            emit_line("double* {box_tmp} = (double*)blink_alloc(sizeof(double));")
            emit_line("*{box_tmp} = {val_str2};")
            emit_line("blink_map_set({obj_str}, {key_str}, (void*){box_tmp});")
        } else {
            emit_line("blink_map_set({obj_str}, {key_str}, (void*){val_str2});")
        }
        if set_var_name != "" {
            emit_trace_state(set_var_name, "insert", val_str2, val_type2)
        }
        let map_name_for_set = if set_var_name != "" { set_var_name } else { obj_str }
        set_map_types(map_name_for_set, CT_STRING, val_type2, "")
        if val_struct != "" {
            set_map_value_struct(map_name_for_set, val_struct)
        }
        if val_type2 == CT_LIST && val_list_elem >= 0 {
            set_map_value_list_elem(map_name_for_set, val_list_elem)
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "get" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let key_str = expr_result_str
        let mut map_var_name = obj_str
        if node_kind(obj_node) == NodeKind.Ident {
            map_var_name = node_name(obj_node)
        }
        let vtype = get_map_value_type(map_var_name)
        let vstruct = get_map_value_struct(map_var_name)
        let res = fresh_temp("_mgetopt_")
        if vstruct != "" {
            ensure_struct_option_type(vstruct)
            let opt_type = struct_option_c_type(vstruct)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = ({c_type_c_name(vstruct)}*)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option_struct(res, CT_VOID, vstruct)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_VOID
            expr_option_inner_struct = vstruct
        } else if vtype == CT_STRING {
            ensure_option_type(CT_STRING)
            let opt_type = option_c_type(CT_STRING)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (const char*)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_STRING)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_STRING
            expr_option_inner_struct = ""
        } else if vtype == CT_LIST {
            ensure_option_type(CT_LIST)
            let opt_type = option_c_type(CT_LIST)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_list*)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_LIST)
            let list_elem = get_map_value_list_elem(map_var_name)
            if list_elem >= 0 {
                set_var_option_inner2(res, list_elem)
            }
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_LIST
            expr_option_inner_struct = ""
            expr_option_inner_list_elem = list_elem
        } else if vtype == CT_MAP {
            ensure_option_type(CT_MAP)
            let opt_type = option_c_type(CT_MAP)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (blink_map*)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_MAP)
            let map_val_struct = get_map_value_struct(map_var_name)
            if map_val_struct != "" {
                set_var_option_inner2_struct(res, map_val_struct)
                expr_option_inner_map_val_struct = map_val_struct
            }
            let map_val_list_elem = get_map_value_list_elem(map_var_name)
            if map_val_list_elem >= 0 {
                set_var_option_inner2(res, map_val_list_elem)
                expr_option_inner_map_val_list_elem = map_val_list_elem
            }
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_MAP
            expr_option_inner_struct = ""
        } else if vtype == CT_FLOAT {
            ensure_option_type(CT_FLOAT)
            let opt_type = option_c_type(CT_FLOAT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = *(double*)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_FLOAT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_FLOAT
            expr_option_inner_struct = ""
        } else {
            ensure_option_type(CT_INT)
            let opt_type = option_c_type(CT_INT)
            emit_line("{opt_type} {res};")
            emit_line("if (blink_map_has({obj_str}, {key_str})) \{")
            emit_line("    {res}.tag = 1; {res}.value = (int64_t)(intptr_t)blink_map_get({obj_str}, {key_str});")
            emit_line("} else \{ {res}.tag = 0; }")
            set_var_option(res, CT_INT)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_INT
            expr_option_inner_struct = ""
        }
        return 1
    }
    if method == "contains_key" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let key_str = expr_result_str
        expr_result_str = "blink_map_has({obj_str}, {key_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "remove" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let key_str = expr_result_str
        expr_result_str = "blink_map_remove({obj_str}, {key_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "len" {
        expr_result_str = "blink_map_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "clear" {
        emit_line("blink_map_clear({obj_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "keys" {
        expr_result_str = "blink_map_keys({obj_str})"
        expr_result_type = CT_LIST
        expr_list_elem_type = CT_STRING
        return 1
    }
    if method == "values" {
        let mut values_var_name = obj_str
        if node_kind(obj_node) == NodeKind.Ident {
            values_var_name = node_name(obj_node)
        }
        let vtype = get_map_value_type(values_var_name)
        expr_result_str = "blink_map_values({obj_str})"
        expr_result_type = CT_LIST
        expr_list_elem_type = vtype
        return 1
    }
    0
}

fn set_key_str(val_str: Str, val_type: Int) -> Str ! Codegen.Emit {
    if val_type == CT_INT {
        return "blink_int_to_key({val_str})"
    }
    val_str
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_set_method(node: Int, obj_str: Str, obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "insert" {
        let mut set_var_name = ""
        if node_kind(obj_node) == NodeKind.Ident {
            set_var_name = node_name(obj_node)
        }
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let val_str = expr_result_str
        let val_type = expr_result_type
        let str_val = set_key_str(val_str, val_type)
        expr_result_str = "blink_set_insert({obj_str}, {str_val})"
        expr_result_type = CT_BOOL
        if set_var_name != "" {
            set_set_elem_type(set_var_name, val_type)
        }
        return 1
    }
    if method == "remove" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let str_val = set_key_str(expr_result_str, expr_result_type)
        expr_result_str = "blink_set_remove({obj_str}, {str_val})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "contains" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let str_val = set_key_str(expr_result_str, expr_result_type)
        expr_result_str = "blink_set_contains({obj_str}, {str_val})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "len" {
        expr_result_str = "blink_set_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "is_empty" {
        expr_result_str = "(blink_set_len({obj_str}) == 0)"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "union" {
        let mut set_var_name = ""
        if node_kind(obj_node) == NodeKind.Ident {
            set_var_name = node_name(obj_node)
        }
        let elem_type = get_set_elem_type(if set_var_name != "" { set_var_name } else { obj_str })
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let other_str = expr_result_str
        expr_result_str = "blink_set_union({obj_str}, {other_str})"
        expr_result_type = CT_SET
        expr_list_elem_type = elem_type
        return 1
    }
    0
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_bytes_method(node: Int, obj_str: Str, _obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "push" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let val_str = expr_result_str
        emit_line("blink_bytes_push({obj_str}, {val_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "get" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        ensure_option_type(CT_INT)
        let opt_type = option_c_type(CT_INT)
        let raw = fresh_temp("_bget_")
        let res = fresh_temp("_bget_opt_")
        emit_line("int64_t {raw} = blink_bytes_get({obj_str}, {idx_str});")
        emit_line("{opt_type} {res} = {raw} >= 0 ? ({opt_type})\{.tag = 1, .value = {raw}} : ({opt_type})\{.tag = 0};")
        set_var_option(res, CT_INT)
        expr_result_str = res
        expr_result_type = CT_OPTION
        expr_option_inner = CT_INT
        expr_option_inner_struct = ""
        return 1
    }
    if method == "set" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let val_str = expr_result_str
        emit_line("blink_bytes_set({obj_str}, {idx_str}, {val_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "len" {
        expr_result_str = "blink_bytes_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "is_empty" {
        expr_result_str = "blink_bytes_is_empty({obj_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    if method == "slice" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let start_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1 + btc_arg_offset))
        let end_str = expr_result_str
        expr_result_str = "blink_bytes_slice({obj_str}, {start_str}, {end_str})"
        expr_result_type = CT_BYTES
        return 1
    }
    if method == "concat" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let other_str = expr_result_str
        expr_result_str = "blink_bytes_concat({obj_str}, {other_str})"
        expr_result_type = CT_BYTES
        return 1
    }
    if method == "to_str" {
        ensure_result_type(CT_STRING, CT_STRING)
        let res_type = result_c_type(CT_STRING, CT_STRING)
        let out = fresh_temp("_bstr_")
        let ok = fresh_temp("_bstr_ok_")
        let res = fresh_temp("_bstr_res_")
        emit_line("const char* {out};")
        emit_line("int {ok} = blink_bytes_to_str_checked({obj_str}, &{out});")
        emit_line("{res_type} {res} = {ok} ? ({res_type})\{.tag = 0, .ok = {out}} : ({res_type})\{.tag = 1, .err = {out}};")
        expr_result_str = res
        expr_result_type = CT_RESULT
        expr_result_ok_type = CT_STRING
        expr_result_err_type = CT_STRING
        return 1
    }
    if method == "to_hex" {
        expr_result_str = "blink_bytes_to_hex({obj_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if emit_bytes_fixed_read(node, obj_str, method, "u16_be", 2) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "u32_be", 4) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "i32_be", 4) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "i64_be", 8) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "u16_le", 2) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "u32_le", 4) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "i32_le", 4) != 0 { return 1 }
    if emit_bytes_fixed_read(node, obj_str, method, "i64_le", 8) != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "u16_be") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "u32_be") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "i32_be") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "i64_be") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "u16_le") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "u32_le") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "i32_le") != 0 { return 1 }
    if emit_bytes_fixed_write(node, obj_str, method, "i64_le") != 0 { return 1 }
    0
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_bytes_fixed_read(node: Int, obj_str: Str, method: Str, suffix: Str, width: Int) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method != "read_{suffix}" { return 0 }
    let args_sl = node_args(node)
    emit_expr(sublist_get(args_sl, btc_arg_offset))
    let off_str = expr_result_str
    ensure_result_type(CT_INT, CT_STRING)
    let res_type = result_c_type(CT_INT, CT_STRING)
    let off_tmp = fresh_temp("_brd_off_")
    let len_tmp = fresh_temp("_brd_len_")
    let res = fresh_temp("_brd_res_")
    emit_line("int64_t {off_tmp} = {off_str};")
    emit_line("int64_t {len_tmp} = blink_bytes_len({obj_str});")
    emit_line("{res_type} {res} = ({off_tmp} < 0 || {off_tmp} + {width} > {len_tmp}) ? ({res_type})\{.tag = 1, .err = \"bytes read {suffix}: offset out of bounds\"} : ({res_type})\{.tag = 0, .ok = blinkrt_bytes_read_{suffix}({obj_str}, {off_tmp})};")
    expr_result_str = res
    expr_result_type = CT_RESULT
    expr_result_ok_type = CT_INT
    expr_result_err_type = CT_STRING
    1
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_bytes_fixed_write(node: Int, obj_str: Str, method: Str, suffix: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method != "write_{suffix}" { return 0 }
    let args_sl = node_args(node)
    emit_expr(sublist_get(args_sl, btc_arg_offset))
    let val_str = expr_result_str
    emit_line("blinkrt_bytes_write_{suffix}({obj_str}, {val_str});")
    expr_result_str = "0"
    expr_result_type = CT_VOID
    1
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_sb_method(node: Int, obj_str: Str, _obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "write" {
        let args_sl = node_args(node)
        let arg_node = sublist_get(args_sl, btc_arg_offset)
        let arg_kind = node_kind(arg_node)
        if arg_kind == NodeKind.InterpString {
            let parts_sl = node_elements(arg_node)
            if parts_sl != -1 {
                let mut pi = 0
                while pi < sublist_length(parts_sl) {
                    let part = sublist_get(parts_sl, pi)
                    let pk = node_kind(part)
                    if pk == NodeKind.Ident && node_str_val(part) == node_name(part) {
                        let lit = node_str_val(part)
                        if lit != "" {
                            emit_line("blink_sb_write({obj_str}, \"{escape_c_string(lit)}\");")
                        }
                    } else {
                        emit_expr(part)
                        let e_str = expr_result_str
                        let e_type = expr_result_type
                        if e_type == CT_INT {
                            emit_line("blink_sb_write_int({obj_str}, {e_str});")
                        } else if e_type == CT_FLOAT {
                            emit_line("blink_sb_write_float({obj_str}, {e_str});")
                        } else if e_type == CT_BOOL {
                            emit_line("blink_sb_write_bool({obj_str}, {e_str});")
                        } else {
                            emit_line("blink_sb_write({obj_str}, {e_str});")
                        }
                    }
                    pi = pi + 1
                }
            }
        } else {
            emit_expr(arg_node)
            let arg_str = expr_result_str
            emit_line("blink_sb_write({obj_str}, {arg_str});")
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "write_char" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let ch_str = expr_result_str
        emit_line("blink_sb_write_char({obj_str}, {ch_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "to_str" {
        expr_result_str = "blink_sb_to_str({obj_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "len" {
        expr_result_str = "blink_sb_len({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "capacity" {
        expr_result_str = "blink_sb_capacity({obj_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "clear" {
        emit_line("blink_sb_clear({obj_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return 1
    }
    if method == "is_empty" {
        expr_result_str = "(blink_sb_is_empty({obj_str}))"
        expr_result_type = CT_BOOL
        return 1
    }
    0
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_template_method(node: Int, obj_str: Str, _obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if method == "parts" {
        expr_result_str = "{obj_str}->parts"
        expr_result_type = CT_LIST
        set_list_elem_type(expr_result_str, CT_STRING)
        expr_list_elem_type = CT_STRING
        return 1
    }
    if method == "count" {
        expr_result_str = "{obj_str}->count"
        expr_result_type = CT_INT
        return 1
    }
    if method == "type_tag" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        expr_result_str = "(int64_t)(intptr_t)blink_list_get({obj_str}->types, {idx_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "get_str" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        expr_result_str = "(const char*)blink_list_get({obj_str}->values, {idx_str})"
        expr_result_type = CT_STRING
        return 1
    }
    if method == "get_int" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        expr_result_str = "(int64_t)(intptr_t)blink_list_get({obj_str}->values, {idx_str})"
        expr_result_type = CT_INT
        return 1
    }
    if method == "get_float" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        let tmp = fresh_temp("_tplv_")
        let ftmp = fresh_temp("_tplf_")
        emit_line("void* {tmp} = blink_list_get({obj_str}->values, {idx_str});")
        emit_line("double {ftmp}; memcpy(&{ftmp}, &{tmp}, sizeof(double));")
        expr_result_str = ftmp
        expr_result_type = CT_FLOAT
        return 1
    }
    if method == "get_bool" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, btc_arg_offset))
        let idx_str = expr_result_str
        expr_result_str = "(int64_t)(intptr_t)blink_list_get({obj_str}->values, {idx_str})"
        expr_result_type = CT_BOOL
        return 1
    }
    0
}

fn emit_builtin_trait_method(node: Int, obj_str: Str, obj_type: Int, obj_node: Int, method: Str) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if lookup_builtin_trait_impl("StrOps", obj_type) != 0 {
        if emit_str_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("ListOps", obj_type) != 0 {
        if emit_list_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("MapOps", obj_type) != 0 {
        if emit_map_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("SetOps", obj_type) != 0 {
        if emit_set_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("BytesOps", obj_type) != 0 {
        if emit_bytes_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("StringBuildOps", obj_type) != 0 {
        if emit_sb_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    if lookup_builtin_trait_impl("TemplateOps", obj_type) != 0 {
        if emit_template_method(node, obj_str, obj_node, method) != 0 { return 1 }
    }
    0
}

// Emit a direct C printf/fprintf call with type dispatch.
// fmt_prefix is the C call prefix before the format string, e.g. "printf(" or "fprintf(stderr, ".
// prefix is an optional string prepended to the output, e.g. "[LOG] " or "".
fn emit_io_typed_direct(fmt_prefix: Str, arg_str: Str, arg_type: Int, newline: Int, prefix: Str) ! Codegen.Emit {
    let nl = if newline != 0 { "\\n" } else { "" }
    if arg_type == CT_INT {
        emit_line("{fmt_prefix}\"{prefix}%%lld{nl}\", (long long){arg_str});")
    } else if arg_type == CT_FLOAT {
        emit_line("{fmt_prefix}\"{prefix}%%g{nl}\", {arg_str});")
    } else if arg_type == CT_BOOL {
        emit_line("{fmt_prefix}\"{prefix}%%s{nl}\", {arg_str} ? \"true\" : \"false\");")
    } else {
        emit_line("{fmt_prefix}\"{prefix}%%s{nl}\", {arg_str});")
    }
}

// Emit snprintf + vtable call with type dispatch (for non-handler IO paths).
// vtable_method is the C vtable call, e.g. "__blink_ev.io->print" or "__ev->io->print".
fn emit_io_typed_vtable(vtable_method: Str, arg_str: Str, arg_type: Int, tmp_prefix: Str) ! Codegen.Emit {
    if arg_type == CT_INT {
        let tmp = fresh_temp(tmp_prefix)
        emit_line("char {tmp}[64]; snprintf({tmp}, 64, \"%%lld\", (long long){arg_str});")
        emit_line("{vtable_method}({tmp});")
    } else if arg_type == CT_FLOAT {
        let tmp = fresh_temp(tmp_prefix)
        emit_line("char {tmp}[64]; snprintf({tmp}, 64, \"%%g\", {arg_str});")
        emit_line("{vtable_method}({tmp});")
    } else if arg_type == CT_BOOL {
        emit_line("{vtable_method}({arg_str} ? \"true\" : \"false\");")
    } else {
        emit_line("{vtable_method}({arg_str});")
    }
}

// Unified IO output method emitter. Parameters:
// - trace_op: trace label (e.g. "io.println"), empty = no trace
// - direct_prefix: C call prefix for direct mode (e.g. "printf(" or "fprintf(stderr, ")
// - newline: 1 = append \n, 0 = no newline
// - vtable_method: vtable call (e.g. "__blink_ev.io->print"), empty = always direct
// - vtable_tmp: temp prefix for vtable snprintf buffers, empty if no vtable
// - direct_text_prefix: text prefix in direct mode (e.g. "[LOG] "), usually empty
// - zero_arg_direct: C statement for zero-arg call in handler body, empty = no-op
// - zero_arg_vtable: C statement for zero-arg call outside handler body, empty = no-op
@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_io_output(node: Int, trace_op: Str, direct_prefix: Str, newline: Int, vtable_method: Str, vtable_tmp: Str, direct_text_prefix: Str, zero_arg_direct: Str, zero_arg_vtable: Str) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let args_sl = node_args(node)
    if args_sl != -1 && sublist_length(args_sl) > 0 {
        emit_expr(sublist_get(args_sl, 0))
        let arg_str = expr_result_str
        let arg_type = expr_result_type
        if trace_op != "" {
            emit_trace_effect_typed("IO", trace_op, "msg", arg_str, arg_type)
        }
        if vtable_method != "" && cg_in_handler_body == 0 {
            emit_io_typed_vtable(vtable_method, arg_str, arg_type, vtable_tmp)
        } else {
            emit_io_typed_direct(direct_prefix, arg_str, arg_type, newline, direct_text_prefix)
        }
    } else if zero_arg_direct != "" || zero_arg_vtable != "" {
        if cg_in_handler_body != 0 || zero_arg_vtable == "" {
            if zero_arg_direct != "" {
                emit_line(zero_arg_direct)
            }
        } else {
            emit_line(zero_arg_vtable)
        }
    }
    expr_result_str = "0"
    expr_result_type = CT_VOID
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_method_call(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let obj_node = node_obj(node)
    let method = node_method(node)
    let mut mc_obj_is_local = 0
    if node_kind(obj_node) == NodeKind.Ident {
        if is_scope_var(node_name(obj_node)) != 0 {
            mc_obj_is_local = 1
        }
    }

    // Static derive method dispatch: Type.from_json(str)
    if node_kind(obj_node) == NodeKind.Ident {
        let static_type_name = node_name(obj_node)
        if method == "from_json" && has_derive_method(static_type_name, "from_json") != 0 {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                let tmp = fresh_temp("_deser_")
                emit_line("blink_Result_{static_type_name}_str {tmp} = blink_{static_type_name}_from_json({arg_str});")
                set_var_struct(tmp, "Result_{static_type_name}_str")
                set_var(tmp, CT_VOID, 0)
                set_var_result_struct(tmp, CT_VOID, CT_STRING, static_type_name, "")
                expr_result_str = tmp
                expr_result_type = CT_RESULT
                expr_result_ok_type = CT_VOID
                expr_result_ok_struct = static_type_name
                expr_result_err_type = CT_STRING
                expr_result_err_struct = ""
                return
            }
        }
        if method == "from_str" && is_str_backed_enum(static_type_name) != 0 {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                let tmp = fresh_temp("_fromstr_")
                emit_line("blink_Option_{static_type_name} {tmp} = {c_fn_name("{static_type_name}_from_str")}({arg_str});")
                set_var_struct(tmp, "Option_{static_type_name}")
                set_var(tmp, CT_OPTION, 0)
                set_var_option(tmp, CT_VOID)
                set_var_option_struct(tmp, CT_VOID, static_type_name)
                expr_result_str = tmp
                expr_result_type = CT_OPTION
                expr_result_ok_type = CT_VOID
                return
            }
        }
    }

    // Data-carrying enum variant constructor: Shape.Circle(5.0)
    if node_kind(obj_node) == NodeKind.Ident {
        let mc_obj_name = node_name(obj_node)
        if is_enum_type(mc_obj_name) != 0 && is_data_enum(mc_obj_name) != 0 {
            let vidx = get_variant_index(mc_obj_name, method)
            if vidx >= 0 {
                let tag = get_variant_tag(mc_obj_name, method)
                let fcount = get_variant_field_count(vidx)
                let args_sl = node_args(node)
                let enum_c_name = c_type_c_name(mc_obj_name)
                let mut init_str = "({enum_c_name})\{.tag = {tag}"
                if fcount > 0 && args_sl != -1 {
                    init_str = init_str.concat(", .data.{method} = \{")
                    let mut fi = 0
                    while fi < sublist_length(args_sl) && fi < fcount {
                        if fi > 0 {
                            init_str = init_str.concat(", ")
                        }
                        let field_name = get_variant_field_name(vidx, fi).unwrap()
                        let field_type = get_variant_field_type_str(vidx, fi).unwrap()
                        emit_expr(sublist_get(args_sl, fi))
                        let arg_str = expr_result_str
                        if field_type == mc_obj_name {
                            let box_tmp = fresh_temp("_ebox")
                            emit_line("{enum_c_name}* {box_tmp} = ({enum_c_name}*)blink_alloc(sizeof({enum_c_name}));")
                            emit_line("*{box_tmp} = {arg_str};")
                            init_str = init_str.concat(".{field_name} = (int64_t)(intptr_t){box_tmp}")
                        } else {
                            init_str = init_str.concat(".{field_name} = {arg_str}")
                        }
                        fi = fi + 1
                    }
                    init_str = init_str.concat("}")
                }
                init_str = init_str.concat("}")
                expr_result_str = init_str
                expr_result_type = CT_VOID
                set_var_struct(init_str, mc_obj_name)
                return
            }
        }
    }

    // Bytes.new() and Bytes.from_str(s) — static constructors
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "Bytes" {
        if method == "new" {
            expr_result_str = "blink_bytes_new()"
            expr_result_type = CT_BYTES
            return
        }
        if method == "from_str" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                expr_result_str = "blink_bytes_from_str({arg_str})"
                expr_result_type = CT_BYTES
                return
            }
            expr_result_str = "blink_bytes_new()"
            expr_result_type = CT_BYTES
            return
        }
    }

    // Char.from_code_point(n) — static constructor
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "Char" {
        if method == "from_code_point" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                expr_result_str = "blink_str_from_char_code({arg_str})"
                expr_result_type = CT_STRING
                return
            }
        }
    }

    // StringBuilder.new() and StringBuilder.with_capacity(n) — static constructors
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "StringBuilder" {
        if method == "new" {
            expr_result_str = "blink_sb_new()"
            expr_result_type = CT_STRINGBUILDER
            return
        }
        if method == "with_capacity" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let cap_str = expr_result_str
                expr_result_str = "blink_sb_with_capacity({cap_str})"
            } else {
                expr_result_str = "blink_sb_new()"
            }
            expr_result_type = CT_STRINGBUILDER
            return
        }
    }

    // Duration static constructors: Duration.nanos(n), Duration.ms(n), etc.
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "Duration" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) > 0 {
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            if method == "nanos" {
                expr_result_str = "blink_Duration_nanos({arg_str})"
                expr_result_type = CT_DURATION
                return
            }
            if method == "ms" {
                expr_result_str = "blink_Duration_ms({arg_str})"
                expr_result_type = CT_DURATION
                return
            }
            if method == "seconds" {
                expr_result_str = "blink_Duration_seconds({arg_str})"
                expr_result_type = CT_DURATION
                return
            }
            if method == "minutes" {
                expr_result_str = "blink_Duration_minutes({arg_str})"
                expr_result_type = CT_DURATION
                return
            }
            if method == "hours" {
                expr_result_str = "blink_Duration_hours({arg_str})"
                expr_result_type = CT_DURATION
                return
            }
        }
    }

    // Instant.from_epoch_secs(n) — static constructor
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "Instant" {
        let args_sl = node_args(node)
        if method == "from_epoch_secs" && args_sl != -1 && sublist_length(args_sl) > 0 {
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            expr_result_str = "blink_Instant_from_epoch_secs({arg_str})"
            expr_result_type = CT_INSTANT
            return
        }
    }

    // io.* output methods — unified dispatch
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "io" && mc_obj_is_local == 0 {
        let io_pfx = ev_field("io")
        if method == "println" {
            emit_io_output(node, "io.println", "printf(", 1, "{io_pfx}->print", "_io_", "", "printf(\"\\n\");", "{io_pfx}->print(\"\");")
            return
        }
        if method == "print" {
            emit_io_output(node, "io.print", "printf(", 0, "{io_pfx}->print_no_nl", "_io_nonl_", "", "", "")
            return
        }
        if method == "print_raw" {
            emit_io_output(node, "", "printf(", 0, "", "", "", "", "")
            return
        }
        if method == "eprintln" {
            emit_io_output(node, "io.eprintln", "fprintf(stderr, ", 1, "{io_pfx}->eprint", "_epr_", "", "fprintf(stderr, \"\\n\");", "{io_pfx}->eprint(\"\");")
            return
        }
        if method == "eprint" {
            emit_io_output(node, "io.eprint", "fprintf(stderr, ", 0, "{io_pfx}->eprint_no_nl", "_epr_nonl_", "", "", "")
            return
        }
        if method == "eprint_raw" {
            emit_io_output(node, "", "fprintf(stderr, ", 0, "", "", "", "", "")
            return
        }
        if method == "log" {
            emit_io_output(node, "io.log", "fprintf(stderr, ", 1, "{io_pfx}->log", "_log_", "[LOG] ", "", "")
            return
        }
        if method == "read_line" {
            let tmp = fresh_temp("_rline_")
            emit_line("const char* {tmp} = blink_stdin_read_line();")
            expr_result_str = tmp
            expr_result_type = CT_STRING
            return
        }
        if method == "read_bytes" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let n_str = expr_result_str
                let tmp = fresh_temp("_rbytes_")
                emit_line("blink_bytes* {tmp} = blink_stdin_read_bytes({n_str});")
                expr_result_str = tmp
            } else {
                expr_result_str = "blink_bytes_new()"
            }
            expr_result_type = CT_BYTES
            return
        }
        if method == "write" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                emit_line("blink_stdout_write({expr_result_str});")
            }
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        if method == "write_bytes" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                emit_line("blink_stdout_write_bytes({expr_result_str});")
            }
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
    }

    // time.* methods — unified dispatch
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "time" && mc_obj_is_local == 0 {
        let time_pfx = ev_field("time")
        if method == "read" {
            expr_result_str = "(blink_Instant)\{.nanos = {time_pfx}->read().nanos}"
            expr_result_type = CT_INSTANT
            return
        }
        if method == "sleep" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let dur_str = expr_result_str
                emit_line("{time_pfx}->sleep((blink_duration_struct)\{.nanos = {dur_str}.nanos});")
            }
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
    }

    // ── net.* operations — old blocks removed, see blink_tcp_* blocks below ──

    // net.read_line(fd) — read line from socket (unix socket primitive)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "read_line" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) > 0 {
            emit_expr(sublist_get(args_sl, 0))
            let fd_str = expr_result_str
            let tmp = fresh_temp("__rline_")
            emit_line("const char* {tmp} = blink_socket_read_line({fd_str});")
            expr_result_str = tmp
        } else {
            expr_result_str = "\"\""
        }
        expr_result_type = CT_STRING
        return
    }

    // async.spawn(closure) — spawn async task on thread pool
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "async" && mc_obj_is_local == 0 && method == "spawn" {
        cg_uses_async = 1
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) > 0 {
            let spawn_arg_node = sublist_get(args_sl, 0)
            let wrapper_idx = cg_async_wrapper_counter
            cg_async_wrapper_counter = cg_async_wrapper_counter + 1
            let wrapper_name = "__async_wrapper_{wrapper_idx}"
            let task_fn_name = "__async_task_{wrapper_idx}"
            let handle_tmp = fresh_temp("__handle_")
            let arg_tmp = fresh_temp("__spawn_arg_")

            if node_kind(spawn_arg_node) == NodeKind.Closure {
                let cap_reg_idx = closure_cap_infos.len()
                emit_async_spawn_closure(spawn_arg_node, wrapper_idx, wrapper_name, task_fn_name)

                emit_line("blink_handle* {handle_tmp} = blink_handle_new();")
                emit_line("__async_arg_{wrapper_idx}_t* {arg_tmp} = (__async_arg_{wrapper_idx}_t*)blink_alloc(sizeof(__async_arg_{wrapper_idx}_t));")
                emit_line("{arg_tmp}->handle = {handle_tmp};")
                let ac_info = closure_cap_infos.get(cap_reg_idx).unwrap()
                if ac_info.count > 0 {
                    let caps_var = "__acaps_{wrapper_idx}"
                    emit_line("void** {caps_var} = (void**)blink_alloc(sizeof(void*) * {ac_info.count});")
                    let mut ci2 = 0
                    while ci2 < ac_info.count {
                        let cap_e = closure_captures.get(ac_info.start + ci2).unwrap()
                        let cap_kind = tp_get_kind(cap_e.tp_id)
                        if cap_e.is_mut != 0 {
                            emit_line("{caps_var}[{ci2}] = (void*){cap_e.name}_cell;")
                        } else if cap_kind == CT_INT {
                            emit_line("{caps_var}[{ci2}] = (void*)(intptr_t){cap_e.name};")
                        } else if cap_kind == CT_FLOAT {
                            let fp_tmp = fresh_temp("__fp_")
                            emit_line("\{double* {fp_tmp} = (double*)blink_alloc(sizeof(double)); *{fp_tmp} = {cap_e.name}; {caps_var}[{ci2}] = (void*){fp_tmp};}")
                        } else if cap_kind == CT_BOOL {
                            emit_line("{caps_var}[{ci2}] = (void*)(intptr_t){cap_e.name};")
                        } else if cap_kind == CT_STRUCT {
                            let st_tmp = fresh_temp("__st_")
                            let st_name = tp_get_sname(cap_e.tp_id)
                            let c_name = c_type_c_name(st_name)
                            emit_line("\{{c_name}* {st_tmp} = ({c_name}*)blink_alloc(sizeof({c_name})); *{st_tmp} = {cap_e.name}; {caps_var}[{ci2}] = (void*){st_tmp};}")
                        } else {
                            emit_line("{caps_var}[{ci2}] = (void*){cap_e.name};")
                        }
                        ci2 = ci2 + 1
                    }
                    emit_line("{arg_tmp}->captures = {caps_var};")
                    emit_line("{arg_tmp}->capture_count = {ac_info.count};")
                }
                emit_line("blink_threadpool_submit(__blink_pool, {wrapper_name}, (void*){arg_tmp});")
            } else {
                emit_expr(spawn_arg_node)
                let closure_str = expr_result_str
                cg_closure_defs.push("typedef struct \{")
                cg_closure_defs.push("    blink_closure* closure;")
                cg_closure_defs.push("    blink_handle* handle;")
                cg_closure_defs.push("} __async_arg_{wrapper_idx}_t;")
                cg_closure_defs.push("")
                cg_closure_defs.push("static void {wrapper_name}(void* __arg) \{")
                cg_closure_defs.push("    __async_arg_{wrapper_idx}_t* __a = (__async_arg_{wrapper_idx}_t*)__arg;")
                cg_closure_defs.push("    blink_closure* __cl = __a->closure;")
                cg_closure_defs.push("    blink_handle* __h = __a->handle;")
                cg_closure_defs.push("    int64_t __r = ((int64_t(*)(const blink_closure*))__cl->fn_ptr)(__cl);")
                cg_closure_defs.push("    blink_handle_set_result(__h, (void*)(intptr_t)__r);")
                cg_closure_defs.push("    GC_FREE(__arg);")
                cg_closure_defs.push("}")
                cg_closure_defs.push("")

                emit_line("blink_handle* {handle_tmp} = blink_handle_new();")
                emit_line("__async_arg_{wrapper_idx}_t* {arg_tmp} = (__async_arg_{wrapper_idx}_t*)blink_alloc(sizeof(__async_arg_{wrapper_idx}_t));")
                emit_line("{arg_tmp}->closure = {closure_str};")
                emit_line("{arg_tmp}->handle = {handle_tmp};")
                emit_line("blink_threadpool_submit(__blink_pool, {wrapper_name}, (void*){arg_tmp});")
            }

            if cg_async_scope_stack.len() > 0 {
                let scope_list = cg_async_scope_stack.get(cg_async_scope_stack.len() - 1).unwrap()
                emit_line("blink_list_push({scope_list}, (void*){handle_tmp});")
            }

            let spawn_ret_str = node_return_type(spawn_arg_node)
            let spawn_ret_ct = type_from_name(spawn_ret_str)
            if spawn_ret_ct == CT_RESULT {
                let ret_ann = node_type_ann(spawn_arg_node)
                if ret_ann != -1 {
                    let elems_sl = node_elements(ret_ann)
                    if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                        let ok_ann = sublist_get(elems_sl, 0)
                        let err_ann = sublist_get(elems_sl, 1)
                        let ok_name = node_name(ok_ann)
                        let err_name = node_name(err_ann)
                        let err_ct = type_from_name(err_name)
                        set_var_handle_full(handle_tmp, CT_RESULT, err_ct, ok_name, err_name)
                    } else {
                        set_var_handle(handle_tmp, CT_RESULT)
                    }
                } else {
                    set_var_handle(handle_tmp, CT_RESULT)
                }
            } else if spawn_ret_ct == CT_OPTION {
                let ret_ann = node_type_ann(spawn_arg_node)
                if ret_ann != -1 {
                    let elems_sl = node_elements(ret_ann)
                    if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                        let inner_ann = sublist_get(elems_sl, 0)
                        let inner_name = node_name(inner_ann)
                        let inner_ct = type_from_name(inner_name)
                        set_var_handle_full(handle_tmp, CT_OPTION, inner_ct, inner_name, "")
                    } else {
                        set_var_handle(handle_tmp, CT_OPTION)
                    }
                } else {
                    set_var_handle(handle_tmp, CT_OPTION)
                }
            } else if (spawn_ret_ct == CT_VOID || spawn_ret_ct == CT_STRUCT || spawn_ret_ct == CT_ENUM) && spawn_ret_str != "Void" && spawn_ret_str != "" && (is_struct_type(spawn_ret_str) != 0 || is_enum_type(spawn_ret_str) != 0) {
                set_var_handle_full(handle_tmp, CT_STRUCT, -1, spawn_ret_str, "")
            } else if spawn_ret_str == "" || spawn_ret_str == "Void" {
                set_var_handle(handle_tmp, CT_INT)
            } else {
                set_var_handle(handle_tmp, spawn_ret_ct)
            }
            expr_result_str = handle_tmp
            expr_result_type = CT_HANDLE
        } else {
            expr_result_str = "0"
            expr_result_type = CT_VOID
        }
        return
    }

    // fs.read — read file contents
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "fs" && mc_obj_is_local == 0 && method == "read" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) > 0 {
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            emit_trace_effect_str("FS.Read", "fs.read", "path", arg_str)
            expr_result_str = "blink_read_file({arg_str})"
            expr_result_type = CT_STRING
        } else {
            expr_result_str = "\"\""
            expr_result_type = CT_STRING
        }
        return
    }

    // fs.write — write file contents
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "fs" && mc_obj_is_local == 0 && method == "write" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) >= 2 {
            emit_expr(sublist_get(args_sl, 0))
            let path_str = expr_result_str
            emit_expr(sublist_get(args_sl, 1))
            let content_str = expr_result_str
            emit_trace_effect_str("FS.Write", "fs.write", "path", path_str)
            emit_line("blink_write_file({path_str}, {content_str});")
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }

    // fs.list_dir — list directory contents
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "fs" && mc_obj_is_local == 0 && method == "list_dir" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) >= 1 {
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            expr_result_str = "blink_list_dir({arg_str})"
            expr_result_type = CT_LIST
            expr_list_elem_type = CT_STRING
        } else {
            expr_result_str = "blink_list_new()"
            expr_result_type = CT_LIST
            expr_list_elem_type = CT_STRING
        }
        return
    }

    // env.args — return List[Str] of command-line arguments
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "env" && mc_obj_is_local == 0 && method == "args" {
        let tmp = fresh_temp("_args_")
        emit_line("blink_list* {tmp} = blink_list_new();")
        emit_line("for (int __ai = 0; __ai < blink_g_argc; __ai++) \{")
        emit_line("    blink_list_push({tmp}, (void*)blink_g_argv[__ai]);")
        emit_line("}")
        set_list_elem_type(tmp, CT_STRING)
        expr_result_str = tmp
        expr_result_type = CT_LIST
        expr_list_elem_type = CT_STRING
        return
    }

    // env.* methods — unified dispatch
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "env" && mc_obj_is_local == 0 {
        let env_pfx = ev_field("env")
        if method == "var" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            emit_trace_effect_str("Env.Read", "env.var", "name", arg_str)
            ensure_option_type(CT_STRING)
            let opt_type = option_c_type(CT_STRING)
            let tmp = fresh_temp("_env_")
            let res = fresh_temp("_env_opt_")
            emit_line("const char* {tmp} = {env_pfx}->read({arg_str});")
            emit_line("{opt_type} {res} = {tmp} ? ({opt_type})\{.tag = 1, .value = {tmp}} : ({opt_type})\{.tag = 0};")
            set_var_option(res, CT_STRING)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_STRING
            expr_option_inner_struct = ""
            return
        }
        if method == "cwd" {
            emit_trace_effect_str("Env.Read", "env.cwd", "op", "\"cwd\"")
            let tmp = fresh_temp("_cwd_")
            emit_line("const char* {tmp} = {env_pfx}->cwd();")
            expr_result_str = tmp
            expr_result_type = CT_STRING
            return
        }
        if method == "set_var" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let name_str = expr_result_str
            emit_expr(sublist_get(args_sl, 1))
            let val_str = expr_result_str
            emit_trace_effect_str("Env.Write", "env.set_var", "name", name_str)
            emit_line("{env_pfx}->write({name_str}, {val_str});")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        if method == "remove_var" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            emit_trace_effect_str("Env.Write", "env.remove_var", "name", arg_str)
            emit_line("{env_pfx}->remove({arg_str});")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        if method == "exit" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            emit_trace_effect_typed("Env", "env.exit", "code", arg_str, CT_INT)
            emit_line("{env_pfx}->exit_fn((int){arg_str});")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
    }

    // default.method(args) — delegate to outer handler inside handler body
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "default" && mc_obj_is_local == 0 && cg_in_handler_body != 0 {
        let outer_name = "__handler_{cg_handler_body_idx}_outer"
        let args_sl = node_args(node)
        let mut args_str = ""
        if args_sl != -1 {
            let mut ai = 0
            while ai < sublist_length(args_sl) {
                if ai > 0 {
                    args_str = args_str.concat(", ")
                }
                emit_expr(sublist_get(args_sl, ai))
                args_str = args_str.concat(expr_result_str)
                ai = ai + 1
            }
        }
        expr_result_str = "{outer_name}->{method}({args_str})"
        expr_result_type = CT_VOID
        return
    }

    // User-defined effect handle dispatch: handle.method(args) -> __blink_ev.ue_handle->method(args)
    if node_kind(obj_node) == NodeKind.Ident {
        let handle_name = node_name(obj_node)
        if is_user_effect_handle(handle_name) != 0 {
            // db.connect(path) — special-case: opens handle, creates handler, and sets up cleanup
            if handle_name == "db" && method == "connect" {
                let args_sl = node_args(node)
                if args_sl != -1 && sublist_length(args_sl) > 0 {
                    emit_expr(sublist_get(args_sl, 0))
                    let path_str = expr_result_str
                    let h_tmp = fresh_temp("__db_handle_")
                    emit_line("void* {h_tmp} = blink_std_db_sqlite_sqlite_open({path_str});")
                    let tmp = fresh_temp("__db_conn_")
                    emit_line("blink_ue_db_vtable* {tmp} = blink_std_db_sqlite_sqlite_handler({h_tmp});")
                    expr_result_str = tmp
                    expr_result_type = CT_HANDLER
                    cg_handler_vtable_type = "blink_ue_db_vtable"
                    cg_handler_vtable_field = "db"
                    cg_handler_is_user_effect = 1
                    cg_handler_cleanup_var = h_tmp
                    cg_handler_cleanup_fn = "blink_std_db_sqlite_sqlite_close"
                    return
                }
            }
            // Single lookup: extract param_types + return info from UeMethod
            let mut matched_uem_param_types: List[Int] = []
            let mut ue_ret_type = CT_VOID
            let mut ue_ret_inner = CT_VOID
            let mut ue_ret_inner_struct = ""
            let mut ue_ret_inner2 = CT_VOID
            let mut ue_ret_inner_struct2 = ""
            let mut ue_ret_c = ""
            let mut ue_ok_elem_ct = CT_VOID
            let mut ue_ok_elem_struct = ""
            let mut mi = 0
            while mi < ue_methods.len() {
                let uem = ue_methods.get(mi).unwrap()
                if uem.effect_handle == handle_name && uem.name == method {
                    matched_uem_param_types = uem.param_types
                    ue_ret_type = uem.ret_ct
                    ue_ret_inner = uem.ret_inner_ct
                    ue_ret_inner_struct = uem.ret_inner_struct
                    ue_ret_inner2 = uem.ret_inner_ct2
                    ue_ret_inner_struct2 = uem.ret_inner_struct2
                    ue_ret_c = uem.ret
                    ue_ok_elem_ct = uem.ret_ok_elem_ct
                    ue_ok_elem_struct = uem.ret_ok_elem_struct
                    break
                }
                mi = mi + 1
            }
            let args_sl = node_args(node)
            let mut args_str = ""
            if args_sl != -1 {
                let mut ai = 0
                while ai < sublist_length(args_sl) {
                    if ai > 0 {
                        args_str = args_str.concat(", ")
                    }
                    let arg_node = sublist_get(args_sl, ai)
                    let mut is_template_param = 0
                    if ai < matched_uem_param_types.len() {
                        if matched_uem_param_types.get(ai).unwrap() == CT_TEMPLATE {
                            is_template_param = 1
                        }
                    }
                    if is_template_param != 0 {
                        let arg_kind = node_kind(arg_node)
                        if arg_kind == NodeKind.InterpString {
                            emit_template_construction(arg_node)
                        } else {
                            diag_error_at("TemplateMismatch", "E0310", "expected Template, found Str — pass a string literal directly", arg_node, "use an interpolated string literal at the call site")
                            emit_expr(arg_node)
                        }
                    } else {
                        emit_expr(arg_node)
                    }
                    args_str = args_str.concat(expr_result_str)
                    ai = ai + 1
                }
            }
            let ue_dpfx = ev_field("ue_{handle_name}")
            if ue_ret_type == CT_VOID {
                emit_line("{ue_dpfx}->{method}({args_str});")
                expr_result_str = "0"
            } else if ue_ret_type == CT_LIST {
                let tmp = fresh_temp("__ue_ret_")
                emit_line("blink_list* {tmp} = {ue_dpfx}->{method}({args_str});")
                if ue_ret_inner_struct != "" {
                    set_list_elem_type(tmp, CT_VOID)
                    set_list_elem_struct(tmp, ue_ret_inner_struct)
                } else {
                    set_list_elem_type(tmp, ue_ret_inner)
                }
                expr_result_str = tmp
                expr_list_elem_type = ue_ret_inner
                expr_list_elem_struct = ue_ret_inner_struct
            } else if ue_ret_type == CT_OPTION {
                let opt_type = option_c_type(ue_ret_inner)
                let tmp = fresh_temp("__ue_ret_")
                emit_line("{opt_type} {tmp} = {ue_dpfx}->{method}({args_str});")
                if ue_ret_inner_struct != "" {
                    let concrete_opt = struct_option_c_type(ue_ret_inner_struct)
                    let conv = fresh_temp("__ue_conv_")
                    let struct_c = c_type_c_name(ue_ret_inner_struct)
                    emit_line("{concrete_opt} {conv};")
                    emit_line("{conv}.tag = {tmp}.tag;")
                    emit_line("if ({tmp}.tag == 1) \{ {conv}.value = ({struct_c}*){tmp}.value; }")
                    set_var_option(conv, CT_VOID)
                    expr_result_str = conv
                } else {
                    set_var_option(tmp, ue_ret_inner)
                    expr_result_str = tmp
                }
                expr_option_inner = ue_ret_inner
                expr_option_inner_struct = ue_ret_inner_struct
            } else if ue_ret_type == CT_RESULT {
                let tmp = fresh_temp("__ue_ret_")
                emit_line("{ue_ret_c} {tmp} = {ue_dpfx}->{method}({args_str});")
                if ue_ret_inner == CT_OPTION && ue_ok_elem_struct != "" {
                    let concrete_opt = struct_option_c_type(ue_ok_elem_struct)
                    let struct_c = c_type_c_name(ue_ok_elem_struct)
                    let err_tag = if ue_ret_inner_struct2 != "" { ue_ret_inner_struct2 } else { c_type_tag(ue_ret_inner2) }
                    let concrete_res = "blink_Result_Option_{ue_ok_elem_struct}_{err_tag}"
                    ensure_struct_option_type(ue_ok_elem_struct)
                    ensure_struct_result_type("Option_{ue_ok_elem_struct}", err_tag)
                    let conv = fresh_temp("__ue_conv_")
                    emit_line("{concrete_res} {conv};")
                    emit_line("{conv}.tag = {tmp}.tag;")
                    emit_line("if ({tmp}.tag == 0) \{")
                    let opt_conv = fresh_temp("__ue_optc_")
                    emit_line("    {concrete_opt} {opt_conv};")
                    emit_line("    {opt_conv}.tag = {tmp}.ok.tag;")
                    emit_line("    if ({tmp}.ok.tag == 1) \{ {opt_conv}.value = ({struct_c}*){tmp}.ok.value; }")
                    emit_line("    {conv}.ok = {opt_conv};")
                    emit_line("} else \{")
                    if ue_ret_inner_struct2 != "" {
                        emit_line("    memcpy(&{conv}.err, &{tmp}.err, sizeof({tmp}.err));")
                    } else {
                        emit_line("    {conv}.err = {tmp}.err;")
                    }
                    emit_line("}")
                    set_var_result_struct(conv, ue_ret_inner, ue_ret_inner2, ue_ret_inner_struct, ue_ret_inner_struct2)
                    expr_result_str = conv
                } else {
                    if ue_ret_inner_struct != "" || ue_ret_inner_struct2 != "" {
                        set_var_result_struct(tmp, ue_ret_inner, ue_ret_inner2, ue_ret_inner_struct, ue_ret_inner_struct2)
                    } else {
                        set_var_result(tmp, ue_ret_inner, ue_ret_inner2)
                    }
                    if ue_ret_inner == CT_LIST && (ue_ok_elem_ct != CT_VOID || ue_ok_elem_struct != "") {
                        set_var_result_ok_elem(tmp, ue_ok_elem_ct, ue_ok_elem_struct)
                    }
                    expr_result_str = tmp
                }
                expr_result_ok_type = ue_ret_inner
                expr_result_err_type = ue_ret_inner2
                expr_result_ok_struct = ue_ret_inner_struct
                expr_result_err_struct = ue_ret_inner_struct2
                if ue_ret_inner == CT_LIST {
                    expr_list_elem_type = ue_ok_elem_ct
                    expr_list_elem_struct = ue_ok_elem_struct
                }
            } else {
                expr_result_str = "{ue_dpfx}->{method}({args_str})"
            }
            expr_result_type = ue_ret_type
            return
        }
    }

    // Qualified trait call: Trait.method(args) parsed as MethodCall(obj=Trait, method=method)
    if node_kind(obj_node) == NodeKind.Ident {
        let trait_name = node_name(obj_node)
        if is_trait_type(trait_name) != 0 {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let first_str = expr_result_str
                let first_type = expr_result_type
                let type_name = get_var_struct(first_str)
                if type_name != "" {
                    let mangled = "{type_name}_{method}"
                    let mut args_str = first_str
                    let mut i = 1
                    while i < sublist_length(args_sl) {
                        args_str = args_str.concat(", ")
                        emit_expr(sublist_get(args_sl, i))
                        args_str = args_str.concat(expr_result_str)
                        i = i + 1
                    }
                    expr_result_str = "{c_fn_name(mangled)}({args_str})"
                    expr_list_elem_type = -1
                    expr_list_elem_struct = ""
                    expr_result_type = get_impl_method_ret(type_name, method)
                    return
                }
                // Builtin trait dispatch: e.g. MapOps.contains_key(m, k)
                if lookup_builtin_trait_impl(trait_name, first_type) != 0 {
                    btc_arg_offset = 1
                    let handled = emit_builtin_trait_method(node, first_str, first_type, obj_node, method)
                    btc_arg_offset = 0
                    if handled != 0 {
                        return
                    }
                }
            }
        }
    }

    // Static From dispatch: Type.from(value)
    if node_kind(obj_node) == NodeKind.Ident {
        let target_type = node_name(obj_node)
        if method == "from" && (is_struct_type(target_type) != 0 || is_enum_type(target_type) != 0) {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                let arg_type = expr_result_type
                let source_type = type_name_from_ct(arg_type)
                let arg_struct = get_var_struct(arg_str)
                let mut src = source_type
                if arg_struct != "" {
                    src = arg_struct
                }
                let from_methods = find_from_impl(src, target_type)
                if from_methods != -1 && sublist_length(from_methods) > 0 {
                    let from_fn = sublist_get(from_methods, 0)
                    let from_name = node_name(from_fn)
                    let mangled = "{target_type}_{from_name}"
                    expr_result_str = "{c_fn_name(mangled)}({arg_str})"
                    expr_result_type = get_fn_ret(mangled)
                    if expr_result_type == CT_VOID {
                        set_var_struct(expr_result_str, target_type)
                    }
                    return
                }
            }
        }
    }

    // Static TryFrom dispatch: Type.try_from(value)
    if node_kind(obj_node) == NodeKind.Ident {
        let target_type = node_name(obj_node)
        if method == "try_from" && (is_struct_type(target_type) != 0 || is_enum_type(target_type) != 0) {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let arg_str = expr_result_str
                let arg_type = expr_result_type
                let source_type = type_name_from_ct(arg_type)
                let arg_struct = get_var_struct(arg_str)
                let mut src = source_type
                if arg_struct != "" {
                    src = arg_struct
                }
                let tf_methods = find_tryfrom_impl(src, target_type)
                if tf_methods != -1 && sublist_length(tf_methods) > 0 {
                    let tf_fn = sublist_get(tf_methods, 0)
                    let tf_name = node_name(tf_fn)
                    let mangled = "{target_type}_{tf_name}"
                    expr_result_str = "{c_fn_name(mangled)}({arg_str})"
                    expr_result_type = get_fn_ret(mangled)
                    let tf_rt = get_fn_ret_type(mangled)
                    let tf_c1 = tp_child1_kind(tf_rt.tp_id)
                    let tf_c2 = tp_child2_kind(tf_rt.tp_id)
                    if tf_c1 != -1 && tf_c2 != -1 {
                        expr_result_ok_type = tf_c1
                        expr_result_err_type = tf_c2
                        set_var_result(expr_result_str, tf_c1, tf_c2)
                    }
                    return
                }
            }
        }
    }

    // Module-qualified function call: module.function(args)
    if node_kind(obj_node) == NodeKind.Ident {
        let mq_mod_name = node_name(obj_node)
        let mq_is_intrinsic = is_intrinsic_method(mq_mod_name, method)
        if is_scope_var(mq_mod_name) == 0 && mq_is_intrinsic == 0 && is_trait_type(mq_mod_name) == 0 && is_struct_type(mq_mod_name) == 0 && is_enum_type(mq_mod_name) == 0 && is_import_module_name(mq_mod_name) != 0 {
            let mq_fn_name = resolve_import_alias(method)
            if is_fn_registered(mq_fn_name) != 0 || is_generic_fn(mq_fn_name) != 0 {
                let args_sl = node_args(node)
                let mut mq_args_str = ""
                if args_sl != -1 {
                    let mut mqi = 0
                    while mqi < sublist_length(args_sl) {
                        if mqi > 0 {
                            mq_args_str = mq_args_str.concat(", ")
                        }
                        emit_expr(sublist_get(args_sl, mqi))
                        mq_args_str = mq_args_str.concat(expr_result_str)
                        mqi = mqi + 1
                    }
                }
                expr_result_str = "{c_fn_name(mq_fn_name)}({mq_args_str})"
                expr_result_type = get_fn_ret(mq_fn_name)
                if expr_result_type == CT_VOID {
                    let mq_sret = get_fn_ret_struct(mq_fn_name)
                    if mq_sret != "" {
                        let mq_tmp = fresh_temp("_mqr")
                        emit_line("{c_type_c_name(mq_sret)} {mq_tmp} = {c_fn_name(mq_fn_name)}({mq_args_str});")
                        set_var_struct(mq_tmp, mq_sret)
                        expr_result_str = mq_tmp
                    }
                }
                let mq_rt = get_fn_ret_type(mq_fn_name)
                expr_result_ok_struct = ""
                expr_result_err_struct = ""
                expr_option_inner_struct = ""
                expr_list_elem_struct = ""
                if expr_result_type == CT_RESULT {
                    expr_result_ok_type = tp_child1_kind(mq_rt.tp_id)
                    expr_result_err_type = tp_child2_kind(mq_rt.tp_id)
                    let mq_fsi = get_fn_ret_struct_inner(mq_fn_name)
                    expr_result_ok_struct = mq_fsi.ok_struct
                    expr_result_err_struct = mq_fsi.err_struct
                }
                if expr_result_type == CT_OPTION {
                    expr_option_inner = tp_child1_kind(mq_rt.tp_id)
                    let mq_fsi = get_fn_ret_struct_inner(mq_fn_name)
                    expr_option_inner_struct = mq_fsi.ok_struct
                }
                if expr_result_type == CT_LIST {
                    expr_list_elem_type = tp_child1_kind(mq_rt.tp_id)
                    let mq_fsi = get_fn_ret_struct_inner(mq_fn_name)
                    expr_list_elem_struct = mq_fsi.ok_struct
                }
                if expr_result_type == CT_MAP {
                    expr_map_key_type = tp_child1_kind(mq_rt.tp_id)
                    expr_map_val_type = tp_child2_kind(mq_rt.tp_id)
                }
                if expr_result_type == CT_SET {
                    expr_list_elem_type = tp_child1_kind(mq_rt.tp_id)
                }
                return
            }
        }
    }

    // net.request(req) -> Result[Response, NetError] — redirects to Blink stdlib
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "request" {
        let args_sl = node_args(node)
        if args_sl != -1 && sublist_length(args_sl) > 0 {
            emit_expr(sublist_get(args_sl, 0))
            let req_str = expr_result_str
            ensure_struct_result_type("Response", "NetError")
            let result_type = struct_result_c_type("Response", "NetError")
            let result_tmp = fresh_temp("__http_result_")
            emit_line("{result_type} {result_tmp} = {c_fn_name("http_do_request")}({req_str});")
            set_var_struct(result_tmp, "")
            set_var_result_struct(result_tmp, CT_VOID, CT_VOID, "Response", "NetError")
            expr_result_str = result_tmp
            expr_result_type = CT_RESULT
            expr_result_ok_type = CT_VOID
            expr_result_err_type = CT_VOID
            expr_result_ok_struct = "Response"
            expr_result_err_struct = "NetError"
        }
        return
    }

    // net.get/post/put/delete/head/patch — handled by Blink stdlib (http_client.bl)
    // Users should use http_client.get(), http_client.post(), etc.

    // net.listen(host, port) -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "listen" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let host_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let port_str = expr_result_str
        expr_result_str = "blink_tcp_listen({host_str}, {port_str})"
        expr_result_type = CT_INT
        return
    }

    // net.accept(fd) -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "accept" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        expr_result_str = "blink_tcp_accept({fd_str})"
        expr_result_type = CT_INT
        return
    }

    // net.read(fd, max_bytes) -> Str
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "read" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let max_str = expr_result_str
        expr_result_str = "blink_tcp_read({fd_str}, {max_str})"
        expr_result_type = CT_STRING
        return
    }

    // net.write(fd, data)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "write" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let data_str = expr_result_str
        emit_line("blink_tcp_write({fd_str}, {data_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }

    // net.close(fd)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "close" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_line("blink_tcp_close({fd_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }

    // net.connect(host, port) -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "connect" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let host_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let port_str = expr_result_str
        expr_result_str = "blink_tcp_connect({host_str}, {port_str})"
        expr_result_type = CT_INT
        return
    }

    // net.set_timeout(fd, ms)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "set_timeout" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let ms_str = expr_result_str
        emit_line("blink_tcp_set_timeout({fd_str}, {ms_str});")
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }

    // net.read_all(fd) -> Str
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "read_all" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        expr_result_str = "blink_tcp_read_all({fd_str})"
        expr_result_type = CT_STRING
        return
    }

    // net.read_bytes(fd, max_bytes) -> Bytes (NULL on error)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "read_bytes" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let max_str = expr_result_str
        expr_result_str = "blink_tcp_read_bytes({fd_str}, {max_str})"
        expr_result_type = CT_BYTES
        return
    }

    // net.write_bytes(fd, data) -> Int (0 on success, -1 on error)
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "net" && mc_obj_is_local == 0 && method == "write_bytes" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        emit_expr(sublist_get(args_sl, 1))
        let data_str = expr_result_str
        expr_result_str = "blink_tcp_write_bytes({fd_str}, {data_str})"
        expr_result_type = CT_INT
        return
    }

    // term.isatty(fd) -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "term" && mc_obj_is_local == 0 && method == "isatty" {
        let args_sl = node_args(node)
        emit_expr(sublist_get(args_sl, 0))
        let fd_str = expr_result_str
        expr_result_str = "blink_term_isatty({fd_str})"
        expr_result_type = CT_INT
        return
    }

    // term.width() -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "term" && mc_obj_is_local == 0 && method == "width" {
        expr_result_str = "blink_term_width()"
        expr_result_type = CT_INT
        return
    }

    // term.height() -> Int
    if node_kind(obj_node) == NodeKind.Ident && node_name(obj_node) == "term" && mc_obj_is_local == 0 && method == "height" {
        expr_result_str = "blink_term_height()"
        expr_result_type = CT_INT
        return
    }

    emit_expr(obj_node)
    let obj_str = expr_result_str
    let obj_type = expr_result_type

    // .into() dispatch — infer target type from assignment context
    if method == "into" {
        let target = cg_let_target_type
        if target == CT_FLOAT && obj_type == CT_INT {
            expr_result_str = "(double){obj_str}"
            expr_result_type = CT_FLOAT
            return
        }
        if target == CT_INT && obj_type == CT_FLOAT {
            expr_result_str = "(int64_t){obj_str}"
            expr_result_type = CT_INT
            return
        }
        if target == CT_STRING && obj_type == CT_INT {
            expr_result_str = "blink_int_to_str({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        if target == CT_STRING && obj_type == CT_FLOAT {
            expr_result_str = "blink_float_to_str({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        let mut src_name = type_name_from_ct(obj_type)
        let src_struct = get_var_struct(obj_str)
        if src_struct != "" {
            src_name = src_struct
        }
        let mut tgt_name = type_name_from_ct(target)
        if target == CT_VOID && cg_let_target_name != "" {
            tgt_name = cg_let_target_name
        }
        let from_methods = find_from_impl(src_name, tgt_name)
        if from_methods != -1 && sublist_length(from_methods) > 0 {
            let from_fn = sublist_get(from_methods, 0)
            let from_name = node_name(from_fn)
            let mangled = "{tgt_name}_{from_name}"
            expr_result_str = "{c_fn_name(mangled)}({obj_str})"
            expr_result_type = target
            return
        }
        emit_line("/* into() conversion not found */")
        expr_result_str = obj_str
        expr_result_type = obj_type
        return
    }

    // Numeric conversion methods
    if method == "to_float" && obj_type == CT_INT {
        expr_result_str = "(double){obj_str}"
        expr_result_type = CT_FLOAT
        return
    }
    if method == "to_int" && obj_type == CT_FLOAT {
        expr_result_str = "(int64_t){obj_str}"
        expr_result_type = CT_INT
        return
    }
    if method == "to_string" {
        if obj_type == CT_INT {
            expr_result_str = "blink_int_to_str({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        if obj_type == CT_FLOAT {
            expr_result_str = "blink_float_to_str({obj_str})"
            expr_result_type = CT_STRING
            return
        }
    }

    // Trait-based builtin method dispatch
    if emit_builtin_trait_method(node, obj_str, obj_type, obj_node, method) != 0 {
        return
    }

    // Iterator adapter and consumer methods — work on both CT_LIST and CT_ITERATOR
    if (obj_type == CT_LIST || obj_type == CT_ITERATOR) && (method == "count" || method == "collect" || method == "for_each" || method == "any" || method == "all" || method == "find" || method == "fold" || method == "map" || method == "filter" || method == "take" || method == "skip" || method == "chain" || method == "flat_map" || method == "enumerate" || method == "zip") {

        // Set element type hint for closure param type inference
        if obj_type == CT_LIST {
            let hint_elem = get_list_elem_type(obj_str)
            if hint_elem != -1 {
                cg_closure_param_type_hint = hint_elem
            }
        } else if obj_type == CT_ITERATOR {
            let hint_elem = get_var_iterator_inner(obj_str)
            if hint_elem > 0 {
                cg_closure_param_type_hint = hint_elem
            }
        }

        // --- Adapter methods: return CT_ITERATOR ---

        if method == "map" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let tag = c_type_tag(elem_type)
            ensure_map_iter(elem_type)
            let adapter_var = fresh_temp("__map_")
            emit_line("blink_MapIterator_{tag} {adapter_var} = \{ .source = &{src_var}, .source_next = ({ifs_opt_type} (*)(void*)){src_next}, .fn = {fn_str} };")
            set_var_iterator(adapter_var, elem_type, "blink_MapIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_MapIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "filter" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let tag = c_type_tag(elem_type)
            ensure_filter_iter(elem_type)
            let adapter_var = fresh_temp("__filter_")
            emit_line("blink_FilterIterator_{tag} {adapter_var} = \{ .source = &{src_var}, .source_next = ({ifs_opt_type} (*)(void*)){src_next}, .fn = {fn_str} };")
            set_var_iterator(adapter_var, elem_type, "blink_FilterIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_FilterIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "take" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let n_str = expr_result_str
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let tag = c_type_tag(elem_type)
            ensure_take_iter(elem_type)
            let adapter_var = fresh_temp("__take_")
            emit_line("blink_TakeIterator_{tag} {adapter_var} = \{ .source = &{src_var}, .source_next = ({ifs_opt_type} (*)(void*)){src_next}, .limit = {n_str}, .count = 0 };")
            set_var_iterator(adapter_var, elem_type, "blink_TakeIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_TakeIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "skip" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let n_str = expr_result_str
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let tag = c_type_tag(elem_type)
            ensure_skip_iter(elem_type)
            let adapter_var = fresh_temp("__skip_")
            emit_line("blink_SkipIterator_{tag} {adapter_var} = \{ .source = &{src_var}, .source_next = ({ifs_opt_type} (*)(void*)){src_next}, .skip_n = {n_str}, .skipped = 0 };")
            set_var_iterator(adapter_var, elem_type, "blink_SkipIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_SkipIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "chain" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let other_str = expr_result_str
            let other_type = expr_result_type
            iter_from_source(obj_str, obj_type)
            let src_a_var = ifs_iter_var
            let next_a = ifs_next_fn
            let elem_type = ifs_elem_type
            let opt_t = ifs_opt_type
            let tag = c_type_tag(elem_type)
            iter_from_source(other_str, other_type)
            let src_b_var = ifs_iter_var
            let next_b = ifs_next_fn
            ensure_chain_iter(elem_type)
            let adapter_var = fresh_temp("__chain_")
            emit_line("blink_ChainIterator_{tag} {adapter_var} = \{ .source_a = &{src_a_var}, .next_a = ({opt_t} (*)(void*)){next_a}, .source_b = &{src_b_var}, .next_b = ({opt_t} (*)(void*)){next_b}, .phase = 0 };")
            set_var_iterator(adapter_var, elem_type, "blink_ChainIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_ChainIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "flat_map" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let tag = c_type_tag(elem_type)
            ensure_flat_map_iter(elem_type)
            let adapter_var = fresh_temp("__flatmap_")
            emit_line("blink_FlatMapIterator_{tag} {adapter_var} = \{ .source = &{src_var}, .source_next = ({ifs_opt_type} (*)(void*)){src_next}, .fn = {fn_str}, .buffer = NULL, .buf_idx = 0 };")
            set_var_iterator(adapter_var, elem_type, "blink_FlatMapIterator_{tag}_next")
            expr_result_str = adapter_var
            expr_result_type = CT_ITERATOR
            expr_iter_next_fn = "blink_FlatMapIterator_{tag}_next"
            expr_list_elem_type = elem_type
            return
        }
        if method == "enumerate" {
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let opt_t = ifs_opt_type
            let result_list = fresh_temp("__enum_")
            let next_var = fresh_temp("__enum_next_")
            let i_var = fresh_temp("__enum_i_")
            emit_line("blink_list* {result_list} = blink_list_new();")
            emit_line("int64_t {i_var} = 0;")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            let pair_var = fresh_temp("__enum_pair_")
            emit_line("blink_list* {pair_var} = blink_list_new();")
            emit_line("blink_list_push({pair_var}, (void*)(intptr_t){i_var});")
            if elem_type == CT_INT {
                emit_line("blink_list_push({pair_var}, (void*)(intptr_t){next_var}.value);")
            } else {
                emit_line("blink_list_push({pair_var}, (void*){next_var}.value);")
            }
            emit_line("blink_list_push({result_list}, (void*){pair_var});")
            emit_line("{i_var}++;")
            cg_indent = cg_indent - 1
            emit_line("}")
            set_list_elem_type(result_list, CT_LIST)
            expr_result_str = result_list
            expr_result_type = CT_LIST
            expr_list_elem_type = CT_LIST
            return
        }
        if method == "zip" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let other_str = expr_result_str
            let other_type = expr_result_type
            iter_from_source(obj_str, obj_type)
            let src_a_var = ifs_iter_var
            let next_a = ifs_next_fn
            let elem_type_a = ifs_elem_type
            let opt_a = ifs_opt_type
            iter_from_source(other_str, other_type)
            let src_b_var = ifs_iter_var
            let next_b = ifs_next_fn
            let elem_type_b = ifs_elem_type
            let opt_b = ifs_opt_type
            let result_list = fresh_temp("__zip_")
            let next_a_var = fresh_temp("__zip_na_")
            let next_b_var = fresh_temp("__zip_nb_")
            emit_line("blink_list* {result_list} = blink_list_new();")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_a} {next_a_var} = (({opt_a} (*)(void*)){next_a})(&{src_a_var});")
            emit_line("if ({next_a_var}.tag == 0) break;")
            emit_line("{opt_b} {next_b_var} = (({opt_b} (*)(void*)){next_b})(&{src_b_var});")
            emit_line("if ({next_b_var}.tag == 0) break;")
            let pair_var = fresh_temp("__zip_pair_")
            emit_line("blink_list* {pair_var} = blink_list_new();")
            if elem_type_a == CT_INT {
                emit_line("blink_list_push({pair_var}, (void*)(intptr_t){next_a_var}.value);")
            } else {
                emit_line("blink_list_push({pair_var}, (void*){next_a_var}.value);")
            }
            if elem_type_b == CT_INT {
                emit_line("blink_list_push({pair_var}, (void*)(intptr_t){next_b_var}.value);")
            } else {
                emit_line("blink_list_push({pair_var}, (void*){next_b_var}.value);")
            }
            emit_line("blink_list_push({result_list}, (void*){pair_var});")
            cg_indent = cg_indent - 1
            emit_line("}")
            set_list_elem_type(result_list, CT_LIST)
            expr_result_str = result_list
            expr_result_type = CT_LIST
            expr_list_elem_type = CT_LIST
            return
        }

        // --- Consumer methods: drive an iterator to completion ---

        if method == "collect" {
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let opt_t = ifs_opt_type
            let result_list = fresh_temp("__collect_")
            let next_var = fresh_temp("__collect_next_")
            emit_line("blink_list* {result_list} = blink_list_new();")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            if elem_type == CT_INT {
                emit_line("blink_list_push({result_list}, (void*)(intptr_t){next_var}.value);")
            } else {
                emit_line("blink_list_push({result_list}, (void*){next_var}.value);")
            }
            cg_indent = cg_indent - 1
            emit_line("}")
            set_list_elem_type(result_list, elem_type)
            expr_result_str = result_list
            expr_result_type = CT_LIST
            expr_list_elem_type = elem_type
            return
        }
        if method == "count" {
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let opt_t = ifs_opt_type
            let count_var = fresh_temp("__count_")
            let next_var = fresh_temp("__count_next_")
            emit_line("int64_t {count_var} = 0;")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("{count_var}++;")
            cg_indent = cg_indent - 1
            emit_line("}")
            expr_result_str = count_var
            expr_result_type = CT_INT
            return
        }
        if obj_type == CT_LIST && (method == "for_each" || method == "any" || method == "all" || method == "fold") {
            let elem_ct = get_list_elem_type(obj_str)
            let elem_name = type_name_from_ct(elem_ct)
            if elem_name != "Void" {
                ensure_option_type(elem_ct)
                let stdlib_name = "list_{method}"
                let args_sl = node_args(node)
                if method == "fold" {
                    emit_expr(sublist_get(args_sl, 0))
                    let init_str = expr_result_str
                    let init_type = expr_result_type
                    let init_name = type_name_from_ct(init_type)
                    emit_expr(sublist_get(args_sl, 1))
                    let fn_str = expr_result_str
                    let ta_str = "{elem_name},{init_name}"
                    let mangled = mangle_generic_name(stdlib_name, ta_str)
                    register_mono_fn(stdlib_name, ta_str)
                    register_mono_instance(stdlib_name, ta_str)
                    reg_fn(mangled, init_type)
                    let result_var = fresh_temp("__fold_")
                    emit_line("{c_type_str(init_type)} {result_var} = {c_fn_name(mangled)}({obj_str}, {init_str}, {fn_str});")
                    expr_result_str = result_var
                    expr_result_type = init_type
                } else {
                    emit_expr(sublist_get(args_sl, 0))
                    let fn_str = expr_result_str
                    let ta_str = elem_name
                    let mangled = mangle_generic_name(stdlib_name, ta_str)
                    register_mono_fn(stdlib_name, ta_str)
                    register_mono_instance(stdlib_name, ta_str)
                    if method == "for_each" {
                        reg_fn(mangled, CT_VOID)
                        emit_line("{c_fn_name(mangled)}({obj_str}, {fn_str});")
                        expr_result_str = "0"
                        expr_result_type = CT_VOID
                    } else {
                        reg_fn(mangled, CT_BOOL)
                        let result_var = fresh_temp("__{method}_")
                        emit_line("int {result_var} = {c_fn_name(mangled)}({obj_str}, {fn_str});")
                        expr_result_str = result_var
                        expr_result_type = CT_BOOL
                    }
                }
                return
            }
        }
        if method == "for_each" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            let fn_sig = expr_closure_sig
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let opt_t = ifs_opt_type

            let next_var = fresh_temp("__fe_next_")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("(({fn_sig}){fn_str}->fn_ptr)({fn_str}, {next_var}.value);")
            cg_indent = cg_indent - 1
            emit_line("}")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        if method == "any" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            let fn_sig = expr_closure_sig
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let opt_t = ifs_opt_type

            let result_var = fresh_temp("__any_")
            let next_var = fresh_temp("__any_next_")
            emit_line("int {result_var} = 0;")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("if ((({fn_sig}){fn_str}->fn_ptr)({fn_str}, {next_var}.value)) \{ {result_var} = 1; break; }")
            cg_indent = cg_indent - 1
            emit_line("}")
            expr_result_str = result_var
            expr_result_type = CT_BOOL
            return
        }
        if method == "all" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            let fn_sig = expr_closure_sig
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let opt_t = ifs_opt_type

            let result_var = fresh_temp("__all_")
            let next_var = fresh_temp("__all_next_")
            emit_line("int {result_var} = 1;")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("if (!(({fn_sig}){fn_str}->fn_ptr)({fn_str}, {next_var}.value)) \{ {result_var} = 0; break; }")
            cg_indent = cg_indent - 1
            emit_line("}")
            expr_result_str = result_var
            expr_result_type = CT_BOOL
            return
        }
        if method == "find" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let fn_str = expr_result_str
            let fn_sig = expr_closure_sig
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let elem_type = ifs_elem_type
            let opt_t = ifs_opt_type
            ensure_option_type(elem_type)
            let result_var = fresh_temp("__find_")
            let next_var = fresh_temp("__find_next_")
            emit_line("{opt_t} {result_var} = ({opt_t})\{.tag = 0};")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("if ((({fn_sig}){fn_str}->fn_ptr)({fn_str}, {next_var}.value)) \{ {result_var} = ({opt_t})\{.tag = 1, .value = {next_var}.value}; break; }")
            cg_indent = cg_indent - 1
            emit_line("}")
            set_var_option(result_var, elem_type)
            expr_result_str = result_var
            expr_result_type = CT_OPTION
            expr_option_inner = elem_type
            expr_option_inner_struct = ""
            return
        }
        if method == "fold" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let init_str = expr_result_str
            let init_type = expr_result_type
            emit_expr(sublist_get(args_sl, 1))
            let fn_str = expr_result_str
            let fn_sig = expr_closure_sig
            iter_from_source(obj_str, obj_type)
            let src_var = ifs_iter_var
            let src_next = ifs_next_fn
            let opt_t = ifs_opt_type
            let acc_var = fresh_temp("__fold_acc_")
            let next_var = fresh_temp("__fold_next_")
            emit_line("{c_type_str(init_type)} {acc_var} = {init_str};")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_t} {next_var} = (({opt_t} (*)(void*)){src_next})(&{src_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("{acc_var} = (({fn_sig}){fn_str}->fn_ptr)({fn_str}, {acc_var}, {next_var}.value);")
            cg_indent = cg_indent - 1
            emit_line("}")
            expr_result_str = acc_var
            expr_result_type = init_type
            return
        }
        cg_closure_param_type_hint = -1
    }

    // Channel methods
    if obj_type == CT_CHANNEL {
        if method == "send" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let val_str = expr_result_str
            let val_type = expr_result_type
            if val_type == CT_INT {
                emit_line("blink_channel_send({obj_str}, (void*)(intptr_t){val_str});")
            } else {
                emit_line("blink_channel_send({obj_str}, (void*){val_str});")
            }
            expr_result_str = "0"
            expr_result_type = CT_INT
            return
        }
        if method == "recv" {
            let recv_tmp = fresh_temp("__recv_")
            let ch_inner = get_var_channel_inner(obj_str)
            emit_line("void* {recv_tmp} = blink_channel_recv({obj_str});")
            if ch_inner == CT_STRING {
                expr_result_str = "(const char*){recv_tmp}"
                expr_result_type = CT_STRING
            } else {
                expr_result_str = "(int64_t)(intptr_t){recv_tmp}"
                expr_result_type = CT_INT
            }
            return
        }
        if method == "close" {
            emit_line("blink_channel_close({obj_str});")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
    }

    // Instant methods
    if obj_type == CT_INSTANT {
        if method == "elapsed" {
            expr_result_str = "(blink_Duration)\{.nanos = blink_Instant_elapsed((blink_instant_struct)\{.nanos = {obj_str}.nanos}).nanos}"
            expr_result_type = CT_DURATION
            return
        }
        if method == "since" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let other_str = expr_result_str
            expr_result_str = "blink_Instant_since({obj_str}, {other_str})"
            expr_result_type = CT_DURATION
            return
        }
        if method == "add" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let dur_str = expr_result_str
            expr_result_str = "blink_Instant_add({obj_str}, {dur_str})"
            expr_result_type = CT_INSTANT
            return
        }
        if method == "to_rfc3339" {
            expr_result_str = "blink_Instant_to_rfc3339((blink_instant_struct)\{.nanos = {obj_str}.nanos})"
            expr_result_type = CT_STRING
            return
        }
        if method == "to_unix_ms" {
            expr_result_str = "blink_Instant_to_unix_ms({obj_str})"
            expr_result_type = CT_INT
            return
        }
        if method == "to_unix_secs" {
            expr_result_str = "blink_Instant_to_unix_secs({obj_str})"
            expr_result_type = CT_INT
            return
        }
    }

    // Duration methods
    if obj_type == CT_DURATION {
        if method == "to_ms" {
            expr_result_str = "blink_Duration_to_ms({obj_str})"
            expr_result_type = CT_INT
            return
        }
        if method == "to_seconds" {
            expr_result_str = "blink_Duration_to_seconds({obj_str})"
            expr_result_type = CT_INT
            return
        }
        if method == "to_nanos" {
            expr_result_str = "blink_Duration_to_nanos({obj_str})"
            expr_result_type = CT_INT
            return
        }
        if method == "add" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let other_str = expr_result_str
            expr_result_str = "blink_Duration_add({obj_str}, {other_str})"
            expr_result_type = CT_DURATION
            return
        }
        if method == "sub" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let other_str = expr_result_str
            expr_result_str = "blink_Duration_sub({obj_str}, {other_str})"
            expr_result_type = CT_DURATION
            return
        }
        if method == "scale" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let n_str = expr_result_str
            expr_result_str = "blink_Duration_scale({obj_str}, {n_str})"
            expr_result_type = CT_DURATION
            return
        }
        if method == "is_zero" {
            expr_result_str = "blink_Duration_is_zero({obj_str})"
            expr_result_type = CT_BOOL
            return
        }
    }

    // Ptr methods
    if obj_type == CT_PTR {
        if method == "deref" {
            expr_result_str = "(*({obj_str}))"
            expr_result_type = CT_INT
            return
        }
        if method == "write" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let val_str = expr_result_str
            emit_line("*({obj_str}) = {val_str};")
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        if method == "is_null" {
            expr_result_str = "({obj_str} == NULL)"
            expr_result_type = CT_BOOL
            return
        }
        if method == "addr" {
            expr_result_str = "((int64_t)(intptr_t){obj_str})"
            expr_result_type = CT_INT
            return
        }
        if method == "to_str" {
            ensure_option_type(CT_STRING)
            let opt_type = option_c_type(CT_STRING)
            let res = fresh_temp("_tostr_opt_")
            emit_line("{opt_type} {res} = ({obj_str} != NULL) ? ({opt_type})\{.tag = 1, .value = blink_strdup((const char*){obj_str})} : ({opt_type})\{.tag = 0};")
            set_var_option(res, CT_STRING)
            expr_result_str = res
            expr_result_type = CT_OPTION
            expr_option_inner = CT_STRING
            expr_option_inner_struct = ""
            return
        }
    }

    if obj_type == CT_FFI_SCOPE {
        if method == "alloc" {
            let inner_c = resolve_ptr_inner_c()
            expr_result_str = "({inner_c}*)blink_ffi_scope_track({obj_str}, calloc(1, sizeof({inner_c})))"
            expr_result_type = CT_PTR
            return
        }
        if method == "cstr" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            expr_result_str = "(uint8_t*)blink_ffi_scope_track({obj_str}, blink_strdup({arg_str}))"
            expr_result_type = CT_PTR
            return
        }
        if method == "take" {
            let args_sl = node_args(node)
            emit_expr(sublist_get(args_sl, 0))
            let arg_str = expr_result_str
            expr_result_str = "blink_ffi_scope_take({obj_str}, {arg_str})"
            expr_result_type = CT_PTR
            return
        }
    }

    // Option methods: unwrap, is_some, is_none
    if obj_type == CT_OPTION {
        if method == "unwrap" {
            let loc_line = node_line(node)
            let sv_inner = get_var_option_inner(obj_str)
            let inner = if sv_inner != -1 { sv_inner } else { expr_option_inner }
            let sv_inner_s = get_var_option_inner_struct(obj_str)
            let inner_s = if sv_inner_s != "" { sv_inner_s } else { expr_option_inner_struct }
            let tmp = fresh_temp("_ounw_")
            if inner_s != "" && is_compound_ct(inner) == 0 {
                let opt_c = struct_option_c_type(inner_s)
                emit_line("{opt_c} {tmp} = {obj_str};")
                emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                let val_tmp = fresh_temp("_ounv_")
                emit_line("{c_type_c_name(inner_s)} {val_tmp} = *{tmp}.value;")
                set_var(val_tmp, CT_STRUCT, 0)
                set_var_struct(val_tmp, inner_s)
                expr_result_str = val_tmp
                expr_result_type = CT_STRUCT
            } else if inner == CT_STRING {
                let opt_c = option_c_type(CT_STRING)
                emit_line("{opt_c} {tmp} = {obj_str};")
                emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                expr_result_str = "{tmp}.value"
                expr_result_type = CT_STRING
            } else if inner == CT_LIST {
                let opt_c = option_c_type(CT_LIST)
                emit_line("{opt_c} {tmp} = {obj_str};")
                emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                let val_tmp = fresh_temp("_ounv_")
                emit_line("blink_list* {val_tmp} = {tmp}.value;")
                set_var(val_tmp, CT_LIST, 0)
                let nested = get_var_option_inner2(obj_str)
                if nested != -1 {
                    set_list_elem_type(val_tmp, nested)
                    expr_list_elem_type = nested
                } else {
                    set_list_elem_type(val_tmp, CT_INT)
                    expr_list_elem_type = CT_INT
                }
                let nested_s = get_var_option_inner2_struct(obj_str)
                if nested_s != "" {
                    set_list_elem_struct(val_tmp, nested_s)
                }
                expr_result_str = val_tmp
                expr_result_type = CT_LIST
            } else if inner == CT_MAP && inner_s != "" {
                let opt_c = struct_option_c_type(inner_s)
                emit_line("{opt_c} {tmp} = {obj_str};")
                emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                let val_tmp = fresh_temp("_ounv_")
                emit_line("blink_map* {val_tmp} = {tmp}.value;")
                set_var(val_tmp, CT_MAP, 0)
                let map_nested = get_var_option_inner2(obj_str)
                if map_nested >= 0 {
                    set_map_value_list_elem(val_tmp, map_nested)
                }
                let map_nested_s = get_var_option_inner2_struct(obj_str)
                if map_nested_s != "" {
                    set_map_value_struct(val_tmp, map_nested_s)
                }
                expr_result_str = val_tmp
                expr_result_type = CT_MAP
            } else if inner == CT_OPTION && inner_s != "" {
                let opt_c = struct_option_c_type(inner_s)
                emit_line("{opt_c} {tmp} = {obj_str};")
                emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                let val_tmp = fresh_temp("_ounv_")
                emit_line("{c_type_c_name(inner_s)} {val_tmp} = *{tmp}.value;")
                set_var(val_tmp, CT_OPTION, 0)
                if inner_s.starts_with("Option_") {
                    let opt_inner_tag = inner_s.slice(7, inner_s.len())
                    let opt_inner_ct = type_from_name_tag(opt_inner_tag)
                    if is_compound_tag(opt_inner_tag) != 0 || is_struct_type(opt_inner_tag) != 0 || is_enum_type(opt_inner_tag) != 0 {
                        set_var_option_struct(val_tmp, opt_inner_ct, opt_inner_tag)
                    } else {
                        set_var_option(val_tmp, opt_inner_ct)
                    }
                } else {
                    set_var_option_struct(val_tmp, CT_INT, inner_s)
                }
                expr_result_str = val_tmp
                expr_result_type = CT_OPTION
            } else {
                if inner == CT_FLOAT {
                    let opt_c = option_c_type(CT_FLOAT)
                    emit_line("{opt_c} {tmp} = {obj_str};")
                    emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                    expr_result_str = "{tmp}.value"
                    expr_result_type = CT_FLOAT
                } else {
                    let opt_c = option_c_type(CT_INT)
                    emit_line("{opt_c} {tmp} = {obj_str};")
                    emit_panic_tag_check(tmp, 0, "unwrap called on None", loc_line)
                    expr_result_str = "{tmp}.value"
                    expr_result_type = CT_INT
                }
            }
            return
        }
        if method == "is_some" {
            expr_result_str = "({obj_str}.tag == 1)"
            expr_result_type = CT_BOOL
            return
        }
        if method == "is_none" {
            expr_result_str = "({obj_str}.tag == 0)"
            expr_result_type = CT_BOOL
            return
        }
    }

    // Result methods: unwrap, unwrap_err, is_ok, is_err
    if obj_type == CT_RESULT {
        if method == "unwrap" {
            let ok_t = get_var_result_ok(obj_str)
            let ok_s = get_var_result_ok_struct(obj_str)
            emit_result_unwrap_inner(
                obj_str, node, ok_t, ok_s, "ok",
                get_var_result_ok_elem(obj_str), get_var_result_ok_elem_struct(obj_str), 1,
            )
            return
        }
        if method == "unwrap_err" {
            let err_t = get_var_result_err(obj_str)
            let err_s = get_var_result_err_struct(obj_str)
            emit_result_unwrap_inner(
                obj_str, node, err_t, err_s, "err", -1, "", 0,
            )
            return
        }
        if method == "is_ok" {
            expr_result_str = "({obj_str}.tag == 0)"
            expr_result_type = CT_BOOL
            return
        }
        if method == "is_err" {
            expr_result_str = "({obj_str}.tag == 1)"
            expr_result_type = CT_BOOL
            return
        }
    }

    // Derived method dispatch (Serialize/Deserialize/Eq/Clone)
    let derive_struct = get_var_struct(obj_str)
    if derive_struct != "" && has_derive_method(derive_struct, method) != 0 {
        if method == "to_json" {
            let ds_mangled = "{derive_struct}_to_json"
            expr_result_str = "{c_fn_name(ds_mangled)}({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        if method == "eq" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let other_str = expr_result_str
                let ds_mangled = "{derive_struct}_eq"
                expr_result_str = "{c_fn_name(ds_mangled)}({obj_str}, {other_str})"
                expr_result_type = CT_BOOL
                return
            }
        }
        if method == "clone" {
            let ds_mangled = "{derive_struct}_clone"
            let tmp = fresh_temp("_clone_")
            emit_line("{c_type_c_name(derive_struct)} {tmp} = {c_fn_name(ds_mangled)}({obj_str});")
            set_var(tmp, CT_VOID, 0)
            set_var_struct(tmp, derive_struct)
            expr_result_str = tmp
            expr_result_type = CT_VOID
            return
        }
    }
    let derive_enum = get_var_enum(obj_str)
    if derive_enum != "" && has_derive_method(derive_enum, method) != 0 {
        if method == "to_json" {
            let de_mangled = "{derive_enum}_to_json"
            expr_result_str = "{c_fn_name(de_mangled)}({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        if method == "to_str" && is_str_backed_enum(derive_enum) != 0 {
            expr_result_str = "{c_fn_name("{derive_enum}_to_str")}({obj_str})"
            expr_result_type = CT_STRING
            return
        }
        if method == "eq" {
            let args_sl = node_args(node)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                emit_expr(sublist_get(args_sl, 0))
                let other_str = expr_result_str
                let de_mangled = "{derive_enum}_eq"
                expr_result_str = "{c_fn_name(de_mangled)}({obj_str}, {other_str})"
                expr_result_type = CT_BOOL
                return
            }
        }
        if method == "clone" {
            if is_data_enum(derive_enum) != 0 {
                let de_mangled = "{derive_enum}_clone"
                let tmp = fresh_temp("_clone_")
                emit_line("{c_type_c_name(derive_enum)} {tmp} = {c_fn_name(de_mangled)}({obj_str});")
                set_var(tmp, CT_VOID, 0)
                set_var_struct(tmp, derive_enum)
                expr_result_str = tmp
                expr_result_type = CT_VOID
            } else {
                let de_mangled = "{derive_enum}_clone"
                expr_result_str = "{c_fn_name(de_mangled)}({obj_str})"
                expr_result_type = CT_INT
                var_enums.push(VarEnumEntry { name: expr_result_str, enum_type: derive_enum })
            }
            return
        }
    }

    // Trait impl method resolution
    let mut struct_type = get_var_struct(obj_str)
    if struct_type == "" {
        struct_type = get_var_enum(obj_str)
    }
    if struct_type != "" && lookup_impl_method(struct_type, method) != 0 {
        let mangled = "{struct_type}_{method}"
        let args_sl = node_args(node)
        let mut args_str = obj_str
        if args_sl != -1 {
            let mut i = 0
            while i < sublist_length(args_sl) {
                args_str = args_str.concat(", ")
                emit_expr(sublist_get(args_sl, i))
                args_str = args_str.concat(expr_result_str)
                i = i + 1
            }
        }
        expr_result_str = "{c_fn_name(mangled)}({args_str})"
        expr_list_elem_type = -1
        expr_list_elem_struct = ""
        expr_result_type = get_impl_method_ret(struct_type, method)
        return
    }

    // Closure field dispatch: struct.closure_field(args)
    if struct_type != "" {
        let cls_field_type = get_struct_field_type(struct_type, method)
        if cls_field_type == CT_CLOSURE {
            let cls_sig = get_struct_field_closure_sig(struct_type, method)
            if cls_sig != "" {
                let cls_ptr = "{obj_str}.{method}"
                let args_sl = node_args(node)
                let mut args_str = cls_ptr
                if args_sl != -1 {
                    let mut i = 0
                    while i < sublist_length(args_sl) {
                        args_str = args_str.concat(", ")
                        emit_expr(sublist_get(args_sl, i))
                        args_str = args_str.concat(expr_result_str)
                        i = i + 1
                    }
                }
                expr_result_str = "(({cls_sig}){cls_ptr}->fn_ptr)({args_str})"
                let ret_part = closure_sig_ret_part(cls_sig)
                if ret_part.starts_with("blink_") {
                    let sname = ret_part.substring(6, ret_part.len() - 6)
                    let resolved = resolve_struct_from_c_name(sname)
                    if resolved != "" {
                        let tmp = fresh_temp("_cls_ret_")
                        emit_line("{ret_part} {tmp} = (({cls_sig}){cls_ptr}->fn_ptr)({args_str});")
                        set_var(tmp, CT_VOID, 0)
                        set_var_struct(tmp, resolved)
                        expr_result_str = tmp
                        expr_result_type = CT_VOID
                    } else {
                        expr_result_type = CT_VOID
                    }
                } else {
                    expr_result_type = closure_ret_ct(ret_part)
                }
                return
            }
        }
    }

    // Generic fallback — emit diagnostic and produce safe placeholder
    let recv_type_name = type_name_from_ct(obj_type)
    diag_error_at("UnresolvedMethod", "E0505", "unresolved method '.{method}' on type {recv_type_name} in '{cg_current_fn_name}'", node, "")
    expr_result_str = "(void)0"
    expr_result_type = CT_VOID
}
