fn for_each[T](cases: List[(Str, T)], body: fn(T) -> Void) {
    let mut _i = 0
    while _i < cases.len() {
        let _case = cases.get(_i).unwrap()
        let (_label, _value) = _case
        body(_value)
        _i = _i + 1
    }
}

test "for_each over List[(Str, Int)] inside test block" {
    let mut total = 0
    for_each([
        ("one", 1),
        ("two", 2),
        ("three", 3),
    ], fn(n: Int) -> Void {
        total = total + n
    })
    assert(total == 6, "total should be 6")
}

fn main() {
    io.println("ok")
}
