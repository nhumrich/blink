// Negative tests: arena values escaping the block must trigger E0700.

fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "global assignment of arena value emits E0700" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        let xs = [1, 2, 3]\n        saved = xs\n    \}\n\}\n"
    expect_compile_error(src, "arena_global_assign", "E0700")
}

test "passing arena value to non-arena function emits E0700" {
    let src = "fn take(xs: List[Int]) -> Int \{\n    xs.len()\n\}\nfn main() \{\n    with arena \{\n        let xs = [1, 2]\n        take(xs)\n    \}\n\}\n"
    expect_compile_error(src, "arena_nonarena_call", "E0700")
}

test "method call on outer receiver with arena arg emits E0700" {
    let src2 = "fn main() \{\n    let mut outer: List[List[Int]] = []\n    with arena \{\n        let xs = [1, 2]\n        outer.push(xs)\n    \}\n\}\n"
    expect_compile_error(src2, "arena_method_outer", "E0700")
}

test "E0700 single-level escape prints 'GC heap' target" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        let xs = [1, 2, 3]\n        saved = xs\n    \}\n\}\n"
    expect_compile_error(src, "arena_e0700_gc_target", "GC heap")
}
