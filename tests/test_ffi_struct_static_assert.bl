fn emit_c(tag: Str, src: Str) -> Str {
    let bl_path = ".tmp/_test_{tag}.bl"
    write_file(bl_path, src)
    let _ = process_run("bin/blink", ["build", bl_path, "--emit", "c"])
    let c_src = read_file("build/_test_{tag}.c")
    shell_exec("rm -f {bl_path} build/_test_{tag}.c")
    c_src
}

test "ffi.struct emits #include from header annotation" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ }\n"
    let c = emit_c("ffi_assert_inc", src)
    assert(c.contains("#include <poll.h>"))
}

test "ffi.struct emits _Static_assert for sizeof" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ }\n"
    let c = emit_c("ffi_assert_size", src)
    assert(c.contains("_Static_assert(sizeof(blink_Pollfd) == sizeof(struct pollfd)"))
}

test "ffi.struct emits _Static_assert for offsetof per field" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ }\n"
    let c = emit_c("ffi_assert_off", src)
    assert(c.contains("offsetof(blink_Pollfd, fd) == offsetof(struct pollfd, fd)"))
    assert(c.contains("offsetof(blink_Pollfd, events) == offsetof(struct pollfd, events)"))
    assert(c.contains("offsetof(blink_Pollfd, revents) == offsetof(struct pollfd, revents)"))
}

test "@ffi(header:) suppresses extern when system header is included (rsxj9v)" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\n@ffi(\"poll\", header: \"poll.h\")\n@trusted(audit: \"t\")\nfn c_poll(fds: Ptr[Pollfd], nfds: U64, t: I32) -> I32 ! FFI \{ }\nfn main() \{ }\n"
    let c = emit_c("ffi_no_extern_when_header", src)
    assert(c.contains("#include <poll.h>"))
    assert(!c.contains("extern int32_t poll("))
}

test "@ffi without header: still emits extern" {
    let src = "@ffi(\"strlen\")\n@trusted(audit: \"t\")\nfn c_strlen(s: Ptr[U8]) -> Int ! FFI \{ }\nfn main() \{ }\n"
    let c = emit_c("ffi_extern_no_header", src)
    assert(c.contains("extern"))
    assert(c.contains("strlen"))
}
