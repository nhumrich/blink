// E0700 prints the resolved promotion target: "GC heap" from an outermost
// `with arena { }` or "outer arena" from a nested block.

fn expect_compile_error(src: Str, tag: Str, needle: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(needle))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "E0700 nested escape prints 'outer arena' target" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        with arena \{\n            let xs = [1, 2, 3]\n            saved = xs\n        \}\n    \}\n\}\n"
    expect_compile_error(src, "arena_e0700_outer_target", "outer arena")
}

test "E0700 nested escape still reports ArenaValueEscapes code" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        with arena \{\n            let xs = [1, 2, 3]\n            saved = xs\n        \}\n    \}\n\}\n"
    expect_compile_error(src, "arena_e0700_outer_code", "E0700")
}
