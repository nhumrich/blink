import compile_test_helpers

test "with_ptr body that pushes on receiver emits E0814" {
    let src = "fn main() \{ let b = Bytes.new(); b.push(1); let n = b.with_ptr(fn(p) \{ b.push(2); 0 }) }\n"
    compile_test_helpers.expect_compile_error(src, "with_ptr_push", "E0814")
}

test "with_ptr body that calls clear on receiver emits E0814" {
    let src = "fn main() \{ let b = Bytes.new(); b.push(1); let n = b.with_ptr(fn(p) \{ b.clear(); 0 }) }\n"
    compile_test_helpers.expect_compile_error(src, "with_ptr_clear", "E0814")
}

test "with_ptr body that calls write_u32_le on receiver emits E0814" {
    let src = "fn main() \{ let b = Bytes.new(); b.push(1); let n = b.with_ptr(fn(p) \{ b.write_u32_le(0); 0 }) }\n"
    compile_test_helpers.expect_compile_error(src, "with_ptr_write_le", "E0814")
}

test "with_ptr body that passes receiver as arg emits E0815" {
    let src = "fn helper(x: Bytes) \{ }\nfn main() \{ let b = Bytes.new(); b.push(1); let n = b.with_ptr(fn(p) \{ helper(b); 0 }) }\n"
    compile_test_helpers.expect_compile_error(src, "with_ptr_pass_arg", "E0815")
}

test "with_ptr body that only reads receiver compiles" {
    let src = "fn main() \{ let b = Bytes.new(); b.push(1); let n = b.with_ptr(fn(p) \{ b.len() }); }\n"
    compile_test_helpers.expect_no_error(src, "with_ptr_read_ok", "E0814")
}
