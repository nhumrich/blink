    CT_OPTION, CT_PTR, CT_RESULT, CT_SET, CT_STRING, CT_STRINGBUILDER,
    CT_ENUM, CT_STRUCT, CT_TEMPLATE, CT_VOID,
    c_fn_name, c_type_c_name, c_type_str, c_type_tag,
    cg_async_scope_stack, cg_async_wrapper_counter, cg_closure_defs,
    cg_closure_param_type_hint, cg_current_fn_name, cg_handler_body_idx,
    cg_handler_cleanup_fn, cg_handler_cleanup_var,
    cg_handler_is_user_effect, cg_handler_vtable_field, cg_handler_vtable_type,
    cg_in_handler_body, cg_indent, cg_let_target_name, cg_let_target_type,
    cg_uses_async,
    closure_cap_infos, closure_captures, closure_ret_ct, closure_sig_ret_part,
    emit_line, ensure_chain_iter, ensure_filter_iter, ensure_flat_map_iter,
