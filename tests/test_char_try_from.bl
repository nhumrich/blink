test "Char.try_from accepts ASCII" {
    let r = Char.try_from(65)
    assert(r.is_ok())
}

test "Char.try_from accepts BMP" {
    let r = Char.try_from(20013)
    assert(r.is_ok())
}

test "Char.try_from rejects surrogate" {
    let r = Char.try_from(55296)
    assert(r.is_err())
}

test "Char.try_from rejects above max" {
    let r = Char.try_from(1114112)
    assert(r.is_err())
}

test "Char.try_from rejects negative" {
    let r = Char.try_from(-1)
    assert(r.is_err())
}

test "Char.try_from error has Char target" {
    let r = Char.try_from(55296)
    match r {
        Ok(_) => assert(false)
        Err(e) => {
            assert_eq(e.source_type, "Int")
            assert_eq(e.target_type, "Char")
        }
    }
}

test "Char.try_from preserves codepoint" {
    let r = Char.try_from(65)
    match r {
        Ok(c) => assert_eq(c.to_int(), 65)
        Err(_) => assert(false)
    }
}
