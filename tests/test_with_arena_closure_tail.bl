type PromPoint { x: Int; y: Int }

fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "closure literal tail, no captures — promotes out of inner arena" {
    let g = with arena {
        fn(x: Int) -> Int { x + 1 }
    }
    assert(g(41) == 42)
    assert(g(-1) == 0)
}

test "closure literal tail with Int capture — promotes immutable value" {
    let n = 10
    let g = with arena {
        fn(x: Int) -> Int { x + n }
    }
    assert(g(5) == 15)
    assert(g(100) == 110)
}

test "closure literal tail with Str capture — uses blink_promote_str" {
    let prefix = "hello-"
    let g = with arena {
        fn(x: Int) -> Int { prefix.len() + x }
    }
    assert(g(4) == 10)
    assert(g(0) == 6)
}

test "closure literal tail with Float capture — uses promote_alloc_atomic" {
    let f = 2.5
    let g = with arena {
        fn(x: Float) -> Float { x + f }
    }
    let r = g(1.5)
    assert(r > 3.99 && r < 4.01)
}

test "closure literal tail with Struct capture — copies struct into target arena" {
    let p = PromPoint { x: 10, y: 20 }
    let g = with arena {
        fn(d: Int) -> Int { p.x + p.y + d }
    }
    assert(g(5) == 35)
    assert(g(-30) == 0)
}

test "let-alias tail resolves to the literal bound in this block" {
    let g = with arena {
        let h = fn(x: Int) -> Int { x * 2 }
        h
    }
    assert(g(7) == 14)
    assert(g(0) == 0)
}

test "lifetime regression: captures survive inner arena destruction + GC pressure" {
    let n = 42
    let g = with arena {
        fn(x: Int) -> Int { x + n }
    }
    // Force GC pressure after the inner arena is gone. If `n` was not
    // promoted out of the inner arena, bdwgc would reuse the freed region
    // and the capture would read corrupted memory.
    let mut sum = 0
    let mut pressure: List[Int] = []
    let mut j = 0
    while j < 5000 {
        pressure.push(j * 3)
        sum = sum + g(j)
        j = j + 1
    }
    // sum(0..4999) + 5000*42 = 12497500 + 210000 = 12707500
    assert(sum == 12707500)
}

test "residual: tail from a function call emits E0702a" {
    let src = "fn make() -> fn(Int) -> Int \{ fn(x: Int) -> Int \{ x + 1 } }\nfn main() \{\n    let g = with arena \{ make() }\n    let _ = g\n}\n"
    expect_compile_error(src, "with_arena_call_origin", "E0702a")
}

test "mut Int capture declared inside block — promotes cell and contents" {
    let g = with arena {
        let mut c = 0
        fn() -> Int { c = c + 1; c }
    }
    assert(g() == 1)
    assert(g() == 2)
    assert(g() == 3)
}

test "mut Str capture declared inside block — cell contents promoted" {
    let g = with arena {
        let mut s = "a"
        fn() -> Int {
            s = s.concat("b")
            s.len()
        }
    }
    assert(g() == 2)
    assert(g() == 3)
    assert(g() == 4)
}

test "mixed mut + immutable captures inside block" {
    let n = 100
    let g = with arena {
        let mut c = 0
        fn() -> Int { c = c + 1; c + n }
    }
    assert(g() == 101)
    assert(g() == 102)
}

test "mut List[Int] capture declared inside block — deep-promote through cell" {
    let g = with arena {
        let mut xs: List[Int] = []
        fn(v: Int) -> Int {
            xs.push(v)
            xs.len()
        }
    }
    assert(g(10) == 1)
    assert(g(20) == 2)
    assert(g(30) == 3)
}

test "promoted mut-capture closure survives inner arena + GC pressure" {
    let g = with arena {
        let mut acc = 0
        fn(x: Int) -> Int { acc = acc + x; acc }
    }
    let mut pressure: List[Int] = []
    let mut j = 0
    let mut last = 0
    while j < 2000 {
        pressure.push(j * 7)
        last = g(j)
        j = j + 1
    }
    // acc = sum(0..1999) = 1999000
    assert(last == 1999000)
}

test "mut Int capture declared OUTSIDE block — closure and outer share the cell" {
    let mut c = 0
    let g = with arena {
        fn() -> Int { c = c + 1; c }
    }
    assert(g() == 1)
    assert(g() == 2)
    assert(c == 2)
    c = 10
    assert(g() == 11)
    assert(c == 11)
}

test "mut Str capture declared OUTSIDE block — shared cell through Str" {
    let mut s = "a"
    let g = with arena {
        fn() -> Int {
            s = s.concat("b")
            s.len()
        }
    }
    assert(g() == 2)
    assert(g() == 3)
    assert(s.len() == 3)
    s = "xyz"
    assert(g() == 4)
    assert(s == "xyzb")
}

test "closure literal tail capturing another closure — promotes via C: descriptor" {
    let inner = fn(x: Int) -> Int { x * 2 }
    let g = with arena {
        fn(x: Int) -> Int { inner(x) + 1 }
    }
    assert(g(3) == 7)
    assert(g(10) == 21)
}

test "closure literal tail with two-deep nested closure captures" {
    let a = fn(x: Int) -> Int { x + 1 }
    let b = fn(x: Int) -> Int { a(x) * 3 }
    let g = with arena {
        fn(x: Int) -> Int { b(x) - 2 }
    }
    assert(g(4) == 13)
}

test "closure literal tail with closure + primitive capture" {
    let inner = fn(x: Int) -> Int { x * 5 }
    let bonus = 7
    let g = with arena {
        fn(x: Int) -> Int { inner(x) + bonus }
    }
    assert(g(2) == 17)
    assert(g(0) == 7)
}

test "closure literal tail with closure-as-let-mut capture" {
    let mut inner = fn(x: Int) -> Int { x + 1 }
    let g = with arena {
        fn(x: Int) -> Int { inner(x) * 2 }
    }
    assert(g(3) == 8)
    inner = fn(x: Int) -> Int { x * 10 }
    assert(g(3) == 60)
}
