import compile_test_helpers

test "ffi.struct with Str field emits E0812" {
    let src = "@ffi.struct(header: \"x.h\", name: \"bad\")\npub type BadFfiStruct \{ name: Str }\nfn main() \{ }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_struct_str", "E0812")
}

test "ffi.struct with Bytes field emits E0812" {
    let src = "@ffi.struct(header: \"x.h\", name: \"bad\")\npub type BadFfiStruct \{ buf: Bytes }\nfn main() \{ }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_struct_bytes", "E0812")
}

test "ffi.struct with List field emits E0812" {
    let src = "@ffi.struct(header: \"x.h\", name: \"bad\")\npub type BadFfiStruct \{ items: List[Int] }\nfn main() \{ }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_struct_list", "E0812")
}

test "ffi.struct with valid I32/I16 fields compiles" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ }\n"
    compile_test_helpers.expect_no_error(src, "ffi_struct_ok", "E0812")
}

test "Ptr.offset on singleton scope.alloc emits E0813" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ let mut s = ffi_scope(); let p: Ptr[Pollfd] = s.alloc(); let _ = p.offset(1) }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_offset_singleton", "E0813")
}

test "Ptr.offset on scope.alloc_n is allowed" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\nfn main() \{ let mut s = ffi_scope(); let p: Ptr[Pollfd] = s.alloc_n(3); let _ = p.offset(1) }\n"
    compile_test_helpers.expect_no_error(src, "ffi_offset_array", "E0813")
}
