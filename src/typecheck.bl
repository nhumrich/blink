import ast.{NodeKind}
import parser.{
    get_annotation, has_annotation,
    node_args, node_assoc_types, node_arms, node_body, node_captures, node_col, node_condition,
    node_effects, node_elements, node_else_body, node_end, node_fields, node_guard,
    node_handlers, node_index, node_int_val, node_is_mut, node_is_pub, node_iterable, node_kind,
    node_left, node_line, node_method, node_methods, node_module, node_name, node_obj,
    node_op, node_params, node_pattern, node_return_type, node_right, node_scrutinee,
    node_start, node_stmts, node_str_val, node_target, node_then_body, node_trait_name,
    node_type_ann, node_type_name, node_type_params, node_value, node_var_name,
    node_set_module, node_set_name,
    sublist_get, sublist_length,
}
import diagnostics.{
    Diag, diag_clear_allows, diag_error_at, diag_error_no_loc,
    diag_push_allows, diag_warn_at,
}

effect TypeCheck {
    effect Register
    effect Resolve
    effect Report
}

// typecheck.bl — Type representation, registries, and type checking
//
// Phase 0: Type registries — registers struct/enum/fn/trait types into pools
// Phase 1: Name resolution — walks function bodies checking identifiers resolve
// Phase 2: Expression type inference — infers types, checks compatibility
//
// The pipeline: lex → parse → typecheck → codegen

// ── Type kind constants ─────────────────────────────────────────────
let TK_INT = 0
let TK_FLOAT = 1
let TK_BOOL = 2
let TK_STR = 3
let TK_VOID = 4
let TK_LIST = 5
let TK_OPTION = 6
let TK_RESULT = 7
let TK_FN = 8
let TK_STRUCT = 9
let TK_ENUM = 10
let TK_TYPEVAR = 11
let TK_UNKNOWN = 12
let TK_CLOSURE = 13
let TK_ITERATOR = 14
let TK_HANDLE = 15
let TK_CHANNEL = 16
let TK_TUPLE = 17
let TK_MAP = 18
let TK_BYTES = 19
let TK_SET = 20
let TK_I8 = 21
let TK_I16 = 22
let TK_I32 = 23
let TK_U8 = 24
let TK_U16 = 25
let TK_U32 = 26
let TK_U64 = 27
let TK_CHAR = 28

// ── Type pool ───────────────────────────────────────────────────────
pub type TypePoolEntry {
    kind: Int
    name: Str
    inner1: Int
    inner2: Int
    params_start: Int
    params_count: Int
}
let mut ty_pool: List[TypePoolEntry] = []
let mut ty_param_list: List[Int] = []

// ── Builtin type indices (populated by init_types) ──────────────────
let mut TYPE_INT: Int = -1
let mut TYPE_FLOAT: Int = -1
let mut TYPE_BOOL: Int = -1
let mut TYPE_STR: Int = -1
let mut TYPE_VOID: Int = -1
let mut TYPE_UNKNOWN: Int = -1
let mut TYPE_I8: Int = -1
let mut TYPE_I16: Int = -1
let mut TYPE_I32: Int = -1
let mut TYPE_U8: Int = -1
let mut TYPE_U16: Int = -1
let mut TYPE_U32: Int = -1
let mut TYPE_U64: Int = -1
let mut TYPE_CHAR: Int = -1

// ── Type registries ─────────────────────────────────────────────────
let mut named_type_names: List[Str] = []
let mut named_type_ids: List[Int] = []

type TcStructField {
    struct_id: Int
    name: Str
    type_id: Int
}
let mut sfield_pool: List[TcStructField] = []

type EnumVariantEntry {
    enum_id: Int
    name: Str
    tag: Int
    has_data: Int
}
let mut evar_pool: List[EnumVariantEntry] = []

type EnumVariantFieldEntry {
    var_idx: Int
    name: Str
    type_id: Int
}
let mut evfield_pool: List[EnumVariantFieldEntry] = []

let mut named_type_map: Map[Str, Int] = Map()
let mut fnsig_map: Map[Str, Int] = Map()

type FnSigEntry {
    name: Str
    ret: Int
    params_start: Int
    params_count: Int
    type_params_start: Int
    type_params_count: Int
    effects_start: Int
    effects_count: Int
}
let mut fnsig_pool: List[FnSigEntry] = []
let mut fnsig_param_list: List[Int] = []
let mut fnsig_type_param_names: List[Str] = []
let mut fnsig_effect_names: List[Str] = []

let mut tc_trait_names: List[Str] = []
let mut tc_trait_method_names: List[Str] = []
let mut tc_trait_assoc_names: List[Str] = []

// Trait method signature registry (for contract validation)
type TraitMethodSigEntry {
    trait_name: Str
    method: Str
    ret: Str
    tparams_start: Int
    tparams_count: Int
    params_start: Int
    params_count: Int
}
let mut tc_tmsig_pool: List[TraitMethodSigEntry] = []
let mut tc_tmsig_param_names: List[Str] = []
let mut tc_trait_tparam_names: List[Str] = []

let mut tc_current_fn_ret: Int = -1
let mut tc_current_fn_name: Str = ""

let mut tc_errors: List[Str] = []
let mut tc_warnings: List[Str] = []

// ── Deprecation tracking ───────────────────────────────────────────
let mut depr_fn_nodes: Map[Str, Int] = Map()
let mut depr_type_nodes: Map[Str, Int] = Map()

// ── Import alias maps ──────────────────────────────────────────────
pub let mut tc_alias_to_original: Map[Str, Str] = Map()
let mut tc_original_to_alias: Map[Str, Str] = Map()

// ── Inferred type hints (for LSP inlayHint) ─────────────────────────
pub type HintEntry {
    line: Int
    col: Int
    name: Str
    type_str: Str
    module: Str
}
pub let mut tc_hints: List[HintEntry] = []

// ── Unused import tracking ──────────────────────────────────────────
let mut tc_symbol_module: Map[Str, Str] = Map()
let mut tc_used_modules: Map[Str, Int] = Map()

fn tc_mark_symbol_used(name: Str) {
    if nr_current_module != "" && nr_current_module != "__main__" { return }
    match tc_symbol_module.get(name) {
        Some(mod_name) => {
            if mod_name != "" {
                tc_used_modules.insert(mod_name, 1)
            }
        }
        None => {}
    }
}

fn tc_mark_qualifier_used(qualifier: Str) {
    if nr_current_module != "" && nr_current_module != "__main__" { return }
    tc_used_modules.insert(qualifier, 1)
    match tc_qualifier_to_module.get(qualifier) {
        Some(mod_name) => tc_used_modules.insert(mod_name, 1)
        None => {}
    }
}

pub fn tc_is_module_used(mod_name: Str) -> Int {
    if tc_used_modules.contains_key(mod_name) {
        return 1
    }
    0
}

// ── Incremental filter ──────────────────────────────────────────────
// When enabled, only functions whose names appear in the filter set
// are typechecked. Used by the incremental recheck engine.

let mut tc_inc_enabled: Int = 0
let mut tc_inc_filter: Map[Str, Int] = Map()

// ── Type creation ───────────────────────────────────────────────────

fn new_type(kind: Int, name: Str) -> Int {
    let idx = ty_pool.len()
    ty_pool.push(TypePoolEntry { kind: kind, name: name, inner1: -1, inner2: -1, params_start: -1, params_count: 0 })
    idx
}

fn make_list_type(inner: Int) -> Int {
    let t = new_type(TK_LIST, "List")
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: inner, ..e })
    t
}

fn make_option_type(inner: Int) -> Int {
    let t = new_type(TK_OPTION, "Option")
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: inner, ..e })
    t
}

fn make_result_type(ok_type: Int, err_type: Int) -> Int {
    let t = new_type(TK_RESULT, "Result")
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: ok_type, inner2: err_type, ..e })
    t
}

fn make_fn_type(ret_type: Int, param_types: List[Int]) -> Int {
    let t = new_type(TK_FN, "Fn")
    let start = ty_param_list.len()
    let mut i = 0
    while i < param_types.len() {
        ty_param_list.push(param_types.get(i).unwrap())
        i = i + 1
    }
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: ret_type, params_start: start, params_count: param_types.len(), ..e })
    t
}

fn make_typevar(name: Str) -> Int {
    new_type(TK_TYPEVAR, name)
}

fn make_tuple_type(elem_types: List[Int]) -> Int {
    let t = new_type(TK_TUPLE, "Tuple")
    let start = ty_param_list.len()
    let mut i = 0
    while i < elem_types.len() {
        ty_param_list.push(elem_types.get(i).unwrap())
        i = i + 1
    }
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { params_start: start, params_count: elem_types.len(), ..e })
    t
}


fn make_map_type(key_type: Int, value_type: Int) -> Int {
    let t = new_type(TK_MAP, "Map")
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: key_type, inner2: value_type, ..e })
    t
}

fn make_set_type(elem_type: Int) -> Int {
    let t = new_type(TK_SET, "Set")
    let e = ty_pool.get(t).unwrap()
    ty_pool.set(t, TypePoolEntry { inner1: elem_type, ..e })
    t
}

// ── Type lookup ─────────────────────────────────────────────────────

fn lookup_named_type(name: Str) -> Int {
    match named_type_map.get(name) {
        Some(v) => return v
        None => {}
    }
    let dot = name.index_of(".")
    if dot >= 0 {
        let bare = name.slice(dot + 1, name.len())
        let resolved = tc_alias_to_original.get(bare) ?? bare
        match named_type_map.get(resolved) {
            Some(v) => return v
            None => {}
        }
        match named_type_map.get(bare) {
            Some(v) => return v
            None => {}
        }
    }
    -1
}

fn resolve_type_name(name: Str) -> Int ! TypeCheck.Resolve {
    if name == "Int" { return TYPE_INT }
    if name == "Float" { return TYPE_FLOAT }
    if name == "Bool" { return TYPE_BOOL }
    if name == "Str" { return TYPE_STR }
    if name == "Void" || name == "" { return TYPE_VOID }
    if name == "I8" { return TYPE_I8 }
    if name == "I16" { return TYPE_I16 }
    if name == "I32" { return TYPE_I32 }
    if name == "U8" { return TYPE_U8 }
    if name == "U16" { return TYPE_U16 }
    if name == "U32" { return TYPE_U32 }
    if name == "U64" { return TYPE_U64 }
    if name == "Char" { return TYPE_CHAR }
    lookup_named_type(name)
}

fn get_struct_field_tid(struct_tid: Int, fname: Str) -> Int {
    let mut i = 0
    while i < sfield_pool.len() {
        let sf = sfield_pool.get(i).unwrap()
        if sf.struct_id == struct_tid && sf.name == fname {
            return sf.type_id
        }
        i = i + 1
    }
    -1
}

fn get_variant_by_name(enum_tid: Int, vname: Str) -> Int {
    let mut i = 0
    while i < evar_pool.len() {
        let ev = evar_pool.get(i).unwrap()
        if ev.enum_id == enum_tid && ev.name == vname {
            return i
        }
        i = i + 1
    }
    -1
}

fn lookup_fnsig(name: Str) -> Int {
    if nr_current_module != "" {
        let qualified = "{nr_current_module}:{name}"
        match fnsig_map.get(qualified) {
            Some(v) => return v
            None => {}
        }
    }
    fnsig_map.get(name) ?? -1
}

fn instantiate_return_type(sig: Int, args_sl: Int) -> Int ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    let fs = fnsig_pool.get(sig).unwrap()
    let ret = fs.ret
    if ret < 0 || ret >= ty_pool.len() { return ret }
    let ret_entry = ty_pool.get(ret).unwrap()
    if ret_entry.kind != TK_TYPEVAR { return ret }

    let tp_name = ret_entry.name
    let tp_start = fs.type_params_start
    let tp_count = fs.type_params_count
    let param_start = fs.params_start
    let param_count = fs.params_count

    let mut ti = 0
    while ti < tp_count {
        if fnsig_type_param_names.get(tp_start + ti).unwrap() == tp_name {
            let mut pi = 0
            while pi < param_count {
                let ptid = fnsig_param_list.get(param_start + pi).unwrap()
                if ptid >= 0 && ptid < ty_pool.len() && ty_pool.get(ptid).unwrap().kind == TK_TYPEVAR && ty_pool.get(ptid).unwrap().name == tp_name {
                    if args_sl != -1 && pi < sublist_length(args_sl) {
                        return infer_type(sublist_get(args_sl, pi))
                    }
                }
                pi = pi + 1
            }
        }
        ti = ti + 1
    }
    ret
}

// ── Error reporting ─────────────────────────────────────────────────

fn tc_error(msg: Str) ! TypeCheck.Report, Diag.Report {
    tc_errors.push(msg)
    diag_error_no_loc("TypeError", "E0300", msg, "")
}

fn tc_error_at(msg: Str, node_id: Int) ! TypeCheck.Report, Diag.Report {
    tc_errors.push(msg)
    diag_error_at("TypeError", "E0300", msg, node_id, "")
}

fn tc_warn(msg: Str) ! TypeCheck.Report {
    tc_warnings.push(msg)
}

// ── Incremental filter API ──────────────────────────────────────────

pub fn tc_set_incremental_filter(names: List[Str]) {
    tc_inc_filter = Map()
    let mut i = 0
    while i < names.len() {
        tc_inc_filter.insert(names.get(i).unwrap(), 1)
        i = i + 1
    }
    tc_inc_enabled = 1
}

pub fn tc_clear_incremental_filter() {
    tc_inc_filter = Map()
    tc_inc_enabled = 0
}

fn tc_should_check_fn(name: Str) -> Int {
    if tc_inc_enabled == 0 {
        return 1
    }
    tc_inc_filter.contains_key(name)
}

// ── Type annotation resolution ──────────────────────────────────────

fn resolve_type_ann(ann_node: Int) -> Int ! TypeCheck.Resolve {
    if ann_node == -1 {
        return TYPE_UNKNOWN
    }
    let name = node_name(ann_node)
    let elems_sl = node_elements(ann_node)

    if name == "List" {
        if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
            let inner = resolve_type_ann(sublist_get(elems_sl, 0))
            return make_list_type(inner)
        }
        return make_list_type(TYPE_UNKNOWN)
    }
    if name == "Option" {
        if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
            let inner = resolve_type_ann(sublist_get(elems_sl, 0))
            return make_option_type(inner)
        }
        return make_option_type(TYPE_UNKNOWN)
    }
    if name == "Result" {
        if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
            let ok_t = resolve_type_ann(sublist_get(elems_sl, 0))
            let err_t = resolve_type_ann(sublist_get(elems_sl, 1))
            return make_result_type(ok_t, err_t)
        }
        return make_result_type(TYPE_UNKNOWN, TYPE_UNKNOWN)
    }
    if name == "Map" {
        if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
            let key_t = resolve_type_ann(sublist_get(elems_sl, 0))
            let val_t = resolve_type_ann(sublist_get(elems_sl, 1))
            return make_map_type(key_t, val_t)
        }
        return make_map_type(TYPE_UNKNOWN, TYPE_UNKNOWN)
    }
    if name == "Set" {
        if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
            let elem_t = resolve_type_ann(sublist_get(elems_sl, 0))
            return make_set_type(elem_t)
        }
        return make_set_type(TYPE_UNKNOWN)
    }
    if name == "Bytes" {
        return new_type(TK_BYTES, "Bytes")
    }

    let resolved = resolve_type_name(name)
    if resolved != -1 {
        return resolved
    }

    make_typevar(name)
}

// ── Registration from AST ───────────────────────────────────────────

fn is_ffi_struct_field_type(ann_name: Str) -> Int {
    if ann_name == "I8" || ann_name == "I16" || ann_name == "I32" || ann_name == "I64" { return 1 }
    if ann_name == "U8" || ann_name == "U16" || ann_name == "U32" || ann_name == "U64" { return 1 }
    if ann_name == "Int" || ann_name == "Float" || ann_name == "F32" || ann_name == "F64" { return 1 }
    if ann_name == "Bool" { return 1 }
    0
}

fn register_struct_type(td: Int) ! TypeCheck.Register, TypeCheck.Resolve, Diag.Report {
    let name = node_name(td)
    let tid = new_type(TK_STRUCT, name)
    named_type_names.push(name)
    named_type_ids.push(tid)
    named_type_map.insert(name, tid)

    let is_ffi_struct = has_annotation(td, "ffi.struct")

    let flds_sl = node_fields(td)
    if flds_sl != -1 {
        let mut i = 0
        while i < sublist_length(flds_sl) {
            let f = sublist_get(flds_sl, i)
            let fname = node_name(f)
            let ftype_ann = node_value(f)
            let ftype_id = resolve_type_ann(ftype_ann)
            sfield_pool.push(TcStructField { struct_id: tid, name: fname, type_id: ftype_id })
            let ftype_ann_name = node_name(ftype_ann)
            if ftype_ann_name == "Fn" {
                if is_callable_field_name(fname) == 0 {
                    nr_callable_field_names.push(fname)
                }
            }
            if is_ffi_struct != 0 {
                if is_ffi_struct_field_type(ftype_ann_name) == 0 {
                    diag_error_at("FfiStructGcField", "E0812", "@ffi.struct field '{fname}' uses non-FFI type '{ftype_ann_name}' — only sized FFI-compatible types (I8/I16/I32/I64, U8/U16/U32/U64, Int, Float, F32, F64, Bool) and other @ffi.struct types are allowed", f, "use a sized integer/float/bool type or another @ffi.struct type")
                }
            }
            i = i + 1
        }
    }

    if has_annotation(td, "deprecated") != 0 {
        depr_type_nodes.insert(name, td)
    }
}

fn register_enum_type(td: Int) ! TypeCheck.Register, TypeCheck.Resolve {
    let name = node_name(td)
    let tid = new_type(TK_ENUM, name)
    named_type_names.push(name)
    named_type_ids.push(tid)
    named_type_map.insert(name, tid)

    let flds_sl = node_fields(td)
    if flds_sl != -1 {
        let mut _tag = 0
        let mut i = 0
        while i < sublist_length(flds_sl) {
            let v = sublist_get(flds_sl, i)
            let vname = node_name(v)
            let var_idx = evar_pool.len()

            let vflds_sl = node_fields(v)
            let mut _has_data = 0
            if vflds_sl != -1 && sublist_length(vflds_sl) > 0 {
                _has_data = 1
                let mut fi = 0
                while fi < sublist_length(vflds_sl) {
                    let vf = sublist_get(vflds_sl, fi)
                    let vf_name = node_name(vf)
                    let vf_type_ann = node_value(vf)
                    let vf_type_id = resolve_type_ann(vf_type_ann)
                    evfield_pool.push(EnumVariantFieldEntry { var_idx: var_idx, name: vf_name, type_id: vf_type_id })
                    fi = fi + 1
                }
            }
            evar_pool.push(EnumVariantEntry { enum_id: tid, name: vname, tag: _tag, has_data: _has_data })

            _tag = _tag + 1
            i = i + 1
        }
    }

    if has_annotation(td, "deprecated") != 0 {
        depr_type_nodes.insert(name, td)
    }
}

fn register_fn_sig(fn_node: Int) ! TypeCheck.Register, TypeCheck.Resolve {
    let name = node_name(fn_node)
    let ret_str = node_return_type(fn_node)
    let ret_ann = node_type_ann(fn_node)
    let mut ret_tid = TYPE_VOID

    if ret_ann != -1 {
        ret_tid = resolve_type_ann(ret_ann)
    } else if ret_str != "" {
        ret_tid = resolve_type_name(ret_str)
        if ret_tid == -1 {
            ret_tid = TYPE_VOID
        }
    }

    let sig_idx = fnsig_pool.len()
    fnsig_map.insert(name, sig_idx)
    let fn_mod = node_module(fn_node)
    if fn_mod != "" {
        fnsig_map.insert("{fn_mod}:{name}", sig_idx)
    }
    let start = fnsig_param_list.len()

    let params_sl = node_params(fn_node)
    let mut count = 0
    if params_sl != -1 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let ptype_str = node_type_name(p)
            let ptype_ann = node_type_ann(p)
            let mut ptid = TYPE_UNKNOWN
            if ptype_ann != -1 {
                ptid = resolve_type_ann(ptype_ann)
            } else if ptype_str != "" {
                ptid = resolve_type_name(ptype_str)
                if ptid == -1 {
                    ptid = TYPE_UNKNOWN
                }
            }
            fnsig_param_list.push(ptid)
            count = count + 1
            i = i + 1
        }
    }

    let tparams_sl = node_type_params(fn_node)
    let tp_start = fnsig_type_param_names.len()
    let mut tp_count = 0
    if tparams_sl != -1 {
        let mut ti = 0
        while ti < sublist_length(tparams_sl) {
            let tp = sublist_get(tparams_sl, ti)
            fnsig_type_param_names.push(node_name(tp))
            tp_count = tp_count + 1
            ti = ti + 1
        }
    }
    let eff_start = fnsig_effect_names.len()
    let effects_sl = node_effects(fn_node)
    let mut eff_count = 0
    if effects_sl != -1 {
        let mut ei = 0
        while ei < sublist_length(effects_sl) {
            let eff = sublist_get(effects_sl, ei)
            fnsig_effect_names.push(node_name(eff))
            eff_count = eff_count + 1
            ei = ei + 1
        }
    }
    fnsig_pool.push(FnSigEntry { name: name, ret: ret_tid, params_start: start, params_count: count, type_params_start: tp_start, type_params_count: tp_count, effects_start: eff_start, effects_count: eff_count })

    if has_annotation(fn_node, "deprecated") != 0 {
        depr_fn_nodes.insert(name, fn_node)
    }
}

fn depr_ann_str_arg(ann_node: Int, key: Str) -> Str {
    let args_sl = node_args(ann_node)
    if args_sl == -1 { return "" }
    let mut i = 0
    while i < sublist_length(args_sl) {
        let arg = sublist_get(args_sl, i)
        if node_name(arg) == key {
            let parts_sl = node_elements(arg)
            if parts_sl != -1 && sublist_length(parts_sl) > 0 {
                return node_str_val(sublist_get(parts_sl, 0))
            }
        }
        i = i + 1
    }
    ""
}

fn check_deprecated_fn(fn_name: Str, call_node: Int) ! Diag.Report {
    if depr_fn_nodes.contains_key(fn_name) == 0 { return }
    let def_node = depr_fn_nodes.get(fn_name) ?? -1
    if def_node == -1 { return }
    let ann = get_annotation(def_node, "deprecated")
    if ann == -1 { return }
    let since = depr_ann_str_arg(ann, "since")
    let replacement = depr_ann_str_arg(ann, "replacement")
    let mut msg = "use of deprecated function '{fn_name}'"
    if since != "" {
        msg = msg.concat(" (deprecated since {since})")
    }
    let mut help = ""
    if replacement != "" {
        help = "use '{replacement}' instead"
    }
    diag_warn_at("DeprecatedUsage", "W2000", msg, call_node, help)
}

fn check_deprecated_type(type_name: Str, usage_node: Int) ! Diag.Report {
    if depr_type_nodes.contains_key(type_name) == 0 { return }
    let def_node = depr_type_nodes.get(type_name) ?? -1
    if def_node == -1 { return }
    let ann = get_annotation(def_node, "deprecated")
    if ann == -1 { return }
    let since = depr_ann_str_arg(ann, "since")
    let replacement = depr_ann_str_arg(ann, "replacement")
    let mut msg = "use of deprecated type '{type_name}'"
    if since != "" {
        msg = msg.concat(" (deprecated since {since})")
    }
    let mut help = ""
    if replacement != "" {
        help = "use '{replacement}' instead"
    }
    diag_warn_at("DeprecatedUsage", "W2000", msg, usage_node, help)
}

fn is_valid_ptr_inner(name: Str) -> Int {
    if name == "Void" { return 1 }
    if name == "U8" || name == "U16" || name == "U32" || name == "U64" { return 1 }
    if name == "I8" || name == "I16" || name == "I32" || name == "I64" { return 1 }
    if name == "Int" || name == "Float" || name == "Ptr" { return 1 }
    0
}

fn check_ptr_in_type_ann(ann_node: Int, has_ffi: Int) ! Diag.Report {
    if ann_node == -1 { return }
    let name = node_name(ann_node)
    if name == "Ptr" {
        if has_ffi == 0 {
            diag_error_at("PtrOutsideFFI", "E0811", "Ptr[T] type can only be used in @ffi functions or @trusted blocks", ann_node, "add @ffi annotation to the function or wrap usage in @trusted")
        }
        let elems_sl = node_elements(ann_node)
        if elems_sl != -1 && sublist_length(elems_sl) > 0 {
            let inner = sublist_get(elems_sl, 0)
            let inner_name = node_name(inner)
            if is_valid_ptr_inner(inner_name) == 0 {
                diag_error_at("InvalidPtrType", "E0810", "invalid Ptr type parameter '{inner_name}' — only Void, U8-U64, I8-I64, Int, Float, Ptr are allowed", inner, "use a valid FFI-compatible type")
            }
        }
        return
    }
    let elems_sl = node_elements(ann_node)
    if elems_sl != -1 {
        let mut i = 0
        while i < sublist_length(elems_sl) {
            check_ptr_in_type_ann(sublist_get(elems_sl, i), has_ffi)
            i = i + 1
        }
    }
}

fn check_ptr_in_type_name(type_name: Str, node: Int, has_ffi: Int) ! Diag.Report {
    if type_name == "Ptr" && has_ffi == 0 {
        diag_error_at("PtrOutsideFFI", "E0811", "Ptr[T] type can only be used in @ffi functions or @trusted blocks", node, "add @ffi annotation to the function or wrap usage in @trusted")
    }
}

fn validate_ffi_fn(fn_node: Int) ! Diag.Report {
    let name = node_name(fn_node)
    let ffi_node = get_annotation(fn_node, "ffi")
    let has_ffi = if ffi_node != -1 { 1 } else { 0 }
    let has_trusted = has_annotation(fn_node, "trusted")
    let requires_node = get_annotation(fn_node, "requires")
    let has_requires = if requires_node != -1 { 1 } else { 0 }
    let ensures_node = get_annotation(fn_node, "ensures")
    let has_ensures = if ensures_node != -1 { 1 } else { 0 }

    if has_ffi != 0 {
        if node_is_pub(fn_node) != 0 && has_trusted == 0 {
            diag_error_at("PubFFI", "E0801", "FFI function '{name}' must not be pub — FFI functions are unsafe and should be wrapped", ffi_node, "remove 'pub' or add @trusted to mark it as audited")
        }
        let effects_sl = node_effects(fn_node)
        if effects_sl == -1 || sublist_length(effects_sl) == 0 {
            diag_error_at("FFINoEffects", "E0802", "FFI function '{name}' must declare effects — FFI calls are side-effectful", ffi_node, "add '! FFI' or appropriate effects to the function signature")
        }
        if has_requires != 0 {
            diag_error_at("ContractOnFFI", "E0803", "@requires cannot be used on FFI function '{name}' — contracts cannot verify foreign code", requires_node, "remove @requires from the FFI function")
        }
        if has_ensures != 0 {
            diag_error_at("ContractOnFFI", "E0803", "@ensures cannot be used on FFI function '{name}' — contracts cannot verify foreign code", ensures_node, "remove @ensures from the FFI function")
        }
        if has_trusted == 0 {
            diag_warn_at("UnauditedFFI", "W0800", "FFI function '{name}' is not marked @trusted — consider auditing and adding @trusted", ffi_node, "add @trusted after auditing the foreign function")
        }
    }

    // Check Ptr[T] in parameter types
    let params_sl = node_params(fn_node)
    if params_sl != -1 {
        let mut pi = 0
        while pi < sublist_length(params_sl) {
            let p = sublist_get(params_sl, pi)
            let ptype_ann = node_type_ann(p)
            if ptype_ann != -1 {
                check_ptr_in_type_ann(ptype_ann, has_ffi)
            } else {
                check_ptr_in_type_name(node_type_name(p), p, has_ffi)
            }
            pi = pi + 1
        }
    }

    // Check Ptr[T] in return type
    let ret_ann = node_type_ann(fn_node)
    if ret_ann != -1 {
        check_ptr_in_type_ann(ret_ann, has_ffi)
    } else {
        let ret_str = node_return_type(fn_node)
        if ret_str == "Ptr" && has_ffi == 0 {
            diag_error_at("PtrOutsideFFI", "E0811", "Ptr[T] type can only be used in @ffi functions or @trusted blocks", fn_node, "add @ffi annotation to the function or wrap usage in @trusted")
        }
    }
}

fn budget_effect_satisfies(budget_eff: Str, fn_eff: Str) -> Int {
    if budget_eff == fn_eff { return 1 }
    if fn_eff.starts_with(budget_eff.concat(".")) { return 1 }
    0
}

fn validate_capabilities_budget(program: Int, fns_sl: Int) ! Diag.Report {
    let cap_node = get_annotation(program, "capabilities")
    if cap_node == -1 { return }
    let mut budget_names: List[Str] = []
    let ann_args_sl = node_args(cap_node)
    if ann_args_sl != -1 {
        let mut ai = 0
        while ai < sublist_length(ann_args_sl) {
            let arg_nd = sublist_get(ann_args_sl, ai)
            budget_names.push(node_name(arg_nd))
            ai = ai + 1
        }
    }
    if fns_sl == -1 { return }
    let mut fi = 0
    while fi < sublist_length(fns_sl) {
        let fn_node = sublist_get(fns_sl, fi)
        let fn_name = node_name(fn_node)
        let fn_mod = node_module(fn_node)
        if fn_name != "main" && !fn_name.starts_with("__test_") && (fn_mod == "__main__") {
            let sig = lookup_fnsig(fn_name)
            if sig != -1 && sig < fnsig_pool.len() {
                let fs = fnsig_pool.get(sig).unwrap()
                let eff_start = fs.effects_start
                let eff_count = fs.effects_count
                let mut ei = 0
                while ei < eff_count {
                    let eff = fnsig_effect_names.get(eff_start + ei).unwrap()
                    let mut allowed = 0
                    let mut bi = 0
                    while bi < budget_names.len() {
                        if budget_effect_satisfies(budget_names.get(bi).unwrap(), eff) != 0 {
                            allowed = 1
                        }
                        bi = bi + 1
                    }
                    if allowed == 0 {
                        diag_error_at("CapabilityBudgetExceeded", "E0501", "function '{fn_name}' uses effect '{eff}' which is not in @capabilities budget", fn_node, "add '{eff}' to @capabilities")
                    }
                    ei = ei + 1
                }
            }
        }
        fi = fi + 1
    }
}

pub fn tc_fn_has_effect(name: Str, eff: Str) -> Int {
    let sig = lookup_fnsig(name)
    if sig == -1 { return 0 }
    let fs = fnsig_pool.get(sig).unwrap()
    let mut i = 0
    while i < fs.effects_count {
        if fnsig_effect_names.get(fs.effects_start + i).unwrap() == eff { return 1 }
        i = i + 1
    }
    0
}

fn register_trait(tr_node: Int) ! TypeCheck.Register {
    let name = node_name(tr_node)
    tc_trait_names.push(name)
    // Collect trait-level type params (e.g., T in trait From[T])
    let tparams_sl = node_type_params(tr_node)
    let tp_start = tc_trait_tparam_names.len()
    let mut tp_count = 0
    if tparams_sl != -1 {
        let mut ti = 0
        while ti < sublist_length(tparams_sl) {
            let tp = sublist_get(tparams_sl, ti)
            tc_trait_tparam_names.push(node_name(tp))
            tp_count = tp_count + 1
            ti = ti + 1
        }
    }
    let methods_sl = node_methods(tr_node)
    if methods_sl != -1 {
        let mut i = 0
        while i < sublist_length(methods_sl) {
            let m = sublist_get(methods_sl, i)
            let mname = node_name(m)
            tc_trait_method_names.push("{name}.{mname}")
            // Store method signature for contract validation
            let p_start = tc_tmsig_param_names.len()
            let params_sl = node_params(m)
            let mut p_count = 0
            if params_sl != -1 {
                let mut j = 0
                while j < sublist_length(params_sl) {
                    let p = sublist_get(params_sl, j)
                    tc_tmsig_param_names.push(node_type_name(p))
                    p_count = p_count + 1
                    j = j + 1
                }
            }
            tc_tmsig_pool.push(TraitMethodSigEntry { trait_name: name, method: mname, ret: node_return_type(m), tparams_start: tp_start, tparams_count: tp_count, params_start: p_start, params_count: p_count })
            i = i + 1
        }
    }
    let assoc_sl = node_assoc_types(tr_node)
    if assoc_sl != -1 {
        let mut ai = 0
        while ai < sublist_length(assoc_sl) {
            let at_node = sublist_get(assoc_sl, ai)
            let aname = node_name(at_node)
            tc_trait_assoc_names.push("{name}.{aname}")
            ai = ai + 1
        }
    }
}

fn subst_trait_type(type_str: Str, impl_type: Str, tmsig_idx: Int, impl_node: Int) -> Str {
    if type_str == "Self" { return impl_type }
    if type_str.starts_with("Self.") {
        let assoc_name = type_str.substring(5, type_str.len() - 5)
        let assoc_sl = node_assoc_types(impl_node)
        if assoc_sl != -1 {
            let mut ai = 0
            while ai < sublist_length(assoc_sl) {
                let at_node = sublist_get(assoc_sl, ai)
                if node_name(at_node) == assoc_name {
                    return node_type_name(at_node)
                }
                ai = ai + 1
            }
        }
        return type_str
    }
    let _tmsig = tc_tmsig_pool.get(tmsig_idx).unwrap()
    let tp_start = _tmsig.tparams_start
    let tp_count = _tmsig.tparams_count
    if tp_count > 0 {
        let impl_targs_sl = node_type_params(impl_node)
        let mut k = 0
        while k < tp_count {
            let tp_name = tc_trait_tparam_names.get(tp_start + k).unwrap()
            if type_str == tp_name {
                if impl_targs_sl != -1 && k < sublist_length(impl_targs_sl) {
                    return node_name(sublist_get(impl_targs_sl, k))
                }
            }
            k = k + 1
        }
    }
    type_str
}

fn validate_trait_impls(program: Int) ! TypeCheck.Register, Diag.Report {
    let impls_sl = node_methods(program)
    if impls_sl == -1 { return }
    let mut ii = 0
    while ii < sublist_length(impls_sl) {
        let im = sublist_get(impls_sl, ii)
        let trait_name = node_trait_name(im)
        let impl_type = node_name(im)
        if is_trait_name(trait_name) == 0 {
            diag_error_at("TraitContract", "E0904", "trait '{trait_name}' is not defined", im, "check the trait name or define 'trait {trait_name} \{ ... }'")
            ii = ii + 1
            continue
        }
        // Check each trait method signature against this impl
        let impl_methods_sl = node_methods(im)
        let mut si = 0
        while si < tc_tmsig_pool.len() {
            let tmsig = tc_tmsig_pool.get(si).unwrap()
            if tmsig.trait_name == trait_name {
                let expected_method = tmsig.method
                let mut found = 0
                let mut mi = 0
                if impl_methods_sl != -1 {
                    while mi < sublist_length(impl_methods_sl) {
                        let impl_m = sublist_get(impl_methods_sl, mi)
                        if node_name(impl_m) == expected_method {
                            found = 1
                            // Check arity
                            let trait_pcount = tmsig.params_count
                            let impl_params_sl = node_params(impl_m)
                            let mut impl_pcount = 0
                            if impl_params_sl != -1 {
                                impl_pcount = sublist_length(impl_params_sl)
                            }
                            if trait_pcount != impl_pcount {
                                diag_error_at("TraitContract", "E0901", "method '{expected_method}' in impl {trait_name} for {impl_type} has {impl_pcount} params, expected {trait_pcount}", impl_m, "trait requires {trait_pcount} parameters (including self)")
                            } else {
                                // Check param types
                                let tp_start = tmsig.params_start
                                let mut pi = 0
                                while pi < trait_pcount {
                                    let trait_ptype = tc_tmsig_param_names.get(tp_start + pi).unwrap()
                                    if trait_ptype != "" {
                                        let impl_p = sublist_get(impl_params_sl, pi)
                                        let raw_impl_ptype = node_type_name(impl_p)
                                        let impl_ptype = if raw_impl_ptype == "Self" { impl_type } else { raw_impl_ptype }
                                        let expected_type = subst_trait_type(trait_ptype, impl_type, si, im)
                                        if impl_ptype != expected_type {
                                            diag_error_at("TraitContract", "E0902", "method '{expected_method}' param has type '{impl_ptype}', expected '{expected_type}'", impl_p, "change type to '{expected_type}' to match trait {trait_name}")
                                        }
                                    }
                                    pi = pi + 1
                                }
                                // Check return type
                                let trait_ret = tmsig.ret
                                if trait_ret != "" {
                                    let raw_impl_ret = node_return_type(impl_m)
                                    let impl_ret = if raw_impl_ret == "Self" { impl_type } else { raw_impl_ret }
                                    let expected_ret = subst_trait_type(trait_ret, impl_type, si, im)
                                    if impl_ret != expected_ret {
                                        diag_error_at("TraitContract", "E0903", "method '{expected_method}' returns '{impl_ret}', expected '{expected_ret}'", impl_m, "change return type to '{expected_ret}' to match trait {trait_name}")
                                    }
                                }
                            }
                            break
                        }
                        mi = mi + 1
                    }
                }
                if found == 0 {
                    diag_error_at("TraitContract", "E0900", "impl {trait_name} for {impl_type} is missing method '{expected_method}'", im, "add 'fn {expected_method}(...)' to the impl block")
                }
            }
            si = si + 1
        }
        let impl_assoc_sl = node_assoc_types(im)
        let mut ati = 0
        while ati < tc_trait_assoc_names.len() {
            let full_name = tc_trait_assoc_names.get(ati).unwrap()
            if full_name.starts_with("{trait_name}.") {
                let expected_assoc = full_name.substring(trait_name.len() + 1, full_name.len() - trait_name.len() - 1)
                let mut found_assoc = 0
                if impl_assoc_sl != -1 {
                    let mut aj = 0
                    while aj < sublist_length(impl_assoc_sl) {
                        let at_node = sublist_get(impl_assoc_sl, aj)
                        if node_name(at_node) == expected_assoc {
                            found_assoc = 1
                            break
                        }
                        aj = aj + 1
                    }
                }
                if found_assoc == 0 {
                    diag_error_at("TraitContract", "E0905", "impl {trait_name} for {impl_type} is missing associated type '{expected_assoc}'", im, "add 'type {expected_assoc} = ...' to the impl block")
                }
            }
            ati = ati + 1
        }
        let conflict_trait = if trait_name == "BlockHandler" { "Closeable" } else if trait_name == "Closeable" { "BlockHandler" } else { "" }
        if conflict_trait != "" {
            let mut ci = 0
            while ci < sublist_length(impls_sl) {
                let other = sublist_get(impls_sl, ci)
                if node_trait_name(other) == conflict_trait && node_name(other) == impl_type {
                    diag_error_at("TraitContract", "E0906", "type '{impl_type}' cannot implement both Closeable and BlockHandler (ambiguous with-block semantics)", im, "remove one of the impl blocks")
                    break
                }
                ci = ci + 1
            }
        }
        ii = ii + 1
    }
}

// ── Main entry point ────────────────────────────────────────────────

fn init_types() ! TypeCheck.Register {
    ty_pool.clear()
    ty_param_list.clear()
    named_type_names.clear()
    named_type_ids.clear()
    named_type_map.clear()
    sfield_pool.clear()
    nr_callable_field_names.clear()
    evar_pool.clear()
    evfield_pool.clear()
    fnsig_pool.clear()
    fnsig_map.clear()
    fnsig_param_list.clear()
    fnsig_type_param_names.clear()
    fnsig_effect_names.clear()
    tc_trait_names.clear()
    tc_trait_method_names.clear()
    tc_trait_assoc_names.clear()
    tc_tmsig_pool.clear()
    tc_tmsig_param_names.clear()
    tc_trait_tparam_names.clear()
    tc_current_fn_ret = -1
    tc_current_fn_name = ""
    tc_errors.clear()
    tc_warnings.clear()
    depr_fn_nodes.clear()
    depr_type_nodes.clear()
    tc_symbol_module.clear()
    tc_used_modules.clear()
    tc_hints.clear()
    tc_build_import_map()

    TYPE_INT = new_type(TK_INT, "Int")
    TYPE_FLOAT = new_type(TK_FLOAT, "Float")
    TYPE_BOOL = new_type(TK_BOOL, "Bool")
    TYPE_STR = new_type(TK_STR, "Str")
    TYPE_VOID = new_type(TK_VOID, "Void")
    TYPE_UNKNOWN = new_type(TK_UNKNOWN, "?")
    TYPE_I8 = new_type(TK_I8, "I8")
    TYPE_I16 = new_type(TK_I16, "I16")
    TYPE_I32 = new_type(TK_I32, "I32")
    TYPE_U8 = new_type(TK_U8, "U8")
    TYPE_U16 = new_type(TK_U16, "U16")
    TYPE_U32 = new_type(TK_U32, "U32")
    TYPE_U64 = new_type(TK_U64, "U64")
    TYPE_CHAR = new_type(TK_CHAR, "Char")
}

pub fn check_types(program: Int) -> Int ! TypeCheck, Diag.Report {
    if trace_mode != "" { trace("typecheck", "start") }
    init_types()

    // Register all type definitions (structs and enums)
    let types_sl = node_fields(program)
    if types_sl != -1 {
        let mut i = 0
        while i < sublist_length(types_sl) {
            let td = sublist_get(types_sl, i)
            let td_flds = node_fields(td)
            let mut is_enum = 0
            if td_flds != -1 && sublist_length(td_flds) > 0 {
                if node_kind(sublist_get(td_flds, 0)) == NodeKind.TypeVariant {
                    is_enum = 1
                }
            }
            if is_enum != 0 {
                register_enum_type(td)
            } else {
                register_struct_type(td)
            }
            i = i + 1
        }
    }

    // Register all function signatures
    let fns_sl = node_params(program)
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            register_fn_sig(sublist_get(fns_sl, i))
            i = i + 1
        }
    }

    // Validate FFI annotations and Ptr[T] usage
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            validate_ffi_fn(sublist_get(fns_sl, i))
            i = i + 1
        }
    }

    validate_capabilities_budget(program, fns_sl)

    // Build symbol-to-module map for unused import detection
    if types_sl != -1 {
        let mut i = 0
        while i < sublist_length(types_sl) {
            let td = sublist_get(types_sl, i)
            let mod_name = node_module(td)
            if mod_name != "" && mod_name != "__main__" {
                tc_symbol_module.insert(node_name(td), mod_name)
                let td_flds = node_fields(td)
                if td_flds != -1 {
                    let mut j = 0
                    while j < sublist_length(td_flds) {
                        let fld = sublist_get(td_flds, j)
                        if node_kind(fld) == NodeKind.TypeVariant {
                            tc_symbol_module.insert(node_name(fld), mod_name)
                        }
                        j = j + 1
                    }
                }
            }
            i = i + 1
        }
    }
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            let fn_node = sublist_get(fns_sl, i)
            let mod_name = node_module(fn_node)
            if mod_name != "" && mod_name != "__main__" {
                let fn_sym_name = node_name(fn_node)
                tc_symbol_module.insert(fn_sym_name, mod_name)
                match tc_original_to_alias.get(fn_sym_name) {
                    Some(alias) => tc_symbol_module.insert(alias, mod_name)
                    None => {}
                }
            }
            i = i + 1
        }
    }
    let lets_sl_sym = node_stmts(program)
    if lets_sl_sym != -1 {
        let mut i = 0
        while i < sublist_length(lets_sl_sym) {
            let l = sublist_get(lets_sl_sym, i)
            let mod_name = node_module(l)
            if mod_name != "" && mod_name != "__main__" {
                tc_symbol_module.insert(node_name(l), mod_name)
            }
            i = i + 1
        }
    }

    // Register traits
    let traits_sl = node_arms(program)
    if traits_sl != -1 {
        let mut i = 0
        while i < sublist_length(traits_sl) {
            register_trait(sublist_get(traits_sl, i))
            i = i + 1
        }
    }
    // Register builtin trait names (handled specially in codegen, no AST nodes)
    tc_trait_names.push("From")
    tc_trait_names.push("TryFrom")
    tc_trait_names.push("Into")
    tc_trait_names.push("Iterator")
    tc_trait_names.push("IntoIterator")

    // Register impl method signatures
    let impls_sl = node_methods(program)
    if impls_sl != -1 {
        let mut i = 0
        while i < sublist_length(impls_sl) {
            let im = sublist_get(impls_sl, i)
            let impl_type = node_name(im)
            let methods_sl = node_methods(im)
            if methods_sl != -1 {
                let mut j = 0
                while j < sublist_length(methods_sl) {
                    let m = sublist_get(methods_sl, j)
                    let orig_name = node_name(m)
                    node_set_name(m, "{impl_type}_{orig_name}")
                    register_fn_sig(m)
                    node_set_name(m, orig_name)
                    j = j + 1
                }
            }
            i = i + 1
        }
    }

    // Validate trait impl contracts
    validate_trait_impls(program)

    // Register user-defined effect handle names
    tc_ue_handles = []
    let effects_decl_sl = node_args(program)
    if effects_decl_sl != -1 {
        let mut ei = 0
        while ei < sublist_length(effects_decl_sl) {
            let ed = sublist_get(effects_decl_sl, ei)
            let eff_name = node_name(ed)
            register_ue_handle(str_to_lower(eff_name))
            ei = ei + 1
        }
    }

    // Build symbol-to-module map (continued): impls, traits, effects
    if impls_sl != -1 {
        let mut i = 0
        while i < sublist_length(impls_sl) {
            let im = sublist_get(impls_sl, i)
            let mod_name = node_module(im)
            if mod_name != "" && mod_name != "__main__" {
                let impl_type = node_name(im)
                tc_symbol_module.insert(impl_type, mod_name)
                let methods_sl_sym = node_methods(im)
                if methods_sl_sym != -1 {
                    let mut j = 0
                    while j < sublist_length(methods_sl_sym) {
                        let m = sublist_get(methods_sl_sym, j)
                        tc_symbol_module.insert("{impl_type}_{node_name(m)}", mod_name)
                        j = j + 1
                    }
                }
            }
            i = i + 1
        }
    }
    if traits_sl != -1 {
        let mut i = 0
        while i < sublist_length(traits_sl) {
            let tr = sublist_get(traits_sl, i)
            let mod_name = node_module(tr)
            if mod_name != "" && mod_name != "__main__" {
                tc_symbol_module.insert(node_name(tr), mod_name)
            }
            i = i + 1
        }
    }
    let effects_sl_sym = node_args(program)
    if effects_sl_sym != -1 {
        let mut i = 0
        while i < sublist_length(effects_sl_sym) {
            let ed = sublist_get(effects_sl_sym, i)
            let mod_name = node_module(ed)
            if mod_name != "" && mod_name != "__main__" {
                tc_symbol_module.insert(node_name(ed), mod_name)
            }
            i = i + 1
        }
    }

    // Remap tc_symbol_module for pub import re-exports
    tc_apply_reexport_remapping()

    // Phase 1: Name resolution
    resolve_names(program)
    nr_warn_unused = 0

    // Phase 2: Expression type inference
    tc_infer_program(program)

    if trace_mode != "" { trace("typecheck", "done ({tc_errors.len()} errors)") }
    tc_errors.len()
}

// ── User-effect handle name tracking ────────────────────────────────

let mut tc_ue_handles: List[Str] = []

fn register_ue_handle(name: Str) {
    tc_ue_handles.push(name)
}

fn is_user_effect_handle_name(name: Str) -> Int {
    let mut i = 0
    while i < tc_ue_handles.len() {
        if tc_ue_handles.get(i).unwrap() == name {
            return 1
        }
        i = i + 1
    }
    0
}

// ── Selective import filtering ──────────────────────────────────────
pub let mut tc_import_modules: List[Str] = []
pub let mut tc_import_qualifiers: List[Str] = []
pub let mut tc_import_nodes: List[Int] = []
let mut tc_module_import_node: Map[Str, Int] = Map()
let mut tc_qualifier_to_module: Map[Str, Str] = Map()
let mut tc_import_modules_idx: Map[Str, Int] = Map()
let mut tc_import_qualifiers_set: Map[Str, Int] = Map()

// ── Pub import re-export tracking ──────────────────────────────────
// Key: "reexporting_mod:item_name" → source module name (selective re-exports)
// Key: "reexporting_mod:*:source_mod" → source module name (wildcard re-exports)
pub let mut tc_reexport_source: Map[Str, Str] = Map()
pub let mut tc_reexport_modules: Map[Str, Int] = Map()

fn tc_apply_reexport_remapping() {
    let keys = tc_reexport_source.keys()
    let mut i = 0
    while i < keys.len() {
        let key = keys.get(i).unwrap()
        let colon_idx = key.index_of(":")
        if colon_idx > 0 {
            let reexporter = key.substring(0, colon_idx)
            let rest = key.substring(colon_idx + 1, key.len() - colon_idx - 1)
            if rest.starts_with("*:") {
                let source_mod = rest.substring(2, rest.len() - 2)
                let sym_keys = tc_symbol_module.keys()
                let mut si = 0
                while si < sym_keys.len() {
                    let sym = sym_keys.get(si).unwrap()
                    if tc_symbol_module.get(sym).unwrap() == source_mod {
                        tc_symbol_module.insert(sym, reexporter)
                    }
                    si = si + 1
                }
            } else {
                let item_name = rest
                match tc_symbol_module.get(item_name) {
                    Some(current_mod) => {
                        let source_mod = tc_reexport_source.get(key).unwrap()
                        if current_mod == source_mod {
                            tc_symbol_module.insert(item_name, reexporter)
                        }
                    }
                    None => {}
                }
            }
        }
        i = i + 1
    }
}

fn tc_build_import_map() {
    tc_module_import_node = Map()
    tc_qualifier_to_module = Map()
    tc_alias_to_original = Map()
    tc_original_to_alias = Map()
    tc_import_modules_idx = Map()
    tc_import_qualifiers_set = Map()
    let mut i = 0
    while i < tc_import_modules.len() {
        let mod_key = tc_import_modules.get(i).unwrap()
        tc_import_modules_idx.insert(mod_key, i)
        let node_id = tc_import_nodes.get(i).unwrap()
        if i < tc_import_qualifiers.len() {
            let qual = tc_import_qualifiers.get(i).unwrap()
            if qual != "" && qual != mod_key {
                tc_qualifier_to_module.insert(qual, mod_key)
            }
            if qual != "" {
                tc_import_qualifiers_set.insert(qual, 1)
            }
        }
        if node_id != -1 {
            tc_module_import_node.insert(mod_key, node_id)
            let names_sl = node_args(node_id)
            if names_sl != -1 {
                let mut j = 0
                while j < sublist_length(names_sl) {
                    let name_node = sublist_get(names_sl, j)
                    let alias = node_str_val(name_node)
                    if alias != "" {
                        let original = node_name(name_node)
                        tc_alias_to_original.insert(alias, original)
                        tc_original_to_alias.insert(original, alias)
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
}

fn is_selected_import(name: Str, imp_node: Int) -> Int {
    let names_sl = node_args(imp_node)
    if names_sl == -1 { return 0 }
    let mut i = 0
    while i < sublist_length(names_sl) {
        let name_node = sublist_get(names_sl, i)
        if node_name(name_node) == name { return 1 }
        let alias = node_str_val(name_node)
        if alias != "" && alias == name { return 1 }
        i = i + 1
    }
    0
}

pub fn is_import_module_name(name: Str) -> Int {
    if tc_import_modules_idx.contains_key(name) { return 1 }
    if tc_import_qualifiers_set.contains_key(name) { return 1 }
    0
}

fn tc_get_dotted_module_path(mod_key: Str) -> Str {
    match tc_module_import_node.get(mod_key) {
        Some(imp_node) => {
            let dotted = node_str_val(imp_node)
            if dotted != "" {
                return dotted
            }
        }
        None => {}
    }
    mod_key
}

fn is_filtered_for_module(name: Str, source_mod: Str, consuming_mod: Str) -> Int {
    if source_mod == consuming_mod { return 0 }
    if source_mod == "" || source_mod == "__main__" { return 0 }
    if consuming_mod == "" { return 0 }
    let key = "{consuming_mod}:{source_mod}"
    match per_module_imports.get(key) {
        Some(imp_node) => {
            if imp_node == -1 { return 1 }
            return is_selected_import(name, imp_node) == 0
        }
        None => {}
    }
    0
}

fn is_builtin_name(name: Str) -> Int {
    if is_primitive_type(name) != 0 { return 1 }
    if is_builtin_fn(name) != 0 { return 1 }
    0
}

fn tc_qualifier_for_module(mod_key: Str) -> Str {
    match tc_import_modules_idx.get(mod_key) {
        Some(idx) => {
            if idx < tc_import_qualifiers.len() {
                let q = tc_import_qualifiers.get(idx).unwrap()
                if q != "" {
                    return q
                }
            }
            return mod_key
        }
        None => {}
    }
    mod_key
}

fn nr_check_selective_access(name: Str, node: Int) -> Int ! Diag.Report {
    if nr_current_module == "" { return 0 }
    if is_builtin_name(name) != 0 { return 0 }
    let source_mod = match tc_symbol_module.get(name) {
        Some(v) => v
        None => return 0
    }
    if is_filtered_for_module(name, source_mod, nr_current_module) != 0 {
        let display_mod = tc_qualifier_for_module(source_mod)
        if node == -1 {
            diag_error_no_loc("ImportNotSelected", "E1006", "'{name}' is not in scope — add it to the import list or use qualified access '{display_mod}.{name}'", "add '{name}' to your selective import")
        } else {
            diag_error_at("ImportNotSelected", "E1006", "'{name}' is not in scope — add it to the import list or use qualified access '{display_mod}.{name}'", node, "add '{name}' to your selective import")
        }
        return 1
    }
    0
}

// ── Import visibility ───────────────────────────────────────────────

let mut nr_private_imports: Map[Str, Str] = Map()
let mut nr_current_module: Str = ""
let mut nr_name_source_module: Map[Str, Str] = Map()

fn nr_check_ambiguity(name: Str, mod_name: Str, local_names: Map[Str, Int]) ! Diag.Report {
    if mod_name == "" || mod_name == "__main__" { return }
    if nr_private_imports.contains_key(name) { return }
    if local_names.contains_key(name) { return }
    match nr_name_source_module.get(name) {
        Some(existing_mod) => {
            if existing_mod != mod_name && existing_mod != "__main__" {
                diag_error_no_loc("AmbiguousImport", "E1005", "name '{name}' is ambiguous — imported from both '{existing_mod}' and '{mod_name}'", "use selective imports to disambiguate, e.g. import {existing_mod}.\{name}")
            }
        }
        None => nr_name_source_module.insert(name, mod_name)
    }
}

fn is_private_access(name: Str) -> Int {
    let mods = match nr_private_imports.get(name) {
        Some(v) => v
        None => return 0
    }
    if mods.contains("|{nr_current_module}|") != 0 { return 0 }
    1
}

fn nr_register_private(name: Str, mod_name: Str) {
    match nr_private_imports.get(name) {
        Some(prev) => nr_private_imports.insert(name, "{prev}{mod_name}|")
        None => nr_private_imports.insert(name, "|{mod_name}|")
    }
}

// ── Name resolution scope ───────────────────────────────────────────

let mut nr_scope_names: List[Str] = []
let mut nr_scope_muts: List[Int] = []
let mut nr_scope_types: List[Int] = []
let mut nr_scope_reads: List[Int] = []
let mut nr_scope_writes: List[Int] = []
let mut nr_scope_nodes: List[Int] = []
// Sticky-read flag: if set, nr_mark_written won't clear the read flag. Used
// for vars captured by a closure — subsequent writes are observable through
// closure calls, so the original read shouldn't be dismissed as "dead".
let mut nr_scope_captured: List[Int] = []
let mut nr_scope_frames: List[Int] = []
let mut nr_scope_depth: Int = 0
let mut nr_loop_depth: Int = 0
let mut nr_in_closure_depth: Int = 0
let mut nr_warn_unused: Int = 0

fn nr_push_scope() {
    nr_scope_frames.push(nr_scope_names.len())
    nr_scope_depth = nr_scope_depth + 1
}

fn nr_pop_scope() ! Diag.Report {
    if nr_scope_frames.len() == 0 {
        return
    }
    let start = nr_scope_frames.get(nr_scope_frames.len() - 1).unwrap()
    nr_scope_frames.pop()
    // Emit unused variable warnings for locals (depth > 1 = inside a function)
    if nr_warn_unused != 0 && nr_scope_depth > 1 {
        let mut i = nr_scope_names.len() - 1
        while i >= start {
            let vname = nr_scope_names.get(i).unwrap()
            if nr_scope_reads.get(i).unwrap() == 0 && vname.len() > 0 && vname.byte_at(0) != 95 { // '_'
                let nd = nr_scope_nodes.get(i).unwrap()
                if nd != -1 {
                    if nr_scope_writes.get(i).unwrap() > 1 {
                        diag_warn_at("SetButNotRead", "W0601", "variable '{vname}' is assigned a value that is never read", nd, "remove the unused assignment, or prefix with '_' to suppress")
                    } else {
                        diag_warn_at("UnusedVariable", "W0600", "variable '{vname}' is never read", nd, "prefix with '_' to suppress this warning")
                    }
                }
            }
            i = i - 1
        }
    }
    while nr_scope_names.len() > start {
        nr_scope_names.pop()
        nr_scope_muts.pop()
        nr_scope_types.pop()
        nr_scope_reads.pop()
        nr_scope_writes.pop()
        nr_scope_nodes.pop()
        nr_scope_captured.pop()
    }
    nr_scope_depth = nr_scope_depth - 1
}

fn nr_define(name: Str) {
    nr_scope_names.push(name)
    nr_scope_muts.push(0)
    nr_scope_types.push(TYPE_UNKNOWN)
    nr_scope_reads.push(0)
    nr_scope_writes.push(1)
    nr_scope_nodes.push(-1)
    nr_scope_captured.push(0)
}

fn nr_check_shadow(name: Str, node: Int) ! Diag.Report {
    if nr_warn_unused == 0 { return }
    if name.len() == 0 { return }
    if name.byte_at(0) == 95 { return } // '_'
    if nr_scope_depth <= 1 { return }
    if nr_scope_frames.len() == 0 { return }
    let frame_start = nr_scope_frames.get(nr_scope_frames.len() - 1).unwrap()
    let mut i = 0
    while i < frame_start {
        if nr_scope_names.get(i).unwrap() == name {
            diag_warn_at("ShadowedVariable", "W0603", "variable '{name}' shadows a variable from an outer scope", node, "rename the variable or prefix with '_' to suppress")
            return
        }
        i = i + 1
    }
}

fn nr_define_at(name: Str, node: Int) ! Diag.Report {
    if node != -1 && nr_current_module != "" {
        node_set_module(node, nr_current_module)
    }
    nr_check_shadow(name, node)
    nr_scope_names.push(name)
    nr_scope_muts.push(0)
    nr_scope_types.push(TYPE_UNKNOWN)
    nr_scope_reads.push(0)
    nr_scope_writes.push(1)
    nr_scope_nodes.push(node)
    nr_scope_captured.push(0)
}

fn nr_define_mut(name: Str, is_mut: Int) {
    nr_scope_names.push(name)
    nr_scope_muts.push(is_mut)
    nr_scope_types.push(TYPE_UNKNOWN)
    nr_scope_reads.push(0)
    nr_scope_writes.push(1)
    nr_scope_nodes.push(-1)
    nr_scope_captured.push(0)
}

fn nr_define_mut_at(name: Str, is_mut: Int, node: Int) ! Diag.Report {
    if node != -1 && nr_current_module != "" {
        node_set_module(node, nr_current_module)
    }
    nr_check_shadow(name, node)
    nr_scope_names.push(name)
    nr_scope_muts.push(is_mut)
    nr_scope_types.push(TYPE_UNKNOWN)
    nr_scope_reads.push(0)
    nr_scope_writes.push(1)
    nr_scope_nodes.push(node)
    nr_scope_captured.push(0)
}

fn nr_define_typed(name: Str, is_mut: Int, tid: Int) {
    nr_scope_names.push(name)
    nr_scope_muts.push(is_mut)
    nr_scope_types.push(tid)
    nr_scope_reads.push(0)
    nr_scope_writes.push(1)
    nr_scope_nodes.push(-1)
    nr_scope_captured.push(0)
}

fn nr_is_defined(name: Str) -> Int {
    let mut i = nr_scope_names.len() - 1
    while i >= 0 {
        if nr_scope_names.get(i).unwrap() == name {
            nr_scope_reads.set(i, 1)
            // If the read happens inside a closure body, the capture may be
            // observed on a later call — don't let subsequent writes in the
            // enclosing scope cancel this read (W0601 false positive).
            if nr_in_closure_depth > 0 {
                // Only mark entries in enclosing scopes (outside the closure
                // frame) as captured. Locals inside the closure are walked
                // the normal way.
                let mut frame_start = 0
                if nr_scope_frames.len() > 0 {
                    frame_start = nr_scope_frames.get(nr_scope_frames.len() - 1).unwrap()
                }
                if i < frame_start {
                    nr_scope_captured.set(i, 1)
                }
            }
            return 1
        }
        i = i - 1
    }
    0
}

fn nr_is_mut(name: Str) -> Int {
    let mut i = nr_scope_names.len() - 1
    while i >= 0 {
        if nr_scope_names.get(i).unwrap() == name {
            return nr_scope_muts.get(i).unwrap()
        }
        i = i - 1
    }
    0
}

fn nr_mark_written(name: Str, _node: Int) ! Diag.Report {
    let mut _fn_frame_start = 0
    if nr_scope_frames.len() > 1 {
        _fn_frame_start = nr_scope_frames.get(1).unwrap()
    }
    let mut i = nr_scope_names.len() - 1
    while i >= 0 {
        if nr_scope_names.get(i).unwrap() == name {
            if nr_loop_depth == 0 && nr_scope_captured.get(i).unwrap() == 0 {
                nr_scope_reads.set(i, 0)
            }
            nr_scope_writes.set(i, nr_scope_writes.get(i).unwrap() + 1)
            return
        }
        i = i - 1
    }
}

fn nr_get_type(name: Str) -> Int {
    let mut i = nr_scope_names.len() - 1
    while i >= 0 {
        if nr_scope_names.get(i).unwrap() == name {
            return nr_scope_types.get(i).unwrap()
        }
        i = i - 1
    }
    TYPE_UNKNOWN
}

fn is_builtin_fn(name: Str) -> Int {
    if name == "arg_count" { return 1 }
    if name == "get_arg" { return 1 }
    if name == "read_file" { return 1 }
    if name == "write_file" { return 1 }
    if name == "file_exists" { return 1 }
    if name == "shell_exec" { return 1 }
    if name == "exit" { return 1 }
    if name == "is_dir" { return 1 }

    if name == "time_ms" { return 1 }
    if name == "Some" { return 1 }
    if name == "None" { return 1 }
    if name == "Ok" { return 1 }
    if name == "Err" { return 1 }
    if name == "assert" { return 1 }
    if name == "assert_eq" { return 1 }
    if name == "assert_ne" { return 1 }
    if name == "debug_assert" { return 1 }
    if name == "Map" { return 1 }
    if name == "Set" { return 1 }
    if name == "Bytes" { return 1 }
    if name == "Channel" { return 1 }
    if name == "StringBuilder" { return 1 }
    if name == "unix_socket_listen" { return 1 }
    if name == "unix_socket_connect" { return 1 }
    if name == "unix_socket_accept" { return 1 }
    if name == "unix_socket_accept_timeout" { return 1 }
    if name == "unix_socket_close" { return 1 }
    if name == "socket_read_line" { return 1 }
    if name == "socket_write" { return 1 }
    if name == "file_mtime" { return 1 }
    if name == "getpid" { return 1 }
    if name == "process_run" { return 1 }
    if name == "process_run_with_stdin" { return 1 }
    if name == "process_exec" { return 1 }
    if name == "alloc_ptr" { return 1 }
    if name == "null_ptr" { return 1 }
    if name == "ffi_scope" { return 1 }
    if name == "Raw" { return 1 }
    0
}

fn is_builtin_method(name: Str) -> Int {
    // String methods
    if name == "len" { return 1 }
    if name == "contains" { return 1 }
    if name == "starts_with" { return 1 }
    if name == "ends_with" { return 1 }
    if name == "concat" { return 1 }
    if name == "slice" { return 1 }
    if name == "to_int" { return 1 }
    if name == "split" { return 1 }
    if name == "char_at" { return 1 }
    if name == "charAt" { return 1 }
    if name == "byte_at" { return 1 }
    if name == "substring" { return 1 }
    if name == "substr" { return 1 }
    if name == "index_of" { return 1 }
    if name == "trim" { return 1 }
    if name == "trim_right" { return 1 }
    if name == "trim_left" { return 1 }
    if name == "to_lower" { return 1 }
    if name == "to_upper" { return 1 }
    if name == "replace" { return 1 }
    if name == "as_cstr" { return 1 }
    if name == "lines" { return 1 }
    if name == "parse_float" { return 1 }
    if name == "parse_int" { return 1 }
    // List methods
    if name == "push" { return 1 }
    if name == "pop" { return 1 }
    if name == "get" { return 1 }
    if name == "set" { return 1 }
    if name == "join" { return 1 }
    if name == "clear" { return 1 }
    // Iterator methods
    if name == "map" { return 1 }
    if name == "filter" { return 1 }
    if name == "collect" { return 1 }
    if name == "count" { return 1 }
    if name == "for_each" { return 1 }
    if name == "any" { return 1 }
    if name == "all" { return 1 }
    if name == "find" { return 1 }
    if name == "fold" { return 1 }
    if name == "take" { return 1 }
    if name == "skip" { return 1 }
    if name == "chain" { return 1 }
    if name == "flat_map" { return 1 }
    if name == "enumerate" { return 1 }
    if name == "zip" { return 1 }
    // Map methods
    if name == "contains_key" { return 1 }
    if name == "remove" { return 1 }
    if name == "clear" { return 1 }
    if name == "keys" { return 1 }
    if name == "values" { return 1 }
    // Set methods
    if name == "insert" { return 1 }
    if name == "union" { return 1 }
    // Ptr methods
    if name == "deref" { return 1 }
    if name == "is_null" { return 1 }
    if name == "addr" { return 1 }
    if name == "offset" { return 1 }
    // FFI scope methods
    if name == "alloc" { return 1 }
    if name == "alloc_n" { return 1 }
    if name == "cstr" { return 1 }
    // Bytes methods
    if name == "is_empty" { return 1 }
    if name == "to_str" { return 1 }
    if name == "to_hex" { return 1 }
    if name == "from_str" { return 1 }
    if name == "from_code_point" { return 1 }
    if name == "read_u16_be" { return 1 }
    if name == "read_u32_be" { return 1 }
    if name == "read_i32_be" { return 1 }
    if name == "read_i64_be" { return 1 }
    if name == "read_u16_le" { return 1 }
    if name == "read_u32_le" { return 1 }
    if name == "read_i32_le" { return 1 }
    if name == "read_i64_le" { return 1 }
    if name == "write_u16_be" { return 1 }
    if name == "write_u32_be" { return 1 }
    if name == "write_i32_be" { return 1 }
    if name == "write_i64_be" { return 1 }
    if name == "write_u16_le" { return 1 }
    if name == "write_u32_le" { return 1 }
    if name == "write_i32_le" { return 1 }
    if name == "write_i64_le" { return 1 }
    // Effect handle methods (io, fs, net, time, async, env)
    if name == "println" { return 1 }
    if name == "print" { return 1 }
    if name == "eprintln" { return 1 }
    if name == "eprint" { return 1 }
    if name == "log" { return 1 }
    if name == "print_raw" { return 1 }
    if name == "eprint_raw" { return 1 }
    if name == "read" { return 1 }
    if name == "write" { return 1 }
    if name == "list_dir" { return 1 }
    if name == "args" { return 1 }
    // Env effect methods
    if name == "var" { return 1 }
    if name == "cwd" { return 1 }
    if name == "set_var" { return 1 }
    if name == "remove_var" { return 1 }
    if name == "sleep" { return 1 }
    if name == "spawn" { return 1 }
    // Net methods
    if name == "request" { return 1 }
    if name == "listen" { return 1 }
    if name == "accept" { return 1 }
    if name == "read_line" { return 1 }
    if name == "read_n" { return 1 }
    if name == "read_bytes" { return 1 }
    if name == "write_bytes" { return 1 }
    if name == "write_line" { return 1 }
    if name == "close" { return 1 }
    if name == "post" { return 1 }
    if name == "put" { return 1 }
    if name == "patch" { return 1 }
    if name == "head" { return 1 }
    if name == "delete" { return 1 }
    // Channel methods
    if name == "send" { return 1 }
    if name == "recv" { return 1 }
    // Conversion methods
    if name == "into" { return 1 }
    if name == "to_float" { return 1 }
    if name == "to_string" { return 1 }
    if name == "from" { return 1 }
    if name == "try_from" { return 1 }
    // Sized int conversion methods
    if name == "to_i8" { return 1 }
    if name == "to_i16" { return 1 }
    if name == "to_i32" { return 1 }
    if name == "to_u8" { return 1 }
    if name == "to_u16" { return 1 }
    if name == "to_u32" { return 1 }
    if name == "to_u64" { return 1 }
    // Sized int wrapping arithmetic
    if name == "wrapping_add" { return 1 }
    if name == "wrapping_sub" { return 1 }
    if name == "wrapping_mul" { return 1 }
    if name == "wrapping_div" { return 1 }
    if name == "wrapping_rem" { return 1 }
    if name == "wrapping_neg" { return 1 }
    // Int methods
    if name == "abs" { return 1 }
    if name == "min" { return 1 }
    if name == "max" { return 1 }
    // Option methods
    if name == "unwrap" { return 1 }
    if name == "is_some" { return 1 }
    if name == "is_none" { return 1 }
    // Result methods
    if name == "unwrap_err" { return 1 }
    if name == "is_ok" { return 1 }
    if name == "is_err" { return 1 }
    // Instant methods
    if name == "elapsed" { return 1 }
    if name == "since" { return 1 }
    if name == "add" { return 1 }
    if name == "to_rfc3339" { return 1 }
    if name == "to_unix_ms" { return 1 }
    if name == "to_unix_secs" { return 1 }
    // Duration static constructors
    if name == "nanos" { return 1 }
    if name == "ms" { return 1 }
    if name == "seconds" { return 1 }
    if name == "minutes" { return 1 }
    if name == "hours" { return 1 }
    // Duration methods
    if name == "to_ms" { return 1 }
    if name == "to_seconds" { return 1 }
    if name == "to_nanos" { return 1 }
    if name == "sub" { return 1 }
    if name == "scale" { return 1 }
    if name == "is_zero" { return 1 }
    // StringBuilder methods
    if name == "clear" { return 1 }
    // Bytes/Instant static constructors
    if name == "new" { return 1 }
    if name == "from_epoch_secs" { return 1 }
    // Template methods
    if name == "parts" { return 1 }
    if name == "count" { return 1 }
    if name == "type_tag" { return 1 }
    if name == "get_str" { return 1 }
    if name == "get_int" { return 1 }
    if name == "get_float" { return 1 }
    if name == "get_bool" { return 1 }
    0
}

fn get_builtin_fn_ret(name: Str) -> Int {
    if name == "arg_count" { return TYPE_INT }
    if name == "get_arg" { return TYPE_STR }
    if name == "read_file" { return TYPE_STR }
    if name == "write_file" { return TYPE_VOID }
    if name == "file_exists" { return TYPE_INT }
    if name == "shell_exec" { return TYPE_INT }
    if name == "exit" { return TYPE_VOID }
    if name == "is_dir" { return TYPE_INT }

    if name == "time_ms" { return TYPE_INT }
    if name == "assert" { return TYPE_VOID }
    if name == "assert_eq" { return TYPE_VOID }
    if name == "assert_ne" { return TYPE_VOID }
    if name == "debug_assert" { return TYPE_VOID }
    if name == "unix_socket_listen" { return TYPE_INT }
    if name == "unix_socket_connect" { return TYPE_INT }
    if name == "unix_socket_accept" { return TYPE_INT }
    if name == "unix_socket_accept_timeout" { return TYPE_INT }
    if name == "unix_socket_close" { return TYPE_VOID }
    if name == "socket_read_line" { return TYPE_STR }
    if name == "socket_write" { return TYPE_VOID }
    if name == "file_mtime" { return TYPE_INT }
    if name == "getpid" { return TYPE_INT }
    if name == "process_run" { return TYPE_VOID }
    if name == "process_run_with_stdin" { return TYPE_VOID }
    if name == "process_exec" { return TYPE_VOID }
    if name == "Bytes" { return new_type(TK_BYTES, "Bytes") }
    if name == "Map" { return make_map_type(TYPE_UNKNOWN, TYPE_UNKNOWN) }
    if name == "Set" { return make_set_type(TYPE_UNKNOWN) }
    TYPE_UNKNOWN
}

fn is_builtin_variant_name(name: Str) -> Int {
    if name == "None" { return 1 }
    if name == "Some" { return 1 }
    if name == "Ok" { return 1 }
    if name == "Err" { return 1 }
    0
}

fn is_variant_name(name: Str) -> Int {
    if is_builtin_variant_name(name) != 0 { return 1 }
    let mut i = 0
    while i < evar_pool.len() {
        if evar_pool.get(i).unwrap().name == name {
            return 1
        }
        i = i + 1
    }
    0
}

fn get_variant_enum_tid(name: Str) -> Int {
    let mut i = 0
    while i < evar_pool.len() {
        let ev = evar_pool.get(i).unwrap()
        if ev.name == name {
            return ev.enum_id
        }
        i = i + 1
    }
    TYPE_UNKNOWN
}

fn is_trait_name(name: Str) -> Int {
    let mut i = 0
    while i < tc_trait_names.len() {
        if tc_trait_names.get(i).unwrap() == name {
            return 1
        }
        i = i + 1
    }
    0
}

fn is_primitive_type(name: Str) -> Int {
    if name == "Int" || name == "Float" || name == "Bool" || name == "Str" { return 1 }
    if name == "Void" || name == "List" || name == "Option" || name == "Result" { return 1 }
    if name == "Iterator" || name == "Handle" || name == "Channel" || name == "Map" || name == "Set" { return 1 }
    if name == "Bytes" || name == "Instant" || name == "Duration" || name == "Char" || name == "StringBuilder" { return 1 }
    if name == "Ptr" || name == "U8" || name == "U16" || name == "U32" || name == "U64" { return 1 }
    if name == "I8" || name == "I16" || name == "I32" || name == "I64" { return 1 }
    if name == "Fn" || name == "Self" || name == "Tuple" || name == "Handler" || name == "Template" { return 1 }
    0
}

fn is_known_type(name: Str) -> Int {
    if is_primitive_type(name) != 0 { return 1 }
    if lookup_named_type(name) != -1 { return 1 }
    0
}

// Impl method registry for name resolution
let mut nr_impl_type_names: List[Str] = []
let mut nr_impl_method_names: List[Str] = []
let mut nr_callable_field_names: List[Str] = []

fn is_callable_field_name(name: Str) -> Int {
    let mut i = 0
    while i < nr_callable_field_names.len() {
        if nr_callable_field_names.get(i).unwrap() == name { return 1 }
        i = i + 1
    }
    0
}

fn nr_has_impl_method(type_name: Str, method: Str) -> Int {
    let mut i = 0
    while i < nr_impl_type_names.len() {
        if nr_impl_type_names.get(i).unwrap() == type_name && nr_impl_method_names.get(i).unwrap() == method {
            return 1
        }
        i = i + 1
    }
    0
}

// ── Name resolution walker ──────────────────────────────────────────

fn resolve_names(program: Int) ! TypeCheck.Resolve, Diag.Report {
    nr_scope_names = []
    nr_scope_muts = []
    nr_scope_types = []
    nr_scope_reads = []
    nr_scope_writes = []
    nr_scope_nodes = []
    nr_scope_captured = []
    nr_scope_frames = []
    nr_scope_depth = 0
    nr_loop_depth = 0
    nr_in_closure_depth = 0
    nr_warn_unused = 1
    nr_impl_type_names = []
    nr_impl_method_names = []
    nr_private_imports = Map()
    nr_name_source_module = Map()
    nr_push_scope()

    // Build private import set: imported non-pub fns, types, lets
    // A name is private only if no pub definition exists for it
    let mut nr_pub_names: Map[Str, Int] = Map()

    // First pass: collect all pub imported names
    // Items that are pub but excluded by selective imports are treated as private
    let fns_sl_priv = node_params(program)
    if fns_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl_priv) {
            let fn_node = sublist_get(fns_sl_priv, i)
            let fn_mod = node_module(fn_node)
            if fn_mod != "" && node_is_pub(fn_node) != 0 {
                nr_pub_names.insert(node_name(fn_node), 1)
            }
            i = i + 1
        }
    }
    let types_sl_priv = node_fields(program)
    if types_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(types_sl_priv) {
            let td = sublist_get(types_sl_priv, i)
            let td_mod = node_module(td)
            if td_mod != "" && node_is_pub(td) != 0 {
                nr_pub_names.insert(node_name(td), 1)
                let td_flds = node_fields(td)
                if td_flds != -1 && sublist_length(td_flds) > 0 {
                    if node_kind(sublist_get(td_flds, 0)) == NodeKind.TypeVariant {
                        let mut vi = 0
                        while vi < sublist_length(td_flds) {
                            nr_pub_names.insert(node_name(sublist_get(td_flds, vi)), 1)
                            vi = vi + 1
                        }
                    }
                }
            }
            i = i + 1
        }
    }
    let traits_sl_priv = node_arms(program)
    if traits_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(traits_sl_priv) {
            let tr = sublist_get(traits_sl_priv, i)
            let tr_mod = node_module(tr)
            if tr_mod != "" && node_is_pub(tr) != 0 {
                nr_pub_names.insert(node_name(tr), 1)
            }
            i = i + 1
        }
    }
    let lets_sl_priv = node_stmts(program)
    if lets_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(lets_sl_priv) {
            let l = sublist_get(lets_sl_priv, i)
            let l_mod = node_module(l)
            if l_mod != "" && node_is_pub(l) != 0 {
                nr_pub_names.insert(node_name(l), 1)
            }
            i = i + 1
        }
    }

    // Second pass: register private names (skip if a pub version exists)
    // Value format: "|mod1|mod2|" so contains("|modX|") works for same-module check
    if fns_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl_priv) {
            let fn_node = sublist_get(fns_sl_priv, i)
            let fn_name = node_name(fn_node)
            let mod_name = node_module(fn_node)
            if mod_name != "" && node_is_pub(fn_node) == 0 && nr_pub_names.contains_key(fn_name) == 0 {
                nr_register_private(fn_name, mod_name)
            }
            i = i + 1
        }
    }
    if types_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(types_sl_priv) {
            let td = sublist_get(types_sl_priv, i)
            let td_name = node_name(td)
            let mod_name = node_module(td)
            if mod_name != "" && node_is_pub(td) == 0 && nr_pub_names.contains_key(td_name) == 0 {
                nr_register_private(td_name, mod_name)
                let td_flds = node_fields(td)
                if td_flds != -1 && sublist_length(td_flds) > 0 {
                    if node_kind(sublist_get(td_flds, 0)) == NodeKind.TypeVariant {
                        let mut vi = 0
                        while vi < sublist_length(td_flds) {
                            let vname = node_name(sublist_get(td_flds, vi))
                            if nr_pub_names.contains_key(vname) == 0 {
                                nr_register_private(vname, mod_name)
                            }
                            vi = vi + 1
                        }
                    }
                }
            }
            i = i + 1
        }
    }
    if traits_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(traits_sl_priv) {
            let tr = sublist_get(traits_sl_priv, i)
            let tr_name = node_name(tr)
            let mod_name = node_module(tr)
            if mod_name != "" && node_is_pub(tr) == 0 && nr_pub_names.contains_key(tr_name) == 0 {
                nr_register_private(tr_name, mod_name)
            }
            i = i + 1
        }
    }
    if lets_sl_priv != -1 {
        let mut i = 0
        while i < sublist_length(lets_sl_priv) {
            let l = sublist_get(lets_sl_priv, i)
            let l_name = node_name(l)
            let mod_name = node_module(l)
            if mod_name != "" && node_is_pub(l) == 0 && nr_pub_names.contains_key(l_name) == 0 {
                nr_register_private(l_name, mod_name)
            }
            i = i + 1
        }
    }

    // Pre-collect __main__ names to suppress ambiguity when local defs shadow
    let mut main_names: Map[Str, Int] = Map()
    let pre_fns = node_params(program)
    if pre_fns != -1 {
        let mut i = 0
        while i < sublist_length(pre_fns) {
            let fn_node = sublist_get(pre_fns, i)
            if node_module(fn_node) == "__main__" {
                main_names.insert(node_name(fn_node), 1)
            }
            i = i + 1
        }
    }
    let pre_lets = node_stmts(program)
    if pre_lets != -1 {
        let mut i = 0
        while i < sublist_length(pre_lets) {
            let l = sublist_get(pre_lets, i)
            if node_module(l) == "__main__" {
                main_names.insert(node_name(l), 1)
            }
            i = i + 1
        }
    }

    // Register all top-level let binding names
    let lets_sl = node_stmts(program)
    if lets_sl != -1 {
        let mut i = 0
        while i < sublist_length(lets_sl) {
            let l = sublist_get(lets_sl, i)
            let l_name = node_name(l)
            let l_mod = node_module(l)
            if l_mod != "__main__" {
                match tc_original_to_alias.get(l_name) {
                    Some(alias) => {
                        nr_check_ambiguity(alias, l_mod, main_names)
                        nr_define(alias)
                        nr_register_private(l_name, l_mod)
                    }
                    None => {
                        nr_check_ambiguity(l_name, l_mod, main_names)
                        nr_define(l_name)
                    }
                }
            } else {
                nr_check_ambiguity(l_name, l_mod, main_names)
                nr_define(l_name)
            }
            i = i + 1
        }
    }

    // Register all function names in scope
    let fns_sl = node_params(program)
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            let fn_node = sublist_get(fns_sl, i)
            let fn_name = node_name(fn_node)
            let fn_mod = node_module(fn_node)
            if fn_mod != "__main__" {
                match tc_original_to_alias.get(fn_name) {
                    Some(alias) => {
                        nr_check_ambiguity(alias, fn_mod, main_names)
                        nr_define(alias)
                        nr_register_private(fn_name, fn_mod)
                    }
                    None => {
                        nr_check_ambiguity(fn_name, fn_mod, main_names)
                        nr_define(fn_name)
                    }
                }
            } else {
                nr_check_ambiguity(fn_name, fn_mod, main_names)
                nr_define(fn_name)
            }
            i = i + 1
        }
    }

    // Register impl methods for method call resolution
    let impls_sl = node_methods(program)
    if impls_sl != -1 {
        let mut i = 0
        while i < sublist_length(impls_sl) {
            let im = sublist_get(impls_sl, i)
            let impl_type = node_name(im)
            let methods_sl = node_methods(im)
            if methods_sl != -1 {
                let mut j = 0
                while j < sublist_length(methods_sl) {
                    let m = sublist_get(methods_sl, j)
                    nr_impl_type_names.push(impl_type)
                    nr_impl_method_names.push(node_name(m))
                    j = j + 1
                }
            }
            i = i + 1
        }
    }

    // Walk each function body
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            let fn_node = sublist_get(fns_sl, i)
            nr_current_module = node_module(fn_node)
            nr_check_fn(fn_node)
            i = i + 1
        }
    }

    // Walk each impl method body
    if impls_sl != -1 {
        let mut i = 0
        while i < sublist_length(impls_sl) {
            let im = sublist_get(impls_sl, i)
            nr_current_module = node_module(im)
            let methods_sl = node_methods(im)
            if methods_sl != -1 {
                let mut j = 0
                while j < sublist_length(methods_sl) {
                    nr_check_fn(sublist_get(methods_sl, j))
                    j = j + 1
                }
            }
            i = i + 1
        }
    }

    // Walk test block bodies for unused import detection
    let tests_sl = node_captures(program)
    if tests_sl != -1 {
        nr_current_module = "__main__"
        let mut i = 0
        while i < sublist_length(tests_sl) {
            let tb = sublist_get(tests_sl, i)
            let tbody = node_body(tb)
            if tbody != -1 {
                nr_check_node(tbody)
            }
            i = i + 1
        }
    }

    nr_pop_scope()
}

fn nr_check_fn(fn_node: Int) ! TypeCheck.Resolve, Diag.Report {
    nr_push_scope()
    let nr_is_ffi = has_annotation(fn_node, "ffi")
    let params_sl = node_params(fn_node)
    if params_sl != -1 && nr_is_ffi == 0 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            nr_define_at(node_name(p), p)
            let ptype_ann = node_type_ann(p)
            if ptype_ann != -1 {
                nr_check_type_ann_visibility(ptype_ann)
            } else {
                nr_check_type_ref(node_type_name(p))
            }
            i = i + 1
        }
    }
    let ret_ann = node_type_ann(fn_node)
    if ret_ann != -1 {
        nr_check_type_ann_visibility(ret_ann)
    } else {
        let ret_str = node_return_type(fn_node)
        if ret_str != "" {
            nr_check_type_ref(ret_str)
        }
    }
    if nr_is_ffi == 0 {
        let body = node_body(fn_node)
        if body != -1 {
            nr_check_node(body)
        }
    }
    nr_pop_scope()
}

fn nr_check_type_ann_visibility(ann_node: Int) ! TypeCheck.Resolve, Diag.Report {
    if ann_node == -1 { return }
    let name = node_name(ann_node)
    nr_check_type_ref(name)
    if name == "Handler" || name == "Template" {
        let elems_sl = node_elements(ann_node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                let child = sublist_get(elems_sl, i)
                let child_name = node_name(child)
                tc_mark_symbol_used(child_name)
                i = i + 1
            }
        }
        return
    }
    let elems_sl = node_elements(ann_node)
    if elems_sl != -1 {
        let mut i = 0
        while i < sublist_length(elems_sl) {
            nr_check_type_ann_visibility(sublist_get(elems_sl, i))
            i = i + 1
        }
    }
}

fn nr_check_type_ref(name: Str) ! TypeCheck.Resolve, Diag.Report {
    if name == "" { return }
    if name.len() == 1 { return }
    if is_known_type(name) != 0 {
        if nr_check_selective_access(name, -1) != 0 { return }
        if is_private_access(name) != 0 {
            tc_errors.push("cannot access private type '{name}'")
            diag_error_no_loc("PrivateItemAccess", "E1003", "cannot access private type '{name}' from another module", "mark the type as 'pub' in its module")
            return
        }
        tc_mark_symbol_used(name)
        return
    }
    if is_trait_name(name) != 0 {
        if nr_check_selective_access(name, -1) != 0 { return }
        if is_private_access(name) != 0 {
            tc_errors.push("cannot access private trait '{name}'")
            diag_error_no_loc("PrivateItemAccess", "E1003", "cannot access private trait '{name}' from another module", "mark the trait as 'pub' in its module")
            return
        }
        tc_mark_symbol_used(name)
        return
    }
    tc_errors.push("unknown type '{name}'")
    diag_error_no_loc("UnknownType", "E0507", "unknown type '{name}'", "")
}

fn nr_check_node(node: Int) ! TypeCheck.Resolve, Diag.Report {
    if node == -1 { return }
    let kind = node_kind(node)

    if kind == NodeKind.Block {
        nr_push_scope()
        let stmts_sl = node_stmts(node)
        if stmts_sl != -1 {
            let mut i = 0
            while i < sublist_length(stmts_sl) {
                nr_check_node(sublist_get(stmts_sl, i))
                i = i + 1
            }
        }
        nr_pop_scope()
        return
    }

    if kind == NodeKind.LetBinding {
        let val = node_value(node)
        if val != -1 {
            nr_check_node(val)
        }
        let let_type_ann = node_target(node)
        if let_type_ann != -1 {
            nr_check_type_ann_visibility(let_type_ann)
        }
        let let_is_mut = node_is_mut(node)
        nr_define_mut_at(node_name(node), let_is_mut, node)
        let let_pat_sl = node_elements(node)
        if let_pat_sl != -1 {
            let let_elems_sl = node_elements(let_pat_sl)
            if let_elems_sl != -1 {
                let mut pi = 0
                while pi < sublist_length(let_elems_sl) {
                    let sp = sublist_get(let_elems_sl, pi)
                    nr_define_mut_at(node_name(sp), let_is_mut, sp)
                    pi = pi + 1
                }
            }
        }
        return
    }

    if kind == NodeKind.Assignment || kind == NodeKind.CompoundAssign {
        let assign_target = node_target(node)
        nr_check_node(node_value(node))
        if assign_target != -1 && node_kind(assign_target) == NodeKind.Ident {
            let assign_name = node_name(assign_target)
            if kind == NodeKind.CompoundAssign {
                nr_check_node(assign_target)
            } else {
                tc_mark_symbol_used(assign_name)
            }
            nr_mark_written(assign_name, node)
        } else {
            nr_check_node(assign_target)
        }
        return
    }

    if kind == NodeKind.ExprStmt {
        nr_check_node(node_value(node))
        return
    }

    if kind == NodeKind.Return {
        nr_check_node(node_value(node))
        return
    }

    if kind == NodeKind.Ident {
        let name = node_name(node)
        if name == "true" || name == "false" || name == "None" { return }
        if nr_is_defined(name) != 0 {
            if nr_check_selective_access(name, node) != 0 { return }
            if is_private_access(name) != 0 {
                tc_errors.push("cannot access private item '{name}'")
                diag_error_at("PrivateItemAccess", "E1003", "cannot access private item '{name}' from another module", node, "mark the item as 'pub' in its module")
                return
            }
            tc_mark_symbol_used(name)
            return
        }
        if name == "io" || name == "fs" || name == "net" || name == "env" || name == "time" || name == "async" || name == "channel" || name == "default" || name == "term" { return }
        if is_user_effect_handle_name(name) != 0 { return }
        if is_variant_name(name) != 0 {
            if nr_check_selective_access(name, node) != 0 { return }
            if is_private_access(name) != 0 {
                tc_errors.push("cannot access private variant '{name}'")
                diag_error_at("PrivateItemAccess", "E1003", "cannot access private variant '{name}' from another module", node, "mark the enum as 'pub' in its module")
                return
            }
            tc_mark_symbol_used(name)
            return
        }
        if is_builtin_fn(name) != 0 { return }
        if is_known_type(name) != 0 {
            if nr_check_selective_access(name, node) != 0 { return }
            if is_private_access(name) != 0 {
                tc_errors.push("cannot access private type '{name}'")
                diag_error_at("PrivateItemAccess", "E1003", "cannot access private type '{name}' from another module", node, "mark the type as 'pub' in its module")
                return
            }
            tc_mark_symbol_used(name)
            return
        }
        if is_trait_name(name) != 0 {
            if nr_check_selective_access(name, node) != 0 { return }
            if is_private_access(name) != 0 {
                tc_errors.push("cannot access private trait '{name}'")
                diag_error_at("PrivateItemAccess", "E1003", "cannot access private trait '{name}' from another module", node, "mark the trait as 'pub' in its module")
                return
            }
            tc_mark_symbol_used(name)
            return
        }
        if is_import_module_name(name) != 0 { return }
        tc_errors.push("undefined variable '{name}'")
        diag_error_at("UndefinedVariable", "E0506", "undefined variable '{name}'", node, "")
        return
    }

    if kind == NodeKind.IntLit || kind == NodeKind.FloatLit || kind == NodeKind.BoolLit {
        return
    }

    if kind == NodeKind.InterpString {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                let part = sublist_get(elems_sl, i)
                let pk = node_kind(part)
                if pk == NodeKind.Ident && node_str_val(part) == node_name(part) {
                    // Simple interpolation like {var} — mark as read but skip full check
                    let iname = node_name(part)
                    if nr_is_defined(iname) != 0 {
                        let _skip = 0
                    }
                } else {
                    nr_check_node(part)
                }
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.Call {
        let callee = node_left(node)
        if callee != -1 {
            let callee_kind = node_kind(callee)
            if callee_kind == NodeKind.Ident {
                let fn_name = node_name(callee)
                if nr_check_selective_access(fn_name, node) == 0 {
                    if nr_is_defined(fn_name) != 0 && is_private_access(fn_name) != 0 {
                        tc_errors.push("cannot access private function '{fn_name}'")
                        diag_error_at("PrivateItemAccess", "E1003", "cannot access private function '{fn_name}' from another module", node, "mark the function as 'pub' in its module")
                    } else if is_variant_name(fn_name) != 0 && is_private_access(fn_name) != 0 {
                        tc_errors.push("cannot access private variant '{fn_name}'")
                        diag_error_at("PrivateItemAccess", "E1003", "cannot access private variant '{fn_name}' from another module", node, "mark the enum as 'pub' in its module")
                    } else if nr_is_defined(fn_name) == 0 && is_builtin_fn(fn_name) == 0 && is_variant_name(fn_name) == 0 && is_known_type(fn_name) == 0 && is_trait_name(fn_name) == 0 {
                        tc_errors.push("undefined function '{fn_name}'")
                        diag_error_at("UndefinedFunction", "E0504", "undefined function '{fn_name}'", node, "")
                    } else {
                        tc_mark_symbol_used(fn_name)
                    }
                }
            } else {
                nr_check_node(callee)
            }
        }
        let args_sl = node_args(node)
        if args_sl != -1 {
            let mut i = 0
            while i < sublist_length(args_sl) {
                nr_check_node(sublist_get(args_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.MethodCall {
        let obj = node_obj(node)
        let mut is_module_qual = 0
        if obj != -1 && node_kind(obj) == NodeKind.Ident {
            let obj_name = node_name(obj)
            if is_import_module_name(obj_name) != 0 && nr_is_defined(obj_name) == 0 {
                is_module_qual = 1
                let mq_method = node_method(node)
                tc_mark_symbol_used(mq_method)
                tc_mark_qualifier_used(obj_name)
            }
        }
        if is_module_qual == 0 && obj != -1 {
            if node_kind(obj) == NodeKind.FieldAccess {
                let inner_obj = node_obj(obj)
                if inner_obj != -1 && node_kind(inner_obj) == NodeKind.Ident {
                    let inner_name = node_name(inner_obj)
                    if is_import_module_name(inner_name) != 0 && nr_is_defined(inner_name) == 0 {
                        let mid_field = node_name(obj)
                        if is_known_type(mid_field) != 0 {
                            let outer_field = node_method(node)
                            tc_mark_symbol_used(mid_field)
                            tc_mark_symbol_used(outer_field)
                            let dotted_mod = tc_get_dotted_module_path(inner_name)
                            diag_error_at("ModuleQualifiedType", "E1007", "cannot access type member '{mid_field}.{outer_field}' via module qualifier — add '{mid_field}' to your import: 'import {dotted_mod}.\{{mid_field}\}' then use '{mid_field}.{outer_field}'", node, "enum variants and type members use type qualifiers, not module qualifiers")
                            return
                        }
                    }
                }
            }
            nr_check_node(obj)
        }
        let method_name = node_method(node)
        if is_module_qual == 0 && is_builtin_method(method_name) == 0 && is_variant_name(method_name) == 0 {
            let mut found_in_impl = 0
            let mut mi = 0
            while mi < nr_impl_method_names.len() {
                if nr_impl_method_names.get(mi).unwrap() == method_name {
                    found_in_impl = 1
                }
                mi = mi + 1
            }
            if found_in_impl == 0 && is_callable_field_name(method_name) == 0 {
                let mut is_ue_call = 0
                if obj != -1 && node_kind(obj) == NodeKind.Ident {
                    if is_user_effect_handle_name(node_name(obj)) != 0 {
                        is_ue_call = 1
                    }
                }
                if is_ue_call == 0 {
                    diag_warn_at("UnknownMethod", "W0501", "unknown method '{method_name}' — may fail at compile time", node, "")
                }
            }
        }
        let args_sl = node_args(node)
        if args_sl != -1 {
            let mut i = 0
            while i < sublist_length(args_sl) {
                nr_check_node(sublist_get(args_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.FieldAccess {
        let obj = node_obj(node)
        if obj != -1 {
            let mut is_mod_fa = 0
            let obj_kind = node_kind(obj)
            if obj_kind == NodeKind.Ident {
                let fa_obj_name = node_name(obj)
                if is_import_module_name(fa_obj_name) != 0 && nr_is_defined(fa_obj_name) == 0 {
                    is_mod_fa = 1
                    let fa_field = node_name(node)
                    tc_mark_symbol_used(fa_field)
                    tc_mark_qualifier_used(fa_obj_name)
                }
            }
            if is_mod_fa == 0 && obj_kind == NodeKind.FieldAccess {
                let inner_obj = node_obj(obj)
                if inner_obj != -1 && node_kind(inner_obj) == NodeKind.Ident {
                    let inner_name = node_name(inner_obj)
                    if is_import_module_name(inner_name) != 0 && nr_is_defined(inner_name) == 0 {
                        let mid_field = node_name(obj)
                        if is_known_type(mid_field) != 0 {
                            let outer_field = node_name(node)
                            tc_mark_symbol_used(mid_field)
                            tc_mark_symbol_used(outer_field)
                            let dotted_mod = tc_get_dotted_module_path(inner_name)
                            diag_error_at("ModuleQualifiedType", "E1007", "cannot access type member '{mid_field}.{outer_field}' via module qualifier — add '{mid_field}' to your import: 'import {dotted_mod}.\{{mid_field}\}' then use '{mid_field}.{outer_field}'", node, "enum variants and type members use type qualifiers, not module qualifiers")
                            return
                        }
                    }
                }
            }
            if is_mod_fa == 0 {
                nr_check_node(obj)
            }
        }
        return
    }

    if kind == NodeKind.IndexExpr {
        nr_check_node(node_obj(node))
        nr_check_node(node_index(node))
        return
    }

    if kind == NodeKind.BinOp {
        nr_check_node(node_left(node))
        nr_check_node(node_right(node))
        return
    }

    if kind == NodeKind.UnaryOp {
        nr_check_node(node_left(node))
        return
    }

    if kind == NodeKind.IfExpr {
        nr_check_node(node_condition(node))
        nr_check_node(node_then_body(node))
        nr_check_node(node_else_body(node))
        return
    }

    if kind == NodeKind.WhileLoop {
        nr_check_node(node_condition(node))
        nr_loop_depth = nr_loop_depth + 1
        nr_check_node(node_body(node))
        nr_loop_depth = nr_loop_depth - 1
        nr_check_node(node_condition(node))
        return
    }

    if kind == NodeKind.LoopExpr {
        nr_loop_depth = nr_loop_depth + 1
        nr_check_node(node_body(node))
        nr_loop_depth = nr_loop_depth - 1
        return
    }

    if kind == NodeKind.ForIn {
        nr_check_node(node_iterable(node))
        nr_push_scope()
        nr_define_at(node_var_name(node), node)
        let for_pat_sl = node_elements(node)
        if for_pat_sl != -1 {
            nr_check_pattern(for_pat_sl)
        }
        nr_loop_depth = nr_loop_depth + 1
        nr_check_node(node_body(node))
        nr_loop_depth = nr_loop_depth - 1
        nr_pop_scope()
        return
    }

    if kind == NodeKind.Break || kind == NodeKind.Continue {
        return
    }

    if kind == NodeKind.MatchExpr {
        nr_check_node(node_scrutinee(node))
        let arms_sl = node_arms(node)
        if arms_sl != -1 {
            let mut i = 0
            while i < sublist_length(arms_sl) {
                let arm = sublist_get(arms_sl, i)
                nr_push_scope()
                nr_check_pattern(node_pattern(arm))
                let guard = node_guard(arm)
                if guard != -1 {
                    nr_check_node(guard)
                }
                nr_check_node(node_body(arm))
                nr_pop_scope()
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.Closure {
        nr_push_scope()
        let params_sl = node_params(node)
        if params_sl != -1 {
            let mut i = 0
            while i < sublist_length(params_sl) {
                let cp = sublist_get(params_sl, i)
                nr_define_at(node_name(cp), cp)
                i = i + 1
            }
        }
        nr_in_closure_depth = nr_in_closure_depth + 1
        nr_check_node(node_body(node))
        nr_in_closure_depth = nr_in_closure_depth - 1
        nr_pop_scope()
        return
    }

    if kind == NodeKind.StructLit {
        let type_name = node_type_name(node)
        if type_name != "" {
            let dot_pos = type_name.index_of(".")
            if dot_pos >= 0 {
                let prefix = type_name.substr(0, dot_pos)
                if is_import_module_name(prefix) != 0 && nr_is_defined(prefix) == 0 {
                    // module.Type qualified construction: mark module used; nr_check_type_ref not needed
                    // (lookup_named_type in type inference strips the qualifier and resolves the bare name)
                    tc_mark_qualifier_used(prefix)
                } else {
                    // Enum.Variant struct-style construction: check the enum type only
                    nr_check_type_ref(prefix)
                }
            } else {
                nr_check_type_ref(type_name)
            }
        }
        let flds_sl = node_fields(node)
        if flds_sl != -1 {
            let mut i = 0
            while i < sublist_length(flds_sl) {
                let f = sublist_get(flds_sl, i)
                nr_check_node(node_value(f))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.ListLit {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                nr_check_node(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.TupleLit {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                nr_check_node(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.RangeLit {
        nr_check_node(node_start(node))
        nr_check_node(node_end(node))
        return
    }

    if kind == NodeKind.WithBlock {
        let wh_sl = node_handlers(node)
        nr_push_scope()
        if wh_sl != -1 {
            let mut wi = 0
            while wi < sublist_length(wh_sl) {
                let wh_item = sublist_get(wh_sl, wi)
                let wh_kind = node_kind(wh_item)
                if wh_kind == NodeKind.WithResource {
                    nr_define_at(node_name(wh_item), wh_item)
                    nr_check_node(node_value(wh_item))
                } else if wh_kind == NodeKind.Ident && node_name(wh_item) == "arena" {
                    // `arena` is a keyword in `with arena { }` — skip the
                    // bare ident so we don't emit E0506. Matches the skip
                    // guard in tc_check_body's WithBlock branch.
                } else {
                    nr_check_node(wh_item)
                }
                wi = wi + 1
            }
        }
        nr_check_node(node_body(node))
        nr_pop_scope()
        return
    }

    if kind == NodeKind.WithResource {
        nr_check_node(node_value(node))
        return
    }

    if kind == NodeKind.HandlerExpr {
        let methods_sl = node_methods(node)
        if methods_sl != -1 {
            let mut i = 0
            while i < sublist_length(methods_sl) {
                nr_check_fn(sublist_get(methods_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.AsyncScope {
        nr_check_node(node_body(node))
        return
    }

    if kind == NodeKind.AsyncSpawn {
        nr_check_node(node_body(node))
        return
    }

    if kind == NodeKind.AwaitExpr {
        nr_check_node(node_value(node))
        return
    }

    if kind == NodeKind.ChannelNew {
        return
    }

    if kind == NodeKind.SpreadExpr {
        nr_check_node(node_value(node))
        return
    }

    if kind == NodeKind.EmbedExpr {
        return
    }

    let _skip = 0
}

fn nr_check_pattern(node: Int) ! TypeCheck.Resolve, Diag.Report {
    if node == -1 { return }
    let kind = node_kind(node)

    if kind == NodeKind.IdentPattern {
        let name = node_name(node)
        if name != "_" && is_variant_name(name) == 0 {
            nr_define_at(name, node)
        }
        return
    }

    if kind == NodeKind.IntPattern || kind == NodeKind.StringPattern || kind == NodeKind.WildcardPattern {
        return
    }

    if kind == NodeKind.EnumPattern {
        let flds_sl = node_fields(node)
        if flds_sl != -1 {
            let is_struct_pat = node_int_val(node)
            let mut i = 0
            while i < sublist_length(flds_sl) {
                let f = sublist_get(flds_sl, i)
                if is_struct_pat != 0 {
                    // Struct-style fields are StructLitField nodes; bind by name
                    let fpat = node_pattern(f)
                    if fpat != -1 {
                        nr_check_pattern(fpat)
                    } else {
                        nr_define_at(node_name(f), f)
                    }
                } else {
                    nr_check_pattern(f)
                }
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.StructPattern {
        let flds_sl = node_fields(node)
        if flds_sl != -1 {
            let mut i = 0
            while i < sublist_length(flds_sl) {
                let f = sublist_get(flds_sl, i)
                nr_define_at(node_name(f), f)
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.TuplePattern {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                nr_check_pattern(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.ListPattern {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                nr_check_pattern(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }

    if kind == NodeKind.OrPattern {
        nr_check_pattern(node_left(node))
        nr_check_pattern(node_right(node))
        return
    }

    if kind == NodeKind.RangePattern {
        return
    }

    if kind == NodeKind.AsPattern {
        nr_check_pattern(node_pattern(node))
        nr_define(node_name(node))
        return
    }

    let _skip = 0
}

// ── Phase 2: Type compatibility ─────────────────────────────────────

fn types_compatible(a: Int, b: Int) -> Int {
    if a == b { return 1 }
    if a == TYPE_UNKNOWN || b == TYPE_UNKNOWN { return 1 }
    if a < 0 || b < 0 { return 1 }
    if a >= ty_pool.len() || b >= ty_pool.len() { return 1 }
    let ta = ty_pool.get(a).unwrap()
    let tb = ty_pool.get(b).unwrap()
    let ka = ta.kind
    let kb = tb.kind
    if ka == TK_TYPEVAR || kb == TK_TYPEVAR { return 1 }
    // Int and Bool are interchangeable in Blink (C-style truthiness)
    if (ka == TK_INT || ka == TK_BOOL) && (kb == TK_INT || kb == TK_BOOL) { return 1 }
    // Sized integer kinds are compatible only with themselves (no implicit promotion)
    let is_sized_a = is_sized_int(ka)
    let is_sized_b = is_sized_int(kb)
    if is_sized_a || is_sized_b { return if ka == kb { 1 } else { 0 } }
    // Enums are tag-ints at runtime — Int and Enum are compatible
    if (ka == TK_INT && kb == TK_ENUM) || (ka == TK_ENUM && kb == TK_INT) { return 1 }
    if ka == kb {
        if ka == TK_LIST || ka == TK_OPTION || ka == TK_ITERATOR || ka == TK_SET {
            return types_compatible(ta.inner1, tb.inner1)
        }
        if ka == TK_MAP {
            if types_compatible(ta.inner1, tb.inner1) == 0 { return 0 }
            return types_compatible(ta.inner2, tb.inner2)
        }
        if ka == TK_RESULT {
            if types_compatible(ta.inner1, tb.inner1) == 0 { return 0 }
            return types_compatible(ta.inner2, tb.inner2)
        }
        if ka == TK_STRUCT || ka == TK_ENUM {
            return 0
        }
        return 1
    }
    0
}

fn type_kind(tid: Int) -> Int {
    if tid < 0 || tid >= ty_pool.len() { return TK_UNKNOWN }
    ty_pool.get(tid).unwrap().kind
}

// Blink treats Int as truthy — Int is valid in Bool contexts
fn is_bool_compat(tid: Int) -> Int {
    if tid == TYPE_UNKNOWN { return 1 }
    if tid == TYPE_BOOL { return 1 }
    if tid == TYPE_INT { return 1 }
    let k = type_kind(tid)
    if k == TK_BOOL || k == TK_INT { return 1 }
    0
}

pub fn is_sized_int(k: Int) -> Int {
    if k == TK_I8 || k == TK_I16 || k == TK_I32 { return 1 }
    if k == TK_U8 || k == TK_U16 || k == TK_U32 || k == TK_U64 { return 1 }
    0
}

fn is_integer_type(tid: Int) -> Int {
    if tid == TYPE_UNKNOWN { return 0 }
    let k = type_kind(tid)
    if k == TK_INT { return 1 }
    is_sized_int(k)
}

fn is_shift_amount_type(tid: Int, rhs_node: Int) -> Int {
    if tid == TYPE_UNKNOWN { return 1 }
    let k = type_kind(tid)
    if k == TK_U32 { return 1 }
    if k == TK_INT && rhs_node != -1 && node_kind(rhs_node) == NodeKind.IntLit { return 1 }
    0
}

fn type_bit_width(tid: Int) -> Int {
    let k = type_kind(tid)
    if k == TK_I8 || k == TK_U8 { return 8 }
    if k == TK_I16 || k == TK_U16 { return 16 }
    if k == TK_I32 || k == TK_U32 { return 32 }
    64
}

fn warn_bitwise_vs_comparison(child: Int, parent: Int, op: Str) ! TypeCheck.Report, Diag.Report {
    if child != -1 && node_kind(child) == NodeKind.BinOp && is_comparison_op(node_op(child)) {
        diag_warn_at("BitwisePrecedence", "W0700", "bitwise '{op}' applied to comparison result; use parentheses to clarify", parent, "wrap the comparison or the bitwise op in parentheses")
    }
}

fn check_bitwise_precedence(node: Int, op: Str) ! TypeCheck.Report, Diag.Report {
    warn_bitwise_vs_comparison(node_left(node), node, op)
    warn_bitwise_vs_comparison(node_right(node), node, op)
}

fn is_comparison_op(op: Str) -> Int {
    if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" { return 1 }
    0
}

// ── Phase 2: Expression type inference ──────────────────────────────

fn infer_type(node: Int) -> Int ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    if node == -1 { return TYPE_UNKNOWN }
    let kind = node_kind(node)

    if kind == NodeKind.IntLit { return TYPE_INT }
    if kind == NodeKind.FloatLit { return TYPE_FLOAT }
    if kind == NodeKind.BoolLit { return TYPE_BOOL }
    if kind == NodeKind.CharLit { return TYPE_CHAR }
    if kind == NodeKind.InterpString { return TYPE_STR }
    if kind == NodeKind.EmbedExpr { return TYPE_STR }

    if kind == NodeKind.Ident {
        let name = node_name(node)
        if name == "true" || name == "false" { return TYPE_BOOL }
        if name == "None" { return make_option_type(TYPE_UNKNOWN) }
        let vt = nr_get_type(name)
        if vt != TYPE_UNKNOWN { return vt }
        if is_variant_name(name) != 0 {
            return get_variant_enum_tid(name)
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.BinOp {
        let op = node_op(node)
        let lt = infer_type(node_left(node))
        let rt = infer_type(node_right(node))

        if is_comparison_op(op) { return TYPE_BOOL }
        if op == "&&" || op == "||" {
            if is_bool_compat(lt) == 0 {
                tc_error_at("logical operator '{op}' requires Bool operands, got {type_to_str(lt)}", node)
            }
            if is_bool_compat(rt) == 0 {
                tc_error_at("logical operator '{op}' requires Bool operands, got {type_to_str(rt)}", node)
            }
            return TYPE_BOOL
        }
        if op == "+" {
            if type_kind(lt) == TK_STR || type_kind(rt) == TK_STR {
                return TYPE_STR
            }
        }
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
            if lt != TYPE_UNKNOWN && rt != TYPE_UNKNOWN {
                if types_compatible(lt, rt) == 0 {
                    tc_error_at("binary '{op}': incompatible types {type_to_str(lt)} and {type_to_str(rt)}", node)
                }
            }
            if lt != TYPE_UNKNOWN { return lt }
            return rt
        }
        if op == "&" || op == "|" || op == "^" {
            check_bitwise_precedence(node, op)
            if lt != TYPE_UNKNOWN && is_integer_type(lt) == 0 {
                tc_error_at("bitwise '{op}' requires integer operand, got {type_to_str(lt)}", node)
            }
            if rt != TYPE_UNKNOWN && is_integer_type(rt) == 0 {
                tc_error_at("bitwise '{op}' requires integer operand, got {type_to_str(rt)}", node)
            }
            if lt != TYPE_UNKNOWN && rt != TYPE_UNKNOWN && types_compatible(lt, rt) == 0 {
                tc_error_at("bitwise '{op}': incompatible types {type_to_str(lt)} and {type_to_str(rt)}", node)
            }
            if lt != TYPE_UNKNOWN { return lt }
            return rt
        }
        if op == "<<" || op == ">>" {
            check_bitwise_precedence(node, op)
            if lt != TYPE_UNKNOWN && is_integer_type(lt) == 0 {
                tc_error_at("shift '{op}' requires integer left operand, got {type_to_str(lt)}", node)
            }
            let rhs = node_right(node)
            if rt != TYPE_UNKNOWN && is_shift_amount_type(rt, rhs) == 0 {
                tc_error_at("shift '{op}' amount must be U32, got {type_to_str(rt)}", node)
            }
            if lt != TYPE_UNKNOWN && rhs != -1 && node_kind(rhs) == NodeKind.IntLit {
                let amt = node_str_val(rhs).to_int()
                let bw = type_bit_width(lt)
                if amt < 0 || amt >= bw {
                    tc_error_at("shift '{op}' amount {amt} out of range for {type_to_str(lt)} (must be 0..{bw})", node)
                }
            }
            if lt != TYPE_UNKNOWN { return lt }
            return TYPE_INT
        }
        if op == "??" {
            let left_k = type_kind(lt)
            if left_k != TK_OPTION && left_k != TK_UNKNOWN {
                tc_error_at("'??' operator requires Option value, got {type_to_str(lt)}", node)
            }
            if left_k == TK_OPTION { return ty_pool.get(lt).unwrap().inner1 }
            return rt
        }
        if lt != TYPE_UNKNOWN { return lt }
        return rt
    }

    if kind == NodeKind.UnaryOp {
        let op = node_op(node)
        let operand = infer_type(node_left(node))
        if op == "!" { return TYPE_BOOL }
        if op == "-" { return operand }
        if op == "~" {
            if operand != TYPE_UNKNOWN && is_integer_type(operand) == 0 {
                tc_error_at("bitwise '~' requires integer operand, got {type_to_str(operand)}", node)
            }
            return operand
        }
        if op == "?" {
            let ok = type_kind(operand)
            if ok == TK_RESULT {
                if tc_current_fn_ret >= 0 && tc_current_fn_ret < ty_pool.len() {
                    let ret_kind = ty_pool.get(tc_current_fn_ret).unwrap().kind
                    if ret_kind != TK_RESULT && ret_kind != TK_UNKNOWN {
                        tc_errors.push("'?' on Result in function '{tc_current_fn_name}' which does not return Result")
                        diag_error_at("QuestionMarkResultInNonResult", "E0508", "'?' on Result in function '{tc_current_fn_name}' which does not return Result", node, "change the return type to Result[T, E]")
                    } else if ret_kind == TK_RESULT {
                        let operand_err = ty_pool.get(operand).unwrap().inner2
                        let ret_err = ty_pool.get(tc_current_fn_ret).unwrap().inner2
                        if types_compatible(operand_err, ret_err) == 0 {
                            tc_errors.push("'?' error type mismatch in function '{tc_current_fn_name}'")
                            diag_error_at("QuestionMarkErrorMismatch", "E0512", "'?' error type mismatch: operand error type does not match return error type in '{tc_current_fn_name}'", node, "ensure the error types are compatible")
                        }
                    }
                }
                return ty_pool.get(operand).unwrap().inner1
            }
            if ok == TK_OPTION {
                if tc_current_fn_ret >= 0 && tc_current_fn_ret < ty_pool.len() {
                    let ret_kind = ty_pool.get(tc_current_fn_ret).unwrap().kind
                    if ret_kind != TK_OPTION && ret_kind != TK_UNKNOWN {
                        tc_errors.push("'?' on Option in function '{tc_current_fn_name}' which does not return Option")
                        diag_error_at("QuestionMarkOptionInNonOption", "E0509", "'?' on Option in function '{tc_current_fn_name}' which does not return Option", node, "change the return type to Option[T]")
                    }
                }
                return ty_pool.get(operand).unwrap().inner1
            }
            if ok != TK_UNKNOWN {
                tc_errors.push("'?' requires Result or Option value")
                diag_error_at("QuestionMarkInvalidOperand", "E0502", "'?' requires a Result or Option value", node, "")
            }
            return operand
        }
        return operand
    }

    if kind == NodeKind.Call {
        let callee = node_left(node)
        if callee != -1 {
            let callee_kind = node_kind(callee)
            if callee_kind == NodeKind.Ident {
                let mut fn_name = node_name(callee)
                fn_name = tc_alias_to_original.get(fn_name) ?? fn_name
                if fn_name == "Some" {
                    let args_sl = node_args(node)
                    if args_sl != -1 && sublist_length(args_sl) >= 1 {
                        let inner = infer_type(sublist_get(args_sl, 0))
                        return make_option_type(inner)
                    }
                    return make_option_type(TYPE_UNKNOWN)
                }
                if fn_name == "Ok" {
                    let args_sl = node_args(node)
                    if args_sl != -1 && sublist_length(args_sl) >= 1 {
                        let inner = infer_type(sublist_get(args_sl, 0))
                        return make_result_type(inner, TYPE_UNKNOWN)
                    }
                    return make_result_type(TYPE_UNKNOWN, TYPE_UNKNOWN)
                }
                if fn_name == "Err" {
                    let args_sl = node_args(node)
                    if args_sl != -1 && sublist_length(args_sl) >= 1 {
                        let inner = infer_type(sublist_get(args_sl, 0))
                        return make_result_type(TYPE_UNKNOWN, inner)
                    }
                    return make_result_type(TYPE_UNKNOWN, TYPE_UNKNOWN)
                }
                if fn_name == "Raw" {
                    let args_sl = node_args(node)
                    if args_sl != -1 && sublist_length(args_sl) >= 1 {
                        return infer_type(sublist_get(args_sl, 0))
                    }
                    return TYPE_STR
                }
                if is_builtin_fn(fn_name) != 0 {
                    return get_builtin_fn_ret(fn_name)
                }
                if is_variant_name(fn_name) != 0 {
                    return get_variant_enum_tid(fn_name)
                }
                let sig = lookup_fnsig(fn_name)
                if sig != -1 {
                    check_deprecated_fn(fn_name, node)
                    let args_sl = node_args(node)
                    let mut arg_count = 0
                    if args_sl != -1 {
                        arg_count = sublist_length(args_sl)
                    }
                    let fs = fnsig_pool.get(sig).unwrap()
                    if arg_count != fs.params_count {
                        let expected = fs.params_count
                        tc_error_at("function '{fn_name}' expects {expected} argument(s), got {arg_count}", node)
                    }
                    if fs.type_params_count > 0 {
                        return instantiate_return_type(sig, args_sl)
                    }
                    return fs.ret
                }
            } else if callee_kind == NodeKind.FieldAccess {
                let obj = node_obj(callee)
                if obj != -1 && node_kind(obj) == NodeKind.Ident {
                    let type_name = node_name(obj)
                    let tid = lookup_named_type(type_name)
                    if tid != -1 { return tid }
                }
            }
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.MethodCall {
        let obj_node = node_obj(node)
        let method = node_method(node)
        let obj_t = infer_type(obj_node)
        let obj_k = type_kind(obj_t)

        if obj_k == TK_LIST {
            if method == "len" || method == "count" { return TYPE_INT }
            if method == "get" { return make_option_type(ty_pool.get(obj_t).unwrap().inner1) }
            if method == "push" || method == "set" || method == "pop" || method == "for_each" || method == "clear" { return TYPE_VOID }
            if method == "map" || method == "filter" || method == "take" || method == "skip" || method == "collect" || method == "concat" || method == "slice" {
                return obj_t
            }
            if method == "contains" || method == "any" || method == "all" || method == "is_empty" { return TYPE_BOOL }
            if method == "find" { return make_option_type(ty_pool.get(obj_t).unwrap().inner1) }
            if method == "fold" {
                let args_sl = node_args(node)
                if args_sl != -1 && sublist_length(args_sl) >= 1 {
                    return infer_type(sublist_get(args_sl, 0))
                }
                return TYPE_UNKNOWN
            }
        }

        if obj_k == TK_STR {
            if method == "len" { return TYPE_INT }
            if method == "contains" || method == "starts_with" || method == "ends_with" { return TYPE_BOOL }
            if method == "substring" || method == "concat" || method == "trim" || method == "trim_right" || method == "trim_left" || method == "to_lower" || method == "to_upper" || method == "replace" || method == "slice" {
                return TYPE_STR
            }
            if method == "byte_at" || method == "index_of" || method == "to_int" { return TYPE_INT }
            if method == "char_at" { return make_option_type(TYPE_CHAR) }
            if method == "split" { return make_list_type(TYPE_STR) }
            if method == "lines" { return make_list_type(TYPE_STR) }
            if method == "parse_float" { return TYPE_FLOAT }
            if method == "parse_int" { return TYPE_INT }
            if method == "is_empty" { return TYPE_BOOL }
        }

        if obj_k == TK_INT {
            if method == "to_str" { return TYPE_STR }
            if method == "abs" || method == "min" || method == "max" { return TYPE_INT }
            if method == "to_i8" { return TYPE_I8 }
            if method == "to_i16" { return TYPE_I16 }
            if method == "to_i32" { return TYPE_I32 }
            if method == "to_u8" { return TYPE_U8 }
            if method == "to_u16" { return TYPE_U16 }
            if method == "to_u32" { return TYPE_U32 }
            if method == "to_u64" { return TYPE_U64 }
        }

        let is_sized_obj = is_sized_int(obj_k)
        if is_sized_obj {
            if method == "to_int" { return TYPE_INT }
            if method == "to_i8" { return TYPE_I8 }
            if method == "to_i16" { return TYPE_I16 }
            if method == "to_i32" { return TYPE_I32 }
            if method == "to_u8" { return TYPE_U8 }
            if method == "to_u16" { return TYPE_U16 }
            if method == "to_u32" { return TYPE_U32 }
            if method == "to_u64" { return TYPE_U64 }
            if method == "wrapping_add" || method == "wrapping_sub" || method == "wrapping_mul" || method == "wrapping_div" || method == "wrapping_rem" || method == "wrapping_neg" {
                return obj_t
            }
        }

        if obj_k == TK_CHAR {
            if method == "to_int" { return TYPE_INT }
            if method == "to_str" { return TYPE_STR }
        }

        if obj_k == TK_OPTION {
            if method == "unwrap" { return ty_pool.get(obj_t).unwrap().inner1 }
            if method == "is_some" || method == "is_none" { return TYPE_BOOL }
        }

        if obj_k == TK_RESULT {
            if method == "unwrap" { return ty_pool.get(obj_t).unwrap().inner1 }
            if method == "unwrap_err" { return ty_pool.get(obj_t).unwrap().inner2 }
            if method == "is_ok" || method == "is_err" { return TYPE_BOOL }
        }

        if obj_k == TK_MAP {
            if method == "len" { return TYPE_INT }
            if method == "contains_key" || method == "remove" { return TYPE_BOOL }
            if method == "insert" || method == "clear" { return TYPE_VOID }
            if method == "get" { return make_option_type(ty_pool.get(obj_t).unwrap().inner2) }
            if method == "keys" { return make_list_type(ty_pool.get(obj_t).unwrap().inner1) }
            if method == "values" { return make_list_type(ty_pool.get(obj_t).unwrap().inner2) }
        }

        if obj_k == TK_SET {
            if method == "len" { return TYPE_INT }
            if method == "is_empty" { return TYPE_BOOL }
            if method == "contains" || method == "insert" || method == "remove" { return TYPE_BOOL }
            if method == "union" { return obj_t }
        }

        if obj_k == TK_BYTES {
            if method == "len" { return TYPE_INT }
            if method == "get" { return make_option_type(TYPE_INT) }
            if method == "is_empty" { return TYPE_BOOL }
            if method == "push" || method == "set" { return TYPE_VOID }
            if method == "slice" || method == "concat" { return obj_t }
            if method == "to_str" { return make_result_type(TYPE_STR, TYPE_STR) }
            if method == "to_hex" { return TYPE_STR }
            if method == "read_u16_be" || method == "read_u32_be" || method == "read_i32_be" || method == "read_i64_be" { return make_result_type(TYPE_INT, TYPE_STR) }
            if method == "read_u16_le" || method == "read_u32_le" || method == "read_i32_le" || method == "read_i64_le" { return make_result_type(TYPE_INT, TYPE_STR) }
            if method == "write_u16_be" || method == "write_u32_be" || method == "write_i32_be" || method == "write_i64_be" { return TYPE_VOID }
            if method == "write_u16_le" || method == "write_u32_le" || method == "write_i32_le" || method == "write_i64_le" { return TYPE_VOID }
        }

        if obj_k == TK_STRUCT || obj_k == TK_ENUM {
            let tname = ty_pool.get(obj_t).unwrap().name
            let sig_name = "{tname}_{method}"
            let sig = lookup_fnsig(sig_name)
            if sig != -1 {
                return fnsig_pool.get(sig).unwrap().ret
            }
        }

        if obj_node != -1 && node_kind(obj_node) == NodeKind.Ident {
            let obj_name = node_name(obj_node)
            if obj_name == "Char" {
                if method == "from_code_point" {
                    return make_result_type(TYPE_CHAR, lookup_named_type("ConversionError"))
                }
            }
            if is_import_module_name(obj_name) != 0 && nr_is_defined(obj_name) == 0 {
                let sig = lookup_fnsig(method)
                if sig != -1 {
                    return fnsig_pool.get(sig).unwrap().ret
                }
            }
            // Static method on a builtin/named type: Type.from(x), Type.try_from(x), etc.
            // The fnsig is registered as `{TypeName}_{method}` by the impl emitter.
            let static_sig_name = "{obj_name}_{method}"
            let static_sig = lookup_fnsig(static_sig_name)
            if static_sig != -1 {
                return fnsig_pool.get(static_sig).unwrap().ret
            }
        }

        return TYPE_UNKNOWN
    }

    if kind == NodeKind.FieldAccess {
        let obj_node = node_obj(node)
        let fname = node_name(node)
        if obj_node == -1 { return TYPE_UNKNOWN }

        if node_kind(obj_node) == NodeKind.Ident {
            let obj_name = node_name(obj_node)
            let tid = lookup_named_type(obj_name)
            if tid != -1 && type_kind(tid) == TK_ENUM {
                return tid
            }
        }

        let obj_t = infer_type(obj_node)
        if type_kind(obj_t) == TK_STRUCT {
            let ft = get_struct_field_tid(obj_t, fname)
            if ft != -1 { return ft }
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.IndexExpr {
        let obj_t = infer_type(node_obj(node))
        if type_kind(obj_t) == TK_LIST {
            return ty_pool.get(obj_t).unwrap().inner1
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.ListLit {
        let elems_sl = node_elements(node)
        if elems_sl != -1 && sublist_length(elems_sl) > 0 {
            let first_t = infer_type(sublist_get(elems_sl, 0))
            return make_list_type(first_t)
        }
        return make_list_type(TYPE_UNKNOWN)
    }

    if kind == NodeKind.StructLit {
        let sname = node_type_name(node)
        if sname != "" {
            let tid = lookup_named_type(sname)
            if tid != -1 {
                check_deprecated_type(sname, node)
                return tid
            }
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.TupleLit {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut elem_types: List[Int] = []
            let mut i = 0
            while i < sublist_length(elems_sl) {
                elem_types.push(infer_type(sublist_get(elems_sl, i)))
                i = i + 1
            }
            return make_tuple_type(elem_types)
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.IfExpr {
        let cond_t = infer_type(node_condition(node))
        if is_bool_compat(cond_t) == 0 {
            tc_error_at("if condition must be Bool, got {type_to_str(cond_t)}", node)
        }
        let then_t = infer_type(node_then_body(node))
        let else_node = node_else_body(node)
        if else_node != -1 {
            let else_t = infer_type(else_node)
            if then_t != TYPE_UNKNOWN && else_t != TYPE_UNKNOWN {
                if types_compatible(then_t, else_t) == 0 {
                    tc_error_at("if branches have incompatible types: {type_to_str(then_t)} vs {type_to_str(else_t)}", node)
                }
            }
            if then_t != TYPE_UNKNOWN { return then_t }
            return else_t
        }
        return then_t
    }

    if kind == NodeKind.MatchExpr {
        let arms_sl = node_arms(node)
        if arms_sl != -1 && sublist_length(arms_sl) > 0 {
            let first_arm = sublist_get(arms_sl, 0)
            return infer_type(node_body(first_arm))
        }
        return TYPE_UNKNOWN
    }

    if kind == NodeKind.Block {
        let stmts_sl = node_stmts(node)
        if stmts_sl != -1 && sublist_length(stmts_sl) > 0 {
            let last = sublist_get(stmts_sl, sublist_length(stmts_sl) - 1)
            let last_k = node_kind(last)
            if last_k == NodeKind.ExprStmt {
                return infer_type(node_value(last))
            }
            if last_k == NodeKind.Return {
                return infer_type(node_value(last))
            }
            if last_k == NodeKind.IfExpr || last_k == NodeKind.MatchExpr || last_k == NodeKind.Call || last_k == NodeKind.MethodCall || last_k == NodeKind.Ident || last_k == NodeKind.IntLit || last_k == NodeKind.FloatLit || last_k == NodeKind.BoolLit || last_k == NodeKind.InterpString || last_k == NodeKind.BinOp || last_k == NodeKind.UnaryOp || last_k == NodeKind.WhileLoop || last_k == NodeKind.ForIn || last_k == NodeKind.LoopExpr || last_k == NodeKind.WithBlock {
                return infer_type(last)
            }
        }
        return TYPE_VOID
    }

    if kind == NodeKind.WhileLoop || kind == NodeKind.ForIn || kind == NodeKind.LoopExpr {
        let body = node_body(node)
        return infer_loop_return_type(body)
    }

    if kind == NodeKind.WithBlock {
        return infer_type(node_body(node))
    }

    if kind == NodeKind.RangeLit {
        return make_list_type(TYPE_INT)
    }

    if kind == NodeKind.Closure {
        return TYPE_UNKNOWN
    }

    TYPE_UNKNOWN
}

fn infer_loop_return_type(node: Int) -> Int ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    if node == -1 { return TYPE_VOID }
    let kind = node_kind(node)

    if kind == NodeKind.Return {
        let rv = infer_type(node_value(node))
        if rv != TYPE_UNKNOWN { return rv }
        return tc_current_fn_ret
    }

    if kind == NodeKind.Block {
        let stmts_sl = node_stmts(node)
        if stmts_sl != -1 {
            let mut i = 0
            while i < sublist_length(stmts_sl) {
                let t = infer_loop_return_type(sublist_get(stmts_sl, i))
                if t != TYPE_VOID {
                    return t
                }
                i = i + 1
            }
        }
        return TYPE_VOID
    }

    if kind == NodeKind.IfExpr {
        let then_t = infer_loop_return_type(node_then_body(node))
        if then_t != TYPE_VOID {
            return then_t
        }
        let else_t = infer_loop_return_type(node_else_body(node))
        if else_t != TYPE_VOID {
            return else_t
        }
        return TYPE_VOID
    }

    if kind == NodeKind.MatchExpr {
        let arms_sl = node_arms(node)
        if arms_sl != -1 {
            let mut i = 0
            while i < sublist_length(arms_sl) {
                let arm = sublist_get(arms_sl, i)
                let t = infer_loop_return_type(node_body(arm))
                if t != TYPE_VOID {
                    return t
                }
                i = i + 1
            }
        }
        return TYPE_VOID
    }

    TYPE_VOID
}

// ── Phase 2: Type check function bodies ─────────────────────────────

fn resolve_param_type(p: Int) -> Int ! TypeCheck.Resolve {
    let ptype_str = node_type_name(p)
    let ptype_ann = node_type_ann(p)
    if ptype_ann != -1 {
        return resolve_type_ann(ptype_ann)
    }
    if ptype_str != "" {
        let t = resolve_type_name(ptype_str)
        if t != -1 { return t }
    }
    TYPE_UNKNOWN
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn tc_check_fn(fn_node: Int) ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    nr_push_scope()
    let fn_name = node_name(fn_node)
    let prev_fn_name = tc_current_fn_name
    let prev_fn_ret = tc_current_fn_ret
    tc_current_fn_name = fn_name
    let sig = lookup_fnsig(fn_name)
    if sig != -1 {
        tc_current_fn_ret = fnsig_pool.get(sig).unwrap().ret
    }

    let is_ffi = has_annotation(fn_node, "ffi")
    diag_push_allows(fn_node)

    let params_sl = node_params(fn_node)
    if params_sl != -1 && is_ffi == 0 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname = node_name(p)
            let ptid = resolve_param_type(p)
            nr_define_typed(pname, 0, ptid)
            i = i + 1
        }
    }

    let body = node_body(fn_node)
    if body != -1 && is_ffi == 0 {
        tc_check_body(body)

        if sig != -1 {
            let declared_ret = fnsig_pool.get(sig).unwrap().ret
            if declared_ret != TYPE_VOID && declared_ret != TYPE_UNKNOWN {
                let inferred_ret = infer_type(body)
                if inferred_ret != TYPE_UNKNOWN {
                    if types_compatible(declared_ret, inferred_ret) == 0 {
                        tc_error_at("function '{fn_name}' declared return type {type_to_str(declared_ret)} but body returns {type_to_str(inferred_ret)}", fn_node)
                    }
                }
            }
        }
    }
    diag_clear_allows()
    tc_current_fn_name = prev_fn_name
    tc_current_fn_ret = prev_fn_ret
    nr_pop_scope()
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn tc_check_body(node: Int) ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    if node == -1 { return }
    let kind = node_kind(node)

    if kind == NodeKind.Block {
        nr_push_scope()
        let stmts_sl = node_stmts(node)
        if stmts_sl != -1 {
            let mut i = 0
            let mut _found_terminal = 0
            while i < sublist_length(stmts_sl) {
                let stmt = sublist_get(stmts_sl, i)
                if _found_terminal != 0 {
                    diag_warn_at("UnreachableCode", "W0700", "unreachable code after return/break/continue", stmt, "remove this code or move it before the control flow statement")
                }
                tc_check_body(stmt)
                let sk = node_kind(stmt)
                if sk == NodeKind.Return || sk == NodeKind.Break || sk == NodeKind.Continue {
                    _found_terminal = 1
                }
                i = i + 1
            }
        }
        nr_pop_scope()
        return
    }

    if kind == NodeKind.LetBinding {
        let vname = node_name(node)
        let val = node_value(node)
        let is_mut = node_is_mut(node)

        let type_str = node_type_name(node)
        let type_ann = node_target(node)
        let mut declared_tid = TYPE_UNKNOWN
        if type_ann != -1 {
            declared_tid = resolve_type_ann(type_ann)
        } else if type_str != "" {
            let rt = resolve_type_name(type_str)
            if rt != -1 {
                declared_tid = rt
            }
        }

        let mut inferred_tid = TYPE_UNKNOWN
        if val != -1 {
            inferred_tid = infer_type(val)
            tc_check_body(val)
        }

        if declared_tid != TYPE_UNKNOWN && inferred_tid != TYPE_UNKNOWN {
            let decl_k = type_kind(declared_tid)
            let is_sized_decl = is_sized_int(decl_k)
            let is_int_lit_direct = val != -1 && node_kind(val) == NodeKind.IntLit
            let is_neg_int_lit = val != -1 && node_kind(val) == NodeKind.UnaryOp && node_op(val) == "-" && node_left(val) != -1 && node_kind(node_left(val)) == NodeKind.IntLit
            let is_int_lit_rhs = inferred_tid == TYPE_INT && (is_int_lit_direct || is_neg_int_lit)
            let literal_to_sized = is_sized_decl && is_int_lit_rhs
            if literal_to_sized == 0 && types_compatible(declared_tid, inferred_tid) == 0 {
                tc_error_at("variable '{vname}': declared type {type_to_str(declared_tid)} but got {type_to_str(inferred_tid)}", node)
            }
        }

        let mut final_tid = declared_tid
        if final_tid == TYPE_UNKNOWN {
            final_tid = inferred_tid
        }
        nr_define_typed(vname, is_mut, final_tid)
        if type_ann == -1 && type_str == "" && final_tid != TYPE_UNKNOWN {
            tc_hints.push(HintEntry { line: node_line(node), col: node_col(node), name: vname, type_str: type_to_str(final_tid), module: nr_current_module })
        }
        let tc_let_pat_sl = node_elements(node)
        if tc_let_pat_sl != -1 {
            let tc_let_elems_sl = node_elements(tc_let_pat_sl)
            if tc_let_elems_sl != -1 {
                let mut tpi = 0
                while tpi < sublist_length(tc_let_elems_sl) {
                    let tsp = sublist_get(tc_let_elems_sl, tpi)
                    nr_define_typed(node_name(tsp), is_mut, TYPE_UNKNOWN)
                    tpi = tpi + 1
                }
            }
        }
        return
    }

    if kind == NodeKind.Assignment || kind == NodeKind.CompoundAssign {
        let target = node_target(node)
        let val = node_value(node)
        if target != -1 && val != -1 {
            let target_t = infer_type(target)
            let val_t = infer_type(val)
            if target_t != TYPE_UNKNOWN && val_t != TYPE_UNKNOWN {
                if types_compatible(target_t, val_t) == 0 {
                    tc_error_at("assignment: cannot assign {type_to_str(val_t)} to {type_to_str(target_t)}", node)
                }
            }
        }
        return
    }

    if kind == NodeKind.IfExpr {
        let cond_t = infer_type(node_condition(node))
        if is_bool_compat(cond_t) == 0 {
            tc_error_at("if condition must be Bool, got {type_to_str(cond_t)}", node)
        }
        tc_check_body(node_then_body(node))
        tc_check_body(node_else_body(node))
        return
    }

    if kind == NodeKind.WhileLoop {
        let cond_t = infer_type(node_condition(node))
        if is_bool_compat(cond_t) == 0 {
            tc_error_at("while condition must be Bool, got {type_to_str(cond_t)}", node)
        }
        tc_check_body(node_body(node))
        return
    }

    if kind == NodeKind.ForIn {
        nr_push_scope()
        let iter_t = infer_type(node_iterable(node))
        let mut elem_t = TYPE_UNKNOWN
        if type_kind(iter_t) == TK_LIST {
            elem_t = ty_pool.get(iter_t).unwrap().inner1
        }
        nr_define_typed(node_var_name(node), 0, elem_t)
        let tc_for_pat_sl = node_elements(node)
        if tc_for_pat_sl != -1 {
            tc_check_pattern_types(tc_for_pat_sl)
        }
        tc_check_body(node_body(node))
        nr_pop_scope()
        return
    }

    if kind == NodeKind.MatchExpr {
        tc_check_body(node_scrutinee(node))
        let scrut_tid = infer_type(node_scrutinee(node))
        let arms_sl = node_arms(node)
        if arms_sl != -1 {
            let mut i = 0
            while i < sublist_length(arms_sl) {
                let arm = sublist_get(arms_sl, i)
                nr_push_scope()
                tc_pattern_binding_type = scrut_tid
                tc_check_pattern_types(node_pattern(arm))
                tc_pattern_binding_type = -1
                tc_check_body(node_body(arm))
                nr_pop_scope()
                i = i + 1
            }

            let mut has_wildcard = 0
            let mut ai = 0
            while ai < sublist_length(arms_sl) {
                let arm = sublist_get(arms_sl, ai)
                let pat = node_pattern(arm)
                if pat != -1 {
                    let pk = node_kind(pat)
                    if pk == NodeKind.WildcardPattern {
                        has_wildcard = 1
                    }
                    if pk == NodeKind.IdentPattern && is_variant_name(node_name(pat)) == 0 {
                        has_wildcard = 1
                    }
                }
                ai = ai + 1
            }
            if has_wildcard == 0 {
                tc_warn("match expression may not be exhaustive (no wildcard or catch-all arm)")
            }
        }
        return
    }

    if kind == NodeKind.LoopExpr {
        tc_check_body(node_body(node))
        return
    }

    if kind == NodeKind.WithBlock {
        let wh_sl2 = node_handlers(node)
        nr_push_scope()
        if wh_sl2 != -1 {
            let mut wi2 = 0
            while wi2 < sublist_length(wh_sl2) {
                let wh_item2 = sublist_get(wh_sl2, wi2)
                let wh_kind2 = node_kind(wh_item2)
                if wh_kind2 == NodeKind.WithResource {
                    nr_define(node_name(wh_item2))
                    tc_check_body(node_value(wh_item2))
                } else if wh_kind2 == NodeKind.Ident && node_name(wh_item2) == "arena" {
                } else {
                    tc_check_body(wh_item2)
                }
                wi2 = wi2 + 1
            }
        }
        tc_check_body(node_body(node))
        nr_pop_scope()
        return
    }

    if kind == NodeKind.WithResource {
        tc_check_body(node_value(node))
        return
    }

    if kind == NodeKind.AsyncScope {
        tc_check_body(node_body(node))
        return
    }

    if kind == NodeKind.AsyncSpawn {
        tc_check_body(node_body(node))
        return
    }

    if kind == NodeKind.Closure {
        nr_push_scope()
        let params_sl = node_params(node)
        if params_sl != -1 {
            let mut i = 0
            while i < sublist_length(params_sl) {
                let p = sublist_get(params_sl, i)
                let pname = node_name(p)
                let ptid = resolve_param_type(p)
                nr_define_typed(pname, 0, ptid)
                i = i + 1
            }
        }
        tc_check_body(node_body(node))
        nr_pop_scope()
        return
    }

    if kind == NodeKind.ExprStmt {
        let val = node_value(node)
        if val != -1 {
            infer_type(val)
        }
        return
    }

    if kind == NodeKind.Return {
        let val = node_value(node)
        if val != -1 {
            infer_type(val)
        }
        return
    }

    let _skip = 0
}

let mut tc_pattern_binding_type: Int = -1

@allow(UnrestoredMutation)
fn tc_check_pattern_types(node: Int) ! TypeCheck.Resolve {
    if node == -1 { return }
    let kind = node_kind(node)
    if kind == NodeKind.IdentPattern {
        let name = node_name(node)
        if name != "_" && is_variant_name(name) == 0 {
            if tc_pattern_binding_type >= 0 {
                nr_define_typed(name, 0, tc_pattern_binding_type)
            } else {
                nr_define(name)
            }
        }
        return
    }
    if kind == NodeKind.EnumPattern {
        let vname = node_name(node)
        let saved_binding = tc_pattern_binding_type
        if vname == "Some" && tc_pattern_binding_type >= 0 && type_kind(tc_pattern_binding_type) == TK_OPTION {
            tc_pattern_binding_type = ty_pool.get(tc_pattern_binding_type).unwrap().inner1
        } else {
            tc_pattern_binding_type = -1
        }
        let flds_sl = node_fields(node)
        if flds_sl != -1 {
            let is_struct_pat = node_int_val(node)
            let mut i = 0
            while i < sublist_length(flds_sl) {
                let f = sublist_get(flds_sl, i)
                if is_struct_pat != 0 {
                    // Struct-style fields: StructLitField nodes; define field names as vars
                    let fpat = node_pattern(f)
                    if fpat != -1 {
                        tc_check_pattern_types(fpat)
                    } else {
                        nr_define(node_name(f))
                    }
                } else {
                    tc_check_pattern_types(f)
                }
                i = i + 1
            }
        }
        tc_pattern_binding_type = saved_binding
        return
    }
    if kind == NodeKind.StructPattern {
        let flds_sl = node_fields(node)
        if flds_sl != -1 {
            let mut i = 0
            while i < sublist_length(flds_sl) {
                nr_define(node_name(sublist_get(flds_sl, i)))
                i = i + 1
            }
        }
        return
    }
    if kind == NodeKind.TuplePattern {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                tc_check_pattern_types(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }
    if kind == NodeKind.ListPattern {
        let elems_sl = node_elements(node)
        if elems_sl != -1 {
            let mut i = 0
            while i < sublist_length(elems_sl) {
                tc_check_pattern_types(sublist_get(elems_sl, i))
                i = i + 1
            }
        }
        return
    }
    if kind == NodeKind.OrPattern {
        tc_check_pattern_types(node_left(node))
        tc_check_pattern_types(node_right(node))
        return
    }
    if kind == NodeKind.AsPattern {
        tc_check_pattern_types(node_pattern(node))
        nr_define(node_name(node))
        return
    }
    let _skip = 0
}

// ── Phase 2: Top-level driver ───────────────────────────────────────

fn tc_infer_program(program: Int) ! TypeCheck.Resolve, TypeCheck.Report, Diag.Report {
    nr_scope_names = []
    nr_scope_muts = []
    nr_scope_types = []
    nr_scope_reads = []
    nr_scope_writes = []
    nr_scope_nodes = []
    nr_scope_frames = []
    nr_scope_depth = 0
    nr_loop_depth = 0
    nr_push_scope()

    // Register top-level let bindings
    let lets_sl = node_stmts(program)
    if lets_sl != -1 {
        let mut i = 0
        while i < sublist_length(lets_sl) {
            let l = sublist_get(lets_sl, i)
            nr_define(node_name(l))
            i = i + 1
        }
    }

    // Register function names
    let fns_sl = node_params(program)
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            nr_define(node_name(sublist_get(fns_sl, i)))
            i = i + 1
        }
    }

    // Type check each function body (skip unaffected when incremental filter active)
    if fns_sl != -1 {
        let mut i = 0
        while i < sublist_length(fns_sl) {
            let fn_node = sublist_get(fns_sl, i)
            nr_current_module = node_module(fn_node)
            if tc_should_check_fn(node_name(fn_node)) != 0 {
                tc_check_fn(fn_node)
            }
            i = i + 1
        }
    }

    // Type check impl methods (skip unaffected when incremental filter active)
    let impls_sl = node_methods(program)
    if impls_sl != -1 {
        let mut i = 0
        while i < sublist_length(impls_sl) {
            let im = sublist_get(impls_sl, i)
            nr_current_module = node_module(im)
            let impl_type = node_name(im)
            let methods_sl = node_methods(im)
            if methods_sl != -1 {
                let mut j = 0
                while j < sublist_length(methods_sl) {
                    let m = sublist_get(methods_sl, j)
                    let orig_name = node_name(m)
                    let qualified = "{impl_type}_{orig_name}"
                    if tc_should_check_fn(qualified) != 0 {
                        node_set_name(m, qualified)
                        tc_check_fn(m)
                        node_set_name(m, orig_name)
                    }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }

    nr_pop_scope()
}

// ── Debug / introspection ───────────────────────────────────────────

fn type_to_str(tid: Int) -> Str {
    if tid < 0 || tid >= ty_pool.len() {
        return "<?>"
    }
    let t = ty_pool.get(tid).unwrap()
    let k = t.kind
    let name = t.name

    if k == TK_INT { return "Int" }
    if k == TK_FLOAT { return "Float" }
    if k == TK_BOOL { return "Bool" }
    if k == TK_STR { return "Str" }
    if k == TK_VOID { return "Void" }
    if k == TK_I8 { return "I8" }
    if k == TK_I16 { return "I16" }
    if k == TK_I32 { return "I32" }
    if k == TK_U8 { return "U8" }
    if k == TK_U16 { return "U16" }
    if k == TK_U32 { return "U32" }
    if k == TK_U64 { return "U64" }
    if k == TK_UNKNOWN { return "?" }
    if k == TK_TYPEVAR { return name }
    if k == TK_STRUCT { return name }
    if k == TK_ENUM { return name }

    if k == TK_LIST {
        return "List[{type_to_str(t.inner1)}]"
    }
    if k == TK_OPTION {
        return "Option[{type_to_str(t.inner1)}]"
    }
    if k == TK_RESULT {
        return "Result[{type_to_str(t.inner1)}, {type_to_str(t.inner2)}]"
    }
    if k == TK_MAP {
        return "Map[{type_to_str(t.inner1)}, {type_to_str(t.inner2)}]"
    }
    if k == TK_SET {
        return "Set[{type_to_str(t.inner1)}]"
    }
    if k == TK_BYTES {
        return "Bytes"
    }
    if k == TK_FN {
        let start = t.params_start
        let count = t.params_count
        let mut params = ""
        let mut i = 0
        while i < count {
            if i > 0 {
                params = params.concat(", ")
            }
            params = params.concat(type_to_str(ty_param_list.get(start + i).unwrap()))
            i = i + 1
        }
        return "Fn({params}) -> {type_to_str(t.inner1)}"
    }
    if k == TK_TUPLE {
        let start = t.params_start
        let count = t.params_count
        let mut elems = ""
        let mut i = 0
        while i < count {
            if i > 0 {
                elems = elems.concat(", ")
            }
            elems = elems.concat(type_to_str(ty_param_list.get(start + i).unwrap()))
            i = i + 1
        }
        return "({elems})"
    }

    name
}
