test "is_fd_tty returns Bool" {
    let result = term.is_fd_tty(1)
    assert(result == true || result == false)
}

test "is_fd_tty on invalid fd returns false" {
    let result = term.is_fd_tty(999)
    assert(result == false)
}

test "move_up produces ANSI cursor sequence" {
    let s = term.move_up(3)
    let e = str_from_code_point(27)
    assert(s.contains("{e}[3A") != 0)
}

test "move_down produces ANSI cursor sequence" {
    let s = term.move_down(2)
    let e = str_from_code_point(27)
    assert(s.contains("{e}[2B") != 0)
}

test "move_right produces ANSI cursor sequence" {
    let s = term.move_right(5)
    let e = str_from_code_point(27)
    assert(s.contains("{e}[5C") != 0)
}

test "move_left produces ANSI cursor sequence" {
    let s = term.move_left(1)
    let e = str_from_code_point(27)
    assert(s.contains("{e}[1D") != 0)
}

test "clear_line produces ANSI sequence" {
    let s = term.clear_line()
    let e = str_from_code_point(27)
    assert(s.contains("{e}[2K") != 0)
}

test "clear_screen produces ANSI sequence" {
    let s = term.clear_screen()
    let e = str_from_code_point(27)
    assert(s.contains("{e}[2J") != 0)
}

test "hide_cursor produces ANSI sequence" {
    let s = term.hide_cursor()
    let e = str_from_code_point(27)
    assert(s.contains("{e}[?25l") != 0)
}

test "show_cursor produces ANSI sequence" {
    let s = term.show_cursor()
    let e = str_from_code_point(27)
    assert(s.contains("{e}[?25h") != 0)
}

test "strip_ansi removes background codes" {
    let colored = term.bg_red("hello")
    let plain = term.strip_ansi(colored)
    assert_eq(plain, "hello")
}

test "strip_ansi removes italic and strikethrough" {
    let styled = term.italic(term.strikethrough("hello"))
    let plain = term.strip_ansi(styled)
    assert_eq(plain, "hello")
}

test "strip_ansi with non-ascii text after escape" {
    let e = str_from_code_point(27)
    let colored = "{e}[31mcafé{e}[0m"
    let plain = term.strip_ansi(colored)
    assert_eq(plain, "café")
}

test "strip_ansi with non-ascii plain text is identity" {
    assert_eq(term.strip_ansi("café"), "café")
}

test "strip_ansi with non-ascii between escape sequences" {
    let e = str_from_code_point(27)
    let s = "{e}[1müber{e}[0m"
    let plain = term.strip_ansi(s)
    assert_eq(plain, "über")
}
