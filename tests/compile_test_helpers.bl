fn run_compile(path: Str, src: Str) -> Str {
    write_file(path, src)
    let args = [path, "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    fs.remove(path)
    output
}

pub fn compile_and_capture(source: Str, tag: Str) -> Str {
    run_compile(".tmp/{tag}.bl", source)
}

pub fn expect_error(output: Str, code: Str, label: Str) {
    if output.contains(code) {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected {code} in output")
    }
}

pub fn expect_clean(output: Str, label: Str) {
    if output.contains("E0900") || output.contains("E0901") || output.contains("E0902") || output.contains("E0903") || output.contains("E0905") {
        io.println("FAIL: {label} — unexpected trait contract error in output")
    } else {
        io.println("PASS: {label}")
    }
}

pub fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    let output = run_compile(".tmp/_test_{tag}.bl", src)
    assert(output.contains(error_code))
}

pub fn expect_no_error(src: Str, tag: Str, error_code: Str) {
    let output = run_compile(".tmp/_test_{tag}.bl", src)
    assert(!output.contains(error_code))
}
