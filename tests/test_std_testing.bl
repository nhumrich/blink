import std.testing.{capture_log, capture_print, capture_eprint}

test "capture_log captures io.log calls" {
    let messages: List[Str] = []
    with capture_log(messages) {
        io.log("hello")
        io.log("world")
    }
    assert_eq(messages.len(), 2)
    assert_eq(messages.get(0).unwrap(), "hello")
    assert_eq(messages.get(1).unwrap(), "world")
}

test "capture_print captures io.println calls" {
    let messages: List[Str] = []
    with capture_print(messages) {
        io.println("first")
        io.println("second")
    }
    assert_eq(messages.len(), 2)
    assert_eq(messages.get(0).unwrap(), "first")
    assert_eq(messages.get(1).unwrap(), "second")
}

test "capture_log and capture_print compose" {
    let logs: List[Str] = []
    let prints: List[Str] = []
    with capture_log(logs), capture_print(prints) {
        io.log("log msg")
        io.println("print msg")
        io.log("log msg 2")
    }
    assert_eq(logs.len(), 2)
    assert_eq(prints.len(), 1)
    assert_eq(logs.get(0).unwrap(), "log msg")
    assert_eq(logs.get(1).unwrap(), "log msg 2")
    assert_eq(prints.get(0).unwrap(), "print msg")
}

test "capture_print captures io.print (no newline) calls" {
    let messages: List[Str] = []
    with capture_print(messages) {
        io.print("no newline")
        io.println("with newline")
    }
    assert_eq(messages.len(), 2)
    assert_eq(messages.get(0).unwrap(), "no newline")
    assert_eq(messages.get(1).unwrap(), "with newline")
}

test "io.print_raw bypasses capture_print" {
    let messages: List[Str] = []
    with capture_print(messages) {
        io.print_raw("raw output")
        io.println("captured")
    }
    assert_eq(messages.len(), 1)
    assert_eq(messages.get(0).unwrap(), "captured")
}

test "capture_log with no calls" {
    let messages: List[Str] = []
    with capture_log(messages) {
        io.println("this is print, not log")
    }
    assert_eq(messages.len(), 0)
}

test "capture_print with no calls" {
    let messages: List[Str] = []
    with capture_print(messages) {
        io.log("this is log, not print")
    }
    assert_eq(messages.len(), 0)
}

test "capture_eprint captures io.eprintln calls" {
    let messages: List[Str] = []
    with capture_eprint(messages) {
        io.eprintln("error one")
        io.eprintln("error two")
    }
    assert_eq(messages.len(), 2)
    assert_eq(messages.get(0).unwrap(), "error one")
    assert_eq(messages.get(1).unwrap(), "error two")
}

test "capture_eprint captures io.eprint calls" {
    let messages: List[Str] = []
    with capture_eprint(messages) {
        io.eprint("no newline")
        io.eprintln("with newline")
    }
    assert_eq(messages.len(), 2)
    assert_eq(messages.get(0).unwrap(), "no newline")
    assert_eq(messages.get(1).unwrap(), "with newline")
}

test "io.eprint_raw bypasses capture_eprint" {
    let messages: List[Str] = []
    with capture_eprint(messages) {
        io.eprint_raw("raw stderr")
        io.eprintln("captured")
    }
    assert_eq(messages.len(), 1)
    assert_eq(messages.get(0).unwrap(), "captured")
}

test "capture_eprint with no calls" {
    let messages: List[Str] = []
    with capture_eprint(messages) {
        io.println("this is stdout, not stderr")
    }
    assert_eq(messages.len(), 0)
}

test "capture_eprint composes with capture_log and capture_print" {
    let eprints: List[Str] = []
    let logs: List[Str] = []
    let prints: List[Str] = []
    with capture_eprint(eprints), capture_log(logs), capture_print(prints) {
        io.eprintln("err")
        io.log("log")
        io.println("out")
    }
    assert_eq(eprints.len(), 1)
    assert_eq(logs.len(), 1)
    assert_eq(prints.len(), 1)
    assert_eq(eprints.get(0).unwrap(), "err")
    assert_eq(logs.get(0).unwrap(), "log")
    assert_eq(prints.get(0).unwrap(), "out")
}
