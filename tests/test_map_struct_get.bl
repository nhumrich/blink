type Item {
    name: Str
    count: Int
}

fn lookup(m: Map[Str, Item], key: Str) -> Item {
    m.get(key)
}

test "map struct get via function param" {
    let m: Map[Str, Item] = Map()
    m.set("a", Item { name: "apple", count: 5 })

    let result = lookup(m, "a")
    assert_eq(result.name, "apple")
    assert_eq(result.count, 5)
}
