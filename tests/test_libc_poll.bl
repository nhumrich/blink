import std.libc.{Pollfd, poll, POLL_EVT_IN}

test "poll with empty list returns Ok empty" {
    let res = poll([], 0)
    match res {
        Ok(out) => assert_eq(out.len(), 0)
        Err(_) => assert(false)
    }
}

test "poll with timeout=0 on stdin returns immediately" {
    let pfd = Pollfd { fd: 0, events: POLL_EVT_IN.to_i16(), revents: 0 }
    let res = poll([pfd], 0)
    let out: List[Pollfd] = match res {
        Ok(o) => o
        Err(_) => { assert(false); [] }
    }
    assert_eq(out.len(), 1)
    let p: Pollfd = out.get(0).unwrap()
    assert_eq(p.fd, 0)
}

test "poll preserves fd and events across the call" {
    let pfd = Pollfd { fd: 1, events: POLL_EVT_IN.to_i16(), revents: 0 }
    let res = poll([pfd], 0)
    let out: List[Pollfd] = match res {
        Ok(o) => o
        Err(_) => { assert(false); [] }
    }
    let p: Pollfd = out.get(0).unwrap()
    assert_eq(p.fd, 1)
    assert_eq(p.events, POLL_EVT_IN.to_i16())
}

test "poll on multiple fds returns same length" {
    let a = Pollfd { fd: 0, events: POLL_EVT_IN.to_i16(), revents: 0 }
    let b = Pollfd { fd: 1, events: POLL_EVT_IN.to_i16(), revents: 0 }
    let c = Pollfd { fd: 2, events: POLL_EVT_IN.to_i16(), revents: 0 }
    let res = poll([a, b, c], 0)
    match res {
        Ok(out) => assert_eq(out.len(), 3)
        Err(_) => assert(false)
    }
}
