// Template[C] compile error tests

test "Str variable passed to Template[DB] param triggers E0310" {
    let src = #"import std.db_sqlite.{sqlite_handler, sqlite_open}
fn main() ! IO {
    let h = sqlite_open(":memory:")
    with sqlite_handler(h) {
        let q = "SELECT 1"
        db.query(q)
    }
}
"#
    write_file("build/_tpl_err.bl", src)
    shell_exec("build/blinkc build/_tpl_err.bl /dev/null --format json > build/_tpl_err_out.txt 2>&1 || true")
    let out = read_file("build/_tpl_err_out.txt")
    shell_exec("rm -f build/_tpl_err.bl build/_tpl_err_out.txt")
    assert(out.contains("E0310"))
}

test "Raw() in Template emits W0310 warning" {
    let src = #"import std.db_sqlite.{sqlite_handler, sqlite_open, sqlite_close}
fn main() ! IO {
    let h = sqlite_open(":memory:")
    with sqlite_handler(h) {
        let table = "items"
        db.exec("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT)")
        db.exec("INSERT INTO items (name) VALUES ('hello')")
        let rows = db.query("SELECT * FROM {Raw(table)}")
        io.println("{rows.unwrap().len()}")
    }
    sqlite_close(h)
}
"#
    write_file("build/_tpl_raw_warn.bl", src)
    shell_exec("build/blinkc build/_tpl_raw_warn.bl /dev/null --format json > build/_tpl_raw_warn_out.txt 2>&1 || true")
    let out = read_file("build/_tpl_raw_warn_out.txt")
    shell_exec("rm -f build/_tpl_raw_warn.bl build/_tpl_raw_warn_out.txt")
    assert(out.contains("W0310"))
}

test "Raw() concatenates into template parts, other interpolations remain parameterized" {
    let src = #"import std.db_sqlite.{sqlite_handler, sqlite_open, sqlite_close}
@allow(RawBypassesParam)
fn main() ! IO {
    let h = sqlite_open(":memory:")
    with sqlite_handler(h) {
        db.exec("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT, price INTEGER)").unwrap()
        db.exec("INSERT INTO items (name, price) VALUES ('Widget', 42)").unwrap()
        db.exec("INSERT INTO items (name, price) VALUES ('Gadget', 99)").unwrap()
        let table = "items"
        let min_price = 50
        let rows = db.query("SELECT name FROM {Raw(table)} WHERE price > {min_price}").unwrap()
        assert_eq(rows.len(), 1)
        assert_eq(rows.get(0).unwrap().get("name").unwrap(), "Gadget")
        io.println("raw_template: ok")
    }
    sqlite_close(h)
}
"#
    write_file("build/_tpl_raw_correct.bl", src)
    shell_exec("bin/blink run build/_tpl_raw_correct.bl > build/_tpl_raw_correct_out.txt 2>&1 || true")
    let out = read_file("build/_tpl_raw_correct_out.txt")
    shell_exec("rm -f build/_tpl_raw_correct.bl build/_tpl_raw_correct_out.txt")
    assert(out.contains("raw_template: ok"))
}
