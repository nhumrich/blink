// Positive tests: non-escaping arena usage must compile clean (no E0700).
import compile_test_helpers

test "arena value read locally does not escape" {
    let src = "fn main() \{\n    with arena \{\n        let xs = [1, 2, 3]\n        assert_eq(xs.len(), 3)\n    }\n}\n"
    compile_test_helpers.expect_no_error(src, "arena_local_read", "E0700")
}

test "arena value passed to safe intrinsic does not escape" {
    let src = "fn main() \{\n    with arena \{\n        let s = \"hi, {41 + 1}\"\n        println(s)\n    }\n}\n"
    compile_test_helpers.expect_no_error(src, "arena_safe_intrinsic", "E0700")
}

test "arena value passed to ! Arena function does not escape" {
    let src = "fn consume(xs: List[Int]) -> Int ! Arena \{\n    xs.len()\n}\nfn main() \{\n    with arena \{\n        let xs = [10, 20]\n        let n = consume(xs)\n        assert_eq(n, 2)\n    }\n}\n"
    compile_test_helpers.expect_no_error(src, "arena_arena_fn", "E0700")
}
