import std.float.{close_to, fabs, is_nan}

test "fabs: positive returns positive" {
    assert_eq(fabs(1.5), 1.5)
    assert_eq(fabs(0.0), 0.0)
}

test "fabs: negative returns positive" {
    assert_eq(fabs(0.0 - 1.5), 1.5)
    assert_eq(fabs(0.0 - 0.0001), 0.0001)
}

test "is_nan: detects NaN" {
    let zero = 0.0
    let nan = zero / zero
    assert_eq(is_nan(nan), true)
}

test "is_nan: rejects finite and infinite" {
    let zero = 0.0
    let inf = 1.0 / zero
    assert_eq(is_nan(0.0), false)
    assert_eq(is_nan(1.5), false)
    assert_eq(is_nan(0.0 - 1.5), false)
    assert_eq(is_nan(inf), false)
}

test "close_to: free-function form, identical values" {
    assert_eq(close_to(1.0, 1.0, 0.0), true)
    assert_eq(close_to(0.0, 0.0, 0.0), true)
}

test "close_to: free-function form, within tolerance" {
    assert_eq(close_to(1.0, 1.0001, 0.001), true)
    assert_eq(close_to(1.0001, 1.0, 0.001), true)
}

test "close_to: free-function form, outside tolerance" {
    assert_eq(close_to(1.0, 2.0, 0.1), false)
    assert_eq(close_to(0.0, 0.001, 0.0001), false)
}

// Method-style call (a.close_to(b, t)) does not resolve on Float today — the
// primitive method-resolution path covers Int/Str/Char but not Float. Filed
// as a friction task; for now, free-function form is the only supported call
// shape. Re-add the method-style test once Float method dispatch lands.

test "close_to: NaN returns false" {
    let zero = 0.0
    let nan = zero / zero
    assert_eq(close_to(nan, 1.0, 1.0), false)
    assert_eq(close_to(1.0, nan, 1.0), false)
    assert_eq(close_to(nan, nan, 1.0), false)
}

test "close_to: negative tolerance returns false" {
    assert_eq(close_to(1.0, 1.0, 0.0 - 0.1), false)
}

test "close_to: identical infinities are close" {
    let zero = 0.0
    let inf = 1.0 / zero
    assert_eq(close_to(inf, inf, 0.0), true)
}

test "close_to: opposite-sign infinities are not close" {
    let zero = 0.0
    let inf = 1.0 / zero
    let ninf = (0.0 - 1.0) / zero
    assert_eq(close_to(inf, ninf, 1.0), false)
}
