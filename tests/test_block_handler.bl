import std.traits

// ── Shared event log for tracking enter/exit ordering ──────────────

let mut log: List[Str] = []

fn reset_log() {
    log.clear()
}

// ── Types ──────────────────────────────────────────────────────────

type Timer {
    name: Str
    id: Int
}

fn make_timer(name: Str, id: Int) -> Timer {
    Timer { name: name, id: id }
}

type Connection {
    id: Int
}

type Transaction {
    conn_id: Int
}

fn make_conn(id: Int) -> Connection {
    Connection { id: id }
}

// ── BlockHandler impls ─────────────────────────────────────────────

impl BlockHandler for Timer {
    type Context = Int
    fn enter(self) -> Int {
        log.push("timer.enter:" + self.id.to_string())
        0
    }
    fn exit(self, ok: Bool) {
        let id = self.id.to_string()
        if ok {
            log.push("timer.exit:" + id + ":ok=true")
        } else {
            log.push("timer.exit:" + id + ":ok=false")
        }
    }
}

impl BlockHandler for Connection {
    type Context = Transaction
    fn enter(self) -> Transaction {
        log.push("conn.enter:" + self.id.to_string())
        Transaction { conn_id: self.id }
    }
    fn exit(self, ok: Bool) {
        let id = self.id.to_string()
        if ok {
            log.push("conn.exit:" + id + ":ok=true")
        } else {
            log.push("conn.exit:" + id + ":ok=false")
        }
    }
}

// ── Helpers ────────────────────────────────────────────────────────

fn do_work() -> Result[Int, Str] {
    Ok(42)
}

fn do_fail() -> Result[Int, Str] {
    Err("failed")
}

// ── Helper fns for tests needing return/? ──────────────────────────

fn fn_with_early_return() {
    with make_conn(1) as _tx {
        log.push("before-return")
        return
    }
    log.push("SHOULD-NOT-REACH")
}

fn fn_with_question_fail() -> Result[Int, Str] {
    with make_conn(2) as _tx {
        log.push("before-?")
        let _v = do_fail()?
        log.push("SHOULD-NOT-REACH")
    }
    log.push("SHOULD-NOT-REACH-EITHER")
    Ok(0)
}

fn fn_with_question_ok() -> Result[Int, Str] {
    with make_conn(3) as _tx {
        let val = do_work()?
        log.push("val:" + val.to_string())
    }
    Ok(0)
}

fn fn_nested_early_return() {
    with make_timer("outer", 1) {
        with make_conn(2) as _tx {
            log.push("deep-body")
            return
        }
        log.push("NOPE-1")
    }
    log.push("NOPE-2")
}

// ── 1. Basic BlockHandler with `as` binding ────────────────────────

test "with as binding — enter returns context bound to name" {
    reset_log()
    with make_conn(1) as tx {
        assert_eq(tx.conn_id, 1)
        log.push("body")
    }
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "conn.enter:1")
    assert_eq(log.get(1).unwrap(), "body")
    assert_eq(log.get(2).unwrap(), "conn.exit:1:ok=true")
}

// ── 2. BlockHandler without `as` binding ───────────────────────────

test "without as binding — enter called, context discarded" {
    reset_log()
    with make_timer("req", 1) {
        log.push("body")
    }
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "timer.enter:1")
    assert_eq(log.get(1).unwrap(), "body")
    assert_eq(log.get(2).unwrap(), "timer.exit:1:ok=true")
}

// ── 3. enter()/exit() call ordering — LIFO for nested blocks ───────

test "nested blocks — cleanup in LIFO order" {
    reset_log()
    with make_timer("outer", 1) {
        log.push("outer-body")
        with make_conn(2) as tx {
            log.push("inner-body:" + tx.conn_id.to_string())
        }
        log.push("back-to-outer")
    }
    assert_eq(log.len(), 7)
    assert_eq(log.get(0).unwrap(), "timer.enter:1")
    assert_eq(log.get(1).unwrap(), "outer-body")
    assert_eq(log.get(2).unwrap(), "conn.enter:2")
    assert_eq(log.get(3).unwrap(), "inner-body:2")
    assert_eq(log.get(4).unwrap(), "conn.exit:2:ok=true")
    assert_eq(log.get(5).unwrap(), "back-to-outer")
    assert_eq(log.get(6).unwrap(), "timer.exit:1:ok=true")
}

// ── 4. exit(false) triggered by `return` ───────────────────────────

test "early return — exit called with ok=false" {
    reset_log()
    fn_with_early_return()
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "conn.enter:1")
    assert_eq(log.get(1).unwrap(), "before-return")
    assert_eq(log.get(2).unwrap(), "conn.exit:1:ok=false")
}

// ── 5. exit(false) triggered by `?` propagation ───────────────────

test "? propagation — exit called with ok=false" {
    reset_log()
    let r = fn_with_question_fail()
    assert(r.is_err())
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "conn.enter:2")
    assert_eq(log.get(1).unwrap(), "before-?")
    assert_eq(log.get(2).unwrap(), "conn.exit:2:ok=false")
}

// ── 5b. Normal `?` (success) — exit ok=true ────────────────────────

test "? with Ok value — exit called with ok=true" {
    reset_log()
    let r = fn_with_question_ok()
    assert(r.is_ok())
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "conn.enter:3")
    assert_eq(log.get(1).unwrap(), "val:42")
    assert_eq(log.get(2).unwrap(), "conn.exit:3:ok=true")
}

// ── 6. Compile error: dual Closeable + BlockHandler impl ───────────

test "dual Closeable+BlockHandler impl triggers E0906" {
    let src = "import std.traits\ntype Foo \{ x: Int }\nimpl Closeable for Foo \{\n    fn close(self) \{ }\n}\nimpl BlockHandler for Foo \{\n    type Context = Int\n    fn enter(self) -> Int \{ 0 }\n    fn exit(self, ok: Bool) \{ }\n}\nfn main() \{ }\n"
    write_file("build/_bh_dual.bl", src)
    shell_exec("build/blinkc build/_bh_dual.bl /dev/null --format json > build/_bh_dual_out.txt 2>&1 || true")
    let out = read_file("build/_bh_dual_out.txt")
    shell_exec("rm -f build/_bh_dual.bl build/_bh_dual_out.txt")
    assert(out.contains("E0906"))
}

// ── 7. Custom user-defined BlockHandler (Timer pattern) ────────────

test "custom Timer BlockHandler — enter and exit lifecycle" {
    reset_log()
    with make_timer("db_query", 10) as elapsed {
        assert_eq(elapsed, 0)
        log.push("working")
    }
    assert_eq(log.len(), 3)
    assert_eq(log.get(0).unwrap(), "timer.enter:10")
    assert_eq(log.get(1).unwrap(), "working")
    assert_eq(log.get(2).unwrap(), "timer.exit:10:ok=true")
}

// ── 8. Multiple BlockHandlers in same with statement ───────────────

test "multiple handlers — both entered, both exited in LIFO" {
    reset_log()
    with make_timer("t", 1), make_conn(2) as tx {
        log.push("body:" + tx.conn_id.to_string())
    }
    assert_eq(log.len(), 5)
    assert_eq(log.get(0).unwrap(), "timer.enter:1")
    assert_eq(log.get(1).unwrap(), "conn.enter:2")
    assert_eq(log.get(2).unwrap(), "body:2")
    assert_eq(log.get(3).unwrap(), "conn.exit:2:ok=true")
    assert_eq(log.get(4).unwrap(), "timer.exit:1:ok=true")
}

// ── 9. Nested with early return — both levels get ok=false ─────────

test "nested with early return — inner and outer exit ok=false" {
    reset_log()
    fn_nested_early_return()
    assert_eq(log.len(), 5)
    assert_eq(log.get(0).unwrap(), "timer.enter:1")
    assert_eq(log.get(1).unwrap(), "conn.enter:2")
    assert_eq(log.get(2).unwrap(), "deep-body")
    assert_eq(log.get(3).unwrap(), "conn.exit:2:ok=false")
    assert_eq(log.get(4).unwrap(), "timer.exit:1:ok=false")
}
