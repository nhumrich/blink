import compile_test_helpers

test "Bytes.as_ptr outside with_ptr emits E0817" {
    let src = "fn main() \{ let b = Bytes(); let _ = b.as_ptr() }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_e0817_outside", "E0817")
}

test "as_ptr() on a non-Bytes receiver does not emit E0817" {
    let src = "fn main() \{ let s: Str = \"hi\"; let _ = s.as_ptr() }\n"
    compile_test_helpers.expect_no_error(src, "ffi_e0817_str_ok", "E0817")
}

test "Bytes.as_ptr inside with_ptr does not emit E0817" {
    let src = "fn main() \{ let b = Bytes(); let _ = b.with_ptr(fn(p) \{ b.as_ptr() }) }\n"
    compile_test_helpers.expect_no_error(src, "ffi_e0817_inside_ok", "E0817")
}
