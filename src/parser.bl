// ── Token input ─────────────────────────────────────────────────────

pub let mut pos: Int = 0

// ── Token navigation ────────────────────────────────────────────────

fn peek_kind() -> TokenKind {
    if pos >= tokens.len() {
        return TokenKind.EOF
    }
    tokens.get(pos).unwrap().kind
}

fn peek_kind_at(p: Int) -> TokenKind {
    if p >= tokens.len() {
        return TokenKind.EOF
    }
    tokens.get(p).unwrap().kind
}

fn peek_value() -> Str {
    if pos >= tokens.len() {
        return ""
    }
    tokens.get(pos).unwrap().value
}

fn peek_line() -> Int {
    let p = if pos >= tokens.len() { tokens.len() - 1 } else { pos }
    if p < 0 { return 1 }
    tokens.get(p).unwrap().line
}

fn peek_col() -> Int {
    let p = if pos >= tokens.len() { tokens.len() - 1 } else { pos }
    if p < 0 { return 1 }
    tokens.get(p).unwrap().col
}

fn peek_end_col() -> Int {
    let p = if pos >= tokens.len() { tokens.len() - 1 } else { pos }
    if p < 0 { return 1 }
    tokens.get(p).unwrap().end_col
}

fn at(kind: TokenKind) -> Int {
    peek_kind() == kind
}

fn advance() -> Int ! Parse.Advance {
    let old = pos
    pos = pos + 1
    old
}

fn advance_value() -> Str ! Parse.Advance {
    if pos >= tokens.len() {
        return ""
    }
    let v = tokens.get(pos).unwrap().value
    pos = pos + 1
    v
}

fn expect(kind: TokenKind) -> Int ! Parse.Advance, Diag.Report {
    if peek_kind() != kind {
        diag_error_range("UnexpectedToken", "E1100", "expected {token_kind_name(kind)}, got {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
    }
    advance()
}

fn expect_value(kind: TokenKind) -> Str ! Parse.Advance, Diag.Report {
    if peek_kind() != kind {
        if kind == TokenKind.Ident && is_keyword(peek_kind()) {
            diag_error_range("KeywordAsIdentifier", "E1103", "'{peek_value()}' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        } else {
            diag_error_range("UnexpectedToken", "E1100", "expected {token_kind_name(kind)}, got {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
        }
    }
    advance_value()
}

fn skip_newlines() ! Parse.Advance {
    while at(TokenKind.Newline) {
        advance()
    }
}

fn skip_newlines_and_comments() ! Parse.Advance {
    while at(TokenKind.Newline) || at(TokenKind.Comment) || at(TokenKind.DocComment) {
        advance()
    }
}

fn maybe_newline() ! Parse.Advance {
    if at(TokenKind.Newline) {
        advance()
    }
}

fn attach_pending_annotations(node: Int) ! Parse.Build {
    if annotation_nodes.len() > 0 {
        let anns_sl = new_sublist()
        let mut ai = 0
        while ai < annotation_nodes.len() {
            sublist_push(anns_sl, annotation_nodes.get(ai).unwrap())
            ai = ai + 1
        }
        finalize_sublist(anns_sl)
        node_set_handlers(node, anns_sl)
        annotation_nodes = []
    }
}

// ── Import statements ────────────────────────────────────────────────

fn parse_import_stmt() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    // 'import' already consumed
    let mut path = expect_value(TokenKind.Ident)
    while at(TokenKind.Dot) {
        advance()
        if at(TokenKind.LBrace) {
            break
        }
        path = path.concat(".").concat(expect_value(TokenKind.Ident))
    }

    let imp_line = peek_line()
    let imp_col = peek_col()
    let mut names_sl = -1
    if at(TokenKind.LBrace) {
        advance()
        skip_newlines_and_comments()
        names_sl = new_sublist()
        while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
            let item_line = peek_line()
            let item_col = peek_col()
            let item_name = expect_value(TokenKind.Ident)
            let mut item_alias = ""
            if at(TokenKind.As) {
                advance()
                item_alias = expect_value(TokenKind.Ident)
            }
            let name_node = node_count()
            nodes.push(AstNode {
                kind: NodeKind.Ident, name: item_name, str_val: item_alias,
                line: item_line, col: item_col,
            })
            sublist_push(names_sl, name_node)
            skip_newlines_and_comments()
            if at(TokenKind.Comma) {
                advance()
                skip_newlines_and_comments()
            }
        }
        expect(TokenKind.RBrace)
        finalize_sublist(names_sl)
    }

    let node = node_count()
    nodes.push(AstNode {
        kind: NodeKind.ImportStmt, str_val: path, args: names_sl,
        line: imp_line, col: imp_col,
    })
    node
}

// ── Top-level ───────────────────────────────────────────────────────

pub fn parse_program() -> Int ! Parse, Diag.Report {
    if trace_mode != "" { trace("parse", "start ({tokens.len()} tokens)") }
    let mut fn_nodes: List[Int] = []
    let mut type_nodes: List[Int] = []
    let mut let_nodes: List[Int] = []
    let mut trait_nodes: List[Int] = []
    let mut impl_nodes: List[Int] = []
    let mut import_nodes: List[Int] = []
    let mut effect_decl_nodes: List[Int] = []
    let mut test_nodes: List[Int] = []
    annotation_nodes = []
    skip_newlines_and_comments()
    while !at(TokenKind.EOF) {
        skip_newlines_and_comments()
        if at(TokenKind.EOF) {
            break
        }
        if at(TokenKind.At) {
            let ann_start_line = peek_line()
            let ann_start_col = peek_col()
            advance()
            let mut ann_name = if is_keyword(peek_kind()) { advance_value() } else { expect_value(TokenKind.Ident) }
            while at(TokenKind.Dot) {
                advance()
                let ann_part = if is_keyword(peek_kind()) { advance_value() } else { expect_value(TokenKind.Ident) }
                ann_name = ann_name.concat(".").concat(ann_part)
            }
            let mut ann_args_sl = -1
            if at(TokenKind.LParen) {
                advance()
                skip_newlines_and_comments()
                let mut ann_arg_nodes: List[Int] = []
                if ann_name == "requires" || ann_name == "ensures" || ann_name == "invariant" {
                    let expr_nd = parse_expr()
                    ann_arg_nodes.push(expr_nd)
                    skip_newlines_and_comments()
                } else {
                    while !at(TokenKind.RParen) && !at(TokenKind.EOF) {
                        if at(TokenKind.StringStart) {
                            let str_nd = parse_interp_string()
                            ann_arg_nodes.push(str_nd)
                        } else {
                            let arg_name = expect_value(TokenKind.Ident)
                            let mut full_arg = arg_name
                            if at(TokenKind.Colon) {
                                advance()
                                skip_newlines_and_comments()
                                if at(TokenKind.StringStart) {
                                    let val_nd = parse_interp_string()
                                    node_set_name(val_nd, full_arg)
                                    ann_arg_nodes.push(val_nd)
                                } else {
                                    let val_name = expect_value(TokenKind.Ident)
                                    let kv_nd = node_count()
                                    nodes.push(AstNode { kind: NodeKind.Ident, name: full_arg.concat(":").concat(val_name), line: peek_line(), col: peek_col() })
                                    ann_arg_nodes.push(kv_nd)
                                }
                            } else {
                                if at(TokenKind.Dot) {
                                    advance()
                                    let child = expect_value(TokenKind.Ident)
                                    full_arg = full_arg.concat(".").concat(child)
                                }
                                let arg_nd = node_count()
                                nodes.push(AstNode { kind: NodeKind.Ident, name: full_arg, line: peek_line(), col: peek_col() })
                                ann_arg_nodes.push(arg_nd)
                            }
                        }
                        skip_newlines_and_comments()
                        if at(TokenKind.Comma) {
                            advance()
                            skip_newlines_and_comments()
                        }
                    }
                }
                expect(TokenKind.RParen)
                if ann_arg_nodes.len() > 0 {
                    ann_args_sl = new_sublist()
                    let mut ai = 0
                    while ai < ann_arg_nodes.len() {
                        sublist_push(ann_args_sl, ann_arg_nodes.get(ai).unwrap())
                        ai = ai + 1
                    }
                    finalize_sublist(ann_args_sl)
                }
            }
            let ann_nd = node_count()
            nodes.push(AstNode {
                kind: NodeKind.Annotation, name: ann_name, args: ann_args_sl,
                line: ann_start_line, col: ann_start_col,
            })
            if ann_name == "capabilities" {
                program_annotation_nodes.push(ann_nd)
            } else {
                annotation_nodes.push(ann_nd)
            }
            skip_newlines_and_comments()
        } else if at(TokenKind.Import) {
            advance()
            let imp = parse_import_stmt()
            import_nodes.push(imp)
            skip_newlines_and_comments()
        } else if at(TokenKind.Type) {
            let td = parse_type_def()
            attach_pending_annotations(td)
            type_nodes.push(td)
        } else if at(TokenKind.Trait) {
            let tr = parse_trait_def()
            attach_pending_annotations(tr)
            trait_nodes.push(tr)
        } else if at(TokenKind.Impl) {
            let im = parse_impl_block()
            attach_pending_annotations(im)
            impl_nodes.push(im)
        } else if at(TokenKind.Let) {
            let lb = parse_let_binding()
            attach_pending_annotations(lb)
            let_nodes.push(lb)
        } else if at(TokenKind.Const) {
            let cb = parse_const_binding()
            attach_pending_annotations(cb)
            let_nodes.push(cb)
        } else if at(TokenKind.Pub) {
            advance()
            skip_newlines_and_comments()
            if at(TokenKind.Fn) {
                let f = parse_fn_def()
                node_set_is_pub(f, 1)
                attach_pending_annotations(f)
                fn_nodes.push(f)
            } else if at(TokenKind.Type) {
                let td = parse_type_def()
                node_set_is_pub(td, 1)
                attach_pending_annotations(td)
                type_nodes.push(td)
            } else if at(TokenKind.Trait) {
                let tr = parse_trait_def()
                node_set_is_pub(tr, 1)
                attach_pending_annotations(tr)
                trait_nodes.push(tr)
            } else if at(TokenKind.Let) {
                let lb = parse_let_binding()
                node_set_is_pub(lb, 1)
                attach_pending_annotations(lb)
                let_nodes.push(lb)
            } else if at(TokenKind.Const) {
                let cb = parse_const_binding()
                node_set_is_pub(cb, 1)
                attach_pending_annotations(cb)
                let_nodes.push(cb)
            } else if at(TokenKind.Effect) {
                let ed = parse_effect_decl()
                node_set_is_pub(ed, 1)
                attach_pending_annotations(ed)
                effect_decl_nodes.push(ed)
            } else if at(TokenKind.Import) {
                advance()
                let imp = parse_import_stmt()
                node_set_is_pub(imp, 1)
                attach_pending_annotations(imp)
                import_nodes.push(imp)
            } else {
                diag_error_range("UnexpectedToken", "E1100", "expected fn, type, trait, or effect after pub", peek_line(), peek_col(), peek_end_col(), "")
                advance()
            }
        } else if at(TokenKind.Effect) {
            let ed = parse_effect_decl()
            attach_pending_annotations(ed)
            effect_decl_nodes.push(ed)
        } else if at(TokenKind.Test) {
            advance()
            let tb = parse_test_block()
            attach_pending_annotations(tb)
            test_nodes.push(tb)
        } else if at(TokenKind.Fn) {
            let f = parse_fn_def()
            attach_pending_annotations(f)
            fn_nodes.push(f)
        } else if at(TokenKind.Mod) {
            let mod_line = peek_line()
            let mod_col = peek_col()
            advance()
            if at(TokenKind.Ident) {
                advance()
            }
            skip_newlines_and_comments()
            if at(TokenKind.LBrace) {
                advance()
                let mut depth = 1
                while depth > 0 && !at(TokenKind.EOF) {
                    if at(TokenKind.LBrace) {
                        depth = depth + 1
                    } else if at(TokenKind.RBrace) {
                        depth = depth - 1
                    }
                    advance()
                }
            }
            diag_error("InlineModuleNotSupported", "E1015", "inline modules are not supported; create a separate file and use 'import' instead (see section 10.1.1)", mod_line, mod_col, "Blink uses file-based modules: one file = one module")
        } else {
            diag_error_range("UnexpectedToken", "E1100", "unexpected token at top level: {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
            advance()
        }
        skip_newlines_and_comments()
    }
    // Build sublists from collected node IDs
    let fns = new_sublist()
    let mut i = 0
    while i < fn_nodes.len() {
        sublist_push(fns, fn_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(fns)
    let types = new_sublist()
    i = 0
    while i < type_nodes.len() {
        sublist_push(types, type_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(types)
    let lets = new_sublist()
    i = 0
    while i < let_nodes.len() {
        sublist_push(lets, let_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(lets)
    let traits = new_sublist()
    i = 0
    while i < trait_nodes.len() {
        sublist_push(traits, trait_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(traits)
    let impls = new_sublist()
    i = 0
    while i < impl_nodes.len() {
        sublist_push(impls, impl_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(impls)
    let imports = new_sublist()
    i = 0
    while i < import_nodes.len() {
        sublist_push(imports, import_nodes.get(i).unwrap())
        i = i + 1
    }
    finalize_sublist(imports)
    let mut effect_decls = -1
    if effect_decl_nodes.len() > 0 {
        effect_decls = new_sublist()
        i = 0
        while i < effect_decl_nodes.len() {
            sublist_push(effect_decls, effect_decl_nodes.get(i).unwrap())
            i = i + 1
        }
        finalize_sublist(effect_decls)
    }
    let mut annotations_sl = -1
    if annotation_nodes.len() > 0 || program_annotation_nodes.len() > 0 {
        annotations_sl = new_sublist()
        i = 0
        while i < program_annotation_nodes.len() {
            sublist_push(annotations_sl, program_annotation_nodes.get(i).unwrap())
            i = i + 1
        }
        i = 0
        while i < annotation_nodes.len() {
            sublist_push(annotations_sl, annotation_nodes.get(i).unwrap())
            i = i + 1
        }
        finalize_sublist(annotations_sl)
    }
    // captures field on Program is reused to store collected test block nodes
    let mut tests_sl = -1
    if test_nodes.len() > 0 {
        tests_sl = new_sublist()
        i = 0
        while i < test_nodes.len() {
            sublist_push(tests_sl, test_nodes.get(i).unwrap())
            i = i + 1
        }
        finalize_sublist(tests_sl)
    }
    let prog = node_count()
    nodes.push(AstNode {
        kind: NodeKind.Program,
        params: fns, fields: types, stmts: lets, arms: traits,
        methods: impls, elements: imports, args: effect_decls,
        handlers: annotations_sl, captures: tests_sl,
        line: peek_line(), col: peek_col(),
    })
    if trace_mode != "" { trace("parse", "done ({fn_nodes.len()} fns, {type_nodes.len()} types, {import_nodes.len()} imports)") }
    prog
}

// ── Type parameters ──────────────────────────────────────────────────

fn parse_type_params() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    if !at(TokenKind.LBracket) {
        return -1
    }
    advance()
    let sl = new_sublist()
    let pname = expect_value(TokenKind.Ident)
    let mut bounds_sl = -1
    if at(TokenKind.Colon) {
        advance()
        bounds_sl = new_sublist()
        sublist_push(bounds_sl, parse_type_annotation())
        while at(TokenKind.Plus) {
            advance()
            skip_newlines()
            sublist_push(bounds_sl, parse_type_annotation())
        }
        finalize_sublist(bounds_sl)
    }
    let tp = node_count()
    nodes.push(AstNode {
        kind: NodeKind.TypeParam, name: pname, elements: bounds_sl,
        line: peek_line(), col: peek_col(),
    })
    sublist_push(sl, tp)
    while at(TokenKind.Comma) {
        advance()
        skip_newlines()
        let pn2 = expect_value(TokenKind.Ident)
        let mut bs2 = -1
        if at(TokenKind.Colon) {
            advance()
            bs2 = new_sublist()
            sublist_push(bs2, parse_type_annotation())
            while at(TokenKind.Plus) {
                advance()
                skip_newlines()
                sublist_push(bs2, parse_type_annotation())
            }
            finalize_sublist(bs2)
        }
        let tp2 = node_count()
        nodes.push(AstNode {
            kind: NodeKind.TypeParam, name: pn2, elements: bs2,
            line: peek_line(), col: peek_col(),
        })
        sublist_push(sl, tp2)
    }
    expect(TokenKind.RBracket)
    finalize_sublist(sl)
    sl
}

// ── Type definitions ────────────────────────────────────────────────

fn parse_type_def() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let td_start_line = peek_line()
    let td_start_col = peek_col()
    expect(TokenKind.Type)
    let name = expect_value(TokenKind.Ident)
    let tparams = parse_type_params()
    skip_newlines_and_comments()
    let mut flds = -1
    let mut td_end_line = -1
    let mut td_end_col = -1
    if at(TokenKind.Equals) {
        advance()
        let alias_type = parse_type_annotation()
        let mut where_expr = -1
        if at(TokenKind.At) {
            advance()
            let ann_name = expect_value(TokenKind.Ident)
            if ann_name == "where" {
                expect(TokenKind.LParen)
                where_expr = parse_expr()
                expect(TokenKind.RParen)
            } else {
                diag_error_range("UnexpectedAnnotation", "E1100", "only @where is supported on type aliases, got @{ann_name}", peek_line(), peek_col(), peek_end_col(), "use @where(predicate) to add a refinement constraint")
            }
        }
        let td = node_count()
        nodes.push(AstNode {
            kind: NodeKind.TypeDef,
            name: name, type_params: tparams,
            value: alias_type, condition: where_expr,
            line: td_start_line, col: td_start_col,
        })
        return td
    }
    if at(TokenKind.LBrace) {
        expect(TokenKind.LBrace)
        skip_newlines_and_comments()
        flds = new_sublist()
        while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
            if at(TokenKind.At) {
                advance()
                let _ann_name = expect_value(TokenKind.Ident)
                if at(TokenKind.LParen) {
                    advance()
                    skip_newlines_and_comments()
                    let mut depth = 1
                    while depth > 0 && !at(TokenKind.EOF) {
                        if at(TokenKind.LParen) {
                            depth = depth + 1
                        } else if at(TokenKind.RParen) {
                            depth = depth - 1
                            if depth == 0 {
                                break
                            }
                        }
                        advance()
                    }
                    expect(TokenKind.RParen)
                }
                skip_newlines_and_comments()
                continue
            }
            if at(TokenKind.EOF) {
                break
            }
            if at(TokenKind.Mut) {
                diag_error_range("MutFieldNotSupported", "E1109", "'mut' is not valid on struct fields — mutability is controlled by the binding (let mut)", peek_line(), peek_col(), peek_end_col(), "remove 'mut' from the field declaration; use 'let mut' when binding the struct")
                while at(TokenKind.Mut) {
                    advance()
                }
            }
            let fname = expect_value(TokenKind.Ident)
            if at(TokenKind.Colon) {
                advance()
                let type_ann = parse_type_annotation()
                let tf_line = peek_line()
                let tf_col = peek_col()
                let mut tf_default = -1
                if at(TokenKind.Equals) {
                    advance()
                    skip_newlines_and_comments()
                    tf_default = parse_expr()
                }
                let tf = node_count()
                nodes.push(AstNode {
                    kind: NodeKind.TypeField,
                    name: fname, value: type_ann, condition: tf_default,
                    line: tf_line, col: tf_col,
                })
                sublist_push(flds, tf)
            } else if at(TokenKind.LParen) {
                advance()
                skip_newlines_and_comments()
                let mut vflds = -1
                if !at(TokenKind.RParen) {
                    vflds = new_sublist()
                    if at(TokenKind.Mut) {
                        diag_error_range("MutFieldNotSupported", "E1109", "'mut' is not valid on struct fields — mutability is controlled by the binding (let mut)", peek_line(), peek_col(), peek_end_col(), "remove 'mut' from the field declaration; use 'let mut' when binding the struct")
                        while at(TokenKind.Mut) {
                            advance()
                        }
                    }
                    let vf_name = expect_value(TokenKind.Ident)
                    if at(TokenKind.Colon) {
                        advance()
                        let vf_type = parse_type_annotation()
                        let vf = node_count()
                        nodes.push(AstNode {
                            kind: NodeKind.TypeField, name: vf_name, value: vf_type,
                            line: peek_line(), col: peek_col(),
                        })
                        sublist_push(vflds, vf)
                        while at(TokenKind.Comma) {
                            advance()
                            skip_newlines_and_comments()
                            if at(TokenKind.RParen) {
                                break
                            }
                            if at(TokenKind.Mut) {
                                diag_error_range("MutFieldNotSupported", "E1109", "'mut' is not valid on struct fields — mutability is controlled by the binding (let mut)", peek_line(), peek_col(), peek_end_col(), "remove 'mut' from the field declaration; use 'let mut' when binding the struct")
                                while at(TokenKind.Mut) {
                                    advance()
                                }
                            }
                            let vf_name2 = expect_value(TokenKind.Ident)
                            expect(TokenKind.Colon)
                            let vf_type2 = parse_type_annotation()
                            let vf2 = node_count()
                            nodes.push(AstNode {
                                kind: NodeKind.TypeField, name: vf_name2, value: vf_type2,
                                line: peek_line(), col: peek_col(),
                            })
                            sublist_push(vflds, vf2)
                        }
                    } else {
                        // Positional variant fields: skip to closing paren
                        let mut paren_depth = 1
                        while paren_depth > 0 && !at(TokenKind.EOF) {
                            if at(TokenKind.LParen) {
                                paren_depth = paren_depth + 1
                            } else if at(TokenKind.RParen) {
                                paren_depth = paren_depth - 1
                                if paren_depth == 0 {
                                    break
                                }
                            }
                            advance()
                        }
                    }
                    finalize_sublist(vflds)
                }
                skip_newlines_and_comments()
                expect(TokenKind.RParen)
                let tv = node_count()
                nodes.push(AstNode {
                    kind: NodeKind.TypeVariant, name: fname, fields: vflds,
                    line: peek_line(), col: peek_col(),
                })
                sublist_push(flds, tv)
            } else if at(TokenKind.LBrace) {
                // Struct-style variant: VariantName { field: Type, ... }
                advance()
                skip_newlines_and_comments()
                let mut vflds = new_sublist()
                while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
                    if at(TokenKind.Mut) {
                        diag_error_range("MutFieldNotSupported", "E1109", "'mut' is not valid on struct fields — mutability is controlled by the binding (let mut)", peek_line(), peek_col(), peek_end_col(), "remove 'mut' from the field declaration; use 'let mut' when binding the struct")
                        while at(TokenKind.Mut) {
                            advance()
                        }
                    }
                    let vf_name = expect_value(TokenKind.Ident)
                    expect(TokenKind.Colon)
                    let vf_type = parse_type_annotation()
                    let vf = node_count()
                    nodes.push(AstNode {
                        kind: NodeKind.TypeField, name: vf_name, value: vf_type,
                        line: peek_line(), col: peek_col(),
                    })
                    sublist_push(vflds, vf)
                    if at(TokenKind.Comma) {
                        advance()
                    }
                    skip_newlines_and_comments()
                }
                finalize_sublist(vflds)
                expect(TokenKind.RBrace)
                let tv = node_count()
                // int_val = 1: reuse shared AstNode flag to distinguish struct-style from tuple-style
                nodes.push(AstNode {
                    kind: NodeKind.TypeVariant, name: fname, fields: vflds, int_val: 1,
                    line: peek_line(), col: peek_col(),
                })
                sublist_push(flds, tv)
            } else {
                let tv_line = peek_line()
                let tv_col = peek_col()
                let mut tv_str = ""
                if at(TokenKind.Equals) {
                    advance()
                    skip_newlines_and_comments()
                    let str_node = parse_interp_string()
                    let parts_sl = node_elements(str_node)
                    if parts_sl != -1 && sublist_length(parts_sl) == 1 {
                        let part = sublist_get(parts_sl, 0)
                        tv_str = node_str_val(part)
                    } else {
                        diag_error_range("InvalidStringBackedEnum", "E1200", "string-backed enum values must be plain string literals", peek_line(), peek_col(), peek_end_col(), "use a simple string like = \"value\"")
                    }
                }
                let tv = node_count()
                nodes.push(AstNode {
                    kind: NodeKind.TypeVariant, name: fname, str_val: tv_str,
                    line: tv_line, col: tv_col,
                })
                sublist_push(flds, tv)
            }
            if at(TokenKind.Comma) {
                advance()
            }
            skip_newlines_and_comments()
        }
        td_end_line = peek_line()
        td_end_col = peek_col()
        expect(TokenKind.RBrace)
        finalize_sublist(flds)
    }
    let td = node_count()
    nodes.push(AstNode {
        kind: NodeKind.TypeDef,
        name: name, fields: flds, type_params: tparams,
        line: td_start_line, col: td_start_col,
        end_line: td_end_line, end_col: td_end_col,
    })
    td
}

fn parse_type_annotation() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    if at(TokenKind.LBracket) {
        advance()
        skip_newlines()
        let inner = parse_type_annotation()
        skip_newlines()
        expect(TokenKind.RBracket)
        let elems = new_sublist()
        sublist_push(elems, inner)
        finalize_sublist(elems)
        let ta = node_count()
        nodes.push(AstNode { kind: NodeKind.TypeAnn, name: "List", elements: elems, line: peek_line(), col: peek_col() })
        return ta
    }
    if at(TokenKind.LParen) {
        advance()
        skip_newlines()
        let elems = new_sublist()
        sublist_push(elems, parse_type_annotation())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            sublist_push(elems, parse_type_annotation())
        }
        skip_newlines()
        expect(TokenKind.RParen)
        finalize_sublist(elems)
        let ta = node_count()
        nodes.push(AstNode { kind: NodeKind.TypeAnn, name: "Tuple", elements: elems, line: peek_line(), col: peek_col() })
        return ta
    }
    if at(TokenKind.Fn) {
        advance()
        expect(TokenKind.LParen)
        let mut elems = -1
        if !at(TokenKind.RParen) {
            elems = new_sublist()
            sublist_push(elems, parse_type_annotation())
            while at(TokenKind.Comma) {
                advance()
                skip_newlines()
                sublist_push(elems, parse_type_annotation())
            }
            finalize_sublist(elems)
        }
        expect(TokenKind.RParen)
        let mut ret_name = "Void"
        let mut ret_ann = -1
        if at(TokenKind.Arrow) {
            advance()
            let rt = parse_type_annotation()
            ret_name = node_name(rt)
            ret_ann = rt
        }
        let ta = node_count()
        nodes.push(AstNode {
            kind: NodeKind.TypeAnn, name: "Fn", elements: elems,
            return_type: ret_name, type_ann: ret_ann,
            line: peek_line(), col: peek_col(),
        })
        return ta
    }
    if at(TokenKind.Handler) {
        advance()
        expect(TokenKind.LBracket)
        let eff_ann = parse_type_annotation()
        expect(TokenKind.RBracket)
        let elems = new_sublist()
        sublist_push(elems, eff_ann)
        finalize_sublist(elems)
        let ta = node_count()
        nodes.push(AstNode { kind: NodeKind.TypeAnn, name: "Handler", elements: elems, line: peek_line(), col: peek_col() })
        return ta
    }
    let mut name = expect_value(TokenKind.Ident)
    if at(TokenKind.Dot) {
        advance()
        let qualified = expect_value(TokenKind.Ident)
        name = name + "." + qualified
    }
    let mut elems = -1
    if at(TokenKind.LBracket) {
        advance()
        elems = new_sublist()
        sublist_push(elems, parse_type_annotation())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            sublist_push(elems, parse_type_annotation())
        }
        expect(TokenKind.RBracket)
        finalize_sublist(elems)
    }
    let ta = node_count()
    nodes.push(AstNode { kind: NodeKind.TypeAnn, name: name, elements: elems, line: peek_line(), col: peek_col() })
    if at(TokenKind.Question) {
        advance()
        let inner_sl = new_sublist()
        sublist_push(inner_sl, ta)
        finalize_sublist(inner_sl)
        let opt = node_count()
        nodes.push(AstNode { kind: NodeKind.TypeAnn, name: "Option", elements: inner_sl, line: peek_line(), col: peek_col() })
        return opt
    }
    ta
}

// ── Effect declarations ─────────────────────────────────────────────

fn parse_effect_op_sig() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    expect(TokenKind.Fn)
    let op_name = expect_value(TokenKind.Ident)
    expect(TokenKind.LParen)
    let params_sl = new_sublist()
    skip_newlines()
    if !at(TokenKind.RParen) {
        sublist_push(params_sl, parse_param())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            if at(TokenKind.RParen) {
                break
            }
            sublist_push(params_sl, parse_param())
        }
        skip_newlines()
    }
    expect(TokenKind.RParen)
    finalize_sublist(params_sl)
    let mut ret_str = ""
    let mut ret_ann = -1
    if at(TokenKind.Arrow) {
        advance()
        let rt = parse_type_annotation()
        ret_str = node_name(rt)
        ret_ann = rt
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.FnDef,
        name: op_name, params: params_sl,
        return_type: ret_str, type_ann: ret_ann,
        line: peek_line(), col: peek_col(),
    })
    nd
}

fn parse_effect_decl() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let eff_start_line = peek_line()
    let eff_start_col = peek_col()
    expect(TokenKind.Effect)
    let name = expect_value(TokenKind.Ident)
    skip_newlines_and_comments()
    if at(TokenKind.LBrace) {
        advance()
        skip_newlines_and_comments()
        let children_sl = new_sublist()
        while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
            expect(TokenKind.Effect)
            let child_name = expect_value(TokenKind.Ident)
            skip_newlines_and_comments()
            let mut child_methods_sl = -1
            if at(TokenKind.LBrace) {
                advance()
                skip_newlines_and_comments()
                child_methods_sl = new_sublist()
                while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
                    sublist_push(child_methods_sl, parse_effect_op_sig())
                    skip_newlines_and_comments()
                }
                expect(TokenKind.RBrace)
                finalize_sublist(child_methods_sl)
            }
            let child = node_count()
            nodes.push(AstNode {
                kind: NodeKind.EffectDecl, name: child_name, methods: child_methods_sl,
                line: peek_line(), col: peek_col(),
            })
            sublist_push(children_sl, child)
            skip_newlines_and_comments()
            if at(TokenKind.Comma) {
                advance()
            }
            skip_newlines_and_comments()
        }
        expect(TokenKind.RBrace)
        finalize_sublist(children_sl)
        let nd = node_count()
        nodes.push(AstNode {
            kind: NodeKind.EffectDecl, name: name, elements: children_sl,
            line: eff_start_line, col: eff_start_col,
        })
        return nd
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.EffectDecl, name: name,
        line: eff_start_line, col: eff_start_col,
    })
    nd
}

// ── Function definitions ────────────────────────────────────────────

fn parse_fn_def() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let fn_start_line = peek_line()
    let fn_start_col = peek_col()
    expect(TokenKind.Fn)
    let name = expect_value(TokenKind.Ident)
    let tparams = parse_type_params()
    expect(TokenKind.LParen)
    let params = new_sublist()
    let mut kw_only = 0
    skip_newlines()
    if at(TokenKind.DashDash) {
        advance()
        kw_only = 1
    }
    if !at(TokenKind.RParen) {
        let p = parse_param()
        if kw_only { node_set_int_val(p, 1) }
        sublist_push(params, p)
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            if at(TokenKind.RParen) {
                break
            }
            if at(TokenKind.DashDash) {
                advance()
                kw_only = 1
            }
            let p2 = parse_param()
            if kw_only { node_set_int_val(p2, 1) }
            sublist_push(params, p2)
        }
        skip_newlines()
    }
    expect(TokenKind.RParen)
    finalize_sublist(params)
    let mut ret_str = ""
    let mut ret_ann = -1
    if at(TokenKind.Arrow) {
        advance()
        let rt = parse_type_annotation()
        ret_str = node_name(rt)
        ret_ann = rt
    }
    let mut effects_sl = -1
    if at(TokenKind.Bang) {
        advance()
        effects_sl = new_sublist()
        let mut eff_name = expect_value(TokenKind.Ident)
        if at(TokenKind.Dot) {
            advance()
            eff_name = eff_name.concat(".").concat(expect_value(TokenKind.Ident))
        }
        let eff = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: eff_name, line: peek_line(), col: peek_col() })
        sublist_push(effects_sl, eff)
        while at(TokenKind.Comma) {
            advance()
            skip_newlines_and_comments()
            let mut eff_name2 = expect_value(TokenKind.Ident)
            if at(TokenKind.Dot) {
                advance()
                eff_name2 = eff_name2.concat(".").concat(expect_value(TokenKind.Ident))
            }
            let eff2 = node_count()
            nodes.push(AstNode { kind: NodeKind.Ident, name: eff_name2, line: peek_line(), col: peek_col() })
            sublist_push(effects_sl, eff2)
        }
        finalize_sublist(effects_sl)
    }
    skip_newlines()
    let mut body_id = -1
    if at(TokenKind.LBrace) {
        body_id = parse_block()
    }
    let mut fn_end_l = -1
    let mut fn_end_c = -1
    if body_id != -1 {
        let el = node_end_line(body_id)
        if el != -1 {
            fn_end_l = el
            fn_end_c = node_end_col(body_id)
        }
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.FnDef,
        name: name, params: params, body: body_id,
        return_type: ret_str, type_params: tparams,
        effects: effects_sl, type_ann: ret_ann,
        line: fn_start_line, col: fn_start_col,
        end_line: fn_end_l, end_col: fn_end_c,
    })
    nd
}

// ── Test blocks ──────────────────────────────────────────────────────

fn parse_test_block() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let test_start_line = peek_line()
    let test_start_col = peek_col()
    // 'test' already consumed — but we capture line from the string token
    let name_node = parse_interp_string()
    let name_parts_sl = node_elements(name_node)
    let mut test_name = ""
    if name_parts_sl != -1 && sublist_length(name_parts_sl) > 0 {
        test_name = node_str_val(sublist_get(name_parts_sl, 0))
    }
    skip_newlines_and_comments()
    let body = parse_block()
    let mut tb_end_l = -1
    let mut tb_end_c = -1
    let el = node_end_line(body)
    if el != -1 {
        tb_end_l = el
        tb_end_c = node_end_col(body)
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.TestBlock,
        str_val: test_name, name: test_name, body: body,
        line: test_start_line, col: test_start_col,
        end_line: tb_end_l, end_col: tb_end_c,
    })
    nd
}

fn parse_param() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut is_mut = 0
    if at(TokenKind.Mut) {
        is_mut = 1
        advance()
    }
    let mut name = ""
    if at(TokenKind.Self) {
        name = "self"
        advance()
    } else {
        name = expect_value(TokenKind.Ident)
    }
    let mut type_str = ""
    let mut type_ann_id = -1
    if at(TokenKind.Colon) {
        advance()
        let ta = parse_type_annotation()
        type_str = node_name(ta)
        type_ann_id = ta
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.Param,
        name: name, type_name: type_str,
        is_mut: is_mut, type_ann: type_ann_id,
        line: peek_line(), col: peek_col(),
    })
    nd
}

fn parse_closure() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    expect(TokenKind.Fn)
    expect(TokenKind.LParen)
    let params = new_sublist()
    let mut cl_kw_only = 0
    skip_newlines()
    if at(TokenKind.DashDash) {
        advance()
        cl_kw_only = 1
    }
    if !at(TokenKind.RParen) {
        let cp = parse_param()
        if cl_kw_only { node_set_int_val(cp, 1) }
        sublist_push(params, cp)
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            if at(TokenKind.RParen) {
                break
            }
            if at(TokenKind.DashDash) {
                advance()
                cl_kw_only = 1
            }
            let cp2 = parse_param()
            if cl_kw_only { node_set_int_val(cp2, 1) }
            sublist_push(params, cp2)
        }
        skip_newlines()
    }
    expect(TokenKind.RParen)
    finalize_sublist(params)
    let mut ret_str = ""
    let mut ret_ann = -1
    if at(TokenKind.Arrow) {
        advance()
        let rt = parse_type_annotation()
        ret_str = node_name(rt)
        ret_ann = rt
    }
    skip_newlines_and_comments()
    let body_id = parse_block()
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.Closure,
        params: params, body: body_id,
        return_type: ret_str, type_ann: ret_ann,
        line: peek_line(), col: peek_col(),
    })
    nd
}

// ── Trait definitions ────────────────────────────────────────────────

fn parse_trait_def() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let trait_start_line = peek_line()
    let trait_start_col = peek_col()
    expect(TokenKind.Trait)
    let name = expect_value(TokenKind.Ident)
    let mut trait_type_args = -1
    if at(TokenKind.LBracket) {
        advance()
        trait_type_args = new_sublist()
        sublist_push(trait_type_args, parse_type_annotation())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            sublist_push(trait_type_args, parse_type_annotation())
        }
        expect(TokenKind.RBracket)
        finalize_sublist(trait_type_args)
    }
    skip_newlines_and_comments()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let assoc_types = new_sublist()
    let methods = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        if at(TokenKind.Fn) {
            let fn_node = parse_fn_def()
            sublist_push(methods, fn_node)
        } else if at(TokenKind.Type) {
            advance()
            let atype_name = expect_value(TokenKind.Ident)
            let at_node = node_count()
            nodes.push(AstNode { kind: NodeKind.AssocType, name: atype_name, line: peek_line(), col: peek_col() })
            sublist_push(assoc_types, at_node)
        } else {
            advance()
        }
        skip_newlines_and_comments()
    }
    let trait_end_line = peek_line()
    let trait_end_col = peek_col()
    expect(TokenKind.RBrace)
    finalize_sublist(methods)
    finalize_sublist(assoc_types)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.TraitDef,
        name: name, methods: methods, assoc_types: assoc_types,
        type_params: trait_type_args,
        line: trait_start_line, col: trait_start_col,
        end_line: trait_end_line, end_col: trait_end_col,
    })
    nd
}

// ── Impl blocks ─────────────────────────────────────────────────────

fn parse_impl_block() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let impl_start_line = peek_line()
    let impl_start_col = peek_col()
    expect(TokenKind.Impl)
    let trait_name = expect_value(TokenKind.Ident)
    let mut trait_type_args = -1
    if at(TokenKind.LBracket) {
        advance()
        trait_type_args = new_sublist()
        sublist_push(trait_type_args, parse_type_annotation())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            sublist_push(trait_type_args, parse_type_annotation())
        }
        expect(TokenKind.RBracket)
        finalize_sublist(trait_type_args)
    }
    skip_newlines_and_comments()
    let mut type_name = ""
    if at(TokenKind.For) {
        advance()
        skip_newlines_and_comments()
        type_name = expect_value(TokenKind.Ident)
    }
    skip_newlines_and_comments()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let assoc_types = new_sublist()
    let methods = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        if at(TokenKind.Fn) {
            let fn_node = parse_fn_def()
            sublist_push(methods, fn_node)
        } else if at(TokenKind.Type) {
            advance()
            let atype_name = expect_value(TokenKind.Ident)
            expect(TokenKind.Equals)
            let ta = parse_type_annotation()
            let concrete_name = node_name(ta)
            let at_node = node_count()
            nodes.push(AstNode {
                kind: NodeKind.AssocType,
                name: atype_name, type_name: concrete_name, type_ann: ta,
                line: peek_line(), col: peek_col(),
            })
            sublist_push(assoc_types, at_node)
        } else {
            advance()
        }
        skip_newlines_and_comments()
    }
    let impl_end_line = peek_line()
    let impl_end_col = peek_col()
    expect(TokenKind.RBrace)
    finalize_sublist(methods)
    finalize_sublist(assoc_types)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.ImplBlock,
        trait_name: trait_name, name: type_name,
        methods: methods, assoc_types: assoc_types,
        type_params: trait_type_args,
        line: impl_start_line, col: impl_start_col,
        end_line: impl_end_line, end_col: impl_end_col,
    })
    nd
}

// ── Handler expressions ──────────────────────────────────────────────

fn parse_handler_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    expect(TokenKind.Handler)
    let effect_name = expect_value(TokenKind.Ident)
    let mut full_name = effect_name
    if at(TokenKind.Dot) {
        advance()
        let child = expect_value(TokenKind.Ident)
        full_name = full_name.concat(".").concat(child)
    }
    skip_newlines_and_comments()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let methods = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        if at(TokenKind.Fn) {
            sublist_push(methods, parse_fn_def())
        } else {
            advance()
        }
        skip_newlines_and_comments()
    }
    expect(TokenKind.RBrace)
    finalize_sublist(methods)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.HandlerExpr, name: full_name, methods: methods,
        line: peek_line(), col: peek_col(),
    })
    nd
}

// ── With blocks ─────────────────────────────────────────────────────

fn parse_with_item() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let expr = parse_expr()
    if at(TokenKind.Equals) {
        let mut lhs_name = ""
        if node_kind(expr) != NodeKind.Ident {
            diag_error_range("UnexpectedToken", "E1100", "left side of `=` in with-clause must be an identifier", peek_line(), peek_col(), peek_end_col(), "")
        } else {
            lhs_name = node_name(expr)
        }
        advance()
        skip_newlines_and_comments()
        let rhs = parse_expr()
        if !at(TokenKind.As) {
            diag_error_range("UnexpectedToken", "E1100", "expected `as <name>` after `{lhs_name} = <expr>` in with-clause, got {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
            let wr = node_count()
            nodes.push(AstNode {
                kind: NodeKind.WithResource, value: rhs, name: lhs_name,
                line: peek_line(), col: peek_col(),
            })
            return wr
        }
        advance()
        let mut binding = ""
        if at(TokenKind.Ident) {
            binding = advance_value()
        } else {
            diag_error_range("UnexpectedToken", "E1100", "expected identifier after `as` in with-clause, got {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
            binding = lhs_name
        }
        if binding != lhs_name && lhs_name != "" {
            diag_error_range("UnexpectedToken", "E1100", "with-clause binding name `{binding}` must match left side `{lhs_name}`", peek_line(), peek_col(), peek_end_col(), "")
        }
        let wr = node_count()
        nodes.push(AstNode {
            kind: NodeKind.WithResource, value: rhs, name: binding,
            line: peek_line(), col: peek_col(),
        })
        return wr
    }
    if at(TokenKind.As) {
        advance()
        let binding = expect_value(TokenKind.Ident)
        let wr = node_count()
        nodes.push(AstNode {
            kind: NodeKind.WithResource, value: expr, name: binding,
            line: peek_line(), col: peek_col(),
        })
        return wr
    }
    expr
}

fn parse_with_block() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    expect(TokenKind.With)
    let handlers_sl = new_sublist()
    sublist_push(handlers_sl, parse_with_item())
    while at(TokenKind.Comma) {
        advance()
        skip_newlines_and_comments()
        sublist_push(handlers_sl, parse_with_item())
    }
    skip_newlines_and_comments()
    let body = parse_block()
    finalize_sublist(handlers_sl)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.WithBlock, handlers: handlers_sl, body: body,
        line: peek_line(), col: peek_col(),
    })
    nd
}

// ── Block ───────────────────────────────────────────────────────────

fn parse_block() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let block_start_line = peek_line()
    let block_start_col = peek_col()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let stmts = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        let stmt = parse_stmt()
        sublist_push(stmts, stmt)
        skip_newlines_and_comments()
    }
    let rbrace_line = peek_line()
    let rbrace_col = peek_col()
    expect(TokenKind.RBrace)
    finalize_sublist(stmts)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.Block, stmts: stmts,
        line: block_start_line, col: block_start_col,
        end_line: rbrace_line, end_col: rbrace_col,
    })
    nd
}

// ── Statements ──────────────────────────────────────────────────────

fn parse_stmt() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    if at(TokenKind.While) {
        let nd = parse_while_loop()
        return nd
    }
    if at(TokenKind.Loop) {
        let nd = parse_loop_expr()
        return nd
    }
    if at(TokenKind.Break) {
        advance()
        maybe_newline()
        let nd = new_node(NodeKind.Break)
        return nd
    }
    if at(TokenKind.Continue) {
        advance()
        maybe_newline()
        let nd = new_node(NodeKind.Continue)
        return nd
    }
    if at(TokenKind.Let) {
        let nd = parse_let_binding()
        return nd
    }
    if at(TokenKind.Const) {
        let nd = parse_const_binding()
        return nd
    }
    if at(TokenKind.For) {
        let nd = parse_for_in()
        return nd
    }
    if at(TokenKind.Return) {
        let nd = parse_return_stmt()
        return nd
    }
    if at(TokenKind.If) {
        let nd = parse_if_expr()
        maybe_newline()
        return nd
    }
    if at(TokenKind.With) {
        let nd = parse_with_block()
        maybe_newline()
        return nd
    }

    if at(TokenKind.Assert) || at(TokenKind.AssertEq) || at(TokenKind.AssertNe) {
        let assert_kind = peek_kind()
        let mut assert_name = "assert"
        if assert_kind == TokenKind.AssertEq {
            assert_name = "assert_eq"
        } else if assert_kind == TokenKind.AssertNe {
            assert_name = "assert_ne"
        }
        advance()
        expect(TokenKind.LParen)
        let args_sl = new_sublist()
        sublist_push(args_sl, parse_expr())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines_and_comments()
            if at(TokenKind.RParen) {
                break
            }
            sublist_push(args_sl, parse_expr())
        }
        expect(TokenKind.RParen)
        finalize_sublist(args_sl)
        let fn_ident = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: assert_name, line: peek_line(), col: peek_col() })
        let call_nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Call, left: fn_ident, args: args_sl, line: peek_line(), col: peek_col() })
        maybe_newline()
        let stmt_nd = node_count()
        nodes.push(AstNode { kind: NodeKind.ExprStmt, value: call_nd, line: peek_line(), col: peek_col() })
        return stmt_nd
    }

    let expr = parse_expr()

    if at(TokenKind.Equals) {
        advance()
        skip_newlines_and_comments()
        let val = parse_expr()
        maybe_newline()
        let nd = node_count()
        nodes.push(AstNode {
            kind: NodeKind.Assignment, target: expr, value: val,
            line: node_line(expr), col: node_col(expr),
        })
        return nd
    }

    if at(TokenKind.PlusEq) || at(TokenKind.MinusEq) || at(TokenKind.StarEq) || at(TokenKind.SlashEq) {
        let op_kind = peek_kind()
        advance()
        skip_newlines_and_comments()
        let val = parse_expr()
        maybe_newline()
        let mut op_str = "+"
        if op_kind == TokenKind.MinusEq {
            op_str = "-"
        } else if op_kind == TokenKind.StarEq {
            op_str = "*"
        } else if op_kind == TokenKind.SlashEq {
            op_str = "/"
        }
        let nd = node_count()
        nodes.push(AstNode {
            kind: NodeKind.CompoundAssign, op: op_str,
            target: expr, value: val,
            line: node_line(expr), col: node_col(expr),
        })
        return nd
    }

    maybe_newline()
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.ExprStmt, value: expr,
        line: node_line(expr), col: node_col(expr),
    })
    nd
}

fn parse_let_binding() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let let_start_line = peek_line()
    let let_start_col = peek_col()
    expect(TokenKind.Let)
    let mut is_mut = 0
    if at(TokenKind.Mut) {
        is_mut = 1
        advance()
    }
    let mut name = ""
    let mut pat = -1
    if at(TokenKind.LParen) {
        pat = parse_pattern()
        name = "_destructure"
    } else {
        name = expect_value(TokenKind.Ident)
    }
    let mut type_ann = -1
    if at(TokenKind.Colon) {
        advance()
        type_ann = parse_type_annotation()
    }
    expect(TokenKind.Equals)
    skip_newlines_and_comments()
    let val = parse_expr()
    maybe_newline()
    let mut let_elems = -1
    if pat != -1 {
        let_elems = pat
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.LetBinding,
        name: name, value: val, is_mut: is_mut, target: type_ann,
        elements: let_elems,
        line: let_start_line, col: let_start_col,
    })
    nd
}

fn parse_const_binding() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let const_start_line = peek_line()
    let const_start_col = peek_col()
    expect(TokenKind.Const)
    let name = expect_value(TokenKind.Ident)
    let mut type_ann = -1
    if at(TokenKind.Colon) {
        advance()
        type_ann = parse_type_annotation()
    }
    expect(TokenKind.Equals)
    skip_newlines_and_comments()
    let val = parse_expr()
    maybe_newline()
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.LetBinding,
        name: name, value: val, is_const: 1, target: type_ann,
        line: const_start_line, col: const_start_col,
    })
    nd
}

fn parse_embed_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    expect(TokenKind.Hash)
    let intrinsic = expect_value(TokenKind.Ident)
    if intrinsic != "embed" {
        diag_error_range("UnknownIntrinsic", "E1108", "unknown compile-time intrinsic '#{intrinsic}' (only #embed is supported)", peek_line(), peek_col(), peek_end_col(), "")
        let nd = new_node(NodeKind.IntLit)
        return nd
    }
    expect(TokenKind.LParen)
    expect(TokenKind.StringStart)
    let path = expect_value(TokenKind.StringPart)
    expect(TokenKind.StringEnd)
    expect(TokenKind.RParen)
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.EmbedExpr, str_val: path,
        line: peek_line(), col: peek_col(),
    })
    nd
}

fn parse_return_stmt() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let ret_start_line = peek_line()
    let ret_start_col = peek_col()
    expect(TokenKind.Return)
    if at(TokenKind.Newline) || at(TokenKind.RBrace) || at(TokenKind.EOF) {
        maybe_newline()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Return, line: ret_start_line, col: ret_start_col })
        return nd
    }
    let val = parse_expr()
    maybe_newline()
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.Return, value: val, line: ret_start_line, col: ret_start_col })
    nd
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn parse_if_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let if_start_line = peek_line()
    let if_start_col = peek_col()
    expect(TokenKind.If)
    skip_newlines_and_comments()
    let cond = parse_expr()
    skip_newlines_and_comments()
    let then_b = parse_block()
    let mut else_b = -1
    let mut peek_pos = pos
    while peek_pos < tokens.len() && (peek_kind_at(peek_pos) == TokenKind.Newline || peek_kind_at(peek_pos) == TokenKind.Comment || peek_kind_at(peek_pos) == TokenKind.DocComment) {
        peek_pos = peek_pos + 1
    }
    if peek_pos < tokens.len() && peek_kind_at(peek_pos) == TokenKind.Else {
        skip_newlines_and_comments()
    }
    if at(TokenKind.Else) {
        advance()
        skip_newlines_and_comments()
        if at(TokenKind.If) {
            let inner = parse_if_expr()
            let stmts = new_sublist()
            sublist_push(stmts, inner)
            finalize_sublist(stmts)
            let blk = node_count()
            nodes.push(AstNode { kind: NodeKind.Block, stmts: stmts, line: peek_line(), col: peek_col() })
            else_b = blk
        } else {
            else_b = parse_block()
        }
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.IfExpr,
        condition: cond, then_body: then_b, else_body: else_b,
        line: if_start_line, col: if_start_col,
    })
    nd
}

fn parse_while_loop() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let while_start_line = peek_line()
    let while_start_col = peek_col()
    expect(TokenKind.While)
    skip_newlines_and_comments()
    let cond = parse_expr()
    skip_newlines_and_comments()
    let body = parse_block()
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.WhileLoop, condition: cond, body: body,
        line: while_start_line, col: while_start_col,
    })
    nd
}

fn parse_loop_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let loop_start_line = peek_line()
    let loop_start_col = peek_col()
    expect(TokenKind.Loop)
    skip_newlines_and_comments()
    let body = parse_block()
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.LoopExpr, body: body,
        line: loop_start_line, col: loop_start_col,
    })
    nd
}

fn parse_for_in() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let for_start_line = peek_line()
    let for_start_col = peek_col()
    expect(TokenKind.For)
    let mut var = ""
    let mut pat = -1
    if at(TokenKind.LParen) {
        pat = parse_pattern()
        var = "_tuple"
    } else {
        var = expect_value(TokenKind.Ident)
    }
    expect(TokenKind.In)
    let iter = parse_expr()
    skip_newlines_and_comments()
    let body = parse_block()
    let mut for_elems = -1
    if pat != -1 {
        for_elems = pat
    }
    let nd = node_count()
    nodes.push(AstNode {
        kind: NodeKind.ForIn, var_name: var, iterable: iter, body: body,
        elements: for_elems,
        line: for_start_line, col: for_start_col,
    })
    nd
}

// ── Expressions (precedence climbing) ───────────────────────────────

fn parse_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    parse_nullcoalesce()
}

fn parse_nullcoalesce() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_or()
    while at(TokenKind.DoubleQuestion) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_or()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "??", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_or() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_and()
    while at(TokenKind.Or) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_and()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "||", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_and() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_bit_or()
    while at(TokenKind.And) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_bit_or()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "&&", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_bit_or() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_bit_xor()
    while at(TokenKind.Pipe) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_bit_xor()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "|", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_bit_xor() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_bit_and()
    while at(TokenKind.Caret) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_bit_and()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "^", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_bit_and() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_equality()
    while at(TokenKind.Amp) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        skip_newlines()
        let right = parse_equality()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: "&", left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_equality() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_comparison()
    while at(TokenKind.EqEq) || at(TokenKind.NotEq) {
        let op_line = peek_line()
        let op_col = peek_col()
        let op = advance_value()
        skip_newlines()
        let right = parse_comparison()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: op, left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_comparison() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_additive()
    while at(TokenKind.Less) || at(TokenKind.Greater) || at(TokenKind.LessEq) || at(TokenKind.GreaterEq) {
        let op_line = peek_line()
        let op_col = peek_col()
        let op = advance_value()
        skip_newlines()
        let right = parse_additive()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: op, left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_additive() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_shift()
    while at(TokenKind.Plus) || at(TokenKind.Minus) {
        let op_line = peek_line()
        let op_col = peek_col()
        let op = advance_value()
        skip_newlines()
        let right = parse_shift()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: op, left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_shift() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_multiplicative()
    while at(TokenKind.Shl) || at(TokenKind.Shr) {
        let op_line = peek_line()
        let op_col = peek_col()
        let op = advance_value()
        skip_newlines()
        let right = parse_multiplicative()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: op, left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_multiplicative() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut left = parse_unary()
    while at(TokenKind.Star) || at(TokenKind.Slash) || at(TokenKind.Percent) {
        let op_line = peek_line()
        let op_col = peek_col()
        let op = advance_value()
        skip_newlines()
        let right = parse_unary()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.BinOp, op: op, left: left, right: right, line: op_line, col: op_col })
        left = nd
    }
    left
}

fn parse_unary() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    if at(TokenKind.Minus) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        let operand = parse_unary()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.UnaryOp, op: "-", left: operand, line: op_line, col: op_col })
        return nd
    }
    if at(TokenKind.Bang) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        let operand = parse_unary()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.UnaryOp, op: "!", left: operand, line: op_line, col: op_col })
        return nd
    }
    if at(TokenKind.Tilde) {
        let op_line = peek_line()
        let op_col = peek_col()
        advance()
        let operand = parse_unary()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.UnaryOp, op: "~", left: operand, line: op_line, col: op_col })
        return nd
    }
    parse_postfix()
}

// ── Postfix: calls, field access, index, method calls ───────────────

@allow(UnrestoredMutation, IncompleteStateRestore)
fn parse_postfix() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mut node = parse_primary()
    let mut running = 1
    while running {
        if at(TokenKind.Dot) {
            advance()
            let mut member = ""
            if at(TokenKind.Int) {
                member = peek_value()
                advance()
            } else {
                member = expect_value(TokenKind.Ident)
            }
            // async.scope { body }
            if member == "scope" && node_kind(node) == NodeKind.Ident && node_name(node) == "async" && at(TokenKind.LBrace) {
                let body = parse_block()
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.AsyncScope, body: body, line: node_line(node), col: node_col(node) })
                node = nd
            // .await — postfix await on handles
            } else if member == "await" {
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.AwaitExpr, obj: node, line: node_line(node), col: node_col(node) })
                node = nd
            // channel.new[T](buffer) — typed channel constructor
            } else if member == "new" && node_kind(node) == NodeKind.Ident && node_name(node) == "channel" && at(TokenKind.LBracket) {
                let tparams = parse_type_params()
                expect(TokenKind.LParen)
                let cn_args = new_sublist()
                if !at(TokenKind.RParen) {
                    sublist_push(cn_args, parse_maybe_named_arg())
                    while at(TokenKind.Comma) {
                        advance()
                        skip_newlines()
                        sublist_push(cn_args, parse_maybe_named_arg())
                    }
                }
                expect(TokenKind.RParen)
                finalize_sublist(cn_args)
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.ChannelNew, type_params: tparams, args: cn_args, line: node_line(node), col: node_col(node) })
                node = nd
            } else if at(TokenKind.LParen) {
                advance()
                let args = new_sublist()
                if !at(TokenKind.RParen) {
                    skip_newlines()
                    sublist_push(args, parse_maybe_named_arg())
                    while at(TokenKind.Comma) {
                        advance()
                        skip_newlines()
                        if at(TokenKind.RParen) {
                            break
                        }
                        sublist_push(args, parse_maybe_named_arg())
                    }
                    skip_newlines()
                }
                expect(TokenKind.RParen)
                finalize_sublist(args)
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.MethodCall, obj: node, method: member, args: args, line: node_line(node), col: node_col(node) })
                node = nd
            } else {
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.FieldAccess, obj: node, name: member, line: node_line(node), col: node_col(node) })
                node = nd
                // Check for struct literal after field access (e.g. Foo.Bar { ... })
                if at(TokenKind.LBrace) {
                    if looks_like_struct_lit() {
                        // Reconstruct dotted name
                        let dotted = flatten_field_access(node)
                        if dotted.is_some() {
                            node = parse_struct_lit(dotted.unwrap())
                        }
                    }
                }
            }
        } else if at(TokenKind.LParen) {
            advance()
            let args = new_sublist()
            if !at(TokenKind.RParen) {
                skip_newlines()
                sublist_push(args, parse_maybe_named_arg())
                while at(TokenKind.Comma) {
                    advance()
                    skip_newlines()
                    if at(TokenKind.RParen) {
                        break
                    }
                    sublist_push(args, parse_maybe_named_arg())
                }
                skip_newlines()
            }
            expect(TokenKind.RParen)
            finalize_sublist(args)
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.Call, left: node, args: args, line: node_line(node), col: node_col(node) })
            node = nd
        } else if at(TokenKind.LBracket) {
            advance()
            skip_newlines()
            let idx = parse_expr()
            skip_newlines()
            expect(TokenKind.RBracket)
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.IndexExpr, obj: node, index: idx, line: node_line(node), col: node_col(node) })
            node = nd
        } else if at(TokenKind.Question) {
            advance()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.UnaryOp, op: "?", left: node, line: node_line(node), col: node_col(node) })
            node = nd
        } else if at(TokenKind.Newline) || at(TokenKind.Comment) {
            let mut peek_pos = pos
            while peek_pos < tokens.len() && (peek_kind_at(peek_pos) == TokenKind.Newline || peek_kind_at(peek_pos) == TokenKind.Comment || peek_kind_at(peek_pos) == TokenKind.DocComment) {
                peek_pos = peek_pos + 1
            }
            if peek_pos < tokens.len() && peek_kind_at(peek_pos) == TokenKind.Dot {
                skip_newlines()
            } else {
                running = 0
            }
        } else {
            running = 0
        }
    }
    node
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn skip_named_arg_label() ! Parse.Advance {
    if at(TokenKind.Ident) {
        let saved = pos
        advance()
        if at(TokenKind.Colon) {
            advance()
            skip_newlines()
        } else {
            pos = saved
        }
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn parse_maybe_named_arg() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    if at(TokenKind.Ident) {
        let saved = pos
        let na_line = peek_line()
        let na_col = peek_col()
        let label = peek_value()
        advance()
        if at(TokenKind.Colon) {
            advance()
            skip_newlines()
            let inner = parse_expr()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.NamedArg, name: label, value: inner, line: na_line, col: na_col })
            return nd
        } else {
            pos = saved
        }
    }
    parse_expr()
}

fn flatten_field_access(node: Int) -> Option[Str] {
    let kind = node_kind(node)
    if kind == NodeKind.Ident {
        return Some(node_name(node))
    }
    if kind == NodeKind.FieldAccess {
        let base = flatten_field_access(node_obj(node))
        if base.is_some() {
            return Some(base.unwrap() + "." + node_name(node))
        }
    }
    None
}

fn looks_like_struct_lit() -> Int {
    // Side-effect-free lookahead: peek past { and whitespace/comments
    // to check for "ident :" pattern without collecting comments
    let mut peek_pos = pos
    if peek_pos >= tokens.len() || peek_kind_at(peek_pos) != TokenKind.LBrace {
        return 0
    }
    peek_pos = peek_pos + 1
    while peek_pos < tokens.len() && (peek_kind_at(peek_pos) == TokenKind.Newline || peek_kind_at(peek_pos) == TokenKind.Comment || peek_kind_at(peek_pos) == TokenKind.DocComment) {
        peek_pos = peek_pos + 1
    }
    if peek_pos >= tokens.len() {
        return 0
    }
    if peek_kind_at(peek_pos) == TokenKind.RBrace {
        return 1
    }
    if peek_kind_at(peek_pos) == TokenKind.DotDot {
        return 1
    }
    if peek_kind_at(peek_pos) != TokenKind.Ident {
        return 0
    }
    peek_pos = peek_pos + 1
    if peek_pos < tokens.len() && peek_kind_at(peek_pos) == TokenKind.Colon {
        return 1
    }
    0
}

// ── Primary expressions ─────────────────────────────────────────────

fn parse_primary() -> Int ! Diag.Report, Parse.Advance, Parse.Build {
    let pm_line = peek_line()
    let pm_col = peek_col()
    if at(TokenKind.Match) {
        let next_pos = pos + 1
        let next_ok = next_pos < tokens.len() && peek_kind_at(next_pos) != TokenKind.RParen && peek_kind_at(next_pos) != TokenKind.RBrace && peek_kind_at(next_pos) != TokenKind.Comma && peek_kind_at(next_pos) != TokenKind.Dot && peek_kind_at(next_pos) != TokenKind.Newline && peek_kind_at(next_pos) != TokenKind.EOF && peek_kind_at(next_pos) != TokenKind.Equals && peek_kind_at(next_pos) != TokenKind.EqEq && peek_kind_at(next_pos) != TokenKind.RBracket && peek_kind_at(next_pos) != TokenKind.StringEnd && peek_kind_at(next_pos) != TokenKind.InterpEnd
        if next_ok {
            return parse_match_expr()
        }
        diag_error_range("KeywordAsIdentifier", "E1103", "'match' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "match", line: pm_line, col: pm_col })
        return nd
    }
    if at(TokenKind.If) {
        let next_pos = pos + 1
        let next_ok = next_pos < tokens.len() && peek_kind_at(next_pos) != TokenKind.RParen && peek_kind_at(next_pos) != TokenKind.RBrace && peek_kind_at(next_pos) != TokenKind.Comma && peek_kind_at(next_pos) != TokenKind.Dot && peek_kind_at(next_pos) != TokenKind.Newline && peek_kind_at(next_pos) != TokenKind.EOF && peek_kind_at(next_pos) != TokenKind.Equals && peek_kind_at(next_pos) != TokenKind.EqEq && peek_kind_at(next_pos) != TokenKind.RBracket && peek_kind_at(next_pos) != TokenKind.StringEnd && peek_kind_at(next_pos) != TokenKind.InterpEnd
        if next_ok {
            return parse_if_expr()
        }
        diag_error_range("KeywordAsIdentifier", "E1103", "'if' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "if", line: pm_line, col: pm_col })
        return nd
    }
    if at(TokenKind.Self) {
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "self", line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.Fn) {
        let next_pos = pos + 1
        if next_pos < tokens.len() && peek_kind_at(next_pos) == TokenKind.LParen {
            return parse_closure()
        }
        diag_error_range("KeywordAsIdentifier", "E1103", "'fn' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "fn", line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.Handler) {
        // Check if this is a handler expression (handler EffectName { ... })
        // vs a keyword used as a variable name (e.g. fn foo(handler: Int) { handler })
        let next_pos = pos + 1
        if next_pos < tokens.len() && peek_kind_at(next_pos) == TokenKind.Ident {
            return parse_handler_expr()
        }
        // Keyword used as identifier — emit error and treat as ident
        diag_error_range("KeywordAsIdentifier", "E1103", "'handler' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "handler", line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.With) {
        let next_pos = pos + 1
        let next_ok = next_pos < tokens.len() && peek_kind_at(next_pos) != TokenKind.RParen && peek_kind_at(next_pos) != TokenKind.RBrace && peek_kind_at(next_pos) != TokenKind.Comma && peek_kind_at(next_pos) != TokenKind.Dot && peek_kind_at(next_pos) != TokenKind.Newline && peek_kind_at(next_pos) != TokenKind.EOF && peek_kind_at(next_pos) != TokenKind.Equals && peek_kind_at(next_pos) != TokenKind.EqEq && peek_kind_at(next_pos) != TokenKind.RBracket && peek_kind_at(next_pos) != TokenKind.StringEnd && peek_kind_at(next_pos) != TokenKind.InterpEnd
        if next_ok {
            return parse_with_block()
        }
        diag_error_range("KeywordAsIdentifier", "E1103", "'with' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: "with", line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.Ident) {
        let name = advance_value()
        if name == "true" {
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.BoolLit, int_val: 1, line: pm_line, col: pm_col })
            return nd
        }
        if name == "false" {
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.BoolLit, int_val: 0, line: pm_line, col: pm_col })
            return nd
        }
        if at(TokenKind.LBrace) && looks_like_struct_lit() {
            return parse_struct_lit(name)
        }
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: name, line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.Int) {
        let val_str = advance_value()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.IntLit, str_val: val_str, line: pm_line, col: pm_col })
        // Check for range
        if at(TokenKind.DotDot) {
            advance()
            let end_nd = parse_primary()
            let rng = node_count()
            nodes.push(AstNode { kind: NodeKind.RangeLit, start: nd, end: end_nd, line: pm_line, col: pm_col })
            return rng
        }
        if at(TokenKind.DotDoteq) {
            advance()
            let end_nd = parse_primary()
            let rng = node_count()
            nodes.push(AstNode { kind: NodeKind.RangeLit, start: nd, end: end_nd, inclusive: 1, line: pm_line, col: pm_col })
            return rng
        }
        return nd
    }

    if at(TokenKind.Float) {
        let val_str = advance_value()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.FloatLit, str_val: val_str, line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.CharLit) {
        let val_str = advance_value()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.CharLit, str_val: val_str, line: pm_line, col: pm_col })
        return nd
    }

    if at(TokenKind.LParen) {
        advance()
        skip_newlines()
        if at(TokenKind.RParen) {
            advance()
            // Unit / empty tuple — represent as int lit 0 for simplicity
            return new_node(NodeKind.IntLit)
        }
        let first = parse_expr()
        if at(TokenKind.Comma) {
            let elems = new_sublist()
            sublist_push(elems, first)
            while at(TokenKind.Comma) {
                advance()
                skip_newlines()
                if at(TokenKind.RParen) {
                    break
                }
                sublist_push(elems, parse_expr())
            }
            expect(TokenKind.RParen)
            finalize_sublist(elems)
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.TupleLit, elements: elems, line: pm_line, col: pm_col })
            return nd
        }
        skip_newlines()
        expect(TokenKind.RParen)
        return first
    }

    if at(TokenKind.Hash) {
        return parse_embed_expr()
    }

    if at(TokenKind.LBracket) {
        return parse_list_lit()
    }

    if at(TokenKind.StringStart) {
        return parse_interp_string()
    }

    if at(TokenKind.LBrace) {
        if tokens.get(pos + 1).unwrap().kind == TokenKind.RBrace {
            diag_error_range("EmptyBraceExpr", "E1107", "empty '\{\}' is not a valid expression — use Map() for empty maps", peek_line(), peek_col(), peek_end_col(), "replace '\{\}' with 'Map()'")
            advance()
            advance()
            return new_node(NodeKind.IntLit)
        }
        return parse_block()
    }

    if is_keyword(peek_kind()) {
        let kw_name = peek_value()
        diag_error_range("KeywordAsIdentifier", "E1103", "'{kw_name}' is a keyword and cannot be used as an identifier", peek_line(), peek_col(), peek_end_col(), "use a different name")
        advance()
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.Ident, name: kw_name, line: pm_line, col: pm_col })
        return nd
    }

    diag_error_range("UnexpectedToken", "E1100", "unexpected token {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
    advance()
    new_node(NodeKind.IntLit)
}

fn parse_struct_lit(type_name: Str) -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let sl_line = peek_line()
    let sl_col = peek_col()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let flds = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        if at(TokenKind.DotDot) {
            let sp_line = peek_line()
            let sp_col = peek_col()
            advance()
            let spread_src = parse_expr()
            let sp = node_count()
            nodes.push(AstNode { kind: NodeKind.SpreadExpr, value: spread_src, line: sp_line, col: sp_col })
            sublist_push(flds, sp)
            if at(TokenKind.Comma) {
                advance()
            }
            skip_newlines_and_comments()
            break
        }
        let fld_line = peek_line()
        let fld_col = peek_col()
        let fname = expect_value(TokenKind.Ident)
        expect(TokenKind.Colon)
        skip_newlines()
        let fval = parse_expr()
        let sf = node_count()
        nodes.push(AstNode { kind: NodeKind.StructLitField, name: fname, value: fval, line: fld_line, col: fld_col })
        sublist_push(flds, sf)
        if at(TokenKind.Comma) {
            advance()
        }
        skip_newlines_and_comments()
    }
    expect(TokenKind.RBrace)
    finalize_sublist(flds)
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.StructLit, type_name: type_name, fields: flds, line: sl_line, col: sl_col })
    nd
}

fn parse_list_lit() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let ll_line = peek_line()
    let ll_col = peek_col()
    expect(TokenKind.LBracket)
    skip_newlines_and_comments()
    let elems = new_sublist()
    while !at(TokenKind.RBracket) && !at(TokenKind.EOF) {
        if at(TokenKind.DotDot) {
            let sp_line = peek_line()
            let sp_col = peek_col()
            advance()
            let spread_src = parse_expr()
            let sp = node_count()
            nodes.push(AstNode { kind: NodeKind.SpreadExpr, value: spread_src, line: sp_line, col: sp_col })
            sublist_push(elems, sp)
        } else {
            sublist_push(elems, parse_expr())
        }
        if at(TokenKind.Comma) {
            advance()
        }
        skip_newlines_and_comments()
    }
    expect(TokenKind.RBracket)
    finalize_sublist(elems)
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.ListLit, elements: elems, line: ll_line, col: ll_col })
    nd
}

fn parse_interp_string() -> Int ! Diag.Report, Parse.Advance, Parse.Build {
    let is_line = peek_line()
    let is_col = peek_col()
    expect(TokenKind.StringStart)
    let parts = new_sublist()
    while !at(TokenKind.StringEnd) && !at(TokenKind.EOF) {
        if at(TokenKind.StringPart) {
            let sp_line = peek_line()
            let sp_col = peek_col()
            let s = advance_value()
            let sn = node_count()
            nodes.push(AstNode { kind: NodeKind.Ident, str_val: s, name: s, line: sp_line, col: sp_col })
            sublist_push(parts, sn)
        } else if at(TokenKind.InterpStart) {
            advance()
            sublist_push(parts, parse_expr())
            expect(TokenKind.InterpEnd)
        } else {
            diag_error_range("UnexpectedToken", "E1101", "unexpected token in string: {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
            advance()
        }
    }
    expect(TokenKind.StringEnd)
    finalize_sublist(parts)
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.InterpString, elements: parts, line: is_line, col: is_col })
    nd
}

// ── Match ───────────────────────────────────────────────────────────

fn parse_match_expr() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let mx_line = peek_line()
    let mx_col = peek_col()
    expect(TokenKind.Match)
    let scrut = parse_expr()
    skip_newlines_and_comments()
    expect(TokenKind.LBrace)
    skip_newlines_and_comments()
    let arms = new_sublist()
    while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
        sublist_push(arms, parse_match_arm())
        skip_newlines_and_comments()
    }
    expect(TokenKind.RBrace)
    finalize_sublist(arms)
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.MatchExpr, scrutinee: scrut, arms: arms, line: mx_line, col: mx_col })
    nd
}

fn parse_match_arm() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let ma_line = peek_line()
    let ma_col = peek_col()
    let pat = parse_pattern()
    let mut guard = -1
    skip_newlines_and_comments()
    if at(TokenKind.If) {
        advance()
        guard = parse_expr()
    }
    skip_newlines_and_comments()
    expect(TokenKind.FatArrow)
    skip_newlines_and_comments()
    let mut body = -1
    if at(TokenKind.LBrace) {
        body = parse_block()
    } else {
        body = parse_stmt()
    }
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.MatchArm, pattern: pat, body: body, guard: guard, line: ma_line, col: ma_col })
    nd
}

fn parse_pattern() -> Int ! Parse.Advance, Parse.Build, Diag.Report {
    let first = parse_single_pattern()
    if !at(TokenKind.Pipe) {
        return first
    }
    let alts = new_sublist()
    sublist_push(alts, first)
    while at(TokenKind.Pipe) {
        advance()
        skip_newlines()
        sublist_push(alts, parse_single_pattern())
    }
    finalize_sublist(alts)
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.OrPattern, elements: alts, line: node_line(first), col: node_col(first) })
    nd
}

fn parse_single_pattern() -> Int ! Diag.Report, Parse.Advance, Parse.Build {
    let sp_line = peek_line()
    let sp_col = peek_col()
    if at(TokenKind.LBracket) {
        advance()
        skip_newlines()
        if at(TokenKind.RBracket) {
            advance()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.ListPattern, line: sp_line, col: sp_col })
            return nd
        }
        let elems = new_sublist()
        let mut has_rest = 0
        sublist_push(elems, parse_pattern())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            if at(TokenKind.DotDot) {
                advance()
                if at(TokenKind.Dot) {
                    advance()
                }
                has_rest = 1
                skip_newlines()
                if at(TokenKind.Comma) {
                    advance()
                    skip_newlines()
                }
                break
            }
            if at(TokenKind.RBracket) {
                break
            }
            sublist_push(elems, parse_pattern())
        }
        skip_newlines()
        expect(TokenKind.RBracket)
        finalize_sublist(elems)
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.ListPattern, elements: elems, inclusive: has_rest, line: sp_line, col: sp_col })
        return nd
    }
    if at(TokenKind.LParen) {
        advance()
        skip_newlines()
        let elems = new_sublist()
        sublist_push(elems, parse_pattern())
        while at(TokenKind.Comma) {
            advance()
            skip_newlines()
            sublist_push(elems, parse_pattern())
        }
        skip_newlines()
        expect(TokenKind.RParen)
        finalize_sublist(elems)
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.TuplePattern, elements: elems, line: sp_line, col: sp_col })
        return nd
    }
    if at(TokenKind.StringStart) {
        let str_node = parse_interp_string()
        let parts_sl = node_elements(str_node)
        let mut str_val = ""
        if parts_sl != -1 && sublist_length(parts_sl) == 1 {
            str_val = node_str_val(sublist_get(parts_sl, 0))
        }
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.StringPattern, str_val: str_val, line: sp_line, col: sp_col })
        return nd
    }
    if at(TokenKind.Int) {
        let v = advance_value()
        if at(TokenKind.DotDot) {
            advance()
            let hi = advance_value()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.RangePattern, str_val: v, name: hi, line: sp_line, col: sp_col })
            return nd
        }
        if at(TokenKind.DotDoteq) {
            advance()
            let hi = advance_value()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.RangePattern, str_val: v, name: hi, inclusive: 1, line: sp_line, col: sp_col })
            return nd
        }
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.IntPattern, str_val: v, line: sp_line, col: sp_col })
        return nd
    }
    if at(TokenKind.CharLit) {
        let v = advance_value()
        if at(TokenKind.DotDot) {
            advance()
            let hi = advance_value()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.RangePattern, str_val: v, name: hi, line: sp_line, col: sp_col })
            return nd
        }
        if at(TokenKind.DotDoteq) {
            advance()
            let hi = advance_value()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.RangePattern, str_val: v, name: hi, inclusive: 1, line: sp_line, col: sp_col })
            return nd
        }
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.IntPattern, str_val: v, line: sp_line, col: sp_col })
        return nd
    }
    if at(TokenKind.Ident) {
        let name = advance_value()
        if name == "_" {
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.WildcardPattern, line: sp_line, col: sp_col })
            return nd
        }
        if name == "true" {
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.IntPattern, str_val: "1", line: sp_line, col: sp_col })
            return nd
        }
        if name == "false" {
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.IntPattern, str_val: "0", line: sp_line, col: sp_col })
            return nd
        }
        // Qualified variant: Type.Variant or Type.Variant(fields) or Type.Variant { fields }
        if at(TokenKind.Dot) {
            advance()
            let variant = advance_value()
            if at(TokenKind.LParen) {
                advance()
                skip_newlines()
                let flds = new_sublist()
                if !at(TokenKind.RParen) {
                    sublist_push(flds, parse_pattern())
                    while at(TokenKind.Comma) {
                        advance()
                        skip_newlines()
                        sublist_push(flds, parse_pattern())
                    }
                }
                skip_newlines()
                expect(TokenKind.RParen)
                finalize_sublist(flds)
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.EnumPattern, name: name, type_name: variant, fields: flds, line: sp_line, col: sp_col })
                return nd
            }
            if at(TokenKind.LBrace) {
                // Struct-style variant pattern: Type.Variant { field, field2 } or Type.Variant { field: pat }
                advance()
                skip_newlines()
                let flds = new_sublist()
                let mut has_rest = 0
                while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
                    if at(TokenKind.DotDot) {
                        advance()
                        has_rest = 1
                        skip_newlines()
                        if at(TokenKind.Comma) {
                            advance()
                            skip_newlines()
                        }
                        break
                    }
                    let fld_line = peek_line()
                    let fld_col = peek_col()
                    let fname = expect_value(TokenKind.Ident)
                    if at(TokenKind.Colon) {
                        advance()
                        skip_newlines()
                        let fpat = parse_pattern()
                        let sf = node_count()
                        nodes.push(AstNode { kind: NodeKind.StructLitField, name: fname, pattern: fpat, line: fld_line, col: fld_col })
                        sublist_push(flds, sf)
                    } else {
                        let sf = node_count()
                        nodes.push(AstNode { kind: NodeKind.StructLitField, name: fname, line: fld_line, col: fld_col })
                        sublist_push(flds, sf)
                    }
                    if at(TokenKind.Comma) {
                        advance()
                        skip_newlines()
                    }
                }
                expect(TokenKind.RBrace)
                finalize_sublist(flds)
                let nd = node_count()
                nodes.push(AstNode { kind: NodeKind.EnumPattern, name: name, type_name: variant, fields: flds, int_val: 1, inclusive: has_rest, line: sp_line, col: sp_col })
                return nd
            }
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.EnumPattern, name: name, type_name: variant, line: sp_line, col: sp_col })
            return nd
        }
        if at(TokenKind.LParen) {
            advance()
            skip_newlines()
            let flds = new_sublist()
            if !at(TokenKind.RParen) {
                sublist_push(flds, parse_pattern())
                while at(TokenKind.Comma) {
                    advance()
                    skip_newlines()
                    sublist_push(flds, parse_pattern())
                }
            }
            skip_newlines()
            expect(TokenKind.RParen)
            finalize_sublist(flds)
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.EnumPattern, name: name, fields: flds, line: sp_line, col: sp_col })
            return nd
        }
        if at(TokenKind.LBrace) {
            advance()
            skip_newlines()
            let flds = new_sublist()
            let mut has_rest = 0
            while !at(TokenKind.RBrace) && !at(TokenKind.EOF) {
                if at(TokenKind.DotDot) {
                    advance()
                    has_rest = 1
                    skip_newlines()
                    if at(TokenKind.Comma) {
                        advance()
                        skip_newlines()
                    }
                    break
                }
                let fld_line = peek_line()
                let fld_col = peek_col()
                let fname = expect_value(TokenKind.Ident)
                if at(TokenKind.Colon) {
                    advance()
                    skip_newlines()
                    let fpat = parse_pattern()
                    let sf = node_count()
                    nodes.push(AstNode { kind: NodeKind.StructLitField, name: fname, pattern: fpat, line: fld_line, col: fld_col })
                    sublist_push(flds, sf)
                } else {
                    let sf = node_count()
                    nodes.push(AstNode { kind: NodeKind.StructLitField, name: fname, line: fld_line, col: fld_col })
                    sublist_push(flds, sf)
                }
                if at(TokenKind.Comma) {
                    advance()
                    skip_newlines()
                }
            }
            expect(TokenKind.RBrace)
            finalize_sublist(flds)
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.StructPattern, type_name: name, fields: flds, inclusive: has_rest, line: sp_line, col: sp_col })
            return nd
        }
        if at(TokenKind.As) {
            advance()
            let inner = parse_pattern()
            let nd = node_count()
            nodes.push(AstNode { kind: NodeKind.AsPattern, name: name, pattern: inner, line: sp_line, col: sp_col })
            return nd
        }
        let nd = node_count()
        nodes.push(AstNode { kind: NodeKind.IdentPattern, name: name, line: sp_line, col: sp_col })
        return nd
    }
    diag_error_range("UnexpectedToken", "E1102", "unexpected token in pattern: {token_kind_name(peek_kind())}", peek_line(), peek_col(), peek_end_col(), "")
    advance()
    let nd = node_count()
    nodes.push(AstNode { kind: NodeKind.WildcardPattern, line: sp_line, col: sp_col })
    nd
}
