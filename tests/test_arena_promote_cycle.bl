fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "self-referential struct returned from arena emits E0701" {
    let src = "type Node \{\n    next: Node\n    value: Int\n}\nfn main() \{\n    with arena \{\n        Node \{ next: Node \{ next: Node \{ value: 0 }, value: 1 }, value: 2 }\n    \}\n}\n"
    expect_compile_error(src, "arena_cycle_self", "E0701")
}

test "mutually recursive types returned from arena emit E0701" {
    let src = "type A \{\n    b: B\n}\ntype B \{\n    a: A\n}\nfn main() \{\n    with arena \{\n        A \{ b: B \{ a: A \{ b: B \{ a: A \{ b: B \{ } } } } } }\n    \}\n}\n"
    expect_compile_error(src, "arena_cycle_mutual", "E0701")
}
