import std.db_row.{Row}

pub effect DB {
    effect Read {
        fn query(sql: Str) -> List[Row]
        fn query_one(sql: Str) -> Option[Row]
    }
    effect Write {
        fn exec(sql: Str)
        fn execute(sql: Str) -> Int
        fn begin() -> Int
        fn commit() -> Int
        fn rollback() -> Int
    }
}
