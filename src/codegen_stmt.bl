fn strip_outer_parens(s: Str) -> Str {
    if s.starts_with("(") && s.ends_with(")") {
        let inner = s.substring(1, s.len() - 2)
        let mut depth = 0
        let mut i = 0
        let mut balanced = 1
        while i < inner.len() {
            let ch = inner.byte_at(i)
            if ch == 40 { // '('
                depth = depth + 1
            } else if ch == 41 { // ')'
                if depth == 0 {
                    balanced = 0
                }
                depth = depth - 1
            }
            i = i + 1
        }
        if balanced != 0 && depth == 0 {
            return inner
        }
    }
    s
}

fn propagate_map_list_elem(var_name: Str, val_ct: Int, val_ann: Int) {
    if val_ct == CT_LIST {
        let val_elems = node_elements(val_ann)
        if val_elems != -1 && sublist_length(val_elems) > 0 {
            let inner_ann = sublist_get(val_elems, 0)
            let inner_name = node_name(inner_ann)
            set_map_value_list_elem(var_name, type_from_name(inner_name))
        }
    }
}

fn infer_node_struct_name(node: Int) -> Str {
    if node == -1 {
        return ""
    }
    let kind = node_kind(node)
    if kind == NodeKind.StructLit {
        return node_type_name(node)
    }
    if kind == NodeKind.ExprStmt {
        let inner = node_value(node)
        if node_kind(inner) == NodeKind.StructLit {
            return node_type_name(inner)
        }
    }
    if kind == NodeKind.Block {
        let stmts_sl = node_stmts(node)
        if stmts_sl != -1 {
            let count = sublist_length(stmts_sl)
            if count > 0 {
                return infer_node_struct_name(sublist_get(stmts_sl, count - 1))
            }
        }
    }
    if kind == NodeKind.IfExpr {
        let r = infer_node_struct_name(node_then_body(node))
        if r != "" {
            return r
        }
        return infer_node_struct_name(node_else_body(node))
    }
    ""
}

fn infer_block_struct_name(block: Int) -> Str {
    infer_node_struct_name(block)
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_if_expr(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let tmp = fresh_temp("_if_")
    let then_type = infer_block_type(node_then_body(node))
    if then_type == CT_VOID || then_type == CT_STRUCT {
        let mut ret_struct = get_fn_ret_struct(cg_current_fn_name)
        if ret_struct == "" {
            ret_struct = infer_block_struct_name(node_then_body(node))
        }
        if ret_struct == "" && node_else_body(node) != -1 {
            ret_struct = infer_block_struct_name(node_else_body(node))
        }
        if ret_struct == "" {
            emit_if_stmt(node)
            expr_result_str = "0"
            expr_result_type = CT_VOID
            return
        }
        emit_line("{c_type_c_name(ret_struct)} {tmp};")
        emit_expr(node_condition(node))
        let cond_str = strip_outer_parens(expr_result_str)
        emit_line("if ({cond_str}) \{")
        cg_indent = cg_indent + 1
        let then_val = emit_block_value(node_then_body(node))
        emit_line("{tmp} = {then_val};")
        cg_indent = cg_indent - 1
        if node_else_body(node) != -1 {
            emit_line("} else \{")
            cg_indent = cg_indent + 1
            let else_val = emit_block_value(node_else_body(node))
            emit_line("{tmp} = {else_val};")
            cg_indent = cg_indent - 1
        }
        emit_line("}")
        set_var(tmp, CT_VOID, 1)
        set_var_struct(tmp, ret_struct)
        expr_result_str = tmp
        expr_result_type = CT_VOID
        return
    }
    if then_type == CT_RESULT {
        let rt = get_fn_ret_type(cg_current_fn_name)
        let fsi = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt_c1 = tp_child1_kind(rt.tp_id)
        let rt_c2 = tp_child2_kind(rt.tp_id)
        if fsi.ok_struct != "" || fsi.err_struct != "" {
            emit_line("{result_c_type_mixed(rt_c1, rt_c2, fsi.ok_struct, fsi.err_struct)} {tmp};")
        } else if rt_c1 >= 0 {
            emit_line("{result_c_type(rt_c1, rt_c2)} {tmp};")
        } else {
            emit_line("{result_c_type(CT_INT, CT_STRING)} {tmp};")
        }
    } else if then_type == CT_OPTION {
        let rt = get_fn_ret_type(cg_current_fn_name)
        let fsi = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt_c1 = tp_child1_kind(rt.tp_id)
        if fsi.ok_struct != "" {
            emit_line("{struct_option_c_type(fsi.ok_struct)} {tmp};")
        } else if rt_c1 >= 0 {
            emit_line("{option_c_type(rt_c1)} {tmp};")
        } else if cg_current_fn_option_inner != 0 {
            emit_line("{option_c_type(cg_current_fn_option_inner)} {tmp};")
        } else {
            emit_line("{option_c_type(CT_INT)} {tmp};")
        }
    } else {
        emit_line("{c_type_str(then_type)} {tmp};")
    }
    emit_expr(node_condition(node))
    let cond_str = strip_outer_parens(expr_result_str)
    emit_line("if ({cond_str}) \{")
    cg_indent = cg_indent + 1
    let then_val = emit_block_value(node_then_body(node))
    emit_line("{tmp} = {then_val};")
    cg_indent = cg_indent - 1
    if node_else_body(node) != -1 {
        emit_line("} else \{")
        cg_indent = cg_indent + 1
        let else_val = emit_block_value(node_else_body(node))
        emit_line("{tmp} = {else_val};")
        cg_indent = cg_indent - 1
    }
    emit_line("}")
    set_var(tmp, then_type, 1)
    if then_type == CT_RESULT {
        let rt2 = get_fn_ret_type(cg_current_fn_name)
        let fsi2 = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt2_c1 = tp_child1_kind(rt2.tp_id)
        let rt2_c2 = tp_child2_kind(rt2.tp_id)
        if fsi2.ok_struct != "" || fsi2.err_struct != "" {
            set_var_result_struct(tmp, rt2_c1, rt2_c2, fsi2.ok_struct, fsi2.err_struct)
            expr_result_ok_struct = fsi2.ok_struct
            expr_result_err_struct = fsi2.err_struct
        } else {
            set_var_result(tmp, rt2_c1, rt2_c2)
        }
        expr_result_ok_type = rt2_c1
        expr_result_err_type = rt2_c2
    }
    if then_type == CT_OPTION {
        let rt3 = get_fn_ret_type(cg_current_fn_name)
        let fsi3 = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt3_c1 = tp_child1_kind(rt3.tp_id)
        if fsi3.ok_struct != "" {
            set_var_option_struct(tmp, rt3_c1, fsi3.ok_struct)
            expr_option_inner_struct = fsi3.ok_struct
        } else {
            set_var_option(tmp, rt3_c1)
        }
        expr_option_inner = rt3_c1
    }
    expr_result_str = tmp
    expr_result_type = then_type
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_match_expr(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let scrut = node_scrutinee(node)

    // Build list of scrutinee values (multiple if tuple literal)
    match_scruts = []
    match_scrut_enum = ""

    if node_kind(scrut) == NodeKind.TupleLit {
        let elems_sl = node_elements(scrut)
        if elems_sl != -1 {
            let mut ei = 0
            while ei < sublist_length(elems_sl) {
                emit_expr(sublist_get(elems_sl, ei))
                let tmp = fresh_temp("_tup_")
                emit_line("{c_type_str(expr_result_type)} {tmp} = {expr_result_str};")
                set_var(tmp, expr_result_type, 1)
                match_scruts.push(MatchScrutEntry { str_val: tmp, scrut_type: expr_result_type })
                ei = ei + 1
            }
        }
    } else {
        if node_kind(scrut) == NodeKind.Ident {
            match_scrut_enum = get_var_enum(node_name(scrut))
        } else if node_kind(scrut) == NodeKind.FieldAccess {
            match_scrut_enum = infer_enum_from_node(scrut)
        }
        emit_expr(scrut)
        if match_scrut_enum == "" && expr_result_type == CT_STRUCT {
            let scrut_s = get_var_struct(expr_result_str)
            if scrut_s != "" && is_data_enum(scrut_s) != 0 {
                match_scrut_enum = scrut_s
            }
        }
        if match_scrut_enum != "" && is_data_enum(match_scrut_enum) != 0 {
            let scrut_tmp = fresh_temp("_scrut_")
            emit_line("{c_type_c_name(match_scrut_enum)} {scrut_tmp} = {expr_result_str};")
            set_var(scrut_tmp, CT_INT, 1)
            match_scruts.push(MatchScrutEntry { str_val: scrut_tmp, scrut_type: expr_result_type })
        } else if expr_result_type == CT_RESULT || expr_result_type == CT_OPTION {
            let scrut_tmp = fresh_temp("_scrut_")
            let rok = expr_result_ok_type
            let rerr = expr_result_err_type
            if expr_result_type == CT_RESULT {
                let rok_s = expr_result_ok_struct
                let rerr_s = expr_result_err_struct
                if rok_s != "" || rerr_s != "" {
                    let res_c = result_c_type_mixed(rok, rerr, rok_s, rerr_s)
                    emit_line("{res_c} {scrut_tmp} = {expr_result_str};")
                } else {
                    let res_c = result_c_type(rok, rerr)
                    emit_line("{res_c} {scrut_tmp} = {expr_result_str};")
                }
            } else {
                let oi = expr_option_inner
                let oi_s = expr_option_inner_struct
                if oi_s != "" {
                    let opt_c = struct_option_c_type(oi_s)
                    emit_line("{opt_c} {scrut_tmp} = {expr_result_str};")
                } else {
                    let opt_c = option_c_type(oi)
                    emit_line("{opt_c} {scrut_tmp} = {expr_result_str};")
                }
            }
            match_scruts.push(MatchScrutEntry { str_val: scrut_tmp, scrut_type: expr_result_type })
        } else if expr_result_type == CT_LIST {
            let scrut_tmp = fresh_temp("_scrut_")
            emit_line("blink_list* {scrut_tmp} = {expr_result_str};")
            set_var(scrut_tmp, CT_LIST, 1)
            let mut src_name = expr_result_str
            if node_kind(scrut) == NodeKind.Ident {
                src_name = node_name(scrut)
            }
            let lelem = get_list_elem_type(src_name)
            if lelem >= 0 {
                set_list_elem_type(scrut_tmp, lelem)
            }
            let lstruct = get_list_elem_struct(src_name)
            if lstruct != "" {
                set_list_elem_struct(scrut_tmp, lstruct)
            }
            match_scruts.push(MatchScrutEntry { str_val: scrut_tmp, scrut_type: CT_LIST })
        } else {
            match_scruts.push(MatchScrutEntry { str_val: expr_result_str, scrut_type: expr_result_type })
        }
    }

    let saved_ok_type = expr_result_ok_type
    let saved_err_type = expr_result_err_type
    let saved_option_inner = expr_option_inner
    let saved_ok_struct = expr_result_ok_struct
    let saved_err_struct = expr_result_err_struct
    let saved_option_inner_struct = expr_option_inner_struct
    let saved_option_inner_map_val_struct = expr_option_inner_map_val_struct
    let saved_option_inner_map_val_list_elem = expr_option_inner_map_val_list_elem

    let arms_sl = node_arms(node)
    if arms_sl == -1 {
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }

    let first_arm = sublist_get(arms_sl, 0)
    let mut result_type = infer_arm_type(first_arm)
    let result_var = fresh_temp("_match_")
    let mut match_struct_name = ""
    if result_type == CT_STRUCT || result_type == CT_VOID {
        match_struct_name = infer_arm_struct_name(first_arm)
        if match_struct_name == "" {
            match_struct_name = get_fn_ret_struct(cg_current_fn_name)
        }
        if match_struct_name == "" && saved_ok_struct != "" {
            let first_body = node_body(first_arm)
            if first_body != -1 {
                let fb_kind = node_kind(first_body)
                let mut check_node = first_body
                if fb_kind == NodeKind.ExprStmt {
                    check_node = node_value(first_body)
                }
                if node_kind(check_node) == NodeKind.Ident {
                    let ib_type = infer_arm_body_from_pattern(first_arm, check_node)
                    if ib_type >= 0 {
                        match_struct_name = saved_ok_struct
                    }
                }
            }
        }
    }
    if match_struct_name != "" {
        emit_line("{c_type_c_name(match_struct_name)} {result_var};")
    } else if result_type == CT_RESULT {
        let rt = get_fn_ret_type(cg_current_fn_name)
        let fsi = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt_c1 = tp_child1_kind(rt.tp_id)
        let rt_c2 = tp_child2_kind(rt.tp_id)
        if fsi.ok_struct != "" || fsi.err_struct != "" {
            emit_line("{result_c_type_mixed(rt_c1, rt_c2, fsi.ok_struct, fsi.err_struct)} {result_var};")
        } else if rt_c1 >= 0 {
            emit_line("{result_c_type(rt_c1, rt_c2)} {result_var};")
        } else {
            emit_line("{result_c_type(CT_INT, CT_STRING)} {result_var};")
        }
    } else if result_type == CT_OPTION {
        let rt = get_fn_ret_type(cg_current_fn_name)
        let fsi = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt_c1 = tp_child1_kind(rt.tp_id)
        if fsi.ok_struct != "" {
            emit_line("{struct_option_c_type(fsi.ok_struct)} {result_var};")
        } else if rt_c1 >= 0 {
            emit_line("{option_c_type(rt_c1)} {result_var};")
        } else {
            emit_line("{option_c_type(CT_INT)} {result_var};")
        }
    } else if result_type != CT_VOID {
        emit_line("{c_type_str(result_type)} {result_var};")
    }

    let mut has_guards = 0
    let mut gi = 0
    while gi < sublist_length(arms_sl) {
        if node_guard(sublist_get(arms_sl, gi)) != -1 {
            has_guards = 1
        }
        gi = gi + 1
    }

    if has_guards {
        emit_line("int _mg_ = 0;")
    }

    let mut _first = 1
    let mut i = 0
    while i < sublist_length(arms_sl) {
        expr_result_ok_type = saved_ok_type
        expr_result_err_type = saved_err_type
        expr_option_inner = saved_option_inner
        expr_result_ok_struct = saved_ok_struct
        expr_result_err_struct = saved_err_struct
        expr_option_inner_struct = saved_option_inner_struct
        expr_option_inner_map_val_struct = saved_option_inner_map_val_struct
        expr_option_inner_map_val_list_elem = saved_option_inner_map_val_list_elem
        let arm = sublist_get(arms_sl, i)
        let pat = node_pattern(arm)

        let pat_cond = pattern_condition(pat, 0, match_scruts.len())
        let guard_node = node_guard(arm)
        let is_wildcard = pat_cond == "" && guard_node == -1

        if has_guards {
            if pat_cond == "" {
                if _first {
                    emit_line("if (!_mg_) \{")
                } else {
                    emit_line("} if (!_mg_) \{")
                }
            } else if _first {
                emit_line("if (!_mg_ && {pat_cond}) \{")
            } else {
                emit_line("} if (!_mg_ && {pat_cond}) \{")
            }
            cg_indent = cg_indent + 1
            bind_pattern_vars(pat, 0, match_scruts.len())
            if guard_node != -1 {
                emit_expr(guard_node)
                let guard_str = expr_result_str
                emit_line("if ({guard_str}) \{")
                cg_indent = cg_indent + 1
                let arm_val = emit_arm_value(node_body(arm))
                if (result_type != CT_VOID || match_struct_name != "") && !(match_struct_name != "" && arm_val == "0") {
                    emit_line("{result_var} = {arm_val};")
                } else if arm_val != "0" && arm_val != "" {
                    emit_line("(void){arm_val};")
                }
                emit_line("_mg_ = 1;")
                cg_indent = cg_indent - 1
                emit_line("}")
            } else {
                let arm_val = emit_arm_value(node_body(arm))
                if (result_type != CT_VOID || match_struct_name != "") && !(match_struct_name != "" && arm_val == "0") {
                    emit_line("{result_var} = {arm_val};")
                } else if arm_val != "0" && arm_val != "" {
                    emit_line("(void){arm_val};")
                }
                emit_line("_mg_ = 1;")
            }
            cg_indent = cg_indent - 1
        } else {
            if is_wildcard {
                if _first {
                    emit_line("\{")
                } else {
                    emit_line("} else \{")
                }
            } else if _first {
                emit_line("if ({strip_outer_parens(pat_cond)}) \{")
            } else {
                emit_line("} else if ({strip_outer_parens(pat_cond)}) \{")
            }
            cg_indent = cg_indent + 1
            let saved_match_scruts = match_scruts
            let saved_match_scrut_enum = match_scrut_enum
            bind_pattern_vars(pat, 0, match_scruts.len())
            let arm_val = emit_arm_value(node_body(arm))
            match_scruts = saved_match_scruts
            match_scrut_enum = saved_match_scrut_enum
            if (result_type != CT_VOID || match_struct_name != "") && !(match_struct_name != "" && arm_val == "0") {
                emit_line("{result_var} = {arm_val};")
            } else if arm_val != "0" && arm_val != "" {
                emit_line("(void){arm_val};")
            }
            cg_indent = cg_indent - 1
        }

        _first = 0
        i = i + 1
    }
    emit_line("}")
    if match_struct_name != "" {
        set_var(result_var, CT_VOID, 1)
        set_var_struct(result_var, match_struct_name)
        expr_result_str = result_var
        expr_result_type = CT_VOID
    } else if result_type == CT_RESULT {
        set_var(result_var, result_type, 1)
        let rt2 = get_fn_ret_type(cg_current_fn_name)
        let fsi2 = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt2_c1 = tp_child1_kind(rt2.tp_id)
        let rt2_c2 = tp_child2_kind(rt2.tp_id)
        if fsi2.ok_struct != "" || fsi2.err_struct != "" {
            set_var_result_struct(result_var, rt2_c1, rt2_c2, fsi2.ok_struct, fsi2.err_struct)
            expr_result_ok_struct = fsi2.ok_struct
            expr_result_err_struct = fsi2.err_struct
        } else {
            set_var_result(result_var, rt2_c1, rt2_c2)
        }
        expr_result_ok_type = rt2_c1
        expr_result_err_type = rt2_c2
        expr_result_str = result_var
        expr_result_type = result_type
    } else if result_type == CT_OPTION {
        set_var(result_var, result_type, 1)
        let rt3 = get_fn_ret_type(cg_current_fn_name)
        let fsi3 = get_fn_ret_struct_inner(cg_current_fn_name)
        let rt3_c1 = tp_child1_kind(rt3.tp_id)
        if fsi3.ok_struct != "" {
            set_var_option_struct(result_var, rt3_c1, fsi3.ok_struct)
            expr_option_inner_struct = fsi3.ok_struct
        } else {
            set_var_option(result_var, rt3_c1)
        }
        expr_option_inner = rt3_c1
        expr_result_str = result_var
        expr_result_type = result_type
    } else if result_type != CT_VOID {
        set_var(result_var, result_type, 1)
        expr_result_str = result_var
        expr_result_type = result_type
    } else {
        expr_result_str = "0"
        expr_result_type = result_type
    }
}

// Build a C condition string for a pattern.
// scrut_off/scrut_len index into match_scruts.
// Returns "" when the pattern always matches (wildcard/ident).
fn pattern_condition(pat: Int, scrut_off: Int, scrut_len: Int) -> Str {
    let pk = node_kind(pat)
    if pk == NodeKind.WildcardPattern {
        return ""
    }
    if pk == NodeKind.IdentPattern {
        let pat_name = node_name(pat)
        if pat_name == "None" {
            return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == 0)"
        }
        let mut enum_name = match_scrut_enum
        if enum_name == "" {
            enum_name = resolve_variant(pat_name)
        }
        if enum_name != "" {
            if is_data_enum(enum_name) != 0 {
                let tag = get_variant_tag(enum_name, pat_name)
                return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == {tag})"
            }
            return "({match_scruts.get(scrut_off).unwrap().str_val} == {c_type_c_name(enum_name)}_{pat_name})"
        }
        return ""
    }
    if pk == NodeKind.IntPattern {
        let pat_val = node_str_val(pat)
        return "({match_scruts.get(scrut_off).unwrap().str_val} == {pat_val})"
    }
    if pk == NodeKind.StringPattern {
        let pat_val = node_str_val(pat)
        return "(blink_str_eq({match_scruts.get(scrut_off).unwrap().str_val}, \"{pat_val}\"))"
    }
    if pk == NodeKind.RangePattern {
        let lo = node_str_val(pat)
        let hi = node_name(pat)
        let scrut = match_scruts.get(scrut_off).unwrap().str_val
        if node_inclusive(pat) != 0 {
            return "({scrut} >= {lo} && {scrut} <= {hi})"
        }
        return "({scrut} >= {lo} && {scrut} < {hi})"
    }
    if pk == NodeKind.EnumPattern {
        let enum_name = node_name(pat)
        let variant_name = node_type_name(pat)
        if enum_name == "Ok" {
            return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == 0)"
        }
        if enum_name == "Err" {
            return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == 1)"
        }
        if enum_name == "Some" {
            return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == 1)"
        }
        if variant_name != "" {
            if is_data_enum(enum_name) != 0 {
                let tag = get_variant_tag(enum_name, variant_name)
                return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == {tag})"
            }
            return "({match_scruts.get(scrut_off).unwrap().str_val} == {c_type_c_name(enum_name)}_{variant_name})"
        }
        let pat_name = node_name(pat)
        let resolved = resolve_variant(pat_name)
        if resolved != "" && is_data_enum(resolved) != 0 {
            let tag = get_variant_tag(resolved, pat_name)
            return "({match_scruts.get(scrut_off).unwrap().str_val}.tag == {tag})"
        }
        return ""
    }
    if pk == NodeKind.StructPattern {
        let flds_sl = node_fields(pat)
        if flds_sl == -1 {
            return ""
        }
        let mut parts = ""
        let mut _parts_n = 0
        let scrut = match_scruts.get(scrut_off).unwrap().str_val
        let mut j = 0
        while j < sublist_length(flds_sl) {
            let sf = sublist_get(flds_sl, j)
            let fname = node_name(sf)
            let fpat = node_pattern(sf)
            if fpat != -1 {
                let saved_scruts = match_scruts
                match_scruts = [MatchScrutEntry { str_val: "{scrut}.{fname}", scrut_type: CT_VOID }]
                let sub_cond = pattern_condition(fpat, 0, 1)
                match_scruts = saved_scruts
                if sub_cond != "" {
                    if _parts_n > 0 {
                        parts = parts.concat(" && ")
                    }
                    parts = parts.concat(sub_cond)
                    _parts_n = _parts_n + 1
                }
            }
            j = j + 1
        }
        return parts
    }
    if pk == NodeKind.OrPattern {
        let alts_sl = node_elements(pat)
        if alts_sl == -1 {
            return ""
        }
        let mut parts = ""
        let mut _parts_n = 0
        let mut j = 0
        while j < sublist_length(alts_sl) {
            let sub_pat = sublist_get(alts_sl, j)
            let sub_cond = pattern_condition(sub_pat, scrut_off, scrut_len)
            if sub_cond != "" {
                if _parts_n > 0 {
                    parts = parts.concat(" || ")
                }
                parts = parts.concat(sub_cond)
                _parts_n = _parts_n + 1
            }
            j = j + 1
        }
        return parts
    }
    if pk == NodeKind.AsPattern {
        let inner = node_pattern(pat)
        return pattern_condition(inner, scrut_off, scrut_len)
    }
    if pk == NodeKind.TuplePattern {
        let elems_sl = node_elements(pat)
        if elems_sl == -1 {
            return ""
        }
        let mut parts = ""
        let mut _parts_n = 0
        let mut j = 0
        while j < sublist_length(elems_sl) {
            let sub_pat = sublist_get(elems_sl, j)
            let sub_cond = pattern_condition(sub_pat, scrut_off + j, 1)
            if sub_cond != "" {
                if _parts_n > 0 {
                    parts = parts.concat(" && ")
                }
                parts = parts.concat(sub_cond)
                _parts_n = _parts_n + 1
            }
            j = j + 1
        }
        return parts
    }
    if pk == NodeKind.ListPattern {
        let elems_sl = node_elements(pat)
        let has_rest = node_inclusive(pat)
        let scrut = match_scruts.get(scrut_off).unwrap().str_val
        let mut elem_count = 0
        if elems_sl != -1 {
            elem_count = sublist_length(elems_sl)
        }
        let mut parts = ""
        let mut _parts_n = 0
        if has_rest != 0 {
            parts = "(blink_list_len({scrut}) >= {elem_count})"
        } else {
            parts = "(blink_list_len({scrut}) == {elem_count})"
        }
        _parts_n = 1
        if elems_sl != -1 {
            let mut j = 0
            while j < sublist_length(elems_sl) {
                let sub_pat = sublist_get(elems_sl, j)
                let saved_scruts = match_scruts
                let elem_type = get_list_elem_type(scrut)
                let elem_struct = get_list_elem_struct(scrut)
                let mut cast = "(int64_t)(intptr_t)"
                let mut sub_scrut_type = CT_STRING
                if elem_type == CT_STRING {
                    cast = "(const char*)"
                    sub_scrut_type = CT_STRING
                } else if elem_struct != "" {
                    cast = "({c_type_c_name(elem_struct)})(intptr_t)"
                    sub_scrut_type = CT_INT
                } else if elem_type >= 0 {
                    sub_scrut_type = elem_type
                }
                match_scruts = [MatchScrutEntry { str_val: "{cast}blink_list_get({scrut}, {j})", scrut_type: sub_scrut_type }]
                let sub_cond = pattern_condition(sub_pat, 0, 1)
                match_scruts = saved_scruts
                if sub_cond != "" {
                    if _parts_n > 0 {
                        parts = parts.concat(" && ")
                    }
                    parts = parts.concat(sub_cond)
                    _parts_n = _parts_n + 1
                }
                j = j + 1
            }
        }
        return parts
    }
    ""
}

// Emit C variable bindings for ident sub-patterns within a pattern.
// scrut_off/scrut_len index into match_scruts.
@allow(UnrestoredMutation, IncompleteStateRestore)
fn bind_pattern_vars(pat: Int, scrut_off: Int, scrut_len: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let pk = node_kind(pat)
    if pk == NodeKind.EnumPattern {
        let enum_name = node_name(pat)
        let variant_name = node_type_name(pat)
        let ep_flds_sl = node_fields(pat)
        if (enum_name == "Ok" || enum_name == "Err" || enum_name == "Some") && ep_flds_sl != -1 && sublist_length(ep_flds_sl) >= 1 {
            let sub_pat = sublist_get(ep_flds_sl, 0)
            let sub_pk = node_kind(sub_pat)
            let scrut = match_scruts.get(scrut_off).unwrap().str_val
            let scrut_type = match_scruts.get(scrut_off).unwrap().scrut_type
            if sub_pk == NodeKind.IdentPattern {
                let bind_name = node_name(sub_pat)
                if bind_name != "_" {
                    let c_bind = c_safe_name(bind_name)
                    let mut field = "ok"
                    let mut inner_ct = CT_STRING
                    let mut inner_struct = ""
                    if enum_name == "Err" {
                        field = "err"
                        if scrut_type == CT_RESULT {
                            inner_ct = expr_result_err_type
                            inner_struct = expr_result_err_struct
                        }
                    } else if enum_name == "Ok" {
                        if scrut_type == CT_RESULT {
                            inner_ct = expr_result_ok_type
                            inner_struct = expr_result_ok_struct
                        }
                    } else if enum_name == "Some" {
                        field = "value"
                        if scrut_type == CT_OPTION {
                            inner_ct = expr_option_inner
                            inner_struct = expr_option_inner_struct
                        }
                    }
                    if inner_struct != "" && inner_ct == CT_RESULT {
                        if field == "value" {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = *{scrut}.{field};")
                        } else {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = {scrut}.{field};")
                        }
                        set_var(bind_name, CT_RESULT, 0)
                        if inner_struct.starts_with("Result_") {
                            let split = split_result_compound(inner_struct)
                            if split.second != "" {
                                let res_ok_ct = type_from_name_tag(split.first)
                                let res_err_ct = type_from_name_tag(split.second)
                                let res_ok_s = if is_struct_type(split.first) != 0 || is_enum_type(split.first) != 0 { split.first } else { "" }
                                let res_err_s = if is_struct_type(split.second) != 0 || is_enum_type(split.second) != 0 { split.second } else { "" }
                                if res_ok_s != "" || res_err_s != "" {
                                    set_var_result_struct(bind_name, res_ok_ct, res_err_ct, res_ok_s, res_err_s)
                                } else {
                                    set_var_result(bind_name, res_ok_ct, res_err_ct)
                                }
                                expr_result_ok_type = res_ok_ct
                                expr_result_err_type = res_err_ct
                                expr_result_ok_struct = res_ok_s
                                expr_result_err_struct = res_err_s
                            } else {
                                set_var_result(bind_name, expr_result_ok_type, expr_result_err_type)
                            }
                        } else {
                            set_var_result(bind_name, expr_result_ok_type, expr_result_err_type)
                        }
                    } else if inner_struct != "" && inner_ct == CT_OPTION {
                        if field == "value" {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = *{scrut}.{field};")
                        } else {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = {scrut}.{field};")
                        }
                        set_var(bind_name, CT_OPTION, 0)
                        if inner_struct.starts_with("Option_") {
                            let opt_inner_tag = inner_struct.slice(7, inner_struct.len())
                            let opt_inner_ct = type_from_name_tag(opt_inner_tag)
                            if is_compound_tag(opt_inner_tag) != 0 || is_struct_type(opt_inner_tag) != 0 || is_enum_type(opt_inner_tag) != 0 {
                                set_var_option_struct(bind_name, opt_inner_ct, opt_inner_tag)
                            } else {
                                set_var_option(bind_name, opt_inner_ct)
                            }
                        } else {
                            set_var_option_struct(bind_name, CT_INT, inner_struct)
                        }
                    } else if inner_struct != "" && inner_ct == CT_MAP {
                        emit_line("blink_map* {c_bind} = {scrut}.{field};")
                        set_var(bind_name, CT_MAP, 0)
                        if expr_option_inner_map_val_struct != "" {
                            set_map_value_struct(bind_name, expr_option_inner_map_val_struct)
                        }
                        if expr_option_inner_map_val_list_elem >= 0 {
                            set_map_value_list_elem(bind_name, expr_option_inner_map_val_list_elem)
                        }
                    } else if inner_struct != "" && inner_ct == CT_LIST {
                        emit_line("blink_list* {c_bind} = {scrut}.{field};")
                        set_var(bind_name, CT_LIST, 0)
                        if expr_option_inner_list_elem >= 0 {
                            set_list_elem_type(bind_name, expr_option_inner_list_elem)
                        }
                        if expr_option_inner_list_struct != "" {
                            set_list_elem_struct(bind_name, expr_option_inner_list_struct)
                        }
                    } else if inner_struct != "" {
                        if field == "value" {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = *{scrut}.{field};")
                        } else {
                            emit_line("{c_type_c_name(inner_struct)} {c_bind} = {scrut}.{field};")
                        }
                        set_var(bind_name, CT_INT, 0)
                        set_var_struct(bind_name, inner_struct)
                        if is_enum_type(inner_struct) != 0 {
                            var_enums.push(VarEnumEntry { name: bind_name, enum_type: inner_struct })
                        }
                    } else {
                        emit_line("{c_type_str(inner_ct)} {c_bind} = {scrut}.{field};")
                        set_var(bind_name, inner_ct, 0)
                        if inner_ct == CT_LIST {
                            if expr_option_inner_list_elem >= 0 {
                                set_list_elem_type(bind_name, expr_option_inner_list_elem)
                            }
                            if expr_option_inner_list_struct != "" {
                                set_list_elem_struct(bind_name, expr_option_inner_list_struct)
                            }
                        }
                    }
                }
            } else if sub_pk == NodeKind.WildcardPattern {
                let _skip = 0
            }
            return
        }
        let mut resolved_enum = enum_name
        let mut resolved_variant = variant_name
        if variant_name == "" {
            resolved_variant = enum_name
            resolved_enum = resolve_variant(enum_name)
        }
        if resolved_enum != "" && is_data_enum(resolved_enum) != 0 && ep_flds_sl != -1 {
            let vidx = get_variant_index(resolved_enum, resolved_variant)
            if vidx >= 0 {
                let fcount = get_variant_field_count(vidx)
                let scrut = match_scruts.get(scrut_off).unwrap().str_val
                let is_struct_pat = node_int_val(pat)
                if is_struct_pat != 0 {
                    // Struct-style pattern: { field, field2 } — bind by field name
                    let mut sfi = 0
                    while sfi < sublist_length(ep_flds_sl) {
                        let sf_node = sublist_get(ep_flds_sl, sfi)
                        let field_name = node_name(sf_node)
                        let fpat_node = node_pattern(sf_node)
                        let mut found_ft = ""
                        let mut vfi = 0
                        while vfi < fcount {
                            let vfn = get_variant_field_name(vidx, vfi)
                            if vfn.is_some() && vfn.unwrap() == field_name {
                                let vft = get_variant_field_type_str(vidx, vfi)
                                if vft.is_some() {
                                    found_ft = vft.unwrap()
                                }
                                break
                            }
                            vfi = vfi + 1
                        }
                        let field_ct = type_from_name(found_ft)
                        if fpat_node != -1 {
                            let saved_scruts = match_scruts
                            match_scruts = [MatchScrutEntry { str_val: "{scrut}.data.{resolved_variant}.{field_name}", scrut_type: field_ct }]
                            bind_pattern_vars(fpat_node, 0, 1)
                            match_scruts = saved_scruts
                        } else {
                            let c_bind = c_safe_name(field_name)
                            if found_ft == resolved_enum {
                                let fc_name = c_type_c_name(found_ft)
                                emit_line("{fc_name} {c_bind} = *({fc_name}*)(intptr_t){scrut}.data.{resolved_variant}.{field_name};")
                                set_var(field_name, CT_VOID, 0)
                                set_var_struct(field_name, found_ft)
                                var_enums.push(VarEnumEntry { name: field_name, enum_type: found_ft })
                            } else if is_struct_type(found_ft) != 0 {
                                emit_line("{c_type_c_name(found_ft)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                set_var(field_name, CT_VOID, 0)
                                set_var_struct(field_name, found_ft)
                            } else if is_enum_type(found_ft) != 0 {
                                emit_line("{c_type_c_name(found_ft)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                set_var(field_name, CT_INT, 0)
                                var_enums.push(VarEnumEntry { name: field_name, enum_type: found_ft })
                            } else if field_ct == CT_LIST {
                                emit_line("blink_list* {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                set_var(field_name, CT_LIST, 0)
                                let bracket_pos = found_ft.index_of("[")
                                if bracket_pos > 0 {
                                    let inner_name = found_ft.substr(bracket_pos + 1, found_ft.len() - bracket_pos - 2)
                                    let inner_ct = type_from_name(inner_name)
                                    if inner_ct != CT_VOID {
                                        set_list_elem_type(field_name, inner_ct)
                                    } else if is_enum_type(inner_name) != 0 || is_struct_type(inner_name) != 0 {
                                        set_list_elem_struct(field_name, inner_name)
                                        set_list_elem_type(field_name, CT_VOID)
                                    }
                                }
                            } else {
                                emit_line("{c_type_str(field_ct)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                set_var(field_name, field_ct, 0)
                            }
                        }
                        sfi = sfi + 1
                    }
                } else {
                    let mut fi = 0
                    while fi < sublist_length(ep_flds_sl) && fi < fcount {
                        let sub_pat = sublist_get(ep_flds_sl, fi)
                        let sub_pk = node_kind(sub_pat)
                        let field_name = get_variant_field_name(vidx, fi).unwrap()
                        let field_type_name = get_variant_field_type_str(vidx, fi).unwrap()
                        let field_ct = type_from_name(field_type_name)
                        if sub_pk == NodeKind.IdentPattern {
                            let bind_name = node_name(sub_pat)
                            if bind_name != "_" {
                                let c_bind = c_safe_name(bind_name)
                                if field_type_name == resolved_enum {
                                    let fc_name = c_type_c_name(field_type_name)
                                    emit_line("{fc_name} {c_bind} = *({fc_name}*)(intptr_t){scrut}.data.{resolved_variant}.{field_name};")
                                    set_var(bind_name, CT_VOID, 0)
                                    set_var_struct(bind_name, field_type_name)
                                    var_enums.push(VarEnumEntry { name: bind_name, enum_type: field_type_name })
                                } else if is_struct_type(field_type_name) != 0 {
                                    emit_line("{c_type_c_name(field_type_name)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                    set_var(bind_name, CT_VOID, 0)
                                    set_var_struct(bind_name, field_type_name)
                                } else if is_enum_type(field_type_name) != 0 {
                                    emit_line("{c_type_c_name(field_type_name)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                    set_var(bind_name, CT_INT, 0)
                                    var_enums.push(VarEnumEntry { name: bind_name, enum_type: field_type_name })
                                } else if field_ct == CT_LIST {
                                    emit_line("blink_list* {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                    set_var(bind_name, CT_LIST, 0)
                                    let bracket_pos = field_type_name.index_of("[")
                                    if bracket_pos > 0 {
                                        let inner_name = field_type_name.substr(bracket_pos + 1, field_type_name.len() - bracket_pos - 2)
                                        let inner_ct = type_from_name(inner_name)
                                        if inner_ct != CT_VOID {
                                            set_list_elem_type(bind_name, inner_ct)
                                        } else if is_enum_type(inner_name) != 0 || is_struct_type(inner_name) != 0 {
                                            set_list_elem_struct(bind_name, inner_name)
                                            set_list_elem_type(bind_name, CT_VOID)
                                        }
                                    }
                                } else {
                                    emit_line("{c_type_str(field_ct)} {c_bind} = {scrut}.data.{resolved_variant}.{field_name};")
                                    set_var(bind_name, field_ct, 0)
                                }
                            }
                        } else if sub_pk == NodeKind.WildcardPattern {
                            let _skip = 0
                        } else {
                            let saved_scruts = match_scruts
                            match_scruts = [MatchScrutEntry { str_val: "{scrut}.data.{resolved_variant}.{field_name}", scrut_type: field_ct }]
                            bind_pattern_vars(sub_pat, 0, 1)
                            match_scruts = saved_scruts
                        }
                        fi = fi + 1
                    }
                }
            }
        }
        return
    }
    if pk == NodeKind.StringPattern {
        return
    }
    if pk == NodeKind.RangePattern {
        return
    }
    if pk == NodeKind.IntPattern {
        return
    }
    if pk == NodeKind.OrPattern {
        let alts_sl = node_elements(pat)
        if alts_sl != -1 && sublist_length(alts_sl) > 0 {
            bind_pattern_vars(sublist_get(alts_sl, 0), scrut_off, scrut_len)
        }
        return
    }
    if pk == NodeKind.StructPattern {
        let flds_sl = node_fields(pat)
        if flds_sl == -1 {
            return
        }
        let scrut = match_scruts.get(scrut_off).unwrap().str_val
        let stype_name = node_type_name(pat)
        let mut j = 0
        while j < sublist_length(flds_sl) {
            let sf = sublist_get(flds_sl, j)
            let fname = node_name(sf)
            let c_fname = c_safe_name(fname)
            let fpat = node_pattern(sf)
            if fpat != -1 {
                let saved_scruts = match_scruts
                match_scruts = [MatchScrutEntry { str_val: "{scrut}.{fname}", scrut_type: CT_VOID }]
                bind_pattern_vars(fpat, 0, 1)
                match_scruts = saved_scruts
            } else {
                emit_line("__typeof__({scrut}.{fname}) {c_fname} = {scrut}.{fname};")
                let ftype = get_struct_field_type(stype_name, fname)
                let fstype = get_struct_field_stype(stype_name, fname)
                set_var(fname, ftype, 0)
                if fstype != "" {
                    set_var_struct(fname, fstype)
                }
            }
            j = j + 1
        }
        return
    }
    if pk == NodeKind.AsPattern {
        let bind_name = node_name(pat)
        let c_bind = c_safe_name(bind_name)
        let st = match_scruts.get(scrut_off).unwrap().scrut_type
        let scrut_str = match_scruts.get(scrut_off).unwrap().str_val
        if match_scrut_enum != "" {
            emit_line("{c_type_c_name(match_scrut_enum)} {c_bind} = {scrut_str};")
            set_var(bind_name, CT_INT, 1)
            var_enums.push(VarEnumEntry { name: bind_name, enum_type: match_scrut_enum })
        } else {
            emit_line("{c_type_str(st)} {c_bind} = {scrut_str};")
            set_var(bind_name, st, 1)
        }
        bind_pattern_vars(node_pattern(pat), scrut_off, scrut_len)
        return
    }
    if pk == NodeKind.IdentPattern {
        let bind_name = node_name(pat)
        if bind_name == "None" {
            return
        }
        let mut enum_name = match_scrut_enum
        if enum_name == "" {
            enum_name = resolve_variant(bind_name)
        }
        if enum_name != "" {
            return
        }
        if scrut_len == 1 {
            let c_bind = c_safe_name(bind_name)
            let st = match_scruts.get(scrut_off).unwrap().scrut_type
            emit_line("{c_type_str(st)} {c_bind} = {match_scruts.get(scrut_off).unwrap().str_val};")
            set_var(bind_name, st, 1)
        }
        return
    }
    if pk == NodeKind.TuplePattern {
        let elems_sl = node_elements(pat)
        if elems_sl != -1 {
            let mut j = 0
            while j < sublist_length(elems_sl) {
                let sub_pat = sublist_get(elems_sl, j)
                bind_pattern_vars(sub_pat, scrut_off + j, 1)
                j = j + 1
            }
        }
        return
    }
    if pk == NodeKind.ListPattern {
        let elems_sl = node_elements(pat)
        if elems_sl != -1 {
            let scrut = match_scruts.get(scrut_off).unwrap().str_val
            let elem_type = get_list_elem_type(scrut)
            let elem_struct = get_list_elem_struct(scrut)
            let mut j = 0
            while j < sublist_length(elems_sl) {
                let sub_pat = sublist_get(elems_sl, j)
                let saved_scruts = match_scruts
                let mut cast = "(int64_t)(intptr_t)"
                let mut bind_ct = CT_INT
                if elem_type == CT_STRING {
                    cast = "(const char*)"
                    bind_ct = CT_STRING
                } else if elem_struct != "" {
                    cast = "({c_type_c_name(elem_struct)})(intptr_t)"
                    bind_ct = CT_INT
                } else if elem_type >= 0 {
                    bind_ct = elem_type
                }
                match_scruts = [MatchScrutEntry { str_val: "{cast}blink_list_get({scrut}, {j})", scrut_type: bind_ct }]
                bind_pattern_vars(sub_pat, 0, 1)
                match_scruts = saved_scruts
                j = j + 1
            }
        }
        return
    }
}

pub fn emit_block_expr(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let stmts_sl = node_stmts(node)
    if stmts_sl == -1 {
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }
    let count = sublist_length(stmts_sl)
    let mut i = 0
    while i < count - 1 {
        emit_stmt(sublist_get(stmts_sl, i))
        i = i + 1
    }
    if count > 0 {
        let last = sublist_get(stmts_sl, count - 1)
        let last_kind = node_kind(last)
        if last_kind == NodeKind.ExprStmt {
            emit_expr(node_value(last))
            return
        }
        emit_stmt(last)
    }
    expr_result_str = "0"
    expr_result_type = CT_VOID
}

fn emit_arm_value(body: Int) -> Str ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if body == -1 {
        return "0"
    }
    let kind = node_kind(body)
    if kind == NodeKind.Block {
        return emit_block_value(body)
    }
    if kind == NodeKind.ExprStmt {
        emit_expr(node_value(body))
        return expr_result_str
    }
    if kind == NodeKind.Assignment || kind == NodeKind.CompoundAssign {
        emit_stmt(body)
        return "0"
    }
    emit_expr(body)
    expr_result_str
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_block_value(block: Int) -> Str ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if block == -1 {
        return "0"
    }
    let stmts_sl = node_stmts(block)
    if stmts_sl == -1 {
        return "0"
    }
    let count = sublist_length(stmts_sl)
    if count == 0 {
        return "0"
    }
    let mut i = 0
    while i < count - 1 {
        emit_stmt(sublist_get(stmts_sl, i))
        i = i + 1
    }
    let last = sublist_get(stmts_sl, count - 1)
    let last_kind = node_kind(last)
    if last_kind == NodeKind.ExprStmt {
        emit_expr(node_value(last))
        return expr_result_str
    }
    if last_kind == NodeKind.IfExpr {
        emit_if_expr(last)
        return expr_result_str
    }
    if last_kind == NodeKind.Return {
        if node_value(last) != -1 {
            emit_expr(node_value(last))
            emit_return_with_trace(expr_result_str, cg_current_fn_ret)
        } else {
            emit_trace_exit_void()
            emit_line("return;")
        }
        return "0"
    }
    emit_stmt(last)
    "0"
}

pub fn infer_block_type(block: Int) -> Int {
    if block == -1 {
        return CT_VOID
    }
    let stmts_sl = node_stmts(block)
    if stmts_sl == -1 {
        return CT_VOID
    }
    let count = sublist_length(stmts_sl)
    if count == 0 {
        return CT_VOID
    }
    let last = sublist_get(stmts_sl, count - 1)
    let last_kind = node_kind(last)
    if last_kind == NodeKind.ExprStmt {
        return infer_expr_type(node_value(last))
    }
    if last_kind == NodeKind.IfExpr {
        return infer_expr_type(last)
    }
    if last_kind == NodeKind.MatchExpr {
        return infer_arm_type(sublist_get(node_arms(last), 0))
    }
    CT_VOID
}

fn infer_arm_struct_name(arm: Int) -> Str {
    infer_node_struct_name(node_body(arm))
}

fn infer_arm_type(arm: Int) -> Int {
    let body = node_body(arm)
    if body == -1 {
        return CT_VOID
    }
    let kind = node_kind(body)
    if kind == NodeKind.Block {
        return infer_block_type(body)
    }
    if kind == NodeKind.ExprStmt {
        let inner = node_value(body)
        let inner_type = infer_arm_body_from_pattern(arm, inner)
        if inner_type >= 0 {
            return inner_type
        }
        return infer_expr_type(inner)
    }
    let pat_type = infer_arm_body_from_pattern(arm, body)
    if pat_type >= 0 {
        return pat_type
    }
    infer_expr_type(body)
}

fn infer_arm_body_from_pattern(arm: Int, body_node: Int) -> Int {
    if node_kind(body_node) != NodeKind.Ident {
        return -1
    }
    let body_name = node_name(body_node)
    let pat = node_pattern(arm)
    if pat == -1 || node_kind(pat) != NodeKind.EnumPattern {
        return -1
    }
    let binding_name = infer_enum_pattern_binding(pat)
    let enum_name = node_name(pat)
    if binding_name == body_name {
        if enum_name == "Some" {
            return expr_option_inner
        } else if enum_name == "Ok" {
            return expr_result_ok_type
        } else if enum_name == "Err" {
            return expr_result_err_type
        }
    }
    let variant_name = node_type_name(pat)
    let mut resolved_enum = enum_name
    let mut resolved_variant = variant_name
    if variant_name == "" {
        resolved_variant = enum_name
        resolved_enum = resolve_variant(enum_name)
    }
    if resolved_enum == "" || is_data_enum(resolved_enum) == 0 {
        return -1
    }
    let vidx = get_variant_index(resolved_enum, resolved_variant)
    if vidx < 0 {
        return -1
    }
    let flds_sl = node_fields(pat)
    if flds_sl == -1 {
        return -1
    }
    let fcount = get_variant_field_count(vidx)
    let mut fi = 0
    while fi < sublist_length(flds_sl) && fi < fcount {
        let sub = sublist_get(flds_sl, fi)
        if node_kind(sub) == NodeKind.IdentPattern {
            if node_name(sub) == body_name {
                let ft = get_variant_field_type_str(vidx, fi)
                if ft.is_some() {
                    return type_from_name(ft.unwrap())
                }
            }
        }
        fi = fi + 1
    }
    -1
}

fn infer_enum_pattern_binding(pat: Int) -> Str {
    let flds_sl = node_fields(pat)
    if flds_sl != -1 && sublist_length(flds_sl) >= 1 {
        let sub = sublist_get(flds_sl, 0)
        if node_kind(sub) == NodeKind.IdentPattern {
            return node_name(sub)
        }
    }
    ""
}

fn infer_expr_type(node: Int) -> Int {
    if node == -1 {
        return CT_VOID
    }
    let kind = node_kind(node)
    if kind == NodeKind.IntLit { return CT_INT }
    if kind == NodeKind.FloatLit { return CT_FLOAT }
    if kind == NodeKind.BoolLit { return CT_BOOL }
    if kind == NodeKind.InterpString { return CT_STRING }
    if kind == NodeKind.ListLit { return CT_LIST }
    if kind == NodeKind.Ident {
        let iname = node_name(node)
        if iname == "None" {
            return CT_OPTION
        }
        if resolve_variant(iname) != "" {
            return CT_INT
        }
        return get_var_type(iname)
    }
    if kind == NodeKind.FieldAccess {
        let fa_obj = node_obj(node)
        let fa_field = node_name(node)
        if node_kind(fa_obj) == NodeKind.Ident {
            let obj_name = node_name(fa_obj)
            if is_enum_type(obj_name) != 0 {
                return CT_INT
            }
            let stype = get_var_struct(obj_name)
            if stype != "" {
                return get_struct_field_type(stype, fa_field)
            }
        }
        return CT_VOID
    }
    if kind == NodeKind.IfExpr {
        let t = infer_block_type(node_then_body(node))
        if t != CT_VOID { return t }
        let e = node_else_body(node)
        if e != -1 { return infer_block_type(e) }
        return CT_VOID
    }
    if kind == NodeKind.Call {
        let func_node = node_left(node)
        if node_kind(func_node) == NodeKind.Ident {
            let call_name = node_name(func_node)
            if call_name == "Ok" || call_name == "Err" {
                return CT_RESULT
            }
            if call_name == "Some" {
                return CT_OPTION
            }
            return get_fn_ret(call_name)
        }
    }
    if kind == NodeKind.MethodCall {
        let mc_method = node_method(node)
        if mc_method == "concat" || mc_method == "trim" || mc_method == "replace" || mc_method == "substr" || mc_method == "to_lower" || mc_method == "to_upper" || mc_method == "strip" || mc_method == "strip_prefix" || mc_method == "strip_suffix" || mc_method == "repeat" || mc_method == "pad_left" || mc_method == "pad_right" || mc_method == "join" {
            return CT_STRING
        }
        if mc_method == "len" || mc_method == "index_of" || mc_method == "count" || mc_method == "insert" {
            return CT_INT
        }
        if mc_method == "starts_with" || mc_method == "ends_with" || mc_method == "contains" || mc_method == "is_empty" || mc_method == "has" {
            return CT_BOOL
        }
        if mc_method == "split" || mc_method == "lines" || mc_method == "chars" || mc_method == "keys" || mc_method == "values" {
            return CT_LIST
        }
        let mc_obj = node_obj(node)
        if mc_method == "get" {
            if node_kind(mc_obj) == NodeKind.Ident {
                let obj_type = get_var_type(node_name(mc_obj))
                if obj_type == CT_MAP {
                    return get_map_value_type(node_name(mc_obj))
                }
            }
        }
        if mc_obj != -1 && node_kind(mc_obj) == NodeKind.Ident {
            let obj_name = node_name(mc_obj)
            let obj_struct = get_var_struct(obj_name)
            if obj_struct != "" {
                let struct_method_ret = get_fn_ret("{obj_struct}_{mc_method}")
                if struct_method_ret != CT_VOID {
                    return struct_method_ret
                }
            } else if is_scope_var(obj_name) == 0 && is_intrinsic_method(obj_name, mc_method) == 0 && is_trait_type(obj_name) == 0 && is_struct_type(obj_name) == 0 && is_enum_type(obj_name) == 0 && is_import_module_name(obj_name) != 0 {
                let resolved_method = resolve_import_alias(mc_method)
                let method_ret = get_fn_ret(resolved_method)
                if method_ret != CT_VOID {
                    return method_ret
                }
            }
        }
    }
    if kind == NodeKind.UnaryOp {
        let op = node_op(node)
        if op == "!" {
            return CT_BOOL
        }
        return infer_expr_type(node_left(node))
    }
    if kind == NodeKind.BinOp {
        let op = node_op(node)
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "&&" || op == "||" {
            return CT_BOOL
        }
        let left_t = infer_expr_type(node_left(node))
        if left_t == CT_STRING { return CT_STRING }
        if op == "+" {
            let right_t = infer_expr_type(node_right(node))
            if right_t == CT_STRING { return CT_STRING }
        }
        return left_t
    }
    CT_VOID
}

// ── Statement codegen ───────────────────────────────────────────────

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_stmt(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let kind = node_kind(node)

    if kind == NodeKind.ExprStmt {
        emit_expr(node_value(node))
        let s = expr_result_str
        if s != "" && s != "0" {
            emit_line("(void){s};")
        }
        return
    }

    if kind == NodeKind.LetBinding {
        emit_let_binding(node)
        return
    }

    if kind == NodeKind.Assignment {
        let assign_target_node = node_target(node)
        emit_expr(assign_target_node)
        let target_str = expr_result_str
        emit_expr(node_value(node))
        let val_str = expr_result_str
        let val_type = expr_result_type
        emit_line("{target_str} = {val_str};")
        if node_kind(assign_target_node) == NodeKind.Ident {
            let var_name = node_name(assign_target_node)
            emit_trace_state(var_name, "assign", target_str, val_type)
        }
        return
    }

    if kind == NodeKind.CompoundAssign {
        let assign_target_node = node_target(node)
        emit_expr(assign_target_node)
        let target_str = expr_result_str
        let target_type = expr_result_type
        emit_expr(node_value(node))
        let val_str = expr_result_str
        let op = node_op(node)
        emit_line("{target_str} {op}= {val_str};")
        if node_kind(assign_target_node) == NodeKind.Ident {
            emit_trace_state(node_name(assign_target_node), "assign", target_str, target_type)
        }
        return
    }

    if kind == NodeKind.Return {
        if node_value(node) != -1 {
            emit_expr(node_value(node))
            emit_return_with_trace(expr_result_str, cg_current_fn_ret)
        } else {
            emit_trace_exit_void()
            emit_line("return;")
        }
        return
    }

    if kind == NodeKind.ForIn {
        emit_for_in(node)
        return
    }

    if kind == NodeKind.WhileLoop {
        let pre_len = cg_lines.len()
        emit_expr(node_condition(node))
        let cond_str = strip_outer_parens(expr_result_str)
        let post_len = cg_lines.len()
        if post_len > pre_len {
            let mut cond_setup: List[Str] = []
            let mut ci = pre_len
            while ci < post_len {
                cond_setup.push(cg_lines.get(ci).unwrap())
                ci = ci + 1
            }
            let mut ri = post_len - 1
            while ri >= pre_len {
                cg_lines.pop()
                ri = ri - 1
            }
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            let mut si = 0
            while si < cond_setup.len() {
                cg_lines.push(cond_setup.get(si).unwrap())
                si = si + 1
            }
            emit_line("if (!({cond_str})) break;")
            emit_block(node_body(node))
            cg_indent = cg_indent - 1
            emit_line("}")
        } else {
            emit_line("while ({cond_str}) \{")
            cg_indent = cg_indent + 1
            emit_block(node_body(node))
            cg_indent = cg_indent - 1
            emit_line("}")
        }
        return
    }

    if kind == NodeKind.LoopExpr {
        emit_line("while (1) \{")
        cg_indent = cg_indent + 1
        emit_block(node_body(node))
        cg_indent = cg_indent - 1
        emit_line("}")
        return
    }

    if kind == NodeKind.Break {
        emit_line("break;")
        return
    }

    if kind == NodeKind.Continue {
        emit_line("continue;")
        return
    }

    if kind == NodeKind.IfExpr {
        emit_if_stmt(node)
        return
    }

    if kind == NodeKind.MatchExpr {
        emit_match_expr(node)
        return
    }

    if kind == NodeKind.WithBlock {
        emit_with_block(node)
        return
    }

    // Fallback: treat as expression
    emit_expr(node)
    let s = expr_result_str
    if s != "" {
        emit_line("{s};")
    }
}

fn infer_enum_from_node(val_node: Int) -> Str {
    let vk = node_kind(val_node)
    if vk == NodeKind.FieldAccess {
        let obj = node_obj(val_node)
        if node_kind(obj) == NodeKind.Ident {
            let obj_name = node_name(obj)
            if is_enum_type(obj_name) != 0 {
                return obj_name
            }
        }
    }
    if vk == NodeKind.Ident {
        return resolve_variant(node_name(val_node))
    }
    if vk == NodeKind.Call {
        let func = node_left(val_node)
        if node_kind(func) == NodeKind.Ident {
            let fn_name = node_name(func)
            let resolved = resolve_variant(fn_name)
            if resolved != "" {
                return resolved
            }
        }
    }
    if vk == NodeKind.MethodCall {
        let mc_obj = node_obj(val_node)
        if node_kind(mc_obj) == NodeKind.Ident {
            let mc_name = node_name(mc_obj)
            if is_enum_type(mc_name) != 0 {
                return mc_name
            }
        }
    }
    ""
}

fn emit_tuple_destructure(pat_node: Int, source_var: Str, struct_name: Str, is_mut: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope {
    let elems_sl = node_elements(pat_node)
    if elems_sl == -1 { return }
    let mut di = 0
    while di < sublist_length(elems_sl) {
        let sub_pat = sublist_get(elems_sl, di)
        let elem_name = node_name(sub_pat)
        let field_name = "_{di}"
        let ft = get_struct_field_type(struct_name, field_name)
        let fs = get_struct_field_stype(struct_name, field_name)
        let c_elem = c_safe_name(elem_name)
        if fs != "" {
            emit_line("{c_type_c_name(fs)} {c_elem} = {source_var}.{field_name};")
            set_var(elem_name, CT_VOID, is_mut)
            set_var_struct(c_elem, fs)
        } else {
            emit_line("{c_type_str(ft)} {c_elem} = {source_var}.{field_name};")
            set_var(elem_name, ft, is_mut)
        }
        di = di + 1
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_let_binding(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let val_node = node_value(node)
    let mut enum_type = infer_enum_from_node(val_node)
    let type_ann = node_target(node)
    if enum_type == "" && type_ann != -1 {
        let ann_name = node_name(type_ann)
        if is_enum_type(ann_name) != 0 {
            enum_type = ann_name
        }
    }
    let saved_let_target = cg_let_target_type
    let saved_let_target_name = cg_let_target_name
    let saved_let_target_ann = cg_let_target_ann
    let mut ann_ct = 0
    if type_ann != -1 {
        ann_ct = type_from_name(node_name(type_ann))
        cg_let_target_type = ann_ct
        cg_let_target_name = node_name(type_ann)
        cg_let_target_ann = type_ann
    } else {
        cg_let_target_type = 0
        cg_let_target_name = ""
        cg_let_target_ann = -1
    }
    emit_expr(val_node)
    cg_let_target_type = saved_let_target
    cg_let_target_name = saved_let_target_name
    cg_let_target_ann = saved_let_target_ann
    let val_str = expr_result_str
    let mut val_type = expr_result_type
    if val_type == CT_RESULT {
        enum_type = ""
    }
    if val_type == CT_INT && (ann_ct == CT_I8 || ann_ct == CT_I16 || ann_ct == CT_I32 || ann_ct == CT_U8 || ann_ct == CT_U16 || ann_ct == CT_U32 || ann_ct == CT_U64) {
        val_type = ann_ct
    }
    let mut name = node_name(node)
    if name == "_destructure" {
        name = fresh_temp("_destr")
    }
    let is_mut = node_is_mut(node)
    set_var(name, val_type, is_mut)
    if enum_type != "" {
        var_enums.push(VarEnumEntry { name: name, enum_type: enum_type })
    }
    if val_type == CT_PTR && type_ann != -1 {
        let pelems_ann = node_elements(type_ann)
        if pelems_ann != -1 && sublist_length(pelems_ann) > 0 {
            let inner_ann_name = node_name(sublist_get(pelems_ann, 0))
            let inner_td = find_type_def_node(inner_ann_name)
            if inner_td != -1 && has_annotation(inner_td, "ffi.struct") != 0 {
                set_var_ffi_ptr_struct(name, inner_ann_name)
            }
        }
    }
    if val_type == CT_HANDLER {
        let mut h_vtt = cg_handler_vtable_type
        let mut h_vtf = cg_handler_vtable_field
        let mut h_is_ue = cg_handler_is_user_effect
        if h_vtf == "" && type_ann != -1 {
            let ann_name = node_name(type_ann)
            if ann_name == "Handler" {
                let ann_elems = node_elements(type_ann)
                if ann_elems != -1 && sublist_length(ann_elems) >= 1 {
                    let effect_ann = sublist_get(ann_elems, 0)
                    let effect_name = node_name(effect_ann)
                    h_vtt = resolve_effect_vtable(effect_name)
                    h_vtf = resolve_effect_field(effect_name)
                    h_is_ue = resolve_effect_is_ue(effect_name)
                }
            }
        }
        set_var_handler(name, h_vtt, h_vtf, h_is_ue)
        cg_handler_vtable_type = ""
        cg_handler_vtable_field = ""
        cg_handler_is_user_effect = 0
    }
    if val_type == CT_CLOSURE {
        set_var_closure(name, expr_closure_sig)
    }
    if val_type == CT_OPTION {
        let mut opt_inner_ct = expr_option_inner
        let mut opt_inner_s = expr_option_inner_struct
        if type_ann != -1 {
            let ann_name = node_name(type_ann)
            if ann_name == "Option" {
                let ann_elems = node_elements(type_ann)
                if ann_elems != -1 && sublist_length(ann_elems) >= 1 {
                    let inner_ann = sublist_get(ann_elems, 0)
                    let inner_name = node_name(inner_ann)
                    let inner_ct = type_from_name(inner_name)
                    if is_struct_type(inner_name) != 0 || is_enum_type(inner_name) != 0 {
                        opt_inner_s = inner_name
                        opt_inner_ct = inner_ct
                    } else if is_compound_ct(inner_ct) != 0 {
                        opt_inner_s = compound_name_from_ann(inner_ann)
                        opt_inner_ct = inner_ct
                    } else {
                        opt_inner_ct = inner_ct
                        opt_inner_s = ""
                    }
                }
            }
        }
        if opt_inner_s != "" {
            set_var_option_struct(name, opt_inner_ct, opt_inner_s)
            ensure_struct_option_type(opt_inner_s)
        } else {
            set_var_option(name, opt_inner_ct)
            ensure_option_type(opt_inner_ct)
        }
        if expr_option_inner == CT_LIST && expr_option_inner_list_elem != -1 {
            set_var_option_inner2(name, expr_option_inner_list_elem)
            expr_option_inner_list_elem = -1
            if expr_option_inner_list_struct != "" {
                set_var_option_inner2_struct(name, expr_option_inner_list_struct)
                expr_option_inner_list_struct = ""
            }
        }
        if expr_option_inner == CT_MAP {
            if expr_option_inner_map_val_list_elem >= 0 {
                set_var_option_inner2(name, expr_option_inner_map_val_list_elem)
                expr_option_inner_map_val_list_elem = -1
            }
            if expr_option_inner_map_val_struct != "" {
                set_var_option_inner2_struct(name, expr_option_inner_map_val_struct)
                expr_option_inner_map_val_struct = ""
            }
        }
    }
    if val_type == CT_RESULT {
        if expr_result_ok_struct != "" || expr_result_err_struct != "" {
            set_var_result_struct(name, expr_result_ok_type, expr_result_err_type, expr_result_ok_struct, expr_result_err_struct)
        } else {
            set_var_result(name, expr_result_ok_type, expr_result_err_type)
        }
        if expr_result_ok_type == CT_LIST && expr_list_elem_type >= 0 {
            set_var_result_ok_elem(name, expr_list_elem_type, expr_list_elem_struct)
        }
    }
    if val_type == CT_HANDLE {
        let inner = get_var_handle_inner(val_str)
        let h_sname = get_var_handle_sname(val_str)
        let h_sname2 = get_var_handle_sname2(val_str)
        let h_inner2 = get_var_handle_inner2(val_str)
        if h_sname != "" || h_sname2 != "" || h_inner2 >= 0 {
            set_var_handle_full(name, if inner >= 0 { inner } else { CT_INT }, h_inner2, h_sname, h_sname2)
        } else if inner >= 0 {
            set_var_handle(name, inner)
        } else {
            set_var_handle(name, CT_INT)
        }
    }
    if val_type == CT_CHANNEL {
        let ch_inner = get_var_channel_inner(val_str)
        if ch_inner >= 0 {
            set_var_channel(name, ch_inner)
        } else {
            set_var_channel(name, CT_INT)
        }
    }
    if node_kind(val_node) == NodeKind.StructLit {
        let expr_struct = get_var_struct(val_str)
        if expr_struct != "" {
            set_var_struct(name, expr_struct)
        } else {
            let sname = node_type_name(val_node)
            if is_struct_type(sname) != 0 {
                set_var_struct(name, sname)
            }
        }
    } else if type_ann != -1 {
        let ann_name = node_name(type_ann)
        if is_struct_type(ann_name) != 0 {
            set_var_struct(name, ann_name)
        } else if ann_name == "Tuple" {
            let tup_name = resolve_tuple_ann(type_ann, -1, "").unwrap()
            set_var_struct(name, tup_name)
        } else {
            let expr_struct = get_var_struct(val_str)
            if expr_struct != "" {
                set_var_struct(name, expr_struct)
            }
        }
    } else {
        let expr_struct = get_var_struct(val_str)
        if expr_struct != "" {
            set_var_struct(name, expr_struct)
        }
    }
    if val_type == CT_LIST && type_ann != -1 {
        let ann_name = node_name(type_ann)
        if ann_name == "List" {
            let elems_sl = node_elements(type_ann)
            if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                let elem_ann = sublist_get(elems_sl, 0)
                let elem_name = node_name(elem_ann)
                let elem_ct = type_from_name(elem_name)
                set_list_elem_type(name, elem_ct)
                if elem_ct == CT_VOID && (is_named_type(elem_name) != 0) {
                    set_list_elem_struct(name, elem_name)
                } else if elem_ct == CT_VOID && elem_name == "Tuple" {
                    let tup_opt = resolve_tuple_ann(elem_ann, -1, "")
                    if tup_opt.is_some() {
                        set_list_elem_struct(name, tup_opt.unwrap())
                    }
                }
                if elem_ct == CT_LIST {
                    let nested_sl = node_elements(elem_ann)
                    if nested_sl != -1 && sublist_length(nested_sl) > 0 {
                        let nested_ann = sublist_get(nested_sl, 0)
                        let nested_name = node_name(nested_ann)
                        let nested_ct = type_from_name(nested_name)
                        set_list_nested_elem_type(name, nested_ct)
                        if nested_ct == CT_VOID && (is_named_type(nested_name) != 0) {
                            set_list_nested_elem_struct(name, nested_name)
                        }
                    }
                }
            }
        }
    }
    if val_type == CT_MAP && type_ann != -1 {
        let ann_name = node_name(type_ann)
        if ann_name == "Map" {
            let elems_sl = node_elements(type_ann)
            if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                let key_ann = sublist_get(elems_sl, 0)
                let val_ann = sublist_get(elems_sl, 1)
                let val_name = node_name(val_ann)
                let key_ct = type_from_name(node_name(key_ann))
                let val_ct = type_from_name(val_name)
                set_map_types(name, key_ct, val_ct, val_name)
                propagate_map_list_elem(name, val_ct, val_ann)
            }
        }
    }
    if val_type == CT_MAP && expr_map_key_type >= 0 {
        set_map_types(name, expr_map_key_type, expr_map_val_type, "")
        expr_map_key_type = -1
        expr_map_val_type = -1
    }
    if val_type == CT_MAP {
        copy_map_value_meta(val_str, name)
    }
    if val_type == CT_LIST && expr_list_elem_type >= 0 && type_ann == -1 {
        set_list_elem_type(name, expr_list_elem_type)
        expr_list_elem_type = -1
        let src_struct = get_list_elem_struct(val_str)
        if src_struct != "" {
            set_list_elem_struct(name, src_struct)
        } else if expr_list_elem_struct != "" {
            set_list_elem_struct(name, expr_list_elem_struct)
        }
        expr_list_elem_struct = ""
        let src_nested = get_list_nested_elem_type(val_str)
        if src_nested != -1 {
            set_list_nested_elem_type(name, src_nested)
        }
        let src_nested_struct = get_list_nested_elem_struct(val_str)
        if src_nested_struct != "" {
            set_list_nested_elem_struct(name, src_nested_struct)
        }
    } else if val_type == CT_LIST && expr_list_elem_type >= 0 {
        expr_list_elem_type = -1
        expr_list_elem_struct = ""
    }
    if val_type == CT_ITERATOR {
        set_var_alias(name, val_str)
        let iter_inner = get_var_iterator_inner(val_str)
        let iter_next = get_var_iter_next_fn(val_str)
        if iter_inner >= 0 {
            set_var_iterator(name, iter_inner, iter_next)
        }
        return
    }
    let struct_type = get_var_struct(name)
    let cname = c_safe_name(name)
    if val_type == CT_OPTION {
        let opt_inner = get_var_option_inner(name)
        let opt_inner_s = get_var_option_inner_struct(name)
        let opt_c_inner = opt_inner
        let opt_c = option_c_type_mixed(opt_c_inner, opt_inner_s)
        if val_str.ends_with("\{.tag = 0}") {
            val_str = "({opt_c})\{.tag = 0}"
        }
        if is_mut != 0 {
            emit_line("{opt_c} {cname} = {val_str};")
        } else {
            emit_line("const {opt_c} {cname} = {val_str};")
        }
    } else if val_type == CT_RESULT {
        let rok = get_var_result_ok(name)
        let rerr = get_var_result_err(name)
        let rok_s = get_var_result_ok_struct(name)
        let rerr_s = get_var_result_err_struct(name)
        let res_c = result_c_type_mixed(rok, rerr, rok_s, rerr_s)
        if is_mut != 0 {
            emit_line("{res_c} {cname} = {val_str};")
        } else {
            emit_line("const {res_c} {cname} = {val_str};")
        }
    } else if enum_type != "" {
        if is_mut != 0 {
            emit_line("{c_type_c_name(enum_type)} {cname} = {val_str};")
        } else {
            emit_line("const {c_type_c_name(enum_type)} {cname} = {val_str};")
        }
    } else if val_type == CT_HANDLER {
        let h_vtt = get_var_handler_vtable_type(name)
        if h_vtt != "" {
            emit_line("{h_vtt}* {cname} = ({h_vtt}*){val_str};")
        } else {
            emit_line("void* {cname} = {val_str};")
        }
    } else if struct_type != "" {
        if is_mut != 0 {
            emit_line("{c_type_c_name(struct_type)} {cname} = {val_str};")
        } else {
            emit_line("const {c_type_c_name(struct_type)} {cname} = {val_str};")
        }
    } else if val_type == CT_PTR && type_ann != -1 {
        let pelems = node_elements(type_ann)
        let mut ptr_c_type = "void*"
        if pelems != -1 && sublist_length(pelems) > 0 {
            ptr_c_type = "{ptr_inner_c_type(node_name(sublist_get(pelems, 0)))}*"
        }
        emit_line("{ptr_c_type} {cname} = {val_str};")
    } else {
        let ts = c_type_str(val_type)
        if is_mut != 0 || val_type == CT_STRING || val_type == CT_LIST || val_type == CT_MAP || val_type == CT_BYTES || val_type == CT_CLOSURE || val_type == CT_ITERATOR || val_type == CT_HANDLE || val_type == CT_CHANNEL || val_type == CT_PTR || val_type == CT_STRINGBUILDER || val_type == CT_FFI_SCOPE {
            emit_line("{ts} {cname} = {val_str};")
        } else {
            emit_line("const {ts} {cname} = {val_str};")
        }
    }
    if name.starts_with("_") {
        emit_line("(void){cname};")
    }
    if is_mut_captured(name) != 0 {
        let cell_type = c_type_str(val_type)
        emit_line("{cell_type}* {cname}_cell = ({cell_type}*)blink_alloc(sizeof({cell_type}));")
        emit_line("*{cname}_cell = {cname};")
    }
    let destr_pat_sl = node_elements(node)
    if destr_pat_sl != -1 {
        let tup_struct = get_var_struct(cname)
        if tup_struct != "" {
            emit_tuple_destructure(destr_pat_sl, cname, tup_struct, is_mut)
        }
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_for_in(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let var_name = node_var_name(node)
    let c_var_name = c_safe_name(var_name)
    let iter_node = node_iterable(node)
    let iter_kind = node_kind(iter_node)

    if iter_kind == NodeKind.RangeLit {
        ensure_range_iter()
        emit_expr(node_start(iter_node))
        let start_str = expr_result_str
        emit_expr(node_end(iter_node))
        let end_str = expr_result_str
        let mut incl_val = "0"
        if node_inclusive(iter_node) != 0 {
            incl_val = "1"
        }
        let iter_var = fresh_temp("__iter_")
        let next_var = fresh_temp("__next_")
        let opt_type = option_c_type(CT_INT)
        emit_line("blink_RangeIterator {iter_var} = \{ .current = {start_str}, .end = {end_str}, .is_inclusive = {incl_val} };")
        emit_line("while (1) \{")
        cg_indent = cg_indent + 1
        emit_line("{opt_type} {next_var} = blink_RangeIterator_next(&{iter_var});")
        emit_line("if ({next_var}.tag == 0) break;")
        emit_line("int64_t {c_var_name} = {next_var}.value;")
        push_scope()
        set_var(var_name, CT_INT, 1)
        emit_block(node_body(node))
        pop_scope()
        cg_indent = cg_indent - 1
        emit_line("}")
    } else {
        emit_expr(iter_node)
        let iter_str = expr_result_str
        let iter_type = expr_result_type
        if iter_type == CT_LIST {
            let mut elem_type = expr_list_elem_type
            if elem_type == -1 { elem_type = get_list_elem_type(iter_str) }
            if elem_type == -1 { elem_type = CT_INT }
            let elem_struct = get_list_elem_struct(iter_str)
            if elem_struct != "" {
                ensure_iter_type(CT_INT)
                let li_type = list_iter_c_type(CT_INT)
                let opt_type = option_c_type(CT_INT)
                let iter_var = fresh_temp("__iter_")
                let next_var = fresh_temp("__next_")
                emit_line("{li_type} {iter_var} = blink_list_into_iter_int({iter_str});")
                emit_line("while (1) \{")
                cg_indent = cg_indent + 1
                emit_line("{opt_type} {next_var} = {li_type}_next(&{iter_var});")
                emit_line("if ({next_var}.tag == 0) break;")
                let struct_c = c_type_c_name(elem_struct)
                emit_line("{struct_c} {c_var_name} = *({struct_c}*)(intptr_t){next_var}.value;")
                push_scope()
                set_var(var_name, CT_VOID, 0)
                set_var_struct(c_var_name, elem_struct)
                if is_enum_type(elem_struct) != 0 {
                    var_enums.push(VarEnumEntry { name: var_name, enum_type: elem_struct })
                }
                let for_pat_sl = node_elements(node)
                if for_pat_sl != -1 {
                    emit_tuple_destructure(for_pat_sl, c_var_name, elem_struct, 0)
                }
                emit_block(node_body(node))
                pop_scope()
                cg_indent = cg_indent - 1
                emit_line("}")
            } else {
                ensure_iter_type(elem_type)
                let tag = c_type_tag(elem_type)
                let li_type = list_iter_c_type(elem_type)
                let opt_type = option_c_type(elem_type)
                let iter_var = fresh_temp("__iter_")
                let next_var = fresh_temp("__next_")
                emit_line("{li_type} {iter_var} = blink_list_into_iter_{tag}({iter_str});")
                emit_line("while (1) \{")
                cg_indent = cg_indent + 1
                emit_line("{opt_type} {next_var} = {li_type}_next(&{iter_var});")
                emit_line("if ({next_var}.tag == 0) break;")
                emit_line("{c_type_str(elem_type)} {c_var_name} = {next_var}.value;")
                push_scope()
                set_var(var_name, elem_type, 0)
                if elem_type == CT_LIST {
                    let nested_et = get_list_nested_elem_type(iter_str)
                    if nested_et != -1 {
                        set_list_elem_type(var_name, nested_et)
                    }
                    let nested_es = get_list_nested_elem_struct(iter_str)
                    if nested_es != "" {
                        set_list_elem_struct(var_name, nested_es)
                    }
                }
                emit_block(node_body(node))
                pop_scope()
                cg_indent = cg_indent - 1
                emit_line("}")
            }
        } else if iter_type == CT_ITERATOR {
            let elem_type = get_var_iterator_inner(iter_str)
            let next_fn = get_var_iter_next_fn(iter_str)
            let opt_type = option_c_type(elem_type)
            let _iter_var = fresh_temp("__iter_")
            let next_var = fresh_temp("__next_")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_type} {next_var} = (({opt_type} (*)(void*)){next_fn})(&{iter_str});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("{c_type_str(elem_type)} {c_var_name} = {next_var}.value;")
            push_scope()
            set_var(var_name, elem_type, 0)
            emit_block(node_body(node))
            pop_scope()
            cg_indent = cg_indent - 1
            emit_line("}")
        } else if iter_type == CT_CHANNEL {
            let ch_inner = get_var_channel_inner(iter_str)
            let recv_tmp = fresh_temp("__chrecv_")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("void* {recv_tmp} = blink_channel_recv({iter_str});")
            emit_line("if ({recv_tmp} == NULL) break;")
            if ch_inner == CT_STRING {
                emit_line("const char* {c_var_name} = (const char*){recv_tmp};")
                push_scope()
                set_var(var_name, CT_STRING, 0)
            } else {
                emit_line("int64_t {c_var_name} = (int64_t)(intptr_t){recv_tmp};")
                push_scope()
                set_var(var_name, CT_INT, 0)
            }
            emit_block(node_body(node))
            pop_scope()
            cg_indent = cg_indent - 1
            emit_line("}")
        } else if iter_type == CT_STRING {
            ensure_str_iter()
            let iter_var = fresh_temp("__str_iter_")
            let next_var = fresh_temp("__str_next_")
            let opt_type = option_c_type(CT_STRING)
            emit_line("blink_StrIterator {iter_var} = \{ .str = {iter_str}, .index = 0, .len = blink_str_len({iter_str}) };")
            emit_line("while (1) \{")
            cg_indent = cg_indent + 1
            emit_line("{opt_type} {next_var} = blink_StrIterator_next(&{iter_var});")
            emit_line("if ({next_var}.tag == 0) break;")
            emit_line("const char* {c_var_name} = {next_var}.value;")
            push_scope()
            set_var(var_name, CT_STRING, 0)
            emit_block(node_body(node))
            pop_scope()
            cg_indent = cg_indent - 1
            emit_line("}")
        } else {
            emit_line("/* unsupported iterable */")
        }
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_if_stmt(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    emit_expr(node_condition(node))
    let cond_str = strip_outer_parens(expr_result_str)
    emit_line("if ({cond_str}) \{")
    cg_indent = cg_indent + 1
    emit_block(node_then_body(node))
    cg_indent = cg_indent - 1
    if node_else_body(node) != -1 {
        let else_b = node_else_body(node)
        let else_stmts = node_stmts(else_b)
        // Check for else-if chain
        if else_stmts != -1 && sublist_length(else_stmts) == 1 {
            let inner = sublist_get(else_stmts, 0)
            if node_kind(inner) == NodeKind.IfExpr {
                let saved_lines2 = cg_lines
                cg_lines = []
                emit_expr(node_condition(inner))
                let hoisted_lines = cg_lines
                cg_lines = saved_lines2
                if hoisted_lines.len() > 0 {
                    emit_line("} else \{")
                    cg_indent = cg_indent + 1
                    emit_if_stmt(inner)
                    cg_indent = cg_indent - 1
                } else {
                    let inner_cond = strip_outer_parens(expr_result_str)
                    emit_line("} else if ({inner_cond}) \{")
                    cg_indent = cg_indent + 1
                    emit_block(node_then_body(inner))
                    cg_indent = cg_indent - 1
                    if node_else_body(inner) != -1 {
                        emit_line("} else \{")
                        cg_indent = cg_indent + 1
                        emit_block(node_else_body(inner))
                        cg_indent = cg_indent - 1
                    }
                }
                emit_line("}")
                return
            }
        }
        emit_line("} else \{")
        cg_indent = cg_indent + 1
        emit_block(else_b)
        cg_indent = cg_indent - 1
    }
    emit_line("}")
}

pub fn emit_block(block: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if block == -1 {
        return
    }
    let stmts_sl = node_stmts(block)
    if stmts_sl == -1 {
        return
    }
    let mut i = 0
    while i < sublist_length(stmts_sl) {
        emit_stmt(sublist_get(stmts_sl, i))
        i = i + 1
    }
}

// __ With-block codegen __

fn emit_bh_setup(struct_name: Str, handler_str: Str, binding: Str, bh_state_vars: List[Str]) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    emit_bh_cleanup_for_type(struct_name)
    let c_type = c_type_c_name(struct_name)
    let enter_fn = c_fn_name("{struct_name}_enter")
    let bh_tmp = fresh_temp("__bh_")
    emit_line("{c_type} {bh_tmp} = {handler_str};")
    let st_var = fresh_temp("__bh_st_")
    emit_line("__blink_bh_state_{c_type} {st_var} __attribute__((cleanup(__blink_bh_cleanup_{c_type}))) = \{ .handler = {bh_tmp}, .ok = 0, .entered = 0 };")
    if binding != "" {
        let ctx_type_name = lookup_assoc_type(struct_name, "Context")
        if ctx_type_name != "" {
            let ctx_c_type = if is_struct_type(ctx_type_name) != 0 { c_type_c_name(ctx_type_name) } else { c_type_str(type_from_name(ctx_type_name)) }
            emitted_let_names.push(binding)
            emitted_let_set.insert(binding, 1)
            emit_line("{ctx_c_type} {binding} = {enter_fn}({bh_tmp});")
            set_var(binding, type_from_name(ctx_type_name), 0)
            if is_struct_type(ctx_type_name) != 0 {
                set_var_struct(binding, ctx_type_name)
            }
        } else {
            emit_line("{enter_fn}({bh_tmp});")
        }
    } else {
        emit_line("{enter_fn}({bh_tmp});")
    }
    emit_line("{st_var}.entered = 1;")
    bh_state_vars.push(st_var)
}

pub fn emit_with_block(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    emit_with_block_core(node, 0, "")
}

// Shared body emission for `with { … }` in both statement and expression form.
// is_expr=1 requests capture-and-promote at the end: the body's tail expression
// is copied into `result_sink` (a caller-allocated C variable) via the walker
// for `result_desc`, after which the inner arena is torn down manually rather
// than via the __attribute__((cleanup)) path. For is_expr=0 the arena handler
// uses the RAII cleanup attribute as before.
@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_with_block_core(node: Int, is_expr: Int, result_sink: Str) -> Str ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let handlers_sl = node_handlers(node)
    let body = node_body(node)
    if handlers_sl == -1 {
        emit_block(body)
        return ""
    }
    let count = sublist_length(handlers_sl)
    let mut resource_names: List[Str] = []
    let mut resource_vars: List[Str] = []
    let mut num_installed_fields = 0
    let mut bh_state_vars: List[Str] = []
    let mut arena_tmp = ""
    let mut arena_prev = ""
    let mut has_arena_handler = 0
    emit_line("\{")
    cg_indent = cg_indent + 1
    let ev_copy = fresh_temp("__ev_with_")
    let mut ev_copy_emitted = 0
    let mut i = 0
    while i < count {
        let item = sublist_get(handlers_sl, i)
        let item_kind = node_kind(item)
        if item_kind == NodeKind.Ident && node_name(item) == "arena" {
            has_arena_handler = 1
            if is_expr != 0 {
                // Manual arena lifecycle: defer destroy until after promotion.
                let ar_tmp = fresh_temp("__arena_")
                let ar_prev = fresh_temp("__arena_prev_")
                emit_line("blink_arena_t* {ar_tmp} = blink_arena_create(BLINK_ARENA_DEFAULT_CHUNK_SIZE);")
                emit_line("blink_arena_t* {ar_prev} = __blink_current_arena;")
                emit_line("__blink_current_arena = {ar_tmp};")
                arena_tmp = ar_tmp
                arena_prev = ar_prev
            } else {
                emit_arena_restore_helper()
                let ar_tmp = fresh_temp("__arena_")
                let ar_st = fresh_temp("__arena_st_")
                emit_line("blink_arena_t* {ar_tmp} = blink_arena_create(BLINK_ARENA_DEFAULT_CHUNK_SIZE);")
                emit_line("__blink_arena_restore_t {ar_st} __attribute__((cleanup(__blink_arena_restore))) = \{ .prev = __blink_current_arena, .arena = {ar_tmp} };")
                emit_line("__blink_current_arena = {ar_tmp};")
            }
            i = i + 1
            continue
        }
        if item_kind == NodeKind.WithResource {
            let binding = node_name(item)
            let res_expr = node_value(item)
            emit_expr(res_expr)
            let res_str = expr_result_str
            let res_type = expr_result_type
            let res_struct = get_var_struct(res_str)
            let tmp = fresh_temp("_wr_")
            let c_decl = if res_struct != "" { c_type_c_name(res_struct) } else { c_type_str(res_type) }
            if res_struct != "" && lookup_impl_type_for_trait("BlockHandler", res_struct) == 1 {
                emit_bh_setup(res_struct, res_str, binding, bh_state_vars)
            } else if res_struct != "" && lookup_impl_type_for_trait("Closeable", res_struct) == 1 {
                emit_cl_cleanup_for_type(res_struct)
                let cl_c_type = c_type_c_name(res_struct)
                emit_line("{c_decl} {tmp} = {res_str};")
                let cl_st = fresh_temp("__cl_st_")
                emit_line("__blink_cl_state_{cl_c_type} {cl_st} __attribute__((cleanup(__blink_cl_cleanup_{cl_c_type}))) = \{ .resource = {tmp} };")
                emitted_let_names.push(binding)
                emitted_let_set.insert(binding, 1)
                emit_line("{c_decl} {binding} = {tmp};")
                set_var(binding, res_type, 0)
                set_var_struct(binding, res_struct)
            } else {
                emit_line("{c_decl} {tmp} = {res_str};")
                emitted_let_names.push(binding)
                emitted_let_set.insert(binding, 1)
                emit_line("{c_decl} {binding} = {tmp};")
                set_var(binding, res_type, 0)
                if res_struct != "" {
                    set_var_struct(binding, res_struct)
                }
                resource_names.push(binding)
                resource_vars.push(tmp)
            }
        } else {
            emit_expr(item)
            let handler_str = expr_result_str
            let handler_type = expr_result_type
            let mut vtable_field = cg_handler_vtable_field
            let mut is_ue = cg_handler_is_user_effect
            let cleanup_var = cg_handler_cleanup_var
            let cleanup_fn = cg_handler_cleanup_fn
            cg_handler_vtable_type = ""
            cg_handler_vtable_field = ""
            cg_handler_is_user_effect = 0
            cg_handler_cleanup_var = ""
            cg_handler_cleanup_fn = ""
            if vtable_field == "" && handler_type == CT_HANDLER {
                vtable_field = get_var_handler_vtable_field(handler_str)
                is_ue = get_var_handler_is_ue(handler_str)
            }
            if vtable_field != "" {
                let field_c = if is_ue != 0 { "ue_{vtable_field}" } else { vtable_field }
                if ev_copy_emitted == 0 {
                    let ev_src = if cg_current_fn_has_ev != 0 { "*__ev" } else { "__blink_ev" }
                    emit_line("blink_ev {ev_copy} = {ev_src};")
                    ev_copy_emitted = 1
                    emit_ev_restore_helper()
                }
                emit_line("{ev_copy}.{field_c} = {handler_str};")
                let restore_var = fresh_temp("__ev_restore_")
                emit_line("__blink_ev_restore_t {restore_var} __attribute__((cleanup(__blink_ev_restore))) = \{ .slot = (void**)&__blink_ev.{field_c}, .saved = (void*)__blink_ev.{field_c} };")
                emit_line("__blink_ev.{field_c} = {handler_str};")
                num_installed_fields = num_installed_fields + 1
                if cleanup_var != "" && cleanup_fn != "" {
                    emit_handle_cleanup(cleanup_fn)
                    let cl_tmp = fresh_temp("__hcl_")
                    emit_line("__blink_hcl_state_{cleanup_fn} {cl_tmp} __attribute__((cleanup(__blink_hcl_cleanup_{cleanup_fn}))) = \{ .handle = {cleanup_var} };")
                }
            } else {
                let h_struct = get_var_struct(handler_str)
                if h_struct != "" && lookup_impl_type_for_trait("BlockHandler", h_struct) == 1 {
                    emit_bh_setup(h_struct, handler_str, "", bh_state_vars)
                } else if handler_str != "" {
                    emit_line("{handler_str};")
                }
            }
        }
        i = i + 1
    }
    let saved_has_ev = cg_current_fn_has_ev
    if num_installed_fields > 0 {
        emit_line("blink_ev* __ev = &{ev_copy};")
        cg_current_fn_has_ev = 1
    }
    let mut actual_desc = ""
    if has_arena_handler != 0 {
        cg_with_arena_depth = cg_with_arena_depth + 1
    }
    let pushed_expr_arena = has_arena_handler != 0 && is_expr != 0 && arena_tmp != ""
    if pushed_expr_arena {
        cg_arena_expr_tmp_stack.push(arena_tmp)
        cg_arena_expr_prev_stack.push(arena_prev)
    }
    if is_expr != 0 {
        let target_expr = if arena_prev != "" { arena_prev } else { "NULL" }
        emit_and_log_promote_phase("begin", target_expr, "", node)
        actual_desc = emit_block_then_capture(body, result_sink, arena_prev)
        emit_and_log_promote_phase("end", target_expr, actual_desc, node)
    } else {
        emit_block(body)
    }
    if pushed_expr_arena {
        cg_arena_expr_tmp_stack.pop()
        cg_arena_expr_prev_stack.pop()
    }
    if has_arena_handler != 0 {
        cg_with_arena_depth = cg_with_arena_depth - 1
    }
    cg_current_fn_has_ev = saved_has_ev
    let mut bhi = 0
    while bhi < bh_state_vars.len() {
        emit_line("{bh_state_vars.get(bhi).unwrap()}.ok = 1;")
        bhi = bhi + 1
    }
    let mut rri = resource_names.len() - 1
    while rri >= 0 {
        let rname = resource_names.get(rri).unwrap()
        let rvar_type = get_var_type(rname)
        if rvar_type == CT_FFI_SCOPE {
            emit_line("blink_ffi_scope_cleanup({rname});")
        }
        rri = rri - 1
    }
    if is_expr != 0 && arena_tmp != "" {
        emit_line("__blink_current_arena = {arena_prev};")
        emit_line("blink_arena_destroy({arena_tmp});")
    }
    cg_indent = cg_indent - 1
    emit_line("}")
    actual_desc
}

@allow(UnrestoredMutation)
fn descriptor_from_expr_state() -> Str {
    let ct = expr_result_type
    if ct == CT_INT || ct == CT_FLOAT || ct == CT_BOOL || ct == CT_STRING {
        return ct_to_descriptor(ct, "")
    }
    if ct == CT_STRUCT || ct == CT_VOID {
        let sname = get_var_struct(expr_result_str)
        if sname != "" { return "S:{sname}" }
        return ""
    }
    if ct == CT_LIST {
        let et = if expr_list_elem_type >= 0 { expr_list_elem_type } else { get_list_elem_type(expr_result_str) }
        let es = if expr_list_elem_struct != "" { expr_list_elem_struct } else { get_list_elem_struct(expr_result_str) }
        return "L:{ct_to_descriptor(et, es)}"
    }
    if ct == CT_MAP {
        let kt = if expr_map_key_type >= 0 { expr_map_key_type } else { get_map_key_type(expr_result_str) }
        let vt = if expr_map_val_type >= 0 { expr_map_val_type } else { get_map_value_type(expr_result_str) }
        let vs = get_map_value_struct(expr_result_str)
        return "M:{ct_to_descriptor(kt, "")}|{ct_to_descriptor(vt, vs)}"
    }
    if ct == CT_OPTION {
        let inner_ct = expr_option_inner
        let inner_s = expr_option_inner_struct
        if inner_s != "" {
            ensure_struct_option_type(inner_s)
            return "O:S:{inner_s}"
        }
        ensure_option_type(inner_ct)
        return "O:{payload_desc_for(inner_ct, "")}"
    }
    if ct == CT_RESULT {
        let ok_t = expr_result_ok_type
        let err_t = expr_result_err_type
        let ok_s = expr_result_ok_struct
        let err_s = expr_result_err_struct
        if ok_s != "" || err_s != "" {
            let ok_tag = if ok_s != "" { ok_s } else { c_type_tag(ok_t) }
            let err_tag = if err_s != "" { err_s } else { c_type_tag(err_t) }
            ensure_struct_result_type(ok_tag, err_tag)
        } else {
            ensure_result_type(ok_t, err_t)
        }
        let ok_d = payload_desc_for(ok_t, ok_s)
        let err_d = payload_desc_for(err_t, err_s)
        return "R:{ok_d}|{err_d}"
    }
    ""
}

// Option/Result payloads hold a compound literal for expr_result_str (not a
// var), so list/map metadata can only be read from the last-published globals.
fn payload_desc_for(ct: Int, sname: Str) -> Str {
    if sname != "" { return "S:{sname}" }
    if ct == CT_LIST {
        let et = if expr_list_elem_type >= 0 { expr_list_elem_type } else { -1 }
        let es = expr_list_elem_struct
        return "L:{ct_to_descriptor(et, es)}"
    }
    if ct == CT_MAP {
        let kt = if expr_map_key_type >= 0 { expr_map_key_type } else { CT_STRING }
        let vt = if expr_map_val_type >= 0 { expr_map_val_type } else { -1 }
        return "M:{ct_to_descriptor(kt, "")}|{ct_to_descriptor(vt, "")}"
    }
    ct_to_descriptor(ct, "")
}

// Returns "" for unsupported kinds (caller maps to an E0702 variant).
pub fn descriptor_from_capture(entry: CaptureEntry) -> Str {
    let k = tp_get_kind(entry.tp_id)
    if k == CT_INT { return "P:Int" }
    if k == CT_BOOL { return "P:Bool" }
    if k == CT_FLOAT { return "P:Float" }
    if k == CT_STRING { return "P:Str" }
    if k == CT_STRUCT {
        let sn = tp_get_sname(entry.tp_id)
        if sn != "" { return "S:{sn}" }
        return ""
    }
    if k == CT_LIST {
        let ek = tp_child1_kind(entry.tp_id)
        let es = tp_child1_sname(entry.tp_id)
        return "L:{ct_to_descriptor(ek, es)}"
    }
    if k == CT_MAP {
        let vk = tp_child2_kind(entry.tp_id)
        let vs = tp_child2_sname(entry.tp_id)
        return "M:P:Str|{ct_to_descriptor(vk, vs)}"
    }
    if k == CT_CLOSURE {
        let sig = tp_get_sname(entry.tp_id)
        return "C:{closure_sig_hash(sig)}"
    }
    ""
}

// `closure_src` must be a C expression of type `blink_closure*` pointing at
// the inner-arena closure. Returns 1 on success, 0 if a carve-out E0702*
// diagnostic was reported instead.
@allow(UnrestoredMutation)
fn emit_closure_tail_promotion(
    closure_src: Str,
    cap_idx: Int,
    tail_node: Int,
    result_sink: Str,
    arena_prev: Str,
    block_local_muts: List[Str],
) -> Int ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let info = closure_cap_infos.get(cap_idx).unwrap()
    let target = if arena_prev != "" { arena_prev } else { "NULL" }

    let mut ci = 0
    while ci < info.count {
        let e = closure_captures.get(info.start + ci).unwrap()
        if descriptor_from_capture(e) == "" {
            diag_error_at(
                "ArenaClosureUnsupportedCapture", "E0702d",
                "cannot promote closure tail of 'with arena \{ expr }': capture of unsupported kind",
                tail_node,
                "construct the closure outside the 'with arena \{ }' block"
            )
            return 0
        }
        ci = ci + 1
    }

    // Bind closure_src to a temp — it may be an rvalue (e.g. blink_closure_new_typed(...))
    // and we reference it repeatedly below.
    let src_tmp = fresh_temp("__acl_src_")
    emit_line("blink_closure* {src_tmp} = {closure_src};")

    if info.count == 0 {
        emit_line("{result_sink} = blink_closure_new_typed({src_tmp}->fn_ptr, NULL, NULL, 0, {src_tmp}->promoter);")
        return 1
    }

    let p_caps = fresh_temp("__acl_caps_")
    emit_line("void** {p_caps} = (void**)blink_promote_alloc({target}, sizeof(void*) * {info.count});")
    emit_line("\{")
    cg_indent = cg_indent + 1
    // emit_promote_elem_into's struct/list/map walkers reference a local
    // `target` identifier, mirroring the @derive promote functions they inline.
    emit_line("blink_arena_t* target = {target};")
    emit_line("blink_arena_t* __acl_save = __blink_current_arena;")
    emit_line("__blink_current_arena = target;")
    let mut i = 0
    while i < info.count {
        let e = closure_captures.get(info.start + i).unwrap()
        let desc = descriptor_from_capture(e)
        queue_promote_type(desc)
        emit_trace_arena_capture("tail", i, desc, tail_node)
        let mut declared_in_block = 0
        if e.is_mut != 0 {
            let mut bi = 0
            while bi < block_local_muts.len() {
                if block_local_muts.get(bi).unwrap() == e.name {
                    declared_in_block = 1
                }
                bi = bi + 1
            }
        }
        emit_promote_capture_slot("{src_tmp}->captures[{i}]", "{p_caps}[{i}]", desc, e.is_mut, declared_in_block, e.tp_id)
        i = i + 1
    }
    emit_line("{result_sink} = blink_closure_new_typed({src_tmp}->fn_ptr, {p_caps}, {src_tmp}->capture_descs, {info.count}, {src_tmp}->promoter);")
    emit_line("__blink_current_arena = __acl_save;")
    cg_indent = cg_indent - 1
    emit_line("}")
    1
}

// declared_in_block=0 aliases an outside-block mut cell to preserve spec §2.8
// shared-cell semantics; =1 deep-copies a block-local cell.
pub fn emit_promote_capture_slot(src_slot: Str, dst_slot: Str, desc: Str, is_mut: Int, declared_in_block: Int, tp_id: Int) ! Codegen.Emit {
    let ct = desc_primary_ct(desc)
    if is_mut != 0 {
        if declared_in_block != 0 {
            let cell_c = if ct == CT_STRUCT { c_type_c_name(tp_get_sname(tp_id)) } else { descriptor_c_type(desc) }
            let src_cell = fresh_temp("__acl_sc_")
            let new_cell = fresh_temp("__acl_nc_")
            emit_line("{cell_c}* {src_cell} = ({cell_c}*){src_slot};")
            emit_line("{cell_c}* {new_cell} = ({cell_c}*)blink_promote_alloc(target, sizeof({cell_c}));")
            if ct == CT_INT || ct == CT_BOOL || ct == CT_FLOAT {
                emit_line("*{new_cell} = *{src_cell};")
            } else if ct == CT_STRING {
                emit_line("*{new_cell} = blink_promote_str(target, *{src_cell});")
            } else {
                let mangle = descriptor_mangle(desc)
                emit_line("*{new_cell} = blink_promote_{mangle}(target, *{src_cell});")
            }
            emit_line("{dst_slot} = (void*){new_cell};")
        } else {
            emit_line("{dst_slot} = {src_slot};")
        }
        return
    }
    let stored = emit_promote_elem_into(src_slot, ct, desc)
    emit_line("{dst_slot} = {stored};")
}

pub fn emit_trace_arena_capture(op: Str, slot: Int, desc: Str, _node: Int) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    emit_line("blink_trace_arena_event(\"{cg_current_fn_name}\", \"{cg_current_module}\", __blink_trace.depth, \"{op}\", (int64_t){slot}, \"{desc}\", 0, 0);")
}

fn emit_and_log_promote_phase(phase: Str, target_expr: Str, desc: Str, node: Int) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    let rel_path = trace_relative_path(diag_file_for_node(node))
    let line = node_line(node)
    let col = node_col(node)
    emit_line("blink_trace_arena_promote(\"{cg_current_fn_name}\", \"{cg_current_module}\", __blink_trace.depth, \"{phase}\", ({target_expr}) ? \"outer arena\" : \"GC heap\", \"{desc}\", \"{rel_path}\", {line}, {col});")
    trace("codegen", "arena.promote {phase} desc={desc} at {rel_path}:{line}:{col}")
}

// Emit the body of an expression-form `with { … }`: run leading statements,
// evaluate the tail expression with the inner arena still active, then
// promote into `result_sink`. Returns the promote descriptor actually used
// so the caller can publish correct metadata.
@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_block_then_capture(block: Int, result_sink: Str, arena_prev: Str) -> Str ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if block == -1 {
        return ""
    }
    let stmts_sl = node_stmts(block)
    if stmts_sl == -1 {
        return ""
    }
    let count = sublist_length(stmts_sl)
    if count == 0 {
        return ""
    }
    // Block-local `let x = <ClosureLit>` aliases let a tail Ident resolve to
    // its originating literal for the cap-info lookup below.
    let mut let_alias_names: List[Str] = []
    let mut let_alias_nodes: List[Int] = []
    // Names of `let mut` bindings introduced *inside* this block. Only these
    // are safe to promote as closure-tail mut captures — an outside-block
    // binding may still be referenced after the with-arena block ends.
    let mut block_local_muts: List[Str] = []
    let mut i = 0
    while i < count - 1 {
        let stmt = sublist_get(stmts_sl, i)
        if node_kind(stmt) == NodeKind.LetBinding {
            let init = node_value(stmt)
            if init != -1 && node_kind(init) == NodeKind.Closure {
                let_alias_names.push(node_name(stmt))
                let_alias_nodes.push(init)
            }
            if node_is_mut(stmt) != 0 {
                block_local_muts.push(node_name(stmt))
            }
        }
        emit_stmt(stmt)
        i = i + 1
    }
    let last = sublist_get(stmts_sl, count - 1)
    let last_kind = node_kind(last)
    let tail_node = if last_kind == NodeKind.ExprStmt { node_value(last) } else { last }
    emit_expr(tail_node)
    let tail_str = expr_result_str
    if expr_result_type == CT_CLOSURE {
        let mut lit_node = -1
        let tk = node_kind(tail_node)
        if tk == NodeKind.Closure {
            lit_node = tail_node
        } else if tk == NodeKind.Ident {
            let tname = node_name(tail_node)
            let mut ai = 0
            while ai < let_alias_names.len() {
                if let_alias_names.get(ai).unwrap() == tname {
                    lit_node = let_alias_nodes.get(ai).unwrap()
                }
                ai = ai + 1
            }
            // Ident lookup doesn't populate expr_closure_sig; fetch it from the
            // var table so the outer let binding can record the right call sig.
            let sig_from_var = get_var_closure_sig(tname)
            if sig_from_var != "" {
                expr_closure_sig = sig_from_var
            }
        }
        let cap_idx = if lit_node == -1 { -1 } else { lookup_closure_lit_cap_idx(lit_node) }
        if cap_idx == -1 {
            diag_error_at(
                "ArenaClosureTailNonLiteral", "E0702a",
                "cannot promote closure tail of 'with arena \{ expr }' whose origin is not a closure literal bound in this block",
                tail_node,
                "construct the closure outside the 'with arena \{ }' block, or bind it via `let <name> = fn(…) \{ … }` immediately inside this block"
            )
            return ""
        }
        if result_sink == "" {
            return ""
        }
        let ok = emit_closure_tail_promotion(tail_str, cap_idx, tail_node, result_sink, arena_prev, block_local_muts)
        if ok == 0 {
            return ""
        }
        return "C:Closure"
    }
    let desc = descriptor_from_expr_state()
    if result_sink != "" && desc != "" {
        let target = if arena_prev != "" { arena_prev } else { "NULL" }
        if desc == "P:Str" {
            emit_line("{result_sink} = blink_promote_str({target}, {tail_str});")
        } else if desc.starts_with("P:") {
            emit_line("{result_sink} = {tail_str};")
        } else {
            let mangle = descriptor_mangle(desc)
            queue_promote_type(desc)
            emit_line("{result_sink} = blink_promote_{mangle}({target}, {tail_str});")
        }
    }
    desc
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_with_block_expr(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let sink = fresh_temp("__with_result_")
    // Buffer the body emission so we can discover the tail descriptor,
    // then prepend a correctly-typed sink declaration.
    let saved_lines = cg_lines
    cg_lines = []
    let desc = emit_with_block_core(node, 1, sink)
    let body_lines = cg_lines
    cg_lines = saved_lines
    if desc == "" {
        // Not promotion-eligible — emit as statement form and publish void.
        let mut bi = 0
        while bi < body_lines.len() {
            cg_lines.push(body_lines.get(bi).unwrap())
            bi = bi + 1
        }
        expr_result_str = "0"
        expr_result_type = CT_VOID
        return
    }
    emit_line("{descriptor_c_type(desc)} {sink};")
    let mut bi = 0
    while bi < body_lines.len() {
        cg_lines.push(body_lines.get(bi).unwrap())
        bi = bi + 1
    }
    expr_result_str = sink
    publish_descriptor_as_var(sink, desc)
}

fn prim_desc_ct(desc: Str) -> Int {
    let ct = desc_primary_ct(desc)
    if ct == CT_BOOL { return CT_INT }
    ct
}

@allow(UnrestoredMutation)
fn publish_descriptor_as_var(sink: Str, desc: Str) ! Codegen.Register, Codegen.Scope {
    let ct = desc_primary_ct(desc)
    if ct == CT_INT || ct == CT_FLOAT || ct == CT_STRING {
        expr_result_type = ct
        return
    }
    if ct == CT_BOOL {
        expr_result_type = CT_INT
        return
    }
    if ct == CT_CLOSURE {
        expr_result_type = CT_CLOSURE
        set_var(sink, CT_CLOSURE, 0)
        if expr_closure_sig != "" {
            set_var_closure(sink, expr_closure_sig)
        }
        return
    }
    if ct == CT_STRUCT {
        expr_result_type = CT_VOID
        set_var(sink, CT_VOID, 1)
        set_var_struct(sink, desc.slice(2, desc.len()))
        return
    }
    if ct == CT_LIST {
        expr_result_type = CT_LIST
        set_var(sink, CT_LIST, 1)
        let inner = inner_desc_of(desc)
        let et = prim_desc_ct(inner)
        expr_list_elem_type = et
        set_list_elem_type(sink, et)
        if inner.starts_with("S:") {
            let sn = inner.slice(2, inner.len())
            expr_list_elem_struct = sn
            set_list_elem_struct(sink, sn)
        }
        return
    }
    if ct == CT_MAP {
        expr_result_type = CT_MAP
        set_var(sink, CT_MAP, 1)
        let rest = desc.slice(2, desc.len())
        let bar = rest.index_of("|")
        let k = rest.slice(0, bar)
        let v = rest.slice(bar + 1, rest.len())
        let kt = prim_desc_ct(k)
        let vt = prim_desc_ct(v)
        let mut vs: Str = ""
        if v.starts_with("S:") { vs = v.slice(2, v.len()) }
        expr_map_key_type = kt
        expr_map_val_type = vt
        set_map_types(sink, kt, vt, vs)
        if vs != "" { set_map_value_struct(sink, vs) }
        return
    }
    if ct == CT_OPTION {
        expr_result_type = CT_OPTION
        let inner = desc.slice(2, desc.len())
        let inner_ct = prim_desc_ct(inner)
        let mut inner_s: Str = ""
        if inner.starts_with("S:") { inner_s = inner.slice(2, inner.len()) }
        if inner_s != "" {
            set_var_option_struct(sink, inner_ct, inner_s)
        } else {
            set_var_option(sink, inner_ct)
        }
        expr_option_inner = inner_ct
        expr_option_inner_struct = inner_s
        return
    }
    if ct == CT_RESULT {
        expr_result_type = CT_RESULT
        let rest = desc.slice(2, desc.len())
        let bar = rest.index_of("|")
        let ok_d = rest.slice(0, bar)
        let err_d = rest.slice(bar + 1, rest.len())
        let ok_t = prim_desc_ct(ok_d)
        let err_t = prim_desc_ct(err_d)
        let mut ok_s: Str = ""
        let mut err_s: Str = ""
        if ok_d.starts_with("S:") { ok_s = ok_d.slice(2, ok_d.len()) }
        if err_d.starts_with("S:") { err_s = err_d.slice(2, err_d.len()) }
        if ok_s != "" || err_s != "" {
            set_var_result_struct(sink, ok_t, err_t, ok_s, err_s)
        } else {
            set_var_result(sink, ok_t, err_t)
        }
        expr_result_ok_type = ok_t
        expr_result_err_type = err_t
        expr_result_ok_struct = ok_s
        expr_result_err_struct = err_s
        return
    }
    expr_result_type = CT_VOID
}


// ── Function codegen ────────────────────────────────────────────────

pub fn ann_str_val(node: Int) -> Str {
    let parts_sl = node_elements(node)
    if parts_sl != -1 && sublist_length(parts_sl) > 0 {
        return node_str_val(sublist_get(parts_sl, 0))
    }
    node_name(node)
}

fn format_param_names(fn_node: Int) -> Str {
    let params_sl = node_params(fn_node)
    if params_sl == -1 {
        return ""
    }
    let count = sublist_length(params_sl)
    if count == 0 {
        return ""
    }
    let mut result = ""
    let mut i = 0
    while i < count {
        let p = sublist_get(params_sl, i)
        let pname = c_safe_name(node_name(p))
        if i > 0 {
            result = result.concat(", ")
        }
        result = result.concat(pname)
        i = i + 1
    }
    result
}

fn get_ffi_ann(fn_node: Int) -> Int {
    get_annotation(fn_node, "ffi")
}

fn format_params(fn_node: Int) -> Str {
    let has_ev = fn_node_has_effects(fn_node) != 0 && get_ffi_ann(fn_node) == -1
    let params_sl = node_params(fn_node)
    if params_sl == -1 {
        if has_ev {
            return "blink_ev* __ev"
        }
        return "void"
    }
    let count = sublist_length(params_sl)
    if count == 0 {
        if has_ev {
            return "blink_ev* __ev"
        }
        return "void"
    }
    let mut result = ""
    let mut i = 0
    while i < count {
        let p = sublist_get(params_sl, i)
        let pname = c_safe_name(node_name(p))
        let ptype = node_type_name(p)
        if i > 0 {
            result = result.concat(", ")
        }
        if ptype == "Fn" {
            result = result.concat("blink_closure* {pname}")
        } else if ptype == "Ptr" {
            let pta = node_type_ann(p)
            if pta != -1 {
                let pelems_sl = node_elements(pta)
                if pelems_sl != -1 && sublist_length(pelems_sl) > 0 {
                    let inner_ann = sublist_get(pelems_sl, 0)
                    let inner_name = node_name(inner_ann)
                    result = result.concat("{ptr_inner_c_type(inner_name)}* {pname}")
                } else {
                    result = result.concat("void* {pname}")
                }
            } else {
                result = result.concat("void* {pname}")
            }
        } else if ptype == "Tuple" {
            let ta = node_type_ann(p)
            if ta != -1 {
                let tup_name = resolve_tuple_ann(ta, -1, "").unwrap()
                result = result.concat("{c_type_c_name(tup_name)} {pname}")
            } else {
                result = result.concat("void {pname}")
            }
        } else if is_enum_type(ptype) != 0 {
            result = result.concat("{c_type_c_name(ptype)} {pname}")
        } else if is_struct_type(ptype) != 0 {
            result = result.concat("{c_type_c_name(ptype)} {pname}")
        } else if ptype == "Result" {
            let ta = node_type_ann(p)
            if ta != -1 {
                let elems_sl = node_elements(ta)
                if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                    let ok_ann = sublist_get(elems_sl, 0)
                    let err_ann = sublist_get(elems_sl, 1)
                    let ok_name = node_name(ok_ann)
                    let err_name = node_name(err_ann)
                    let ok_t = type_from_name(ok_name)
                    let err_t = type_from_name(err_name)
                    let ok_is_type = is_struct_type(ok_name) != 0 || is_enum_type(ok_name) != 0
                    let err_is_type = is_struct_type(err_name) != 0 || is_enum_type(err_name) != 0
                    if ok_is_type || err_is_type {
                        let ok_tag = if ok_is_type { ok_name } else { c_type_tag(ok_t) }
                        let err_tag = if err_is_type { err_name } else { c_type_tag(err_t) }
                        result = result.concat("blink_Result_{ok_tag}_{err_tag} {pname}")
                    } else {
                        result = result.concat("{result_c_type(ok_t, err_t)} {pname}")
                    }
                } else {
                    result = result.concat("{result_c_type(CT_INT, CT_STRING)} {pname}")
                }
            } else {
                result = result.concat("{result_c_type(CT_INT, CT_STRING)} {pname}")
            }
        } else if ptype == "Option" {
            let ta = node_type_ann(p)
            if ta != -1 {
                let elems_sl = node_elements(ta)
                if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                    let inner_ann = sublist_get(elems_sl, 0)
                    let inner_name = node_name(inner_ann)
                    let inner_t = type_from_name(inner_name)
                    if is_struct_type(inner_name) != 0 || is_enum_type(inner_name) != 0 {
                        result = result.concat("blink_Option_{inner_name} {pname}")
                    } else {
                        result = result.concat("{option_c_type(inner_t)} {pname}")
                    }
                } else {
                    result = result.concat("{option_c_type(CT_INT)} {pname}")
                }
            } else {
                result = result.concat("{option_c_type(CT_INT)} {pname}")
            }
        } else if ptype == "Handler" {
            let ta = node_type_ann(p)
            if ta != -1 {
                let elems_sl = node_elements(ta)
                if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                    let effect_ann = sublist_get(elems_sl, 0)
                    let effect_name = node_name(effect_ann)
                    let vt = resolve_effect_vtable(effect_name)
                    if vt != "" {
                        result = result.concat("{vt}* {pname}")
                    } else {
                        result = result.concat("void* {pname}")
                    }
                } else {
                    result = result.concat("void* {pname}")
                }
            } else {
                result = result.concat("void* {pname}")
            }
        } else {
            let ct = type_from_name(ptype)
            result = result.concat("{c_type_str(ct)} {pname}")
        }
        i = i + 1
    }
    if has_ev {
        if result == "" {
            result = "blink_ev* __ev"
        } else {
            result = result.concat(", blink_ev* __ev")
        }
    }
    result
}

pub fn format_impl_params(fn_node: Int, impl_type: Str) -> Str {
    let params_sl = node_params(fn_node)
    let self_name = impl_method_self_name(fn_node)
    let mut result = ""
    if self_name != "" {
        let impl_ct = type_from_name(impl_type)
        if builtin_receiver_type_name(impl_ct) != "" {
            result = "{c_type_str(impl_ct)} {self_name}"
        } else {
            result = "{c_type_c_name(impl_type)} {self_name}"
        }
    }
    let mut _first = 1
    if self_name != "" {
        _first = 0
    }
    if params_sl != -1 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname_raw = node_name(p)
            if pname_raw != "self" && pname_raw != "_self" {
                let pname = c_safe_name(pname_raw)
                let ptype_raw = node_type_name(p)
                let ptype = resolve_self_type(ptype_raw, impl_type)
                if _first == 0 {
                    result = result.concat(", ")
                }
                _first = 0
                if ptype == "Fn" {
                    result = result.concat("blink_closure* {pname}")
                } else if ptype == "Tuple" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let tup_name = resolve_tuple_ann(ta, -1, "").unwrap()
                        result = result.concat("{c_type_c_name(tup_name)} {pname}")
                    } else {
                        result = result.concat("void {pname}")
                    }
                } else if is_struct_type(ptype) != 0 {
                    result = result.concat("{c_type_c_name(ptype)} {pname}")
                } else if is_enum_type(ptype) != 0 {
                    result = result.concat("{c_type_c_name(ptype)} {pname}")
                } else {
                    let ct = type_from_name(ptype)
                    result = result.concat("{c_type_str(ct)} {pname}")
                }
            }
            i = i + 1
        }
    }
    if result == "" {
        result = "void"
    }
    result
}

fn emit_unused_param_voids(params_sl: Int) ! Codegen.Emit {
    if params_sl != -1 {
        let mut j = 0
        while j < sublist_length(params_sl) {
            let p = sublist_get(params_sl, j)
            let pname = node_name(p)
            if pname.starts_with("_") {
                emit_line("(void){c_safe_name(pname)};")
            }
            j = j + 1
        }
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_requires_assertions(fn_node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let anns_sl = node_handlers(fn_node)
    if anns_sl == -1 {
        return
    }
    let mut i = 0
    while i < sublist_length(anns_sl) {
        let ann = sublist_get(anns_sl, i)
        let ann_name = node_name(ann)
        if ann_name == "requires" {
            let args_sl = node_args(ann)
            if args_sl != -1 && sublist_length(args_sl) > 0 {
                let expr_node = sublist_get(args_sl, 0)
                emit_expr(expr_node)
                let cond = expr_result_str
                emit_line("if (!({cond})) \{ fprintf(stderr, \"precondition failed: @requires in %s\\n\", \"{cg_current_fn_name}\"); exit(1); }")
            }
        }
        i = i + 1
    }
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_impl_method_def(fn_node: Int, impl_type: Str, im_node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    push_scope()
    cg_temp_counter = 0
    cg_handler_vtable_type = ""
    cg_handler_vtable_field = ""
    cg_handler_is_user_effect = 0
    cg_current_module = node_module(fn_node)
    let mname = node_name(fn_node)
    let mangled = mangle_impl_method(im_node, impl_type, mname)
    cg_current_fn_name = mangled
    cg_current_fn_has_ev = if fn_node_has_effects(fn_node) != 0 { 1 } else { 0 }
    let ret_str_raw = node_return_type(fn_node)
    let ret_str = resolve_self_type(ret_str_raw, impl_type)
    let ret_type = type_from_name(ret_str)
    cg_current_fn_ret = ret_type
    if ret_type == CT_OPTION {
        cg_current_fn_option_inner = resolve_option_inner_from_ann(fn_node)
    } else {
        cg_current_fn_option_inner = 0
    }
    let params = format_impl_params(fn_node, impl_type)
    let enum_ret = get_fn_enum_ret(mangled)
    let mut sig = ""
    if enum_ret != "" {
        sig = "{c_type_c_name(enum_ret)} {c_fn_name(mangled)}({params})"
    } else if is_struct_type(ret_str) != 0 {
        sig = "{c_type_c_name(ret_str)} {c_fn_name(mangled)}({params})"
    } else {
        let resolved = resolve_ret_type_from_ann(fn_node)
        if resolved != "" {
            sig = "{resolved} {c_fn_name(mangled)}({params})"
        } else {
            sig = "{c_type_str(ret_type)} {c_fn_name(mangled)}({params})"
        }
    }

    let self_name = impl_method_self_name(fn_node)
    if self_name != "" {
        let impl_ct = type_from_name(impl_type)
        if builtin_receiver_type_name(impl_ct) != "" {
            set_var(self_name, impl_ct, 0)
        } else {
            set_var(self_name, CT_VOID, 0)
            set_var_struct(self_name, impl_type)
        }
    }

    let params_sl = node_params(fn_node)
    if params_sl != -1 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname = node_name(p)
            if pname != "self" && pname != "_self" {
                let ptype_raw = node_type_name(p)
                let ptype = resolve_self_type(ptype_raw, impl_type)
                if ptype == "Fn" {
                    set_var(pname, CT_CLOSURE, 1)
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let sig_str = build_closure_sig_from_type_ann(ta)
                        set_var_closure(pname, sig_str)
                    }
                } else {
                    let param_ct = if is_enum_type(ptype) != 0 { CT_INT } else { type_from_name(ptype) }
                    set_var(pname, param_ct, 1)
                    if is_struct_type(ptype) != 0 {
                        set_var_struct(pname, ptype)
                    }
                    if is_enum_type(ptype) != 0 {
                        var_enums.push(VarEnumEntry { name: pname, enum_type: ptype })
                    }
                    if ptype == "List" {
                        let ta = node_type_ann(p)
                        if ta != -1 {
                            let elems_sl = node_elements(ta)
                            if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                                let elem_ann = sublist_get(elems_sl, 0)
                                let elem_name = node_name(elem_ann)
                                let elem_ct = type_from_name(elem_name)
                                set_list_elem_type(pname, elem_ct)
                                if elem_ct == CT_VOID && (is_named_type(elem_name) != 0) {
                                    set_list_elem_struct(pname, elem_name)
                                } else if elem_ct == CT_VOID && elem_name == "Tuple" {
                                    let tup_opt = resolve_tuple_ann(elem_ann, -1, "")
                                    if tup_opt.is_some() {
                                        set_list_elem_struct(pname, tup_opt.unwrap())
                                    }
                                }
                                if elem_ct == CT_LIST {
                                    let nested_sl = node_elements(elem_ann)
                                    if nested_sl != -1 && sublist_length(nested_sl) > 0 {
                                        let nested_ann = sublist_get(nested_sl, 0)
                                        let nested_name = node_name(nested_ann)
                                        let nested_ct = type_from_name(nested_name)
                                        set_list_nested_elem_type(pname, nested_ct)
                                        if nested_ct == CT_VOID && is_struct_type(nested_name) != 0 {
                                            set_list_nested_elem_struct(pname, nested_name)
                                        }
                                    }
                                }
                            }
                        }
                    }
                    if ptype == "Map" {
                        let ta = node_type_ann(p)
                        if ta != -1 {
                            let elems_sl = node_elements(ta)
                            if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                                let key_ann = sublist_get(elems_sl, 0)
                                let val_ann = sublist_get(elems_sl, 1)
                                let val_name = node_name(val_ann)
                                let val_ct = type_from_name(val_name)
                                set_map_types(pname, type_from_name(node_name(key_ann)), val_ct, val_name)
                                propagate_map_list_elem(pname, val_ct, val_ann)
                            }
                        }
                    }
                    if ptype == "Set" {
                        let ta = node_type_ann(p)
                        if ta != -1 {
                            let elems_sl = node_elements(ta)
                            if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                                let elem_ann = sublist_get(elems_sl, 0)
                                let elem_name = node_name(elem_ann)
                                let elem_ct = type_from_name(elem_name)
                                set_set_elem_type(pname, elem_ct)
                            }
                        }
                    }
                    if ptype == "Tuple" {
                        let ta = node_type_ann(p)
                        if ta != -1 {
                            let tup_name = resolve_tuple_ann(ta, -1, "").unwrap()
                            set_var_struct(pname, tup_name)
                        }
                    }
                }
            }
            i = i + 1
        }
    }

    let mut body_ret = ret_type
    if is_struct_type(ret_str) != 0 || is_enum_type(ret_str) != 0 || ret_str == "Tuple" {
        body_ret = CT_INT
    }
    cg_current_fn_node = fn_node
    let saved_trace_fn = cg_trace_fn_qualified
    let saved_trace_mod = cg_trace_module
    let saved_in_traced = cg_in_traced_fn
    cg_in_traced_fn = 0
    emit_line("{sig} \{")
    cg_indent = cg_indent + 1

    emit_unused_param_voids(params_sl)

    let trace_file = diag_file_for_node(fn_node)
    emit_trace_enter(fn_node, mname, cg_current_module, trace_file)

    emit_requires_assertions(fn_node)
    emit_fn_body(node_body(fn_node), body_ret)
    if ret_type == CT_VOID {
        emit_trace_exit_void()
    }
    cg_indent = cg_indent - 1
    emit_line("}")
    cg_trace_fn_qualified = saved_trace_fn
    cg_trace_module = saved_trace_mod
    cg_in_traced_fn = saved_in_traced
    pop_scope()
}

fn ffi_c_ret_type(fn_node: Int) -> Str {
    let ret_str = node_return_type(fn_node)
    let ret_type = type_from_name(ret_str)
    if is_struct_type(ret_str) != 0 || is_enum_type(ret_str) != 0 {
        return c_type_c_name(ret_str)
    }
    let resolved = resolve_ret_type_from_ann(fn_node)
    if resolved != "" { return resolved }
    c_type_str(ret_type)
}

pub fn emit_fn_decl(fn_node: Int) ! Codegen.Emit {
    let name = node_name(fn_node)
    let ffi_ann = get_ffi_ann(fn_node)
    if ffi_ann != -1 {
        let ffi_args_sl = node_args(ffi_ann)
        let mut ffi_symbol = name
        if ffi_args_sl != -1 {
            let ffi_argc = sublist_length(ffi_args_sl)
            if ffi_argc >= 2 {
                ffi_symbol = ann_str_val(sublist_get(ffi_args_sl, 1))
            } else if ffi_argc == 1 {
                ffi_symbol = ann_str_val(sublist_get(ffi_args_sl, 0))
            }
        }
        let c_name = c_fn_name(name)
        if c_name != ffi_symbol || !is_runtime_header_fn(ffi_symbol) {
            let params = format_params(fn_node)
            let c_ret = ffi_c_ret_type(fn_node)
            emit_line("{c_ret} {c_name}({params});")
        }
        return
    }
    if name == "main" {
        emit_line("void blink_main(blink_ev* __ev);")
        return
    }
    let params = format_params(fn_node)
    let enum_ret = get_fn_enum_ret(name)
    if enum_ret != "" {
        emit_line("{c_type_c_name(enum_ret)} {c_fn_name(name)}({params});")
    } else {
        let ret_str = node_return_type(fn_node)
        if is_struct_type(ret_str) != 0 {
            emit_line("{c_type_c_name(ret_str)} {c_fn_name(name)}({params});")
        } else {
            let resolved = resolve_ret_type_from_ann(fn_node)
            if resolved != "" {
                emit_line("{resolved} {c_fn_name(name)}({params});")
            } else {
                let ret_type = type_from_name(ret_str)
                emit_line("{c_type_str(ret_type)} {c_fn_name(name)}({params});")
            }
        }
    }
}

// ── Trace helpers ────────────────────────────────────────────────────

let mut cg_trace_fn_qualified: Str = ""
let mut cg_trace_module: Str = ""
pub let mut cg_in_traced_fn: Int = 0

fn trace_format_spec(ptype: Str) -> Str {
    if ptype == "Int" { return "%lld" }
    if ptype == "Float" { return "%g" }
    if ptype == "Bool" { return "%s" }
    if ptype == "Str" { return "%s" }
    "<{ptype}>"
}

fn trace_c_arg_expr(pname: Str, ptype: Str) -> Str {
    let c_name = c_safe_name(pname)
    if ptype == "Int" { return "(long long){c_name}" }
    if ptype == "Float" { return "(double){c_name}" }
    if ptype == "Bool" { return "{c_name} ? \"true\" : \"false\"" }
    if ptype == "Str" { return "{c_name} ? {c_name} : \"null\"" }
    "\"{ptype}\""
}

fn trace_ret_is_primitive(ret_str: Str) -> Int {
    if ret_str == "Int" || ret_str == "Float" || ret_str == "Bool" || ret_str == "Str" {
        return 1
    }
    0
}

fn trace_relative_path(file_path: Str) -> Str {
    let idx = file_path.index_of("src/")
    if idx >= 0 {
        return file_path.substring(idx, file_path.len() - idx)
    }
    let idx2 = file_path.index_of("lib/")
    if idx2 >= 0 {
        return file_path.substring(idx2, file_path.len() - idx2)
    }
    file_path
}

fn emit_trace_enter(fn_node: Int, fn_name: Str, module_name: Str, file_path: Str) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    let line = node_line(fn_node)
    let col = node_col(fn_node)
    let rel_path = trace_relative_path(file_path)
    let qualified = if module_name != "" && module_name != "__main__" { "{module_name}.{fn_name}" } else { fn_name }
    let mod_str = if module_name != "" { module_name } else { "__main__" }

    cg_trace_fn_qualified = qualified
    cg_trace_module = mod_str
    cg_in_traced_fn = 1

    emit_line("int64_t __trace_enter_ts = 0;")

    let params_sl = node_params(fn_node)
    let has_params = params_sl != -1 && sublist_length(params_sl) > 0

    if has_params {
        emit_line("char __trace_args_buf[1024];")
        let mut fmt_str = ""
        let mut arg_exprs = ""
        let mut pi = 0
        let param_count = sublist_length(params_sl)
        while pi < param_count {
            let p = sublist_get(params_sl, pi)
            let pname = node_name(p)
            let ptype = node_type_name(p)
            if pi > 0 {
                fmt_str = fmt_str.concat(",")
            }
            let escaped_name = pname.replace("\"", "\\\"")
            let spec = trace_format_spec(ptype)
            fmt_str = fmt_str.concat("\\\"").concat(escaped_name).concat("\\\":\\\"").concat(spec).concat("\\\"")
            arg_exprs = arg_exprs.concat(", ").concat(trace_c_arg_expr(pname, ptype))
            pi = pi + 1
        }
        emit_line("if (__blink_trace.active && blink_trace_match(\"{qualified}\", \"{mod_str}\", __blink_trace.depth)) \{")
        cg_indent = cg_indent + 1
        emit_line("__trace_enter_ts = blink_trace_ts_us();")
        emit_line("snprintf(__trace_args_buf, sizeof(__trace_args_buf), \"{fmt_str}\"{arg_exprs});")
        emit_line("blink_trace_enter(\"{qualified}\", \"{mod_str}\", __blink_trace.depth, \"{rel_path}\", {line}, {col}, __trace_args_buf);")
        emit_line("__blink_trace.depth++;")
        cg_indent = cg_indent - 1
        emit_line("}")
    } else {
        emit_line("if (__blink_trace.active && blink_trace_match(\"{qualified}\", \"{mod_str}\", __blink_trace.depth)) \{")
        cg_indent = cg_indent + 1
        emit_line("__trace_enter_ts = blink_trace_ts_us();")
        emit_line("blink_trace_enter(\"{qualified}\", \"{mod_str}\", __blink_trace.depth, \"{rel_path}\", {line}, {col}, NULL);")
        emit_line("__blink_trace.depth++;")
        cg_indent = cg_indent - 1
        emit_line("}")
    }
}

pub fn emit_trace_exit_void() ! Codegen.Emit {
    if cg_in_traced_fn == 0 { return }
    emit_line("if (__trace_enter_ts) \{")
    cg_indent = cg_indent + 1
    emit_line("__blink_trace.depth--;")
    emit_line("blink_trace_exit(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, __trace_enter_ts, \"()\");")
    cg_indent = cg_indent - 1
    emit_line("}")
}

fn emit_trace_exit_with_val(val_expr: Str, ret_str: Str) ! Codegen.Emit {
    if cg_in_traced_fn == 0 { return }
    emit_line("if (__trace_enter_ts) \{")
    cg_indent = cg_indent + 1
    emit_line("__blink_trace.depth--;")
    if trace_ret_is_primitive(ret_str) != 0 {
        let spec = trace_format_spec(ret_str)
        emit_line("char __trace_ret_buf[256];")
        if ret_str == "Int" {
            emit_line("snprintf(__trace_ret_buf, sizeof(__trace_ret_buf), \"{spec}\", (long long){val_expr});")
        } else if ret_str == "Float" {
            emit_line("snprintf(__trace_ret_buf, sizeof(__trace_ret_buf), \"{spec}\", (double){val_expr});")
        } else if ret_str == "Bool" {
            emit_line("snprintf(__trace_ret_buf, sizeof(__trace_ret_buf), \"{spec}\", {val_expr} ? \"true\" : \"false\");")
        } else if ret_str == "Str" {
            emit_line("snprintf(__trace_ret_buf, sizeof(__trace_ret_buf), \"%s\", {val_expr} ? {val_expr} : \"null\");")
        }
        emit_line("blink_trace_exit(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, __trace_enter_ts, __trace_ret_buf);")
    } else {
        emit_line("blink_trace_exit(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, __trace_enter_ts, \"<{ret_str}>\");")
    }
    cg_indent = cg_indent - 1
    emit_line("}")
}

@allow(UnrestoredMutation)
pub fn emit_return_with_trace(val_str: Str, ret_type: Int) ! Codegen.Emit {
    let mut actual_val = val_str
    if cg_in_handler_body != 0 && cg_handler_body_is_ue != 0 && ret_type == CT_RESULT && cg_current_fn_option_inner == CT_PTR {
        let fsi = get_fn_ret_struct_inner(cg_current_fn_name)
        if fsi.ok_struct == "Option_ptr" && expr_result_ok_type == CT_OPTION && expr_result_ok_struct != "" && expr_result_ok_struct != "Option_ptr" {
            let mut concrete_struct = expr_result_ok_struct
            if concrete_struct.starts_with("Option_") {
                concrete_struct = concrete_struct.substring(7, concrete_struct.len() - 7)
            }
            let src = fresh_temp("__hret_src_")
            let dst = fresh_temp("__hret_dst_")
            let ret_c_name = "blink_Result_Option_ptr_{fsi.err_struct}"
            let concrete_type = "blink_Result_Option_{concrete_struct}_{fsi.err_struct}"
            emit_line("{concrete_type} {src} = {val_str};")
            emit_line("{ret_c_name} {dst};")
            emit_line("{dst}.tag = {src}.tag;")
            emit_line("if ({src}.tag == 0) \{")
            emit_line("    blink_Option_ptr __hret_opt;")
            emit_line("    __hret_opt.tag = {src}.ok.tag;")
            emit_line("    if ({src}.ok.tag == 1) \{")
            emit_line("        {c_type_c_name(concrete_struct)}* __hret_p = ({c_type_c_name(concrete_struct)}*)blink_alloc(sizeof({c_type_c_name(concrete_struct)}));")
            emit_line("        *__hret_p = *{src}.ok.value;")
            emit_line("        __hret_opt.value = (void*)__hret_p;")
            emit_line("    }")
            emit_line("    {dst}.ok = __hret_opt;")
            emit_line("} else \{")
            emit_line("    memcpy(&{dst}.err, &{src}.err, sizeof({src}.err));")
            emit_line("}")
            actual_val = dst
        }
    }
    let ret_name = type_name_from_ct(ret_type)
    if cg_in_traced_fn != 0 && trace_ret_is_primitive(ret_name) != 0 {
        let ret_tmp = fresh_temp("__trace_rv_")
        emit_line("{c_type_str(ret_type)} {ret_tmp} = {actual_val};")
        emit_trace_exit_with_val(ret_tmp, ret_name)
        emit_line("return {ret_tmp};")
    } else {
        emit_trace_exit_with_val(actual_val, ret_name)
        emit_line("return {actual_val};")
    }
}

fn emit_trace_effect(eff_name: Str, op: Str, args_json_expr: Str) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    if cg_in_traced_fn == 0 { return }
    emit_line("if (__blink_trace.active && blink_trace_match_effect(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{eff_name}\")) \{")
    cg_indent = cg_indent + 1
    emit_line("blink_trace_effect(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{eff_name}\", \"{op}\", {args_json_expr});")
    cg_indent = cg_indent - 1
    emit_line("}")
}

pub fn emit_trace_effect_str(eff_name: Str, op: Str, key: Str, val_expr: Str) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    if cg_in_traced_fn == 0 { return }
    let tbuf = fresh_temp("__te_")
    emit_line("char {tbuf}[256]; snprintf({tbuf}, 256, \"\\\"{key}\\\":\\\"%%.200s\\\"\", {val_expr} ? {val_expr} : \"null\");")
    emit_trace_effect(eff_name, op, tbuf)
}

pub fn emit_trace_effect_typed(eff_name: Str, op: Str, key: Str, val_expr: Str, val_type: Int) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    if cg_in_traced_fn == 0 { return }
    let tbuf = fresh_temp("__te_")
    if val_type == CT_INT {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"\\\"{key}\\\":\\\"%lld\\\"\", (long long){val_expr});")
    } else if val_type == CT_FLOAT {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"\\\"{key}\\\":\\\"%g\\\"\", (double){val_expr});")
    } else if val_type == CT_BOOL {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"\\\"{key}\\\":\\\"%s\\\"\", {val_expr} ? \"true\" : \"false\");")
    } else {
        emit_line("char {tbuf}[256]; snprintf({tbuf}, 256, \"\\\"{key}\\\":\\\"%%.200s\\\"\", {val_expr} ? {val_expr} : \"null\");")
    }
    emit_trace_effect(eff_name, op, tbuf)
}

pub fn emit_trace_state(var_name: Str, op: Str, val_expr: Str, val_type: Int) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    if cg_in_traced_fn == 0 { return }
    let tbuf = fresh_temp("__ts_")
    if val_type == CT_INT {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"%lld\", (long long){val_expr});")
    } else if val_type == CT_FLOAT {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"%g\", (double){val_expr});")
    } else if val_type == CT_BOOL {
        emit_line("char {tbuf}[64]; snprintf({tbuf}, 64, \"%s\", {val_expr} ? \"true\" : \"false\");")
    } else if val_type == CT_STRING {
        emit_line("char {tbuf}[256]; snprintf({tbuf}, 256, \"%%.200s\", {val_expr} ? {val_expr} : \"null\");")
    } else {
        emit_line("const char* {tbuf} = \"<{type_name_from_ct(val_type)}>\";")
    }
    emit_line("if (__blink_trace.active && blink_trace_match_state(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{var_name}\")) \{")
    cg_indent = cg_indent + 1
    emit_line("blink_trace_state_event(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{var_name}\", \"{op}\", {tbuf});")
    cg_indent = cg_indent - 1
    emit_line("}")
}

fn emit_trace_state_str(var_name: Str, op: Str, val_expr: Str) ! Codegen.Emit {
    if cg_trace_codegen == 0 { return }
    if cg_in_traced_fn == 0 { return }
    let tbuf = fresh_temp("__ts_")
    emit_line("char {tbuf}[256]; snprintf({tbuf}, 256, \"%%.200s\", {val_expr} ? {val_expr} : \"null\");")
    emit_line("if (__blink_trace.active && blink_trace_match_state(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{var_name}\")) \{")
    cg_indent = cg_indent + 1
    emit_line("blink_trace_state_event(\"{cg_trace_fn_qualified}\", \"{cg_trace_module}\", __blink_trace.depth, \"{var_name}\", \"{op}\", {tbuf});")
    cg_indent = cg_indent - 1
    emit_line("}")
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_fn_def(fn_node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    push_scope()
    cg_temp_counter = 0
    cg_handler_vtable_type = ""
    cg_handler_vtable_field = ""
    cg_handler_is_user_effect = 0
    cg_current_module = node_module(fn_node)
    let name = node_name(fn_node)
    cg_current_fn_name = name
    cg_current_fn_has_ev = if fn_node_has_effects(fn_node) != 0 && get_ffi_ann(fn_node) == -1 { 1 } else { 0 }
    let ret_str = node_return_type(fn_node)
    let ret_type = type_from_name(ret_str)
    cg_current_fn_ret = ret_type
    if ret_type == CT_OPTION {
        cg_current_fn_option_inner = resolve_option_inner_from_ann(fn_node)
    } else {
        cg_current_fn_option_inner = 0
    }
    let ffi_ann = get_ffi_ann(fn_node)
    if ffi_ann != -1 {
        let ffi_args_sl = node_args(ffi_ann)
        let mut ffi_lib = ""
        let mut ffi_symbol = name
        if ffi_args_sl != -1 {
            let ffi_argc = sublist_length(ffi_args_sl)
            if ffi_argc >= 2 {
                ffi_lib = ann_str_val(sublist_get(ffi_args_sl, 0))
                ffi_symbol = ann_str_val(sublist_get(ffi_args_sl, 1))
            } else if ffi_argc == 1 {
                ffi_symbol = ann_str_val(sublist_get(ffi_args_sl, 0))
            }
        }
        if ffi_lib != "" && !cg_ffi_lib_set.contains_key(ffi_lib) {
            cg_ffi_libs.push(ffi_lib)
            cg_ffi_lib_set.insert(ffi_lib, 1)
        }
        if ffi_symbol.starts_with("blink_sqlite3_") {
            cg_uses_sqlite = 1
        }
        let params = format_params(fn_node)
        let param_names = format_param_names(fn_node)
        let c_ret = ffi_c_ret_type(fn_node)
        let c_name = c_fn_name(name)
        let is_header_fn = is_runtime_header_fn(ffi_symbol)
        if !is_header_fn {
            emit_line("extern {c_ret} {ffi_symbol}({params});")
        }
        if !(c_name == ffi_symbol && is_header_fn) {
            if ret_type == CT_VOID {
                if params == "void" {
                    emit_line("void {c_name}(void) \{ {ffi_symbol}(); }")
                } else {
                    emit_line("void {c_name}({params}) \{ {ffi_symbol}({param_names}); }")
                }
            } else if params == "void" {
                emit_line("{c_ret} {c_name}(void) \{ return {ffi_symbol}(); }")
            } else {
                emit_line("{c_ret} {c_name}({params}) \{ return {ffi_symbol}({param_names}); }")
            }
        }
        emit_line("")
        pop_scope()
        return
    }

    let mut sig = ""
    if name == "main" {
        sig = "void blink_main(blink_ev* __ev)"
    } else {
        let params = format_params(fn_node)
        let enum_ret = get_fn_enum_ret(name)
        if enum_ret != "" {
            sig = "{c_type_c_name(enum_ret)} {c_fn_name(name)}({params})"
        } else if is_struct_type(ret_str) != 0 {
            sig = "{c_type_c_name(ret_str)} {c_fn_name(name)}({params})"
        } else {
            let resolved = resolve_ret_type_from_ann(fn_node)
            if resolved != "" {
                sig = "{resolved} {c_fn_name(name)}({params})"
            } else {
                sig = "{c_type_str(ret_type)} {c_fn_name(name)}({params})"
            }
        }
    }

    // Register params in scope
    let params_sl = node_params(fn_node)
    if params_sl != -1 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname = node_name(p)
            let ptype = node_type_name(p)
            if ptype == "Fn" {
                set_var(pname, CT_CLOSURE, 1)
                let ta = node_type_ann(p)
                if ta != -1 {
                    let sig_str = build_closure_sig_from_type_ann(ta)
                    set_var_closure(pname, sig_str)
                }
            } else {
                let param_ct = if is_enum_type(ptype) != 0 { CT_INT } else { type_from_name(ptype) }
                set_var(pname, param_ct, 1)
                if is_struct_type(ptype) != 0 {
                    set_var_struct(pname, ptype)
                }
                if is_enum_type(ptype) != 0 {
                    var_enums.push(VarEnumEntry { name: pname, enum_type: ptype })
                }
                if ptype == "List" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                            let elem_ann = sublist_get(elems_sl, 0)
                            let elem_name = node_name(elem_ann)
                            let elem_ct = type_from_name(elem_name)
                            set_list_elem_type(pname, elem_ct)
                            if elem_ct == CT_VOID && (is_named_type(elem_name) != 0) {
                                set_list_elem_struct(pname, elem_name)
                            } else if elem_ct == CT_VOID && elem_name == "Tuple" {
                                let tup_opt = resolve_tuple_ann(elem_ann, -1, "")
                                if tup_opt.is_some() {
                                    set_list_elem_struct(pname, tup_opt.unwrap())
                                }
                            }
                            if elem_ct == CT_LIST {
                                let nested_sl = node_elements(elem_ann)
                                if nested_sl != -1 && sublist_length(nested_sl) > 0 {
                                    let nested_ann = sublist_get(nested_sl, 0)
                                    let nested_name = node_name(nested_ann)
                                    let nested_ct = type_from_name(nested_name)
                                    set_list_nested_elem_type(pname, nested_ct)
                                    if nested_ct == CT_VOID && is_struct_type(nested_name) != 0 {
                                        set_list_nested_elem_struct(pname, nested_name)
                                    }
                                }
                            }
                        }
                    }
                }
                if ptype == "Map" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                            let key_ann = sublist_get(elems_sl, 0)
                            let val_ann = sublist_get(elems_sl, 1)
                            let val_name = node_name(val_ann)
                            let val_ct = type_from_name(val_name)
                            set_map_types(pname, type_from_name(node_name(key_ann)), val_ct, val_name)
                            if val_ct == CT_LIST {
                                let val_elems = node_elements(val_ann)
                                if val_elems != -1 && sublist_length(val_elems) > 0 {
                                    let inner_ann = sublist_get(val_elems, 0)
                                    let inner_name = node_name(inner_ann)
                                    set_map_value_list_elem(pname, type_from_name(inner_name))
                                }
                            }
                        }
                    }
                }
                if ptype == "Tuple" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let tup_name = resolve_tuple_ann(ta, -1, "").unwrap()
                        set_var_struct(pname, tup_name)
                    }
                }
                if ptype == "Result" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                            let ok_ann = sublist_get(elems_sl, 0)
                            let err_ann = sublist_get(elems_sl, 1)
                            let ok_name = node_name(ok_ann)
                            let err_name = node_name(err_ann)
                            let ok_t = type_from_name(ok_name)
                            let err_t = type_from_name(err_name)
                            let ok_is_s = is_struct_type(ok_name) != 0
                            let err_is_s = is_struct_type(err_name) != 0
                            if ok_is_s || err_is_s {
                                let ok_s = if ok_is_s { ok_name } else { "" }
                                let err_s = if err_is_s { err_name } else { "" }
                                set_var_result_struct(pname, ok_t, err_t, ok_s, err_s)
                            } else {
                                set_var_result(pname, ok_t, err_t)
                            }
                        }
                    }
                }
                if ptype == "Option" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                            let inner_ann = sublist_get(elems_sl, 0)
                            let inner_name = node_name(inner_ann)
                            let inner_t = type_from_name(inner_name)
                            if is_struct_type(inner_name) != 0 {
                                set_var_option_struct(pname, inner_t, inner_name)
                            } else {
                                set_var_option(pname, inner_t)
                            }
                        }
                    }
                }
                if ptype == "Handler" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                            let effect_ann = sublist_get(elems_sl, 0)
                            let effect_name = node_name(effect_ann)
                            let h_vtt = resolve_effect_vtable(effect_name)
                            let h_vtf = resolve_effect_field(effect_name)
                            let h_is_ue = resolve_effect_is_ue(effect_name)
                            set_var_handler(pname, h_vtt, h_vtf, h_is_ue)
                        }
                    }
                }
            }
            i = i + 1
        }
    }

    mut_captured_vars = []
    prescan_mut_captures(node_body(fn_node))

    let mut body_ret = ret_type
    if is_struct_type(ret_str) != 0 || is_enum_type(ret_str) != 0 || ret_str == "Tuple" {
        body_ret = CT_INT
    }
    cg_current_fn_node = fn_node
    let saved_trace_fn = cg_trace_fn_qualified
    let saved_trace_mod = cg_trace_module
    let saved_in_traced = cg_in_traced_fn
    cg_in_traced_fn = 0
    emit_line("{sig} \{")
    cg_indent = cg_indent + 1

    emit_unused_param_voids(params_sl)

    let trace_file = diag_file_for_node(fn_node)
    emit_trace_enter(fn_node, name, cg_current_module, trace_file)

    emit_requires_assertions(fn_node)
    emit_fn_body(node_body(fn_node), body_ret)
    if ret_type == CT_VOID {
        emit_trace_exit_void()
    }
    cg_indent = cg_indent - 1
    emit_line("}")
    cg_trace_fn_qualified = saved_trace_fn
    cg_trace_module = saved_trace_mod
    cg_in_traced_fn = saved_in_traced
    pop_scope()
}

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_fn_body(block: Int, ret_type: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    if block == -1 {
        return
    }
    let stmts_sl = node_stmts(block)
    if stmts_sl == -1 {
        return
    }
    let count = sublist_length(stmts_sl)
    if count == 0 {
        return
    }
    let mut i = 0
    while i < count - 1 {
        emit_stmt(sublist_get(stmts_sl, i))
        i = i + 1
    }
    let last = sublist_get(stmts_sl, count - 1)
    let last_kind = node_kind(last)
    if ret_type != CT_VOID && last_kind == NodeKind.ExprStmt {
        emit_expr(node_value(last))
        emit_return_with_trace(expr_result_str, cg_current_fn_ret)
    } else if ret_type != CT_VOID && last_kind == NodeKind.IfExpr {
        emit_if_expr(last)
        emit_return_with_trace(expr_result_str, cg_current_fn_ret)
    } else if ret_type != CT_VOID && last_kind == NodeKind.MatchExpr {
        emit_match_expr(last)
        emit_return_with_trace(expr_result_str, cg_current_fn_ret)
    } else if ret_type != CT_VOID && last_kind == NodeKind.WithBlock {
        emit_with_block_expr(last)
        emit_return_with_trace(expr_result_str, cg_current_fn_ret)
    } else {
        emit_stmt(last)
    }
}

// ── Type definition codegen ─────────────────────────────────────────

pub fn find_type_def(name: Str) -> Int {
    let types_sl = node_fields(cg_program_node)
    if types_sl == -1 {
        return -1
    }
    let mut i = 0
    while i < sublist_length(types_sl) {
        let td = sublist_get(types_sl, i)
        if node_name(td) == name {
            return td
        }
        i = i + 1
    }
    -1
}

pub fn register_mono_field_types(base_name: Str, mono_name: Str, concrete_args: Str) {
    // Check if already registered
    let mut check = 0
    while check < sf_entries.len() {
        if sf_entries.get(check).unwrap().struct_name == mono_name {
            return
        }
        check = check + 1
    }
    let td = find_type_def(base_name)
    if td == -1 {
        return
    }
    let tparams_sl = node_type_params(td)
    if tparams_sl == -1 {
        return
    }
    let flds_sl = node_fields(td)
    if flds_sl == -1 {
        return
    }
    let mut i = 0
    while i < sublist_length(flds_sl) {
        let f = sublist_get(flds_sl, i)
        let fname = node_name(f)
        let type_ann_node = node_value(f)
        if type_ann_node != -1 {
            let type_name = node_name(type_ann_node)
            let resolved = resolve_tparam(type_name, tparams_sl, concrete_args)
            if is_struct_type(resolved) != 0 || is_enum_type(resolved) != 0 {
                reg_sf_entry(mono_name, fname, CT_STRUCT, resolved, sv_tp(CT_STRUCT, -1, -1, resolved))
            } else {
                let ct = type_from_name(resolved)
                let inner_elems = node_elements(type_ann_node)
                if (ct == CT_OPTION || ct == CT_LIST) && inner_elems != -1 && sublist_length(inner_elems) >= 1 {
                    let inner_name = resolve_tparam(node_name(sublist_get(inner_elems, 0)), tparams_sl, concrete_args)
                    let inner_ct = type_from_name(inner_name)
                    let inner_sname = if is_struct_type(inner_name) != 0 || is_enum_type(inner_name) != 0 { inner_name } else { "" }
                    reg_sf_entry(mono_name, fname, ct, "", sv_tp(ct, inner_ct, -1, inner_sname))
                } else if ct == CT_MAP && inner_elems != -1 && sublist_length(inner_elems) >= 2 {
                    let key_name = resolve_tparam(node_name(sublist_get(inner_elems, 0)), tparams_sl, concrete_args)
                    let val_name = resolve_tparam(node_name(sublist_get(inner_elems, 1)), tparams_sl, concrete_args)
                    let key_ct = type_from_name(key_name)
                    let val_ct = type_from_name(val_name)
                    let val_sname = if is_struct_type(val_name) != 0 || is_enum_type(val_name) != 0 { val_name } else { "" }
                    reg_sf_entry(mono_name, fname, ct, "", sv_tp(ct, key_ct, val_ct, val_sname))
                } else if ct == CT_RESULT && inner_elems != -1 && sublist_length(inner_elems) >= 2 {
                    let ok_name = resolve_tparam(node_name(sublist_get(inner_elems, 0)), tparams_sl, concrete_args)
                    let err_name = resolve_tparam(node_name(sublist_get(inner_elems, 1)), tparams_sl, concrete_args)
                    let ok_ct = type_from_name(ok_name)
                    let err_ct = type_from_name(err_name)
                    reg_sf_entry(mono_name, fname, ct, "", sv_tp(ct, ok_ct, err_ct, ""))
                } else {
                    reg_sf_entry(mono_name, fname, ct, "", sv_tp(ct, -1, -1, ""))
                }
            }
        } else {
            reg_sf_entry(mono_name, fname, CT_INT, "", sv_tp(CT_INT, -1, -1, ""))
        }
        i = i + 1
    }
}

fn emit_mono_struct_typedef(base_name: Str, concrete_args: Str) ! Codegen.Emit {
    let td = find_type_def(base_name)
    if td == -1 {
        return
    }
    let tparams_sl = node_type_params(td)
    if tparams_sl == -1 {
        return
    }
    let c_name = mangle_generic_name(base_name, concrete_args)
    let flds_sl = node_fields(td)
    if flds_sl == -1 {
        return
    }
    struct_reg_names.push(c_name)
    struct_reg_set.insert(c_name, 1)
    emit_line("typedef struct \{")
    cg_indent = cg_indent + 1
    let mut i = 0
    while i < sublist_length(flds_sl) {
        let f = sublist_get(flds_sl, i)
        let fname = node_name(f)
        let type_ann_node = node_value(f)
        if type_ann_node != -1 {
            let type_name = node_name(type_ann_node)
            let resolved = resolve_tparam(type_name, tparams_sl, concrete_args)
            if is_struct_type(resolved) != 0 {
                emit_line("{c_type_c_name(resolved)} {fname};")
                reg_sf_entry(c_name, fname, CT_VOID, resolved, sv_tp(CT_VOID, -1, -1, resolved))
            } else if resolved == "Option" {
                let inner_elems = node_elements(type_ann_node)
                if inner_elems != -1 && sublist_length(inner_elems) >= 1 {
                    let inner_ann = sublist_get(inner_elems, 0)
                    let inner_raw = node_name(inner_ann)
                    let inner_resolved = resolve_tparam(inner_raw, tparams_sl, concrete_args)
                    let inner_ct = type_from_name(inner_resolved)
                    if is_struct_type(inner_resolved) != 0 || is_enum_type(inner_resolved) != 0 {
                        ensure_struct_option_type(inner_resolved)
                        let opt_c = struct_option_c_type(inner_resolved)
                        emit_line("{opt_c} {fname};")
                        reg_sf_entry(c_name, fname, CT_OPTION, opt_c, sv_tp(CT_OPTION, inner_ct, -1, inner_resolved))
                    } else if is_compound_ct(inner_ct) != 0 {
                        let compound_name = compound_name_from_ann(inner_ann)
                        ensure_struct_option_type(compound_name)
                        let opt_c = struct_option_c_type(compound_name)
                        emit_line("{opt_c} {fname};")
                        reg_sf_entry(c_name, fname, CT_OPTION, opt_c, sv_tp(CT_OPTION, inner_ct, -1, compound_name))
                    } else {
                        ensure_option_type(inner_ct)
                        let opt_c = option_c_type(inner_ct)
                        emit_line("{opt_c} {fname};")
                        reg_sf_entry(c_name, fname, CT_OPTION, "", sv_tp(CT_OPTION, inner_ct, -1, ""))
                    }
                } else {
                    ensure_option_type(CT_INT)
                    let opt_c = option_c_type(CT_INT)
                    emit_line("{opt_c} {fname};")
                    reg_sf_entry(c_name, fname, CT_OPTION, "", sv_tp(CT_OPTION, CT_INT, -1, ""))
                }
            } else if resolved == "Result" {
                let inner_elems = node_elements(type_ann_node)
                if inner_elems != -1 && sublist_length(inner_elems) >= 2 {
                    let ok_ann = sublist_get(inner_elems, 0)
                    let err_ann = sublist_get(inner_elems, 1)
                    let ok_raw = node_name(ok_ann)
                    let err_raw = node_name(err_ann)
                    let ok_resolved = resolve_tparam(ok_raw, tparams_sl, concrete_args)
                    let err_resolved = resolve_tparam(err_raw, tparams_sl, concrete_args)
                    let ok_ct = type_from_name(ok_resolved)
                    let err_ct = type_from_name(err_resolved)
                    let ok_is_type = is_struct_type(ok_resolved) != 0 || is_enum_type(ok_resolved) != 0
                    let err_is_type = is_struct_type(err_resolved) != 0 || is_enum_type(err_resolved) != 0
                    if ok_is_type || err_is_type {
                        let ok_tag = if ok_is_type { ok_resolved } else { c_type_tag(ok_ct) }
                        let err_tag = if err_is_type { err_resolved } else { c_type_tag(err_ct) }
                        ensure_struct_result_type(ok_tag, err_tag)
                        let res_c = struct_result_c_type(ok_tag, err_tag)
                        emit_line("{res_c} {fname};")
                        reg_sf_entry(c_name, fname, CT_RESULT, res_c, sv_tp(CT_RESULT, ok_ct, err_ct, ""))
                    } else {
                        ensure_result_type(ok_ct, err_ct)
                        let res_c = result_c_type(ok_ct, err_ct)
                        emit_line("{res_c} {fname};")
                        reg_sf_entry(c_name, fname, CT_RESULT, "", sv_tp(CT_RESULT, ok_ct, err_ct, ""))
                    }
                } else {
                    ensure_result_type(CT_INT, CT_STRING)
                    let res_c = result_c_type(CT_INT, CT_STRING)
                    emit_line("{res_c} {fname};")
                    reg_sf_entry(c_name, fname, CT_RESULT, "", sv_tp(CT_RESULT, CT_INT, CT_STRING, ""))
                }
            } else {
                let ct = type_from_name(resolved)
                emit_line("{c_type_str(ct)} {fname};")
                reg_sf_entry(c_name, fname, ct, "", sv_tp(ct, -1, -1, ""))
            }
        } else {
            emit_line("int64_t {fname};")
            reg_sf_entry(c_name, fname, CT_INT, "", sv_tp(CT_INT, -1, -1, ""))
        }
        i = i + 1
    }
    cg_indent = cg_indent - 1
    emit_line("} {c_type_c_name(c_name)};")
    emit_line("")
}

pub fn emit_all_mono_typedefs() ! Codegen.Emit {
    let mut i = 0
    while i < mono_instances.len() {
        let mi = mono_instances.get(i).unwrap()
        let td = find_type_def(mi.base)
        if td != -1 {
            let flds_sl = node_fields(td)
            if flds_sl != -1 && sublist_length(flds_sl) > 0 {
                if node_kind(sublist_get(flds_sl, 0)) != NodeKind.TypeVariant {
                    emit_mono_struct_typedef(mi.base, mi.args)
                }
            }
        }
        i = i + 1
    }
}

fn build_closure_sig_resolved_mono(ta: Int, tparams_sl: Int, concrete_args: Str) -> Str {
    let ret_raw = node_return_type(ta)
    let ret_name = resolve_tparam(ret_raw, tparams_sl, concrete_args)
    let ret_type = type_from_name(ret_name)
    let elems_sl = node_elements(ta)
    let mut sig_params = "const blink_closure*"
    if elems_sl != -1 && sublist_length(elems_sl) > 0 {
        let mut i = 0
        while i < sublist_length(elems_sl) {
            let elem = sublist_get(elems_sl, i)
            let ename_raw = node_name(elem)
            let ename = resolve_tparam(ename_raw, tparams_sl, concrete_args)
            sig_params = sig_params.concat(", ")
            if is_enum_type(ename) != 0 {
                sig_params = sig_params.concat(c_type_c_name(ename))
            } else if is_struct_type(ename) != 0 {
                sig_params = sig_params.concat(c_type_c_name(ename))
            } else {
                sig_params = sig_params.concat(c_type_str(type_from_name(ename)))
            }
            i = i + 1
        }
    }
    let mut ret_str = c_type_str(ret_type)
    if is_struct_type(ret_name) != 0 {
        ret_str = c_type_c_name(ret_name)
    } else if is_enum_type(ret_name) != 0 {
        ret_str = c_type_c_name(ret_name)
    }
    "{ret_str}(*)({sig_params})"
}

@allow(UnrestoredMutation, IncompleteStateRestore)
fn emit_mono_fn_def(fn_node: Int, concrete_args: Str) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    cg_handler_vtable_type = ""
    cg_handler_vtable_field = ""
    cg_handler_is_user_effect = 0
    cg_current_module = node_module(fn_node)
    let base_name = node_name(fn_node)
    let mangled = mangle_generic_name(base_name, concrete_args)
    let tparams_sl = node_type_params(fn_node)

    // Resolve return type
    let ret_str = node_return_type(fn_node)
    let resolved_ret = resolve_tparam(ret_str, tparams_sl, concrete_args)
    let ret_type = type_from_name(resolved_ret)
    let mut ret_c_str = c_type_str(ret_type)
    if ret_type == CT_OPTION {
        let ret_ann = node_type_ann(fn_node)
        if ret_ann != -1 {
            let elems_sl = node_elements(ret_ann)
            if elems_sl != -1 && sublist_length(elems_sl) >= 1 {
                let inner_ann = sublist_get(elems_sl, 0)
                let inner_name_raw = node_name(inner_ann)
                let inner_name = resolve_tparam(inner_name_raw, tparams_sl, concrete_args)
                let inner_ct = type_from_name(inner_name)
                if inner_ct == CT_VOID && is_struct_type(inner_name) != 0 {
                    ensure_struct_option_type(inner_name)
                    ret_c_str = struct_option_c_type(inner_name)
                } else if is_compound_ct(inner_ct) != 0 {
                    let compound_name = compound_name_from_ann(inner_ann)
                    ensure_struct_option_type(compound_name)
                    ret_c_str = struct_option_c_type(compound_name)
                } else {
                    ensure_option_type(inner_ct)
                    ret_c_str = option_c_type(inner_ct)
                }
                cg_current_fn_option_inner = inner_ct
            }
        }
    } else if ret_type == CT_RESULT {
        let ret_ann = node_type_ann(fn_node)
        if ret_ann != -1 {
            let elems_sl = node_elements(ret_ann)
            if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                let ok_ann = sublist_get(elems_sl, 0)
                let err_ann = sublist_get(elems_sl, 1)
                let ok_name = resolve_tparam(node_name(ok_ann), tparams_sl, concrete_args)
                let err_name = resolve_tparam(node_name(err_ann), tparams_sl, concrete_args)
                let ok_ct = type_from_name(ok_name)
                let err_ct = type_from_name(err_name)
                ensure_result_type(ok_ct, err_ct)
                ret_c_str = result_c_type(ok_ct, err_ct)
            }
        }
    } else if is_struct_type(resolved_ret) != 0 || is_enum_type(resolved_ret) != 0 {
        let td = find_type_def(resolved_ret)
        let mut is_generic_ret = 0
        if td != -1 {
            let td_tparams = node_type_params(td)
            if td_tparams != -1 && sublist_length(td_tparams) > 0 {
                is_generic_ret = 1
                let ret_ann = node_type_ann(fn_node)
                if ret_ann != -1 {
                    let ret_elems = node_elements(ret_ann)
                    if ret_elems != -1 {
                        let mut mono_args = ""
                        let mut ai = 0
                        while ai < sublist_length(ret_elems) {
                            let elem = sublist_get(ret_elems, ai)
                            let raw_name = node_name(elem)
                            let resolved_arg = resolve_tparam(raw_name, tparams_sl, concrete_args)
                            if ai > 0 {
                                mono_args = mono_args.concat(",")
                            }
                            mono_args = mono_args.concat(resolved_arg)
                            ai = ai + 1
                        }
                        let mono_name = mangle_generic_name(resolved_ret, mono_args)
                        ret_c_str = c_type_c_name(mono_name)
                    }
                }
            }
        }
        if is_generic_ret == 0 {
            ret_c_str = c_type_c_name(resolved_ret)
        }
    }

    // Build parameter string with substituted types
    let params_sl = node_params(fn_node)
    let mut params_c = "void"
    if params_sl != -1 && sublist_length(params_sl) > 0 {
        params_c = ""
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname = c_safe_name(node_name(p))
            let ptype = node_type_name(p)
            let resolved_ptype = resolve_tparam(ptype, tparams_sl, concrete_args)
            if i > 0 {
                params_c = params_c.concat(", ")
            }
            if is_struct_type(resolved_ptype) != 0 {
                params_c = params_c.concat("{c_type_c_name(resolved_ptype)} {pname}")
            } else if is_enum_type(resolved_ptype) != 0 {
                params_c = params_c.concat("{c_type_c_name(resolved_ptype)} {pname}")
            } else {
                let ct = type_from_name(resolved_ptype)
                params_c = params_c.concat("{c_type_str(ct)} {pname}")
            }
            i = i + 1
        }
    }

    // Forward declaration
    emit_line("{ret_c_str} {c_fn_name(mangled)}({params_c});")

    // Register params in scope
    push_scope()
    cg_temp_counter = 0
    if params_sl != -1 {
        let mut i = 0
        while i < sublist_length(params_sl) {
            let p = sublist_get(params_sl, i)
            let pname = node_name(p)
            let ptype = node_type_name(p)
            let resolved_ptype = resolve_tparam(ptype, tparams_sl, concrete_args)
            if resolved_ptype == "Fn" {
                set_var(pname, CT_CLOSURE, 1)
                let ta = node_type_ann(p)
                if ta != -1 {
                    let sig_str = build_closure_sig_resolved_mono(ta, tparams_sl, concrete_args)
                    set_var_closure(pname, sig_str)
                }
            } else {
                let param_ct = if is_enum_type(resolved_ptype) != 0 { CT_INT } else { type_from_name(resolved_ptype) }
                set_var(pname, param_ct, 1)
                if is_struct_type(resolved_ptype) != 0 {
                    set_var_struct(pname, resolved_ptype)
                }
                if is_enum_type(resolved_ptype) != 0 {
                    var_enums.push(VarEnumEntry { name: pname, enum_type: resolved_ptype })
                }
                if resolved_ptype == "List" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                            let elem_ann = sublist_get(elems_sl, 0)
                            let elem_name_raw = node_name(elem_ann)
                            let elem_name = resolve_tparam(elem_name_raw, tparams_sl, concrete_args)
                            let elem_ct = type_from_name(elem_name)
                            set_list_elem_type(pname, elem_ct)
                            if elem_ct != CT_VOID {
                                ensure_option_type(elem_ct)
                            }
                            if elem_ct == CT_VOID && (is_named_type(elem_name) != 0) {
                                set_list_elem_struct(pname, elem_name)
                            } else if elem_ct == CT_VOID && elem_name == "Tuple" {
                                let tup_opt = resolve_tuple_ann(elem_ann, tparams_sl, concrete_args)
                                if tup_opt.is_some() {
                                    set_list_elem_struct(pname, tup_opt.unwrap())
                                }
                            }
                            if elem_ct == CT_LIST {
                                let nested_sl = node_elements(elem_ann)
                                if nested_sl != -1 && sublist_length(nested_sl) > 0 {
                                    let nested_ann = sublist_get(nested_sl, 0)
                                    let nested_name = node_name(nested_ann)
                                    let nested_ct = type_from_name(nested_name)
                                    set_list_nested_elem_type(pname, nested_ct)
                                    if nested_ct == CT_VOID && is_struct_type(nested_name) != 0 {
                                        set_list_nested_elem_struct(pname, nested_name)
                                    }
                                }
                            }
                        }
                    }
                }
                if resolved_ptype == "Map" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let elems_sl = node_elements(ta)
                        if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                            let key_ann = sublist_get(elems_sl, 0)
                            let val_ann = sublist_get(elems_sl, 1)
                            let val_name = node_name(val_ann)
                            let val_ct = type_from_name(val_name)
                            set_map_types(pname, type_from_name(node_name(key_ann)), val_ct, val_name)
                            if val_ct == CT_LIST {
                                let val_elems = node_elements(val_ann)
                                if val_elems != -1 && sublist_length(val_elems) > 0 {
                                    let inner_ann = sublist_get(val_elems, 0)
                                    let inner_name = node_name(inner_ann)
                                    set_map_value_list_elem(pname, type_from_name(inner_name))
                                }
                            }
                        }
                    }
                }
                if resolved_ptype == "Tuple" {
                    let ta = node_type_ann(p)
                    if ta != -1 {
                        let tup_name = resolve_tuple_ann(ta, tparams_sl, concrete_args).unwrap()
                        set_var_struct(pname, tup_name)
                    }
                }
            }
            i = i + 1
        }
    }

    let saved_trace_fn = cg_trace_fn_qualified
    let saved_trace_mod = cg_trace_module
    let saved_in_traced = cg_in_traced_fn
    cg_in_traced_fn = 0
    let saved_fn_name = cg_current_fn_name
    let saved_fn_has_ev = cg_current_fn_has_ev
    let saved_fn_ret = cg_current_fn_ret
    let saved_fn_option_inner = cg_current_fn_option_inner
    cg_current_fn_name = mangled
    cg_current_fn_has_ev = if fn_node_has_effects(fn_node) != 0 { 1 } else { 0 }
    cg_current_fn_ret = ret_type
    emit_line("{ret_c_str} {c_fn_name(mangled)}({params_c}) \{")
    cg_indent = cg_indent + 1

    emit_unused_param_voids(params_sl)

    let trace_mod = node_module(fn_node)
    let trace_file = diag_file_for_node(fn_node)
    emit_trace_enter(fn_node, mangled, trace_mod, trace_file)

    let mut body_ret = ret_type
    if is_struct_type(resolved_ret) != 0 || is_enum_type(resolved_ret) != 0 {
        body_ret = CT_INT
    }
    emit_fn_body(node_body(fn_node), body_ret)
    if ret_type == CT_VOID && body_ret == CT_VOID {
        emit_trace_exit_void()
    }
    cg_indent = cg_indent - 1
    emit_line("}")
    emit_line("")
    cg_current_fn_name = saved_fn_name
    cg_current_fn_has_ev = saved_fn_has_ev
    cg_current_fn_ret = saved_fn_ret
    cg_current_fn_option_inner = saved_fn_option_inner
    cg_trace_fn_qualified = saved_trace_fn
    cg_trace_module = saved_trace_mod
    cg_in_traced_fn = saved_in_traced
    pop_scope()
}

pub fn emit_all_mono_fns() ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let mut i = 0
    while i < mono_fns.len() {
        let mf = mono_fns.get(i).unwrap()
        let fn_node = get_generic_fn_node(mf.base)
        if fn_node != -1 {
            emit_mono_fn_def(fn_node, mf.args)
        }
        i = i + 1
    }
}

pub fn emit_mono_typedefs_from(start: Int) ! Codegen.Emit {
    let mut i = start
    while i < mono_instances.len() {
        let mi = mono_instances.get(i).unwrap()
        let td = find_type_def(mi.base)
        if td != -1 {
            let flds_sl = node_fields(td)
            if flds_sl != -1 && sublist_length(flds_sl) > 0 {
                if node_kind(sublist_get(flds_sl, 0)) != NodeKind.TypeVariant {
                    emit_mono_struct_typedef(mi.base, mi.args)
                }
            }
        }
        i = i + 1
    }
}

pub fn emit_mono_fns_from(start: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let mut i = start
    while i < mono_fns.len() {
        let mf = mono_fns.get(i).unwrap()
        let fn_node = get_generic_fn_node(mf.base)
        if fn_node != -1 {
            emit_mono_fn_def(fn_node, mf.args)
        }
        i = i + 1
    }
}

let mut struct_typedef_emitted: Map[Str, Int] = Map()

pub fn emit_struct_typedef(td_node: Int) ! Codegen.Emit {
    let name = node_name(td_node)
    if struct_typedef_emitted.contains_key(name) != 0 { return }
    struct_typedef_emitted.insert(name, 1)
    // ConversionError's C typedef lives in runtime_core.h — skip emission to avoid duplication.
    if name == "ConversionError" { return }
    let flds_sl = node_fields(td_node)
    if flds_sl == -1 {
        return
    }
    // Check if this is a variant-only type (enum), skip for now
    if sublist_length(flds_sl) > 0 {
        let first = sublist_get(flds_sl, 0)
        if node_kind(first) == NodeKind.TypeVariant {
            return
        }
    }
    // Skip generic types — they get monomorphized instances instead
    let tparams_sl = node_type_params(td_node)
    if tparams_sl != -1 && sublist_length(tparams_sl) > 0 {
        return
    }
    emit_line("typedef struct \{")
    cg_indent = cg_indent + 1
    let mut i = 0
    while i < sublist_length(flds_sl) {
        let f = sublist_get(flds_sl, i)
        let fname = node_name(f)
        let type_ann_node = node_value(f)
        if type_ann_node != -1 {
            let type_name = node_name(type_ann_node)
            if type_name == "Fn" {
                emit_line("blink_closure* {fname};")
                reg_sf_entry(name, fname, CT_CLOSURE, "", sv_tp(CT_CLOSURE, -1, -1, ""))
                let sig = build_closure_sig_from_type_ann(type_ann_node)
                sf_closure_sigs.push(StructFieldClosureSig { struct_name: name, field_name: fname, sig: sig })
            } else if type_name == name {
                emit_line("int64_t {fname};")
                reg_sf_entry(name, fname, CT_INT, "", sv_tp(CT_INT, -1, -1, ""))
            } else if is_struct_type(type_name) != 0 {
                emit_line("{c_type_c_name(type_name)} {fname};")
                reg_sf_entry(name, fname, CT_VOID, type_name, sv_tp(CT_VOID, -1, -1, type_name))
            } else if is_enum_type(type_name) != 0 {
                if is_data_enum(type_name) != 0 {
                    emit_line("{c_type_c_name(type_name)} {fname};")
                } else {
                    emit_line("int64_t {fname};")
                }
                reg_sf_entry(name, fname, CT_VOID, type_name, sv_tp(CT_VOID, -1, -1, type_name))
            } else {
                let ct = type_from_name(type_name)
                emit_line("{c_type_str(ct)} {fname};")
                let field_tp = tp_from_ann(type_ann_node)
                reg_sf_entry(name, fname, ct, "", field_tp)
            }
        } else {
            emit_line("int64_t {fname};")
            reg_sf_entry(name, fname, CT_INT, "", sv_tp(CT_INT, -1, -1, ""))
        }
        let default_node = node_condition(f)
        if default_node != -1 {
            struct_field_defaults.push(StructFieldDefault { struct_name: name, field_name: fname, default_node: default_node })
        }
        i = i + 1
    }
    cg_indent = cg_indent - 1
    emit_line("} {c_type_c_name(name)};")
    emit_line("")
    let inv_anns_sl = node_handlers(td_node)
    if inv_anns_sl != -1 {
        let mut ai = 0
        while ai < sublist_length(inv_anns_sl) {
            let ann = sublist_get(inv_anns_sl, ai)
            let ann_name = node_name(ann)
            if ann_name == "invariant" {
                let args_sl = node_args(ann)
                if args_sl != -1 && sublist_length(args_sl) > 0 {
                    let expr_node = sublist_get(args_sl, 0)
                    struct_invariants.push(StructInvariant { struct_name: name, expr_node: expr_node })
                }
            }
            ai = ai + 1
        }
    }
}

fn build_type_name_from_ann(ann: Int) -> Str {
    let name = node_name(ann)
    let elems = node_elements(ann)
    if elems == -1 || sublist_length(elems) == 0 {
        return name
    }
    let mut params = ""
    let mut i = 0
    while i < sublist_length(elems) {
        if i > 0 {
            params = params.concat(", ")
        }
        let inner = sublist_get(elems, i)
        params = params.concat(build_type_name_from_ann(inner))
        i = i + 1
    }
    "{name}[{params}]"
}

let mut enum_typedef_emitted: Map[Str, Int] = Map()

pub fn emit_enum_typedef(td_node: Int) ! Codegen.Emit {
    let name = node_name(td_node)
    if enum_typedef_emitted.contains_key(name) != 0 { return }
    enum_typedef_emitted.insert(name, 1)
    let flds_sl = node_fields(td_node)
    if flds_sl == -1 {
        return
    }
    let enum_idx = enum_regs.len()

    let mut has_data = 0
    let mut str_backed_count = 0
    let mut variant_count = 0
    let mut i = 0
    while i < sublist_length(flds_sl) {
        let v = sublist_get(flds_sl, i)
        let vflds = node_fields(v)
        if vflds != -1 && sublist_length(vflds) > 0 {
            has_data = 1
        }
        let vstr = node_str_val(v)
        if vstr != "" {
            str_backed_count = str_backed_count + 1
        }
        variant_count = variant_count + 1
        i = i + 1
    }
    let is_sb = if str_backed_count > 0 && str_backed_count == variant_count { 1 } else { 0 }
    enum_regs.push(EnumReg { name: name, has_data: has_data, is_str_backed: is_sb })
    enum_reg_set.insert(name, has_data)
    if is_sb != 0 {
        enum_str_backed_set.insert(name, 1)
    }

    i = 0
    while i < sublist_length(flds_sl) {
        let v = sublist_get(flds_sl, i)
        let vname = node_name(v)
        let vflds = node_fields(v)
        let ev_str = node_str_val(v)
        if vflds != -1 && sublist_length(vflds) > 0 {
            let mut field_names = ""
            let mut field_types = ""
            let mut fi = 0
            while fi < sublist_length(vflds) {
                let vf = sublist_get(vflds, fi)
                let vf_name = node_name(vf)
                let vf_type_ann = node_value(vf)
                let mut vf_type_name = "Int"
                if vf_type_ann != -1 {
                    vf_type_name = build_type_name_from_ann(vf_type_ann)
                }
                if fi > 0 {
                    field_names = field_names.concat(",")
                    field_types = field_types.concat(",")
                }
                field_names = field_names.concat(vf_name)
                field_types = field_types.concat(vf_type_name)
                fi = fi + 1
            }
            enum_variants.push(EnumVariant { name: vname, enum_idx: enum_idx, field_names: field_names, field_types: field_types, field_count: sublist_length(vflds), str_value: ev_str })
        } else {
            enum_variants.push(EnumVariant { name: vname, enum_idx: enum_idx, field_names: "", field_types: "", field_count: 0, str_value: ev_str })
        }
        i = i + 1
    }

    if has_data == 0 {
        let mut variants_str = ""
        i = 0
        while i < sublist_length(flds_sl) {
            let v = sublist_get(flds_sl, i)
            let vname = node_name(v)
            if i > 0 {
                variants_str = variants_str.concat(", ")
            }
            variants_str = variants_str.concat("{c_type_c_name(name)}_{vname}")
            i = i + 1
        }
        emit_line("typedef enum \{ {variants_str} } {c_type_c_name(name)};")
        emit_line("")
    } else {
        emit_line("typedef struct \{")
        cg_indent = cg_indent + 1
        emit_line("int tag;")
        emit_line("union \{")
        cg_indent = cg_indent + 1
        i = 0
        while i < sublist_length(flds_sl) {
            let v = sublist_get(flds_sl, i)
            let vname = node_name(v)
            let vflds = node_fields(v)
            if vflds != -1 && sublist_length(vflds) > 0 {
                emit_line("struct \{")
                cg_indent = cg_indent + 1
                let mut fi = 0
                while fi < sublist_length(vflds) {
                    let vf = sublist_get(vflds, fi)
                    let vf_name = node_name(vf)
                    let vf_type_ann = node_value(vf)
                    let mut vf_c_type = "int64_t"
                    if vf_type_ann != -1 {
                        let vf_type_name = node_name(vf_type_ann)
                        if vf_type_name == name {
                            vf_c_type = "int64_t"
                        } else if is_struct_type(vf_type_name) != 0 {
                            vf_c_type = "{c_type_c_name(vf_type_name)}"
                        } else if is_enum_type(vf_type_name) != 0 {
                            if is_data_enum(vf_type_name) != 0 {
                                vf_c_type = "{c_type_c_name(vf_type_name)}"
                            } else {
                                vf_c_type = "{c_type_c_name(vf_type_name)}"
                            }
                        } else {
                            vf_c_type = c_type_str(type_from_name(vf_type_name))
                        }
                    }
                    emit_line("{vf_c_type} {vf_name};")
                    fi = fi + 1
                }
                cg_indent = cg_indent - 1
                emit_line("} {vname};")
            }
            i = i + 1
        }
        cg_indent = cg_indent - 1
        emit_line("} data;")
        cg_indent = cg_indent - 1
        emit_line("} {c_type_c_name(name)};")
        emit_line("")
        i = 0
        while i < sublist_length(flds_sl) {
            let v = sublist_get(flds_sl, i)
            let vname = node_name(v)
            emit_line("#define {c_type_c_name(name)}_{vname}_TAG {i}")
            i = i + 1
        }
        emit_line("")
    }

    if is_sb != 0 {
        let cn = c_type_c_name(name)
        emit_line("const char* {c_fn_name("{name}_to_str")}({cn} self) \{")
        cg_indent = cg_indent + 1
        emit_line("switch (self) \{")
        cg_indent = cg_indent + 1
        i = 0
        while i < enum_variants.len() {
            let evar = enum_variants.get(i).unwrap()
            if evar.enum_idx == enum_idx {
                emit_line("case {cn}_{evar.name}: return \"{evar.str_value}\";")
            }
            i = i + 1
        }
        emit_line("default: return \"\";")
        cg_indent = cg_indent - 1
        emit_line("}")
        cg_indent = cg_indent - 1
        emit_line("}")
        emit_line("")

        emit_struct_option_typedef(name)
        emit_line("blink_Option_{name} {c_fn_name("{name}_from_str")}(const char* s) \{")
        cg_indent = cg_indent + 1
        emit_line("blink_Option_{name} _r;")
        let mut first = 1
        i = 0
        while i < enum_variants.len() {
            let evar = enum_variants.get(i).unwrap()
            if evar.enum_idx == enum_idx {
                if first == 1 {
                    emit_line("if (blink_str_eq(s, \"{evar.str_value}\")) \{")
                    first = 0
                } else {
                    emit_line("} else if (blink_str_eq(s, \"{evar.str_value}\")) \{")
                }
                cg_indent = cg_indent + 1
                let box_tmp = fresh_temp("_ebox_")
                emit_line("{cn}* {box_tmp} = ({cn}*)blink_alloc(sizeof({cn})); *{box_tmp} = {cn}_{evar.name};")
                emit_line("_r.tag = 1; _r.value = {box_tmp};")
                cg_indent = cg_indent - 1
            }
            i = i + 1
        }
        emit_line("} else \{")
        cg_indent = cg_indent + 1
        emit_line("_r.tag = 0;")
        cg_indent = cg_indent - 1
        emit_line("}")
        emit_line("return _r;")
        cg_indent = cg_indent - 1
        emit_line("}")
        emit_line("")

        derive_method_entries.push(DeriveMethodEntry { type_name: name, method_name: "to_str", ret_type: CT_STRING })
        derive_method_entries.push(DeriveMethodEntry { type_name: name, method_name: "from_str", ret_type: CT_VOID })
    }
}

// ── Top-level: generate ─────────────────────────────────────────────

@allow(UnrestoredMutation, IncompleteStateRestore)
pub fn emit_top_level_let(node: Int) ! Codegen.Emit, Codegen.Register, Codegen.Scope, Diag.Report {
    let saved_lines = cg_lines
    cg_lines = []
    emit_expr(node_value(node))
    let val_str = expr_result_str
    let val_type = expr_result_type
    let helper_lines = cg_lines
    cg_lines = saved_lines
    let name = node_name(node)
    let is_mut = node_is_mut(node)
    set_var(name, val_type, is_mut)
    // Track list element type from annotation
    let type_ann = node_target(node)
    if val_type == CT_LIST && type_ann != -1 {
        let ann_name = node_name(type_ann)
        if ann_name == "List" {
            let elems_sl = node_elements(type_ann)
            if elems_sl != -1 && sublist_length(elems_sl) > 0 {
                let elem_ann = sublist_get(elems_sl, 0)
                let elem_name = node_name(elem_ann)
                let elem_ct = type_from_name(elem_name)
                set_list_elem_type(name, elem_ct)
                if elem_ct == CT_VOID && (is_named_type(elem_name) != 0) {
                    set_list_elem_struct(name, elem_name)
                } else if elem_ct == CT_VOID && elem_name == "Tuple" {
                    let tup_opt = resolve_tuple_ann(elem_ann, -1, "")
                    if tup_opt.is_some() {
                        set_list_elem_struct(name, tup_opt.unwrap())
                    }
                }
                if elem_ct == CT_LIST {
                    let nested_sl = node_elements(elem_ann)
                    if nested_sl != -1 && sublist_length(nested_sl) > 0 {
                        let nested_ann = sublist_get(nested_sl, 0)
                        let nested_name = node_name(nested_ann)
                        let nested_ct = type_from_name(nested_name)
                        set_list_nested_elem_type(name, nested_ct)
                        if nested_ct == CT_VOID && (is_named_type(nested_name) != 0) {
                            set_list_nested_elem_struct(name, nested_name)
                        }
                    }
                }
            }
        }
    }
    if val_type == CT_MAP && type_ann != -1 {
        let ann_name = node_name(type_ann)
        if ann_name == "Map" {
            let elems_sl = node_elements(type_ann)
            if elems_sl != -1 && sublist_length(elems_sl) >= 2 {
                let key_ann = sublist_get(elems_sl, 0)
                let val_ann = sublist_get(elems_sl, 1)
                let val_name = node_name(val_ann)
                let key_ct = type_from_name(node_name(key_ann))
                let val_ct = type_from_name(val_name)
                set_map_types(name, key_ct, val_ct, val_name)
                propagate_map_list_elem(name, val_ct, val_ann)
            }
        }
    }
    if val_type == CT_MAP && expr_map_key_type >= 0 {
        set_map_types(name, expr_map_key_type, expr_map_val_type, "")
        expr_map_key_type = -1
        expr_map_val_type = -1
    }
    if val_type == CT_MAP {
        copy_map_value_meta(val_str, name)
    }
    if val_type == CT_LIST && expr_list_elem_type >= 0 && type_ann == -1 {
        set_list_elem_type(name, expr_list_elem_type)
        expr_list_elem_type = -1
        let src_struct = get_list_elem_struct(val_str)
        if src_struct != "" {
            set_list_elem_struct(name, src_struct)
        } else if expr_list_elem_struct != "" {
            set_list_elem_struct(name, expr_list_elem_struct)
        }
        expr_list_elem_struct = ""
        let src_nested = get_list_nested_elem_type(val_str)
        if src_nested != -1 {
            set_list_nested_elem_type(name, src_nested)
        }
        let src_nested_struct = get_list_nested_elem_struct(val_str)
        if src_nested_struct != "" {
            set_list_nested_elem_struct(name, src_nested_struct)
        }
    } else if val_type == CT_LIST && expr_list_elem_type >= 0 {
        expr_list_elem_type = -1
        expr_list_elem_struct = ""
    }
    let ts = c_type_str(val_type)
    let cname = c_safe_name(name)
    let needs_init = helper_lines.len() > 0 || val_type == CT_LIST || val_type == CT_MAP || val_type == CT_CHANNEL
    if needs_init {
        emit_line("BLINK_UNUSED static {ts} {cname};")
        let mut hi = 0
        while hi < helper_lines.len() {
            cg_global_inits.push(helper_lines.get(hi).unwrap())
            hi = hi + 1
        }
        cg_global_inits.push("    ".concat(cname).concat(" = ").concat(val_str).concat(";"))
    } else if is_mut != 0 {
        emit_line("BLINK_UNUSED static ".concat(ts).concat(" ").concat(cname).concat(" = ").concat(val_str).concat(";"))
    } else {
        let qualifier = if val_type == CT_STRING { "BLINK_UNUSED static " } else { "BLINK_UNUSED static const " }
        emit_line(qualifier.concat(ts).concat(" ").concat(cname).concat(" = ").concat(val_str).concat(";"))
    }
}
