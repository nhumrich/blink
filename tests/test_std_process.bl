// std.process: idiomatic Pid handle wrapping the spawn/wait/kill builtins.

import std.process.{spawn, Pid, SIGTERM, SIGKILL}

test "spawn returns a Pid; wait gives stdout + zero exit" {
    let pid = spawn("echo", ["std-process-spawn"])
    let r = pid.wait()
    assert_eq(r.exit_code, 0)
    assert(r.out.contains("std-process-spawn"))
}

test "kill SIGKILL terminates a sleeping child" {
    let pid = spawn("sh", ["-c", "sleep 30"])
    let rc = pid.kill(SIGKILL)
    assert_eq(rc, 0)
    let r = pid.wait()
    assert_eq(r.exit_code, 137)
}

test "send_signal SIGTERM is observable by child" {
    let pid = spawn("sh", ["-c", "trap 'exit 143' TERM; sleep 30"])
    let rc = pid.send_signal(SIGTERM)
    assert_eq(rc, 0)
    let r = pid.wait()
    assert_eq(r.exit_code, 143)
}

test "kill on already-reaped child returns -1" {
    let pid = spawn("echo", ["done"])
    let _ = pid.wait()
    let rc = pid.kill(SIGTERM)
    assert_eq(rc, -1)
}
