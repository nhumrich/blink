FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git \
	bash \
    gcc \
    libc6-dev \
    libsqlite3-dev \
    parallel \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Install task runner
RUN sh -c "$(curl --location https://taskfile.dev/install.sh)" -- -b /usr/local/bin

RUN useradd -m -s /bin/bash airlock
USER airlock
RUN git config --global user.email "airlock@container" && git config --global user.name "airlock"

COPY --chown=airlock:airlock . /workspace
WORKDIR /workspace

# Build blink toolchain from generated C sources (avoids host glibc mismatch)
RUN cc -o build/blinkc build/pactc.c -lm && cc -o bin/blink build/cli.c -lm
ENV PATH="/workspace/bin:${PATH}"

RUN git init && git add -A && git commit -m "initial"
