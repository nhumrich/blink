pub type DBError {
    QueryError(msg: Str)
    ExecError(msg: Str)
    ConnectionError(msg: Str)
    NotFound
}

/// Format a DBError as a human-readable string.
pub fn db_error_display(err: DBError) -> Str {
    match err {
        DBError.QueryError(msg) => "query_error: {msg}"
        DBError.ExecError(msg) => "exec_error: {msg}"
        DBError.ConnectionError(msg) => "connection_error: {msg}"
        DBError.NotFound => "not_found"
    }
}
