// Regression: `blink test` on sources with compile errors must fail fast
// with diagnostics — not hang in async.scope. blink build reports them
// instantly; blink test should match that wall time.

fn main() {
    let pwd_result = process_run("sh", ["-c", "pwd -P"])
    let mut blink_root = pwd_result.out
    let mut end = blink_root.len()
    while end > 0 {
        let ch = blink_root.byte_at(end - 1)
        if ch == 10 || ch == 13 { end = end - 1 } else { break }
    }
    blink_root = blink_root.substring(0, end)

    let base = ".tmp/_test_test_compile_errors"
    shell_exec("rm -rf {base}")
    shell_exec("mkdir -p {base}/src {base}/tests")

    write_file("{base}/blink.toml", "[package]\nname = \"tcerr\"\nversion = \"0.1.0\"\n\n[dependencies]\n")
    write_file("{base}/src/tcerr.bl", "pub fn add(a: Int, b: Int) -> Int \{\n    a + b\n\}\n")

    let mut body = "import tcerr.\{add\}\n\n"
    let mut bi = 0
    while bi < 30 {
        body = "{body}test \"broken_{bi}\" \{\n    let x = unknown_fn_{bi}() + bad_thing_{bi}()\n    if x \{ io.eprintln(\"a\") \}\n\}\n\n"
        bi = bi + 1
    }

    let mut idx = 0
    while idx < 30 {
        let path = "{base}/tests/test_broken_{idx}.bl"
        write_file(path, body)
        idx = idx + 1
    }

    let cmd = "cd {base} && timeout 10 {blink_root}/build/blink test tests/ 2>&1"
    let start = time_ms()
    let result = process_run("sh", ["-c", cmd])
    let elapsed = time_ms() - start

    if result.exit_code == 124 {
        io.println("FAIL: blink test hung on compile errors (timed out, {elapsed}ms)")
        shell_exec("rm -rf {base}")
        return
    }
    if elapsed > 8000 {
        io.println("FAIL: blink test too slow on compile errors ({elapsed}ms)")
        shell_exec("rm -rf {base}")
        return
    }
    if !result.out.contains("UndefinedFunction") && !result.out.contains("undefined function") && !result.out.contains("error") {
        io.println("FAIL: expected compile error diagnostics, got: {result.out}")
        shell_exec("rm -rf {base}")
        return
    }
    if result.exit_code == 0 {
        io.println("FAIL: expected non-zero exit on compile errors")
        shell_exec("rm -rf {base}")
        return
    }
    io.println("PASS: blink test fails fast on compile errors ({elapsed}ms)")
    shell_exec("rm -rf {base}")
}
