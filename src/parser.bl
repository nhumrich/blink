// and the compiler driver (e.g. attaching pub/annotations after a nested
// parse returns). New parser code should construct nodes directly:
//   let nd = node_count()
//   nodes.push(AstNode { kind: K, field: val, ..., line: peek_line(), col: peek_col() })

pub fn node_set_int_val(id: Int, val: Int) {
    let n = nodes.get(id).unwrap()
    nodes.set(id, AstNode { int_val: val, ..n })
}

