    Codegen, CT_INT, CT_FLOAT, CT_BOOL, CT_VOID, CT_STRUCT, CT_CLOSURE, CT_OPTION,
    CaptureEntry, ClosureCapInfo, VarEnumEntry,
    emit_line, c_safe_name, c_type_str, c_type_c_name, type_from_name,
    tp_get_kind_raw, tp_get_sname,
    scope_vars, push_scope, pop_scope, set_var, set_var_closure, set_var_struct, get_var_tp,
