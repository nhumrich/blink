import compile_test_helpers

test "pub on FFI function emits E0801" {
    let src = "@ffi(\"strlen\")\npub fn c_strlen(s: Ptr[U8]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    compile_test_helpers.expect_compile_error(src, "ffi_pub", "E0801")
}

test "FFI without effects emits E0802" {
    let src = "@ffi(\"strlen\")\n@trusted\nfn c_strlen(s: Ptr[U8]) -> Int \{ \}\nfn main() \{ \}\n"
    compile_test_helpers.expect_compile_error(src, "ffi_noeff", "E0802")
}

test "contract on FFI emits E0803" {
    let src = "@ffi(\"strlen\")\n@trusted\n@requires(true)\nfn c_strlen(s: Ptr[U8]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    compile_test_helpers.expect_compile_error(src, "ffi_contract", "E0803")
}

test "Ptr with invalid inner type emits E0810" {
    let src = "@ffi(\"test\")\n@trusted\nfn bad(p: Ptr[Str]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    compile_test_helpers.expect_compile_error(src, "ffi_ptrtype", "E0810")
}

test "Ptr outside FFI emits E0811" {
    let src = "fn bad(_p: Ptr[U8]) -> Int \{ 0 \}\nfn main() \{ \}\n"
    compile_test_helpers.expect_compile_error(src, "ffi_ptrout", "E0811")
}

test "Ptr[T] is allowed when T is @ffi.struct (q534yn)" {
    let src = "@ffi.struct(header: \"poll.h\", name: \"pollfd\")\npub type Pollfd \{ fd: I32, events: I16, revents: I16 }\n@ffi(\"poll\", header: \"poll.h\")\n@trusted(audit: \"test\")\nfn c_poll(fds: Ptr[Pollfd], nfds: U64, t: I32) -> I32 ! FFI \{ }\nfn main() \{ }\n"
    compile_test_helpers.expect_no_error(src, "ffi_ptr_struct_ok", "E0810")
}

test "Ptr[T] still rejected when T is a plain user type" {
    let src = "pub type Foo \{ x: Int }\n@ffi(\"f\")\n@trusted(audit: \"t\")\nfn f(p: Ptr[Foo]) -> Int ! FFI \{ }\nfn main() \{ }\n"
    compile_test_helpers.expect_compile_error(src, "ffi_ptr_plainuser", "E0810")
}
