import std.db_sqlite.{db_connect, sqlite_handler, sqlite_open, sqlite_close, sqlite_prepare,
    sqlite_bind_int, sqlite_step, sqlite_column_text, sqlite_finalize, sqlite_errmsg}

fn main() ! IO {
    let handle = sqlite_open(":memory:")

    with sqlite_handler(handle) {
        db.exec("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, age INTEGER)").unwrap()

        db.exec("INSERT INTO users (name, age) VALUES ('Alice', 30)").unwrap()
        db.exec("INSERT INTO users (name, age) VALUES ('Bob', 25)").unwrap()

        let rid = db.execute("INSERT INTO users (name, age) VALUES ('Charlie', 35)").unwrap()
        io.println("last rowid: {rid}")

        let rows = db.query("SELECT name, age FROM users ORDER BY name").unwrap()
        let mut i = 0
        while i < rows.len() {
            let row = rows.get(i).unwrap()
            let name = row.get("name").unwrap()
            let age = row.get("age").unwrap()
            io.println("{name} is {age}")
            i = i + 1
        }

        let alice = db.query_one("SELECT name, age FROM users WHERE name = 'Alice'").unwrap().unwrap()
        let alice_age = alice.get_int("age").unwrap()
        io.println("alice age int: {alice_age}")

        let name_by_idx = alice.get_at(0).unwrap()
        io.println("alice by index: {name_by_idx}")

        io.println("row len: {alice.len()}")

        let missing = alice.get("nonexistent")
        if missing.is_none() {
            io.println("missing column: correct")
        }

        let name_str = alice.get_str("name").unwrap()
        io.println("get_str: {name_str}")

        let one = db.query_one("SELECT name FROM users WHERE name = 'Bob'").unwrap().unwrap()
        io.println("found: {one.get("name").unwrap()}")

        let none = db.query_one("SELECT name FROM users WHERE name = 'Nobody'").unwrap()
        if none.is_none() {
            io.println("not found: correct")
        }

        let stmt = sqlite_prepare(handle, "SELECT name FROM users WHERE age > ?")
        sqlite_bind_int(stmt, 1, 28)
        let mut rc = sqlite_step(stmt)
        while rc == 100 {
            let name = sqlite_column_text(stmt, 0)
            io.println("older than 28: {name}")
            rc = sqlite_step(stmt)
        }
        sqlite_finalize(stmt)

        db.begin().unwrap()
        db.exec("INSERT INTO users (name, age) VALUES ('Dave', 40)").unwrap()
        db.commit().unwrap()

        db.begin().unwrap()
        db.exec("INSERT INTO users (name, age) VALUES ('Eve', 50)").unwrap()
        db.rollback().unwrap()

        let final_rows = db.query("SELECT name FROM users ORDER BY name").unwrap()
        io.println("total users: {final_rows.len()}")

        for row in final_rows {
            let n = row.get("name").unwrap()
            io.println("user: {n}")
        }

        let err_result = db.query("SELECT * FROM nonexistent_table")
        if err_result.is_err() {
            io.println("error handled: correct")
        }

        let msg = sqlite_errmsg(handle)
        io.println("errmsg: {msg}")
    }

    sqlite_close(handle)

    // Test db_connect with Closeable auto-cleanup
    with db_connect(":memory:") as conn, sqlite_handler(conn.handle) {
        db.exec("CREATE TABLE t (v INT)").unwrap()
        db.exec("INSERT INTO t VALUES (1)").unwrap()
        let rows = db.query("SELECT v FROM t").unwrap()
        assert_eq(rows.len(), 1)
        io.println("db_connect: ok")
    }

    // Test Template[DB] parameterized queries
    let h2 = sqlite_open(":memory:")
    with sqlite_handler(h2) {
        db.exec("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT, price INTEGER)").unwrap()
        let name = "Widget"
        let price = 42
        db.exec("INSERT INTO items (name, price) VALUES ({name}, {price})").unwrap()
        let item_name = "Gadget"
        let item_price = 99
        db.execute("INSERT INTO items (name, price) VALUES ({item_name}, {item_price})").unwrap()

        // Parameterized query
        let min_price = 50
        let result = db.query("SELECT name FROM items WHERE price > {min_price}").unwrap()
        assert_eq(result.len(), 1)
        let found = result.get(0).unwrap().get("name").unwrap()
        assert_eq(found, "Gadget")
        io.println("parameterized query: {found}")

        // Parameterized query_one
        let search_name = "Widget"
        let widget = db.query_one("SELECT price FROM items WHERE name = {search_name}").unwrap().unwrap()
        let widget_price = widget.get_int("price").unwrap()
        assert_eq(widget_price, 42)
        io.println("parameterized query_one: {widget_price}")

        // Mixed literal and parameterized
        let target_id = 1
        let row = db.query_one("SELECT name, price FROM items WHERE id = {target_id}").unwrap().unwrap()
        io.println("mixed: {row.get("name").unwrap()} = {row.get("price").unwrap()}")
    }
    sqlite_close(h2)
}
