fn main() {
    let i8: I8 = -5
    let i16: I16 = 1000
    let i32: I32 = 100000
    let u8: U8 = 200
    let u16: U16 = 50000
    let u32: U32 = 4000000000
    let u64: U64 = 18000000000000000000
    assert_eq("i8={i8}", "i8=-5")
    assert_eq("i16={i16}", "i16=1000")
    assert_eq("i32={i32}", "i32=100000")
    assert_eq("u8={u8}", "u8=200")
    assert_eq("u16={u16}", "u16=50000")
    assert_eq("u32={u32}", "u32=4000000000")
    assert_eq("u64={u64}", "u64=18000000000000000000")
}
