#!/bin/sh
# Thin wrapper that builds and runs the self-hosted Blink CLI.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI_BIN="$ROOT_DIR/build/blink"

if [ ! -f "$CLI_BIN" ]; then
    echo "blink: CLI not built yet. Building..." >&2
    BLINKC="$ROOT_DIR/build/blinkc"
    if [ ! -f "$BLINKC" ]; then
        echo "blink: compiler not found. Run ./bootstrap/bootstrap.sh first" >&2
        exit 1
    fi
    "$BLINKC" "$ROOT_DIR/src/cli.pact" "$ROOT_DIR/build/cli.c"
    cc -o "$CLI_BIN" "$ROOT_DIR/build/cli.c" -lm -lgc
fi

BLINK_ROOT="$ROOT_DIR" exec "$CLI_BIN" "$@"
