import std.db_sqlite { db_connect, sqlite_handler }
import std.db_stmt { Stmt, STEP_ROW }

fn main() ! IO {
    with db_connect(":memory:") as conn, sqlite_handler(conn.handle) {
        db.exec("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT, count INTEGER)").unwrap()
        db.exec("INSERT INTO items (name, count) VALUES ('apple', 5)").unwrap()
        db.exec("INSERT INTO items (name, count) VALUES ('banana', 3)").unwrap()
        db.exec("INSERT INTO items (name, count) VALUES ('cherry', 8)").unwrap()
        with db.prepare("SELECT name, count FROM items WHERE count > ?").unwrap() as stmt {
            stmt.bind_int(1, 4).unwrap()
            let mut rc = stmt.step().unwrap()
            let mut found = 0
            while rc == STEP_ROW {
                let name = stmt.column_text(0)
                let count = stmt.column_int(1)
                io.println("{name}: {count}")
                found = found + 1
                rc = stmt.step().unwrap()
            }
            assert_eq(found, 2)
            io.println("found {found} items")
        }
        with db.prepare("SELECT count FROM items WHERE name = ?").unwrap() as stmt {
            stmt.bind_text(1, "banana").unwrap()
            let rc = stmt.step().unwrap()
            assert_eq(rc, STEP_ROW)
            let count = stmt.column_int(0)
            assert_eq(count, 3)
            io.println("banana count: {count}")
        }
        with db.prepare("SELECT name FROM items ORDER BY name").unwrap() as stmt {
            let rc1 = stmt.step().unwrap()
            assert_eq(rc1, STEP_ROW)
            let first = stmt.column_text(0)
            io.println("first pass: {first}")
            stmt.reset().unwrap()
            let rc2 = stmt.step().unwrap()
            assert_eq(rc2, STEP_ROW)
            let second = stmt.column_text(0)
            io.println("after reset: {second}")
            assert_eq(first, second)
        }
        io.println("all stmt tests passed")
    }
}
