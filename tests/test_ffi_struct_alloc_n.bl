@ffi.struct(header: "poll.h", name: "pollfd")
pub type Pollfd {
    fd: I32,
    events: I16,
    revents: I16,
}

test "scope.alloc_n returns Ptr to first cell" {
    let mut scope = ffi_scope()
    let p: Ptr[Pollfd] = scope.alloc_n(3)
    p.fd.write(10)
    p.events.write(1)
    p.revents.write(0)
    assert_eq(p.fd.read(), 10)
    assert_eq(p.events.read(), 1)
}

test "Ptr.offset addresses array cells independently" {
    let mut scope = ffi_scope()
    let p: Ptr[Pollfd] = scope.alloc_n(3)
    p.fd.write(100)
    let p1 = p.offset(1)
    p1.fd.write(200)
    let p2 = p.offset(2)
    p2.fd.write(300)
    assert_eq(p.fd.read(), 100)
    assert_eq(p1.fd.read(), 200)
    assert_eq(p2.fd.read(), 300)
}

test "chained Ptr.offset uses correct stride" {
    let mut scope = ffi_scope()
    let p: Ptr[Pollfd] = scope.alloc_n(4)
    let p1 = p.offset(1)
    let p2 = p1.offset(1)
    p.fd.write(10)
    p1.fd.write(20)
    p2.fd.write(30)
    assert_eq(p.fd.read(), 10)
    assert_eq(p1.fd.read(), 20)
    assert_eq(p2.fd.read(), 30)
}
