test "basic push and len" {
    let b = Bytes.new()
    b.push(72)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    assert_eq(b.len(), 5)
}

test "get valid and out of bounds" {
    let b = Bytes.new()
    b.push(72)
    b.push(101)
    b.push(108)
    assert_eq(b.get(0) ?? -1, 72)
    assert_eq(b.get(99) ?? -1, -1)
}

test "to_str" {
    let b = Bytes.new()
    b.push(72)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    match b.to_str() {
        Ok(s) => assert_eq(s, "Hello")
        Err(e) => assert(false)
    }
}

test "set modifies byte" {
    let b = Bytes.new()
    b.push(72)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    b.set(0, 104)
    match b.to_str() {
        Ok(s) => assert_eq(s, "hello")
        Err(e) => assert(false)
    }
}

test "slice" {
    let b = Bytes.new()
    b.push(104)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    let sl = b.slice(0, 3)
    assert_eq(sl.len(), 3)
    match sl.to_str() {
        Ok(s) => assert_eq(s, "hel")
        Err(e) => assert(false)
    }
}

test "from_str" {
    let b2 = Bytes.from_str("world")
    match b2.to_str() {
        Ok(s) => assert_eq(s, "world")
        Err(e) => assert(false)
    }
    assert_eq(b2.len(), 5)
}

test "Bytes() constructor" {
    let b3 = Bytes()
    b3.push(65)
    match b3.to_str() {
        Ok(s) => assert_eq(s, "A")
        Err(e) => assert(false)
    }
}

test "is_empty" {
    let empty = Bytes.new()
    assert_eq(empty.is_empty(), true)

    let b = Bytes.new()
    b.push(72)
    assert_eq(b.is_empty(), false)
}

test "concat" {
    let b = Bytes.new()
    b.push(104)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    let b2 = Bytes.from_str("world")
    let joined = b.concat(b2)
    match joined.to_str() {
        Ok(s) => assert_eq(s, "helloworld")
        Err(e) => assert(false)
    }
    assert_eq(joined.len(), 10)
}

test "to_hex" {
    let b = Bytes.new()
    b.push(104)
    b.push(101)
    b.push(108)
    b.push(108)
    b.push(111)
    assert_eq(b.to_hex(), "68656c6c6f")
}

test "invalid utf8 returns Err" {
    let bad = Bytes.new()
    bad.push(255)
    bad.push(254)
    assert(bad.to_str().is_err())
}

test "free function bytes_new and bytes_len" {
    let b = bytes_new()
    assert_eq(bytes_len(b), 0)
    assert_eq(bytes_is_empty(b), 1)
}

test "free function bytes_push and bytes_get" {
    let b = bytes_new()
    bytes_push(b, 72)
    bytes_push(b, 101)
    assert_eq(bytes_len(b), 2)
    assert_eq(bytes_get(b, 0), 72)
    assert_eq(bytes_get(b, 1), 101)
}

test "free function bytes_from_str and bytes_to_hex" {
    let b = bytes_from_str("hello")
    assert_eq(bytes_len(b), 5)
    assert_eq(bytes_to_hex(b), "68656c6c6f")
}

test "free function bytes_set" {
    let b = bytes_from_str("Hello")
    bytes_set(b, 0, 104)
    assert_eq(bytes_get(b, 0), 104)
}

test "free function bytes_slice and bytes_concat" {
    let a = bytes_from_str("hello")
    let b = bytes_from_str("world")
    let joined = bytes_concat(a, b)
    assert_eq(bytes_len(joined), 10)
    let sl = bytes_slice(joined, 0, 5)
    assert_eq(bytes_len(sl), 5)
}

test "fixed-width round-trip u16_be" {
    let b = Bytes.new()
    b.write_u16_be(43981) // 0xABCD
    assert_eq(b.len(), 2)
    assert_eq(b.read_u16_be(0).unwrap(), 43981)
}

test "fixed-width round-trip u32_be" {
    let b = Bytes.new()
    b.write_u32_be(287454020) // 0x11223344
    assert_eq(b.len(), 4)
    assert_eq(b.read_u32_be(0).unwrap(), 287454020)
}

test "fixed-width round-trip i32_be" {
    let b = Bytes.new()
    b.write_i32_be(0 - 123456)
    assert_eq(b.read_i32_be(0).unwrap(), 0 - 123456)
}

test "fixed-width round-trip i64_be" {
    let b = Bytes.new()
    b.write_i64_be(0 - 9000000000)
    assert_eq(b.read_i64_be(0).unwrap(), 0 - 9000000000)
}

test "fixed-width round-trip u16_le" {
    let b = Bytes.new()
    b.write_u16_le(43981)
    assert_eq(b.read_u16_le(0).unwrap(), 43981)
}

test "fixed-width round-trip u32_le" {
    let b = Bytes.new()
    b.write_u32_le(287454020)
    assert_eq(b.read_u32_le(0).unwrap(), 287454020)
}

test "fixed-width round-trip i32_le" {
    let b = Bytes.new()
    b.write_i32_le(0 - 123456)
    assert_eq(b.read_i32_le(0).unwrap(), 0 - 123456)
}

test "fixed-width round-trip i64_le" {
    let b = Bytes.new()
    b.write_i64_le(0 - 9000000000)
    assert_eq(b.read_i64_le(0).unwrap(), 0 - 9000000000)
}

test "be vs le disagreement for i32" {
    let b = Bytes.new()
    b.push(0)
    b.push(0)
    b.push(0)
    b.push(42) // 0x2A
    assert_eq(b.read_i32_be(0).unwrap(), 42)
    // 0x2A000000 = 704643072
    assert_eq(b.read_i32_le(0).unwrap(), 704643072)
}

test "u16 zero-extension (no sign bit leak)" {
    let b = Bytes.new()
    b.write_u16_be(65535) // 0xFFFF
    assert_eq(b.read_u16_be(0).unwrap(), 65535)
    let c = Bytes.new()
    c.write_u16_le(65535)
    assert_eq(c.read_u16_le(0).unwrap(), 65535)
}

test "u32 zero-extension" {
    let b = Bytes.new()
    b.write_u32_be(4294967295) // 0xFFFFFFFF
    assert_eq(b.read_u32_be(0).unwrap(), 4294967295)
}

test "i32 sign-extension round-trip" {
    let b = Bytes.new()
    b.write_i32_be(0 - 1)
    assert_eq(b.read_i32_be(0).unwrap(), 0 - 1)
    let c = Bytes.new()
    c.write_i32_le(0 - 1)
    assert_eq(c.read_i32_le(0).unwrap(), 0 - 1)
}

test "read out of bounds returns Err" {
    let b = Bytes.new()
    b.push(1)
    b.push(2)
    assert(b.read_u32_be(0).is_err())
    assert(b.read_u32_le(0).is_err())
    assert(b.read_i64_be(0).is_err())
    assert(b.read_i64_le(0).is_err())
}

test "read negative offset returns Err" {
    let b = Bytes.new()
    b.write_u32_be(42)
    assert(b.read_u32_be(0 - 1).is_err())
}

test "sequential writes append" {
    let b = Bytes.new()
    b.write_u16_be(258) // 0x0102
    b.write_u16_be(772) // 0x0304
    assert_eq(b.len(), 4)
    assert_eq(b.read_u16_be(0).unwrap(), 258)
    assert_eq(b.read_u16_be(2).unwrap(), 772)
}

test "free function fixed-width helpers" {
    let b = bytes_new()
    bytes_write_u32_be(b, 3735928559) // 0xDEADBEEF
    assert_eq(bytes_len(b), 4)
    let r = bytes_read_u32_be(b, 0)
    assert_eq(r.unwrap(), 3735928559)
}

// ── Bytes.zeroed ──────────────────────────────────────────────────────

test "Bytes.zeroed length and contents" {
    let b = Bytes.zeroed(8)
    assert_eq(b.len(), 8)
    let mut i = 0
    while i < 8 {
        assert_eq(b.get(i) ?? -1, 0)
        i = i + 1
    }
}

test "Bytes.zeroed(0) is empty" {
    let b = Bytes.zeroed(0)
    assert_eq(b.len(), 0)
    assert_eq(b.is_empty(), true)
}

// ── set_*_le/be: round-trip ───────────────────────────────────────────

test "set_u16_be round-trip" {
    let b = Bytes.zeroed(4)
    assert(b.set_u16_be(0, 43981).is_ok()) // 0xABCD
    assert(b.set_u16_be(2, 4660).is_ok())  // 0x1234
    assert_eq(b.read_u16_be(0).unwrap(), 43981)
    assert_eq(b.read_u16_be(2).unwrap(), 4660)
}

test "set_u16_le round-trip" {
    let b = Bytes.zeroed(2)
    assert(b.set_u16_le(0, 43981).is_ok())
    assert_eq(b.read_u16_le(0).unwrap(), 43981)
}

test "set_i16_be/le round-trip" {
    let b = Bytes.zeroed(4)
    assert(b.set_i16_be(0, 0 - 1).is_ok())
    assert(b.set_i16_le(2, 0 - 12345).is_ok())
    // i16 read not in API; verify via byte pattern + u16
    assert_eq(b.read_u16_be(0).unwrap(), 65535)
}

test "set_u32_be/le round-trip" {
    let b = Bytes.zeroed(8)
    assert(b.set_u32_be(0, 287454020).is_ok()) // 0x11223344
    assert(b.set_u32_le(4, 4294967295).is_ok())
    assert_eq(b.read_u32_be(0).unwrap(), 287454020)
    assert_eq(b.read_u32_le(4).unwrap(), 4294967295)
}

test "set_i32_be/le round-trip" {
    let b = Bytes.zeroed(8)
    assert(b.set_i32_be(0, 0 - 123456).is_ok())
    assert(b.set_i32_le(4, 0 - 1).is_ok())
    assert_eq(b.read_i32_be(0).unwrap(), 0 - 123456)
    assert_eq(b.read_i32_le(4).unwrap(), 0 - 1)
}

test "set_u64_be/le round-trip" {
    let b = Bytes.zeroed(16)
    assert(b.set_u64_be(0, 1311768467463790320).is_ok()) // 0x123456789ABCDEF0
    assert(b.set_u64_le(8, 1).is_ok())
    // u64 read not in API; verify via i64 (positive value fits)
    assert_eq(b.read_i64_be(0).unwrap(), 1311768467463790320)
    assert_eq(b.read_i64_le(8).unwrap(), 1)
}

test "set_i64_be/le round-trip" {
    let b = Bytes.zeroed(16)
    assert(b.set_i64_be(0, 0 - 9000000000).is_ok())
    assert(b.set_i64_le(8, 0 - 1).is_ok())
    assert_eq(b.read_i64_be(0).unwrap(), 0 - 9000000000)
    assert_eq(b.read_i64_le(8).unwrap(), 0 - 1)
}

// ── set_*_le vs _be: explicit byte pattern ────────────────────────────

test "set_u16 endianness byte pattern" {
    let b = Bytes.zeroed(4)
    assert(b.set_u16_be(0, 258).is_ok()) // 0x0102 → 01 02
    assert(b.set_u16_le(2, 258).is_ok()) // 0x0102 → 02 01
    assert_eq(b.get(0) ?? -1, 1)
    assert_eq(b.get(1) ?? -1, 2)
    assert_eq(b.get(2) ?? -1, 2)
    assert_eq(b.get(3) ?? -1, 1)
}

test "set_u32 endianness byte pattern" {
    let b = Bytes.zeroed(8)
    assert(b.set_u32_be(0, 16909060).is_ok()) // 0x01020304 → 01 02 03 04
    assert(b.set_u32_le(4, 16909060).is_ok()) // → 04 03 02 01
    assert_eq(b.get(0) ?? -1, 1)
    assert_eq(b.get(3) ?? -1, 4)
    assert_eq(b.get(4) ?? -1, 4)
    assert_eq(b.get(7) ?? -1, 1)
}

// ── set_* bounds checks (vs len, not cap) ─────────────────────────────

test "set_u16_be past end returns Err" {
    let b = Bytes.zeroed(2)
    assert(b.set_u16_be(1, 0).is_err()) // off+2 = 3 > len 2
    assert(b.set_u16_be(2, 0).is_err()) // off+2 = 4 > len 2
    assert(b.set_u16_be(0 - 1, 0).is_err())
}

test "set_u32_le past end returns Err" {
    let b = Bytes.zeroed(4)
    assert(b.set_u32_le(1, 0).is_err())
    assert(b.set_u32_le(0, 0).is_ok())
}

test "set_i64_be past end returns Err" {
    let b = Bytes.zeroed(8)
    assert(b.set_i64_be(1, 0).is_err())
    assert(b.set_i64_be(0, 42).is_ok())
}

// ── set_* does NOT grow (bounds vs len, distinguishing it from write_*) ──

test "set_u32_be does not grow buffer" {
    let b = Bytes.zeroed(4)
    assert(b.set_u32_be(0, 42).is_ok())
    assert_eq(b.len(), 4)
}

// ── free-function form available too ──────────────────────────────────

test "free function bytes_set_u32_be round-trip" {
    let b = Bytes.zeroed(4)
    let r = bytes_set_u32_be(b, 0, 3735928559) // 0xDEADBEEF
    assert(r.is_ok())
    assert_eq(bytes_read_u32_be(b, 0).unwrap(), 3735928559)
}
