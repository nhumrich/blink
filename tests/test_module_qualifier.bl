fn run_cmd(cmd: Str, label: Str) -> Int {
    let rc = shell_exec(cmd)
    if rc != 0 {
        io.println("FAIL: {label} (rc={rc})")
    }
    rc
}

fn check_output(path: Str, expected: Str, label: Str) {
    shell_exec("{path} > {path}_out.txt 2>&1 || true")
    let output = read_file("{path}_out.txt")
    if output.starts_with(expected) {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected '{expected}', got: {output}")
    }
}

fn check_no_warnings(base: Str, blink: Str, src: Str, label: Str) {
    shell_exec("cd {base} && {blink} check {src} 2>../check.txt; true")
    let output = read_file("{base}/../check.txt")
    if output.contains("warning") != 0 {
        io.println("FAIL: {label} — unexpected warnings: {output}")
    } else {
        io.println("PASS: {label}")
    }
}

fn check_build_error(base: Str, blink: Str, src: Str, expected_err: Str, label: Str) {
    shell_exec("cd {base} && {blink} build {src} -o build/err_test 2>../err.txt; true")
    let output = read_file("{base}/../err.txt")
    if output.contains(expected_err) != 0 {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected error containing '{expected_err}', got: {output}")
    }
}

fn main() {
    let base = ".tmp/_test_module_qualifier"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    shell_exec("mkdir -p {base}/app/src/utils")
    shell_exec("mkdir -p {base}/app/build")
    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n")

    // --- Test 1: Leaf qualifier for dotted imports ---
    // import mymod.submod should allow submod.func() not mymod_submod.func()
    write_file(
        "{base}/app/src/utils/math.bl",
        "pub fn double(x: Int) -> Int \{\n    x * 2\n}\n"
    )
    write_file(
        "{base}/app/src/t1.bl",
        "import utils.math\n\nfn main() \{\n    io.println(\"\{math.double(21)\}\")\n}\n"
    )
    let rc1 = run_cmd("cd {base}/app && {blink} build src/t1.bl -o build/t1 2>&1", "build leaf qualifier")
    if rc1 == 0 {
        check_output("{base}/app/build/t1", "42", "leaf qualifier: math.double() works")
    }

    // --- Test 2: Unused import should show leaf name, not mangled name ---
    write_file(
        "{base}/app/src/t2.bl",
        "import utils.math\n\nfn main() \{\n    io.println(\"hello\")\n}\n"
    )
    shell_exec("cd {base}/app && {blink} check src/t2.bl 2>../t2_err.txt; true")
    let t2_err = read_file("{base}/t2_err.txt")
    if t2_err.contains("module 'math'") != 0 {
        io.println("PASS: unused import shows leaf name 'math'")
    } else if t2_err.contains("module 'utils_math'") != 0 {
        io.println("FAIL: unused import shows mangled name 'utils_math' instead of 'math'")
    } else {
        io.println("FAIL: unexpected output: {t2_err}")
    }

    // --- Test 3: E1006 error message should show leaf qualifier ---
    // When using selective import, accessing an unselected symbol should suggest
    // the leaf qualifier, not the mangled name
    write_file(
        "{base}/app/src/utils/extra.bl",
        "pub fn alpha() -> Int \{\n    1\n}\n\npub fn beta() -> Int \{\n    2\n}\n"
    )
    write_file(
        "{base}/app/src/t3.bl",
        "import utils.extra.\{alpha\}\n\nfn main() \{\n    io.println(\"\{alpha()\}\")\n    io.println(\"\{beta()\}\")\n}\n"
    )
    shell_exec("cd {base}/app && {blink} check src/t3.bl 2>../t3_err.txt; true")
    let t3_err = read_file("{base}/t3_err.txt")
    if t3_err.contains("utils_extra.beta") != 0 {
        io.println("FAIL: E1006 shows mangled name 'utils_extra.beta' instead of 'extra.beta'")
    } else if t3_err.contains("extra.beta") != 0 {
        io.println("PASS: E1006 shows leaf qualifier 'extra.beta'")
    } else {
        io.println("FAIL: unexpected E1006 output: {t3_err}")
    }

    // --- Test 4: No leaked stdlib warnings when importing std.net ---
    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n\n[dependencies]\n\"std/net\" = \"0.1\"\n")
    write_file(
        "{base}/app/src/t4.bl",
        "import std.net\n\nfn main() \{\n    io.println(\"net imported\")\n}\n"
    )
    shell_exec("cd {base}/app && {blink} check src/t4.bl 2>../t4_err.txt; true")
    let t4_err = read_file("{base}/t4_err.txt")
    if t4_err.contains("UnknownMethod") != 0 {
        io.println("FAIL: stdlib warnings leaked through — {t4_err}")
    } else if t4_err.contains("module 'std_net'") != 0 {
        io.println("FAIL: unused import shows mangled name 'std_net'")
    } else if t4_err.contains("module 'net'") != 0 {
        io.println("PASS: unused import shows correct leaf name 'net'")
    } else {
        io.println("PASS: no leaked stdlib warnings")
    }
    // restore blink.toml without net dep for other tests
    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n")

    shell_exec("rm -rf {base}")
}
